---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const products = [{"title": "Projektor (XGA)", "priceImg": "https://scenkonsult.se/wp-content/uploads/2025/09/Pris_874.png", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_bild_projektor_20250824-1024x853.png", "desc": "XGA-projektor för presentationer och konferenser. Enkel att ansluta. Duk ingår vid behov."}, {"title": "Projektor (FHD)", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_bild_projektor1_20250824.png", "desc": "Full HD-projektor med hög ljusstyrka. Passar för stora lokaler och dagsljus-miljöer."}, {"title": "65″ Skärm (UHD)", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_bild_65-skarm-1024x853.png", "desc": "65-tums 4K LED-skärm. Perfekt för presentationer, showreel och reception."}, {"title": "75″ Skärm (UHD)", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_bild_75-skarm_20250824.png", "desc": "75-tums 4K LED-skärm. Kraftfull bild för event och konferenser med hög publik."}, {"title": "Moduluppbyggd Skärm (FHD)", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_bild_modulskarm_20250824-1024x853.png", "desc": "Modulär LED-vägg — bygg ihop valfri storlek. Extremt ljusstark, fungerar även i dagsljus."}, {"title": "Skärm på Trailer (FHD)", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_bild_trailer_skarm_20250824.png", "desc": "Stor bildskärm monterad på trailer. Komplett lösning för utomhus-event och festivaler."}, {"title": "Industriella Storskärmar", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/Big_screen.png", "desc": "Industriella storbildsskärmar för krävande miljöer och permanenta installationer. Pris på förfrågan."}];
---
<ServiceLayout
  title="Hyra Projektor & Skärm Stockholm | Scenkonsult"
  description="Hyra projektor och LED-skärm för event och konferens i Stockholm. FHD och UHD. Från 874 kr/dygn. Sedan 1986."
  pageHeading="Uthyrning av Bild — Projektorer & Skärmar"
  intro="Projektorer, LED-väggar och bildskärmar för alla typer av event. Full HD och 4K. Vi hjälper dig välja rätt storlek och teknik för din lokal."
  note="Alla priser är hyra per dygn (22 timmar). Utrustning hämtas enl överenskommelse från kl 13:00 och återlämnas innan kl 11:00 nästkommande dag. Vi erbjuder även leverans- och monteringstjänster."
  products={products}
/>
