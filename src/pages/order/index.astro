---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Din order – Scenkonsult Norden"
  description="Följ status på din order och chatta med oss direkt."
>

<style is:global>
  .order-page {
    min-height: 100vh;
    padding-top: calc(var(--nav-offset, 166px) + 2.5rem);
    padding-bottom: 4rem;
  }
  .order-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.25rem;
    color: #f0eeff;
  }

  /* ── STATES ───────────────────────────────────────────── */
  .state { display: none; }
  .state.active { display: block; }

  /* Loading */
  .loading-box {
    text-align: center;
    padding: 4rem 2rem;
    color: rgba(255,255,255,0.45);
  }
  .spinner {
    width: 36px; height: 36px;
    border: 3px solid rgba(196,181,244,0.2);
    border-top-color: #c4b5f4;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 1rem;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Error */
  .error-box {
    background: rgba(248,113,113,0.08);
    border: 1px solid rgba(248,113,113,0.25);
    border-radius: 16px;
    padding: 2.5rem;
    text-align: center;
    color: #f87171;
  }
  .error-box h2 { margin-bottom: 0.5rem; }
  .error-box p { color: rgba(255,255,255,0.5); font-size: 0.9rem; }

  /* ── ORDER CARD ────────────────────────────────────────── */
  .order-header { margin-bottom: 2rem; }
  .order-id {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35);
    margin-bottom: 0.5rem;
  }
  .order-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    color: #fff;
    margin-bottom: 0.5rem;
  }
  .order-subtitle { color: rgba(255,255,255,0.5); font-size: 0.95rem; }

  /* Status banner */
  .status-banner {
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    border: 1px solid transparent;
  }
  .status-banner.s-open       { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); }
  .status-banner.s-proposal   { background: rgba(96,165,250,0.08);  border-color: rgba(96,165,250,0.2);  }
  .status-banner.s-waiting    { background: rgba(251,191,36,0.08);  border-color: rgba(251,191,36,0.2);  }
  .status-banner.s-confirmed  { background: rgba(74,222,128,0.08);  border-color: rgba(74,222,128,0.25); }
  .status-banner.s-fakturerad { background: rgba(196,181,244,0.10); border-color: rgba(196,181,244,0.3); }
  .status-banner.s-betald     { background: rgba(74,222,128,0.10);  border-color: rgba(74,222,128,0.35); }
  .status-banner.s-cancelled  { background: rgba(248,113,113,0.08); border-color: rgba(248,113,113,0.2); }
  .status-icon { font-size: 2rem; flex-shrink: 0; }
  .status-label {
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }
  .status-desc { color: rgba(255,255,255,0.5); font-size: 0.875rem; }

  /* ── SECTION ───────────────────────────────────────────── */
  .section {
    background: #1a1740;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    margin-bottom: 1.25rem;
    overflow: hidden;
  }
  .section-head {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    font-weight: 700;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }
  .section-body { padding: 1.25rem 1.5rem; }

  /* Info grid */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .info-field { }
  .info-label { font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-bottom: 0.2rem; }
  .info-value { font-size: 0.95rem; font-weight: 500; color: #f0eeff; }

  /* Product table */
  /* ── CHECKOUT-INSPIRERAD LAYOUT ──────────────────────────── */

  /* Orderrader — likt varukorg */
  .order-cart-wrap {
    background: #151333;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 1.25rem;
  }
  .order-cart-header {
    padding: 0.75rem 1.25rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: rgba(196,181,244,0.6);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: grid;
    grid-template-columns: 64px 1fr 60px 72px 80px;
    gap: 0.5rem;
    align-items: center;
  }
  .order-cart-row {
    display: grid;
    grid-template-columns: 64px 1fr 60px 72px 80px;
    gap: 0.5rem;
    align-items: center;
    padding: 0.625rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .order-cart-row:last-child { border-bottom: none; }
  .order-cart-row.svc-row { background: rgba(255,255,255,0.015); }
  .row-img {
    width: 56px; height: 48px;
    border-radius: 8px;
    overflow: hidden;
    background: #0c0a24;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .row-img img { width:100%;height:100%;object-fit:cover; }
  .row-img svg { width:100%;height:100%;display:block; }
  .row-img-clickable { cursor: zoom-in; }
  .order-cart-row-clickable:hover .row-img { transform: scale(1.06); }
  .order-cart-row-clickable:hover { background: rgba(196,181,244,0.05); }
  .order-cart-row-clickable { transition: background 0.15s; }
  .row-info-hint {
    display: inline-flex; align-items: center; justify-content: center;
    width: 15px; height: 15px; border-radius: 50%;
    background: rgba(196,181,244,0.2);
    color: #c4b5f4; font-size: 0.6rem; font-weight: 700;
    margin-left: 5px; vertical-align: middle;
    font-style: normal;
  }
  .row-name   { font-weight: 600; font-size: 0.9rem; color: #f0eeff; display: flex; align-items: center; }
  .row-cat    { font-size: 0.72rem; color: rgba(255,255,255,0.4); margin-top:1px; }
  .row-qty    { text-align: center; color: rgba(255,255,255,0.6); font-size: 0.88rem; }
  .row-price  { text-align: right; color: rgba(255,255,255,0.5); font-size: 0.88rem; }
  .row-total  { text-align: right; color: #c4b5f4; font-weight: 700; font-size: 0.9rem; }

  /* Section separator */
  .order-sec-label {
    padding: 0.45rem 1.25rem 0.3rem;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: rgba(196,181,244,0.5);
    border-top: 1px solid rgba(255,255,255,0.06);
    background: rgba(196,181,244,0.03);
  }
  .order-sec-label:first-child { border-top: none; background: transparent; }

  /* Tidpunkter */
  .order-times {
    display: flex;
    gap: 1.5rem;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    background: rgba(196,181,244,0.04);
  }
  .order-time-item { display: flex; flex-direction: column; gap: 1px; }
  .order-time-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing:0.07em; color: rgba(255,255,255,0.35); }
  .order-time-value { font-size: 0.88rem; font-weight: 600; color: #f0eeff; }

  /* Totals box */
  .order-totals {
    background: #1a1740;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1.25rem;
  }
  .totals-row {
    display: flex; justify-content: space-between;
    font-size: 0.875rem; color: rgba(255,255,255,0.5);
    margin-bottom: 0.4rem;
  }
  .totals-row.grand {
    font-size: 1.1rem; font-weight: 700; color: #c4b5f4;
    margin-top: 0.6rem; padding-top: 0.6rem;
    border-top: 1px solid rgba(196,181,244,0.2);
    margin-bottom: 0;
  }
  .totals-note { font-size: 0.75rem; color: rgba(255,255,255,0.3); margin-top:0.5rem; font-style:italic; }

  @media (max-width:480px) {
    .order-cart-header { display: none; }
    .order-cart-row { grid-template-columns: 56px 1fr 60px; }
    .row-price { display: none; }
  }


  /* ── CHATT ─────────────────────────────────────────────── */
  .chat-messages { display: flex; flex-direction: column; gap: 0.875rem; margin-bottom: 1.25rem; }
  .chat-empty { color: rgba(255,255,255,0.4); font-size: 0.9rem; font-style: italic; padding: 0.5rem 0; }
  .msg-wrap { display: flex; flex-direction: column; }
  .msg-wrap.admin    { align-items: flex-start; }
  .msg-wrap.customer { align-items: flex-end; }
  .msg-sender-label { font-size: 0.7rem; font-weight: 700; color: rgba(255,255,255,0.4); margin-bottom: 0.2rem; padding: 0 0.25rem; }
  .msg-bubble {
    max-width: 82%;
    padding: 0.7rem 1rem;
    border-radius: 14px;
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .msg-wrap.admin    .msg-bubble { background: #221f50; color: #f0eeff; border-bottom-left-radius: 4px; }
  .msg-wrap.customer .msg-bubble { background: #332885; color: #fff; border-bottom-right-radius: 4px; }
  .msg-meta { font-size: 0.7rem; color: rgba(255,255,255,0.3); margin-top: 0.25rem; padding: 0 0.25rem; }

  .chat-input-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 1rem;
  }
  .chat-textarea {
    width: 100%;
    box-sizing: border-box;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    color: #f0eeff;
    font-family: inherit;
    font-size: 0.9rem;
    line-height: 1.5;
    resize: vertical;
    min-height: 80px;
    transition: border-color 0.15s;
    color-scheme: dark;
  }
  .chat-textarea:focus { outline: none; border-color: rgba(196,181,244,0.4); }
  .chat-textarea::placeholder { color: rgba(255,255,255,0.25); }
  .chat-send-btn {
    align-self: flex-end;
    background: #c4b5f4;
    color: #0c0a24;
    border: none;
    border-radius: 8px;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s;
  }
  .chat-send-btn:hover { background: #e2dcfb; }
  .chat-send-btn:disabled { opacity: 0.5; cursor: not-allowed; }

</style>

<div class="order-page">
<div class="order-wrap">

  <!-- LOADING -->
  <div class="state active" id="stateLoading">
    <div class="loading-box">
      <div class="spinner"></div>
      Hämtar din order…
    </div>
  </div>

  <!-- ERROR -->
  <div class="state" id="stateError">
    <div class="error-box">
      <h2>Länken är ogiltig</h2>
      <p>Orderinformationen kunde inte hittas. Kontrollera att du använder rätt länk från bekräftelsemailet.</p>
      <p style="margin-top:1.5rem">
        Frågor? Ring oss på <a href="tel:0724481000" style="color:#f87171">072-448 10 00</a>
      </p>
    </div>
  </div>

  <!-- ORDER -->
  <div class="state" id="stateOrder">

    <!-- Header -->
    <div class="order-header">
      <div class="order-id" id="orderId"></div>
      <h1 class="order-title" id="orderTitle">Din order</h1>
      <p class="order-subtitle" id="orderSubtitle"></p>
    </div>

    <!-- Status banner -->
    <div class="status-banner" id="statusBanner">
      <div class="status-icon" id="statusIcon"></div>
      <div style="flex:1">
        <div class="status-label" id="statusLabel"></div>
        <div class="status-desc" id="statusDesc"></div>
      </div>
    </div>
    <div id="statusCta" style="display:none"></div>

    <!-- Products + event info combined checkout-style -->
    <div class="order-cart-wrap" id="orderCartWrap">
      <div class="order-cart-header">
        <span></span>
        <span>Produkt / Tjänst</span>
        <span style="text-align:center">Antal</span>
        <span style="text-align:right">À-pris</span>
        <span style="text-align:right">Summa</span>
      </div>
      <div id="prodTableWrap"></div>
    </div>

    <!-- Totals -->
    <div class="order-totals" id="orderTotals" style="display:none">
      <div class="totals-row" id="totalsExcl"></div>
      <div class="totals-row" id="totalsMoms"></div>
      <div class="totals-row grand" id="totalsGrand"></div>
      <div class="totals-note" id="totalsNote" style="display:none">* Tilläggstjänsters priser är estimat och bekräftas vid orderbekräftelse.</div>
    </div>

    <!-- Chatt -->
    <div class="section">
      <div class="section-head">Meddelanden <span id="unreadBadge" style="display:none;background:#f87171;color:#fff;border-radius:99px;padding:1px 7px;font-size:0.7rem;margin-left:6px;font-weight:700;text-transform:none;letter-spacing:0"></span></div>
      <div class="section-body">
        <div class="chat-messages" id="chatMessages">
          <div class="chat-empty">Inga meddelanden ännu.</div>
        </div>
        <div class="chat-input-wrap">
          <textarea class="chat-textarea" id="chatInput" placeholder="Skriv ett meddelande till Scenkonsult…"></textarea>
          <button class="chat-send-btn" id="chatSendBtn">Skicka meddelande →</button>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="order-footer">
      Scenkonsult Norden &nbsp;·&nbsp;
      <a href="tel:0724481000">072-448 10 00</a> &nbsp;·&nbsp;
      <a href="mailto:info@scenkonsult.se">info@scenkonsult.se</a><br>
      Mån–Fre 09:00–17:00 · Jour vid pågående uthyrning
    </div>

  </div><!-- /stateOrder -->

</div>
</div>

<script>
const STATUS = {
  open:        { icon: '📬', label: 'Förfrågan mottagen',  desc: 'Vi har tagit emot din förfrågan och återkommer inom kort.',                   cls: 's-open'      },
  proposal:    { icon: '📤', label: 'Offert skickad',      desc: 'Vi har skickat ett offert — se produkter och priser nedan.',                  cls: 's-proposal'  },
  waiting:     { icon: '⏳', label: 'Offert klar',         desc: 'Offerten är klar — granska detaljerna nedan och hör av dig om du har frågor.', cls: 's-waiting'   },
  confirmed:   { icon: '✅', label: 'Order bekräftad',     desc: 'Ordern är bekräftad av Scenkonsult Norden.',                                  cls: 's-confirmed' },
  fakturerad:  { icon: '🧾', label: 'Faktura skickad',     desc: 'En faktura har skickats till din e-post. Välkommen på eventet!',              cls: 's-fakturerad'},
  betald:      { icon: '💚', label: 'Betald — klart!',     desc: 'Tack! Betalning mottagen. Vi ses på eventet!',                               cls: 's-betald'    },
  cancelled:   { icon: '❌', label: 'Avbruten',             desc: 'Den här ordern är avbruten. Kontakta oss om du har frågor.',                  cls: 's-cancelled' },
};

const fmt     = n  => typeof n === 'number' ? n.toLocaleString('sv-SE') : '–';
const fmtDate = d  => d ? new Date(d).toLocaleDateString('sv-SE', { year:'numeric', month:'long', day:'numeric' }) : null;
const fmtTime = d  => d ? new Date(d).toLocaleString('sv-SE', { dateStyle:'short', timeStyle:'short' }) : '';

// Produktbild-karta: id → sökväg

// ── Produktkatalog — läses från quote-catalog.json (single source of truth) ──
import _quoteCatalog from '../../data/quote-catalog.json';

// Bygg flat lookup: id → { desc, image, artno, catName }
const ORDER_CATALOG = (() => {
  const cat = {};
  const add = (prods, catName) => {
    for (const p of (prods || [])) {
      if (!p.id) continue;
      cat[p.id] = { desc: p.desc || '', image: p.image || '', artno: p.artno || '', catName };
    }
  };
  for (const [catName, data] of Object.entries(_quoteCatalog)) {
    if (data.products) add(data.products, catName);
    if (data.sub) for (const [subName, prods] of Object.entries(data.sub)) add(prods, subName);
  }
  return cat;
})();

function _lookupOrderProduct(item) {
  const id = item.id || '';
  return ORDER_CATALOG[id]
      || ORDER_CATALOG['scen-' + id]
      || ORDER_CATALOG[id.replace(/^(scen-|dj-utr-)/,'')]
      || {};
}

function _getOrderImg(item) {
  if (item.image) return item.image;
  return _lookupOrderProduct(item).image || null;
}

function openOrderProductModal(item) {
  if (!window.skModalOpen) return;
  const info   = _lookupOrderProduct(item);
  const imgSrc = _getOrderImg(item);
  window.skModalOpen({
    name:      item.name,
    artno:     item.artno || info.artno || '',
    desc:      info.desc || '',
    rows:      [],
    price:     item.price,
    priceNote: '/dygn',
    category:  item.category || info.catName || '',
    cartId:    '',
    images:    imgSrc ? [imgSrc] : [],
    videos:    [],
    persons:   '',
    hideCart:  true,
  });
}
window.openOrderProductModal = openOrderProductModal;

let cartId    = null;
let cartToken = null;
let messages  = [];

function show(id) {
  ['stateLoading','stateError','stateOrder'].forEach(s => {
    document.getElementById(s).classList.toggle('active', s === id);
  });
}

async function loadOrder() {
  const params = new URLSearchParams(location.search);
  cartId    = params.get('cart');
  cartToken = params.get('token');

  if (!cartId || !cartToken) { show('stateError'); return; }

  try {
    const res  = await fetch(`/.netlify/functions/cart-get?id=${cartId}&token=${cartToken}`);
    const data = await res.json();
    if (!res.ok) { show('stateError'); return; }
    renderOrder(data.cart);
    messages = data.messages || [];
    renderMessages();
    show('stateOrder');
  } catch {
    show('stateError');
  }
}

function renderOrder(c) {
  // Header
  document.getElementById('orderId').textContent    = c.id;
  document.getElementById('orderTitle').textContent = `Hej ${c.customer_name?.split(' ')[0] || 'där'}!`;
  // Visa företagsnamn om det finns
  const subtitleParts = [];
  if (c.customer_company) subtitleParts.push(c.customer_company);
  if (c.event_date) subtitleParts.push(`Order för event ${fmtDate(c.event_date)}${c.event_location ? ' · ' + c.event_location : ''}`);
  else subtitleParts.push('Här kan du följa status på din order och skicka meddelanden till oss.');
  document.getElementById('orderSubtitle').textContent = subtitleParts.join(' · ');
  // orderSubtitle set above with company info

  // Status
  const s = STATUS[c.status] || STATUS.open;
  const banner = document.getElementById('statusBanner');
  banner.className = `status-banner ${s.cls}`;
  document.getElementById('statusIcon').textContent  = s.icon;
  document.getElementById('statusLabel').textContent = s.label;
  document.getElementById('statusDesc').textContent  = s.desc;

  // Status-specifikt CTA-block
  const ctaEl = document.getElementById('statusCta');
  ctaEl.innerHTML = '';
  ctaEl.style.display = 'none';
  banner.style.borderRadius = '';

  if (c.confirmed_at) {
    // Kund har redan bekräftat digitalt
    banner.style.borderRadius = '12px 12px 0 0';
    ctaEl.style.display = '';
    ctaEl.innerHTML = `
      <div style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;gap:10px">
        <span style="font-size:1.4rem">✅</span>
        <div>
          <div style="color:rgba(255,255,255,0.9);font-size:0.9rem;font-weight:600">Digitalt bekräftad</div>
          <div style="color:rgba(255,255,255,0.5);font-size:0.8rem">Du godkände denna order ${fmtTime(c.confirmed_at)}</div>
        </div>
      </div>`;
  } else if (c.status === 'confirmed' || c.status === 'waiting') {
    // Offert klar — kund kan bekräfta digitalt
    banner.style.borderRadius = '12px 12px 0 0';
    ctaEl.style.display = '';
    ctaEl.innerHTML = renderConfirmBox(c);
  } else if (c.status === 'proposal' || c.status === 'open') {
    // Vi håller på att se över förfrågan
    banner.style.borderRadius = '12px 12px 0 0';
    ctaEl.style.display = '';
    ctaEl.innerHTML = `
      <div style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid rgba(255,255,255,0.08);">
        <p style="color:rgba(255,255,255,0.6);font-size:0.9rem;margin:0;">Vi ser över din förfrågan och återkommer med en offert. Frågor? Ring oss på
          <a href="tel:0724481000" style="color:#c4b5f4;">072-448 10 00</a>.
        </p>
      </div>`;
  }

  // Sätt Cart-objekt globalt för bekräftelseflödet
  window._currentCart = c;

  // Event info visas nu inne i productTableWrap (order-times-row)

  // Products — separera produkter och tjänster, visa samlad total inkl. moms
  const SVC_CATS_ORDER = ['Tjänster', 'Tillägg'];
  const items     = c.items || [];
  const realItems = items.filter(i => !i._note);
  const noteItem  = items.find(i => i._note);
  const prodItems = realItems.filter(i => !SVC_CATS_ORDER.includes(i.category) && !(i.id && i.id.startsWith('fakturaavgift')));
  const svcItems  = realItems.filter(i => SVC_CATS_ORDER.includes(i.category) && !(i.id && i.id.startsWith('fakturaavgift')));
  const feeItem   = realItems.find(i => i.id && i.id.startsWith('fakturaavgift'));

  const prodTotal = prodItems.reduce((s, i) => s + ((i.price||0) * (i.qty||i.quantity||1)), 0);
  const svcTotal  = svcItems.reduce((s, i) => s + ((i.price||0) * (i.qty||i.quantity||1)), 0);
  const feeTotal  = feeItem ? (feeItem.price||0) * (feeItem.qty||1) : 0;
  const grandExcl = prodTotal + svcTotal + feeTotal;
  const moms      = Math.round(grandExcl * 0.25);
  const grandIncl = grandExcl + moms;

  // ── Bygg checkout-inspirerade rader ──
  const SVC_ICONS = {
    lev_standard:   { svg: '<svg width="36" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 4v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>', bg: '#3730a3' },
    lev_skrymmande: { svg: '<svg width="36" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 4v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/><rect x="19" y="5" width="4" height="6" rx="0.5" fill="rgba(255,255,255,0.3)"/></svg>', bg: '#4338ca' },
    lev_lastbil:    { svg: '<svg width="36" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 3h16v13H1z"/><path d="M17 8h4l2 3v6h-6V8z"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/></svg>', bg: '#1d4ed8' },
    montering:      { svg: '<svg width="36" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', bg: '#5b21b6' },
    teknik:         { svg: '<svg width="36" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/></svg>', bg: '#6d28d9' },
    faktura:        { svg: '<svg width="36" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>', bg: '#4c1d95' },
    default:        { svg: '<svg width="36" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>', bg: '#3730a3' },
  };

  const svcIcon = id => {
    const s = (id||'').toLowerCase();
    if (s.includes('lastbil') || s.includes('bakgavel')) return SVC_ICONS.lev_lastbil;
    if (s.includes('skrymmande') || s.includes('slap'))  return SVC_ICONS.lev_skrymmande;
    if (s.includes('lev') || s.includes('transport'))    return SVC_ICONS.lev_standard;
    if (s.includes('monter') || s.includes('rigg'))      return SVC_ICONS.montering;
    if (s.includes('teknik') || s.includes('engineer'))  return SVC_ICONS.teknik;
    if (s.includes('faktura'))                           return SVC_ICONS.faktura;
    return SVC_ICONS.default;
  };

  // Lagra items för popup-referens
  window._orderItems = window._orderItems || {};

  const mkProdRow = (i, globalIdx) => {
    const qty    = i.qty || i.quantity || 1;
    const total  = (i.price||0) * qty;
    const imgSrc = _getOrderImg(i);
    const info   = _lookupOrderProduct(i);
    // Visa popup bara om vi har faktiskt produktinnehåll (bild eller specs)
    const hasInfo = !!(info.desc || info.catName || imgSrc);
    // Store item for onclick reference
    const key = 'p' + globalIdx;
    window._orderItems[key] = i;
    const imgEl = imgSrc
      ? `<div class="row-img${hasInfo?' row-img-clickable':''}"><img src="${imgSrc}" alt="" loading="lazy" onerror="this.style.display='none'"></div>`
      : `<div class="row-img">📦</div>`;
    const infoHint = hasInfo ? ` <span class="row-info-hint">ℹ</span>` : '';
    const clickProps = hasInfo ? `onclick="openOrderProductModal(window._orderItems['${key}'])" title="Klicka för mer info"` : '';
    return `<div class="order-cart-row${hasInfo?' order-cart-row-clickable':''}" ${clickProps}>
      ${imgEl}
      <div><div class="row-name">${i.name||'–'}${infoHint}</div>${info.artno ? `<div class="row-cat">${info.artno}</div>` : ''}</div>
      <div class="row-qty">${qty > 1 ? qty + ' st' : '1 st'}</div>
      <div class="row-price">${fmt(i.price)} kr</div>
      <div class="row-total">${fmt(total)} kr</div>
    </div>`;
  };

  const mkSvcRow = i => {
    const qty    = i.qty || i.quantity || 1;
    const total  = (i.price||0) * qty;
    const iconDef = svcIcon(i.id);
    return `<div class="order-cart-row svc-row">
      <div class="row-img" style="background:${iconDef.bg};padding:10px">${iconDef.svg}</div>
      <div><div class="row-name">${i.name||'–'}</div><div class="row-cat">Tilläggstjänst</div></div>
      <div class="row-qty">${qty > 1 ? qty + ' st' : '1 st'}</div>
      <div class="row-price">${fmt(i.price)} kr</div>
      <div class="row-total">${fmt(total)} kr</div>
    </div>`;
  };

  let html = '';
  window._orderItems = {};
  let _rowIdx = 0;

  if (prodItems.length > 0) {
    html += `<div class="order-sec-label">Utrustning</div>`;
    html += prodItems.map(i => mkProdRow(i, _rowIdx++)).join('');
  }
  if (svcItems.length > 0) {
    html += `<div class="order-sec-label">Tilläggstjänster</div>`;
    html += svcItems.map(mkSvcRow).join('');
  }
  if (feeItem) {
    html += `<div class="order-sec-label">Fakturaavgift</div>`;
    html += mkSvcRow(feeItem);
  }
  if (noteItem) {
    html += `<div style="padding:0.6rem 1.25rem;font-size:0.8rem;color:rgba(255,255,255,0.4);font-style:italic;border-top:1px dashed rgba(255,255,255,0.06)">📝 ${noteItem.name}</div>`;
  }

  // Tidpunkter
  if (c.event_date) {
    const dlTime  = c.delivery_time || '13:00';
    const rtTime  = c.return_time   || '11:00';
    const retDate = c.return_date   || c.event_date;
    html += `<div class="order-times">
      <div class="order-time-item">
        <span class="order-time-label">📅 Utlämning</span>
        <span class="order-time-value">${fmtDate(c.event_date)} kl ${dlTime}</span>
      </div>
      <div class="order-time-item">
        <span class="order-time-label">📅 Återlämning</span>
        <span class="order-time-value">${fmtDate(retDate)} kl ${rtTime}</span>
      </div>
      ${c.event_location ? `<div class="order-time-item"><span class="order-time-label">📍 Plats</span><span class="order-time-value">${c.event_location}</span></div>` : ''}
    </div>`;
  }

  document.getElementById('prodTableWrap').innerHTML = html;

  // Totals box
  const totalsEl = document.getElementById('orderTotals');
  if (totalsEl && grandExcl > 0) {
    document.getElementById('totalsExcl').innerHTML  = `<span>Exkl. moms</span><span>${fmt(grandExcl)} kr</span>`;
    document.getElementById('totalsMoms').innerHTML  = `<span>Moms 25%</span><span>${fmt(moms)} kr</span>`;
    document.getElementById('totalsGrand').innerHTML = `<span>Totalt inkl. moms</span><span>${fmt(grandIncl)} kr</span>`;
    const noteEl = document.getElementById('totalsNote');
    if (noteEl) noteEl.style.display = svcItems.length > 0 ? '' : 'none';
    totalsEl.style.display = '';
  }
}

function renderMessages() {
  const container = document.getElementById('chatMessages');
  const unread    = messages.filter(m => m.sender === 'admin' && !m.read_at);

  // Unread badge
  const badge = document.getElementById('unreadBadge');
  if (unread.length > 0) {
    badge.style.display = 'inline';
    badge.textContent   = `${unread.length} ny${unread.length > 1 ? 'a' : 't'}`;
  } else {
    badge.style.display = 'none';
  }

  if (messages.length === 0) {
    container.innerHTML = '<div class="chat-empty">Inga meddelanden ännu. Hör gärna av dig om du har frågor!</div>';
    return;
  }

  container.innerHTML = messages.map(m => `
    <div class="msg-wrap ${m.sender}">
      <div class="msg-sender-label">${m.sender === 'admin' ? '🎭 Scenkonsult Norden' : '👤 Du'}</div>
      <div class="msg-bubble">${m.body.replace(/\n/g,'<br>').replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" style="color:#c4b5f4">$1</a>')}</div>
      <div class="msg-meta">${fmtTime(m.created_at)}</div>
    </div>`).join('');

  // Scroll to bottom
  setTimeout(() => container.scrollTop = container.scrollHeight, 50);
}

function renderConfirmBox(c) {
  const total = (c.items||[]).filter(i=>!i._note).reduce((s,i)=>s+((i.price||0)*(i.qty||1)),0);
  return `
    <div style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid rgba(255,255,255,0.08)">
      <div style="color:rgba(255,255,255,0.9);font-size:0.95rem;font-weight:600;margin-bottom:0.75rem">
        Bekräfta din order
      </div>
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1rem;margin-bottom:1rem;font-size:0.85rem;color:rgba(255,255,255,0.7);line-height:1.6">
        ${(() => {
          const _prod = (c.items||[]).filter(i => !i._note && !['Tjänster','Tillägg'].includes(i.category) && !(i.id&&i.id.startsWith('fakturaavgift')));
          const _svc  = (c.items||[]).filter(i => !i._note && ['Tjänster','Tillägg'].includes(i.category) && !(i.id&&i.id.startsWith('fakturaavgift')));
          const parts = [];
          if (_prod.length) parts.push(_prod.length + ' produkt' + (_prod.length>1?'er':''));
          if (_svc.length)  parts.push(_svc.length + ' tjänst' + (_svc.length>1?'er':''));
          const dlTime = c.delivery_time || '13:00';
          const rtTime = c.return_time   || '11:00';
          const retDate = c.return_date  || c.event_date;
          const dateStr = c.event_date ? `${fmtDate(c.event_date)} kl ${dlTime}` : null;
          const retStr  = retDate ? `${fmtDate(retDate)} kl ${rtTime}` : null;
          return `Ordern avser <strong style="color:#fff">${parts.join(' och ') || 'produkter'}</strong>`
            + (c.event_location ? ` till <strong style="color:#fff">${c.event_location}</strong>` : '')
            + (dateStr ? `.<br>Utlämning <strong style="color:#fff">${dateStr}</strong>` : '')
            + (retStr  ? ` · Återlämning <strong style="color:#fff">${retStr}</strong>` : '')
            + `.<br>Totalt <strong style="color:#c4b5f4">${Math.round(total*1.25).toLocaleString('sv-SE')} kr inkl. moms</strong>.`;
        })()}
      </div>
      <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;margin-bottom:1rem">
        <input type="checkbox" id="confirm-tos" onchange="document.getElementById('confirm-btn').disabled=!this.checked"
          style="margin-top:2px;accent-color:#c4b5f4;width:16px;height:16px;flex-shrink:0">
        <span style="color:rgba(255,255,255,0.7);font-size:0.85rem;line-height:1.5">
          Jag har läst och godkänner
          <a href="/hyresvillkor/" target="_blank" style="color:#c4b5f4">Scenkonsult Nordens allmänna hyresvillkor §1–§15</a>
          och bekräftar denna order.
        </span>
      </label>
      <button id="confirm-btn" disabled onclick="confirmOrder()"
        style="width:100%;padding:0.875rem;background:#c4b5f4;color:#0c0a24;border:none;border-radius:10px;font-size:0.95rem;font-weight:700;cursor:pointer;transition:opacity .2s;font-family:inherit">
        ✅ Bekräfta order
      </button>
      <p style="color:rgba(255,255,255,0.3);font-size:0.75rem;margin-top:0.75rem;text-align:center">
        Din bekräftelse loggas med tidsstämpel och IP-adress som bindande avtal.
      </p>
    </div>`;
}

async function confirmOrder() {
  const btn = document.getElementById('confirm-btn');
  if (!btn || btn.disabled) return;
  btn.disabled = true;
  btn.textContent = '⏳ Bekräftar…';

  try {
    const c = window._currentCart;
    if (!c) throw new Error('Order ej laddad — ladda om sidan och försök igen.');
    if (!cartToken) throw new Error('Token saknas — öppna länken från mailet igen.');

    const total = (c.items||[]).filter(i=>!i._note).reduce((s,i)=>s+((i.price||0)*(i.qty||1)),0);
    const confirmationText = `Order ${c.id} bekräftad av kund. Hyresvillkor §1–§15 godkända. Totalt ${total} kr exkl. moms.`;

    const res = await fetch('/.netlify/functions/cart-update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        token:             cartToken,
        cart_id:           cartId,
        action:            'customer_confirm',
        confirmation_text: confirmationText,
      })
    });
    const data = await res.json();
    if (res.ok && data.ok) {
      // Update UI — show signed state
      const ctaEl = document.getElementById('statusCta');
      ctaEl.innerHTML = `
        <div style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid rgba(255,255,255,0.08);">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:0.75rem">
            <span style="font-size:1.5rem">✅</span>
            <div>
              <div style="color:rgba(255,255,255,0.9);font-size:0.95rem;font-weight:700">Order digitalt bekräftad!</div>
              <div style="color:rgba(255,255,255,0.5);font-size:0.8rem">Tack! Vi bekräftar via e-post och ses på eventet.</div>
            </div>
          </div>
          <div style="font-size:0.8rem;color:rgba(255,255,255,0.3);font-family:monospace">
            Ref: ${c.id} · ${new Date().toLocaleString('sv-SE')}
          </div>
        </div>`;
    } else {
      alert(data.error || data.message || `Fel ${res.status}: Något gick fel. Försök igen eller kontakta oss.`);
      btn.disabled = false;
      btn.textContent = '✅ Bekräfta order';
    }
  } catch(e) {
    alert(e.message || 'Nätverksfel — kontrollera din anslutning och försök igen.');
    btn.disabled = false;
    btn.textContent = '✅ Bekräfta order';
  }
}

async function sendMessage() {
  const input = document.getElementById('chatInput');
  const btn   = document.getElementById('chatSendBtn');
  const text  = input?.value.trim();
  if (!text) return;

  btn.disabled      = true;
  btn.textContent   = 'Skickar…';

  try {
    const res  = await fetch('/.netlify/functions/cart-message', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ cart_id: cartId, token: cartToken, body: text })
    });
    const data = await res.json();

    if (res.ok) {
      messages.push({
        id:         data.message?.id || Date.now(),
        sender:     'customer',
        body:       text,
        read_at:    null,
        created_at: new Date().toISOString()
      });
      input.value = '';
      renderMessages();
    } else {
      alert(data.error || 'Kunde inte skicka meddelandet. Försök igen.');
    }
  } catch {
    alert('Nätverksfel — kontrollera din anslutning och försök igen.');
  }

  btn.disabled    = false;
  btn.textContent = 'Skicka meddelande →';
}

document.getElementById('chatSendBtn').addEventListener('click', sendMessage);
document.getElementById('chatInput').addEventListener('keydown', e => {
  if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) sendMessage();
});

// Exponera funktioner som anropas via onclick i dynamisk HTML
window.confirmOrder = confirmOrder;

loadOrder();
</script>

