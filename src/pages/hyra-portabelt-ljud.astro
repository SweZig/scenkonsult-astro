---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const packages = [{"name": "Portabel S", "price": "från 499 kr / dygn", "desc": "1× batteridriven fullrangehögtalare. Upp till 4 tim batteri. 20–50 pers."}, {"name": "Portabel M", "price": "från 799 kr / dygn", "desc": "2× portabla högtalare + bluetooth-mixer. Full stereo. 50–150 pers."}, {"name": "Portabel utomhus", "price": "från 1 199 kr / dygn", "desc": "IP-klassade enheter för regn och damm. Sub + diskanter. 150–400 pers."}];
const includes = ["Leverans och upphämtning ingår (Storstockholm)", "Fulladdat batteri vid leverans", "IP-klassad för utomhusbruk", "Trådlöst Bluetooth och XLR-ingång", "Jourtjänst kvällstid", "Ingen elinstallation krävs"];
---
<ServiceLayout
  title="Hyra portabelt ljud batteridrivet Stockholm | Scenkonsult"
  description="Hyra batteridriven PA-högtalare i Stockholm. IP-klassad, kabelfri. Proffsjud utomhus utan eluttag. Från 499 kr/dygn."
  hero_title="Hyra portabelt ljud"
  hero_subtitle="batteridrivet & kabelfritt"
  category="Uthyrning — Portabelt ljud"
  from_price="499"
  intro="Batteridriven, IP-klassad och fri från kablar. Proffsjud utomhus utan eluttag. Perfekt för utomhusfester, torgaktiviteter och events utan stabil elförsörjning."
  packages={packages}
  includes={includes}
/>
