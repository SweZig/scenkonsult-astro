---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const products = [{"title": "Portable, Small", "priceImg": "https://scenkonsult.se/wp-content/uploads/2025/09/Pris_499.png", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/09/pp_ljud_portable_small_20250919.png", "desc": "Kompakt batteridriven högtalare. Bluetooth och XLR-ingång. Upp till 4 tim batteri. Perfekt för torget eller trädgården."}, {"title": "Portable, Small+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/09/pp_ljud_portable_small_20250919-1.png", "desc": "Utökad portable-lösning med sub och diskant. Mer tryck och räckvidd. Upp till 50 gäster."}, {"title": "Portable, Medium", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/09/pp_ljud_portable_medium_20250919.png", "desc": "Komplett portabelt system för medelstora utomhus-events. 50-150 gäster."}, {"title": "Portable, Medium+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/09/pp_ljud_portable_medium_20250919-1.png", "desc": "Kraftfullt portabelt system med extra basstöd. Perfekt för utomhuskonserter. 150-300 gäster."}, {"title": "Portable, Large", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/09/pp_ljud_portable_large_20250919.png", "desc": "Stort portabelt system för festivaler och utomhus-event utan eltillgång. 300-500 gäster."}, {"title": "Portable, Large+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/09/pp_ljud_portable_large_20250919-1.png", "desc": "Maximalt portabelt system. Fullt självförsörjande med batteri och solpanel-kompatibelt. 500+ gäster."}];
---
<ServiceLayout
  title="Hyra Portabelt Ljud Stockholm | Batteridrivet | Scenkonsult"
  description="Hyra batteridriven PA-högtalare i Stockholm. IP-klassad, kabelfri. Proffsjud utomhus utan eluttag. Sedan 1986."
  pageHeading="Uthyrning av Portabelt Ljud"
  intro="Batteridriven, IP-klassad och fri från kablar. Proffsjud utomhus utan eluttag. Perfekt för utomhus-events, torgaktiviteter och events utan stabil elförsörjning."
  note="Alla priser är hyra per dygn (22 timmar). Utrustning hämtas enl överenskommelse från kl 13:00 och återlämnas innan kl 11:00 nästkommande dag. Vi erbjuder även leverans- och monteringstjänster."
  products={products}
/>
