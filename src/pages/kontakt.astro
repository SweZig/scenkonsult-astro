---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Kontakt & Bokning | Scenkonsult"
  description="Kontakta Scenkonsult för uthyrning av scen, ljud och ljus. Vi svarar inom ett par timmar. Ring 072-448 10 00 eller skicka ett meddelande."
>
<style>
.contact-hero {
  background: var(--ink-deep); padding: 7rem 5vw 5rem;
  padding-top: calc(36px + 74px + 4rem);
}
.contact-hero .overline { color: rgba(255,255,255,0.4); }
.contact-hero .overline::after { background: rgba(255,255,255,0.3); }
.contact-hero h1 { color: white; margin-top: 0.5rem; }
.contact-hero p { color: rgba(255,255,255,0.55); margin-top: 0.75rem; }

.contact-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 0;
  min-height: 60vh;
}
.contact-form-col {
  padding: 4rem 5vw; background: var(--cream);
  border-right: 1px solid var(--rule);
}
.contact-info-col { padding: 4rem 5vw; background: var(--white); }

.form-group { margin-bottom: 1.5rem; }
.form-group label {
  display: block; font-family: 'Space Grotesk', sans-serif;
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--mid); margin-bottom: 0.5rem;
}
.form-group input,
.form-group select,
.form-group textarea {
  width: 100%; padding: 0.85rem 1rem; border: 1px solid var(--rule);
  background: var(--white); font-family: 'Source Sans 3', sans-serif;
  font-size: 0.95rem; color: var(--text); border-radius: 2px;
  transition: border-color 0.2s; outline: none; resize: vertical;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { border-color: var(--ink); }
.form-group textarea { min-height: 130px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.form-submit {
  font-family: 'Space Grotesk', sans-serif; font-size: 0.75rem; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  background: var(--ink); color: white; border: none; padding: 1rem 2.5rem;
  border-radius: 2px; cursor: pointer; width: 100%; transition: background 0.2s;
}
.form-submit:hover { background: var(--ink-deep); }

.info-card {
  padding: 1.75rem 0; border-bottom: 1px solid var(--rule);
}
.info-card:last-child { border-bottom: none; }
.info-card-label {
  font-family: 'Space Grotesk', sans-serif; font-size: 0.6rem; font-weight: 700;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--mid); margin-bottom: 0.4rem;
}
.info-card-val {
  font-family: 'DM Serif Display', serif; font-size: 1.3rem; color: var(--ink);
}
.info-card-val a { text-decoration: none; color: var(--ink); }
.info-card-desc { font-size: 0.85rem; color: var(--mid); line-height: 1.7; margin-top: 0.3rem; }

.success-msg {
  display: none; background: var(--ink-tint); border: 1px solid var(--ink);
  border-radius: 3px; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem;
  font-family: 'Space Grotesk', sans-serif; font-size: 0.85rem; color: var(--ink); font-weight: 600;
}

@media (max-width: 768px) {
  .contact-hero { padding-top: calc(32px + 64px + 3rem); }
  .contact-grid { grid-template-columns: 1fr; }
  .contact-form-col, .contact-info-col { padding: 3rem 5vw; }
  .form-row { grid-template-columns: 1fr; }
}
</style>

<div class="contact-hero">
  <span class="overline">Kontakt & Bokning</span>
  <h1 class="display">Vi svarar inom<br><em>ett par timmar</em></h1>
  <p class="lead">Berätta om ditt event — vi hjälper dig välja rätt utrustning och presenterar pris.</p>
</div>

<div class="contact-grid">
  <div class="contact-form-col">
    <span class="overline">Skicka förfrågan</span>

    <div class="success-msg" id="successMsg">
      ✓ Tack för din förfrågan! Vi återkommer inom ett par timmar.
    </div>

    <form name="bokning" method="POST" data-netlify="true" id="contactForm">
      <input type="hidden" name="form-name" value="bokning" />

      <div class="form-row">
        <div class="form-group">
          <label for="name">Namn *</label>
          <input type="text" id="name" name="name" required placeholder="Ditt namn" />
        </div>
        <div class="form-group">
          <label for="phone">Telefon *</label>
          <input type="tel" id="phone" name="phone" required placeholder="07X-XXX XX XX" />
        </div>
      </div>

      <div class="form-group">
        <label for="email">E-post *</label>
        <input type="email" id="email" name="email" required placeholder="din@email.se" />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="eventdate">Eventdatum</label>
          <input type="date" id="eventdate" name="eventdate" />
        </div>
        <div class="form-group">
          <label for="guests">Antal gäster</label>
          <input type="text" id="guests" name="guests" placeholder="t.ex. 50–100" />
        </div>
      </div>

      <div class="form-group">
        <label for="service">Vad behöver du?</label>
        <select id="service" name="service">
          <option value="">Välj kategori...</option>
          <option>Scen</option>
          <option>Ljud – Event & konferens</option>
          <option>Ljud – Musik & dans</option>
          <option>Ljud – Live & konsert</option>
          <option>Ljus</option>
          <option>Projektor & skärm</option>
          <option>Portabelt ljud</option>
          <option>DJ-utrustning</option>
          <option>Komplett event (scen + ljud + ljus)</option>
        </select>
      </div>

      <div class="form-group">
        <label for="message">Beskriv ditt event *</label>
        <textarea id="message" name="message" required placeholder="Berätta lite om evenemanget — plats, upplägg, specifika önskemål..."></textarea>
      </div>

      <button type="submit" class="form-submit">Skicka förfrågan →</button>
    </form>
  </div>

  <div class="contact-info-col">
    <span class="overline">Kontaktuppgifter</span>

    <div class="info-card">
      <div class="info-card-label">Telefon</div>
      <div class="info-card-val"><a href="tel:0724481000">072-448 10 00</a></div>
      <div class="info-card-desc">Jourtjänst kvällstid under pågående event</div>
    </div>

    <div class="info-card">
      <div class="info-card-label">Svarstid</div>
      <div class="info-card-val">Inom ett par timmar</div>
      <div class="info-card-desc">Vi återkommer snabbt med förslag och pris — kostnadsfritt</div>
    </div>

    <div class="info-card">
      <div class="info-card-label">Leveransområde</div>
      <div class="info-card-val">Hela Storstockholm</div>
      <div class="info-card-desc">Leverans och montering ingår. Vi riggar och kalibrerar på plats.</div>
    </div>

    <div class="info-card">
      <div class="info-card-label">Erfarenhet</div>
      <div class="info-card-val">Sedan 1986</div>
      <div class="info-card-desc">38+ år i branschen. Från privata fester till ambassader och bolagsstämmor.</div>
    </div>

    <div class="info-card">
      <div class="info-card-label">Avbokning</div>
      <div class="info-card-val">Generösa villkor</div>
      <div class="info-card-desc">Inga dolda avgifter. Vi behandlar dig som vi vill bli behandlade.</div>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById('contactForm');
  const successMsg = document.getElementById('successMsg');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form as HTMLFormElement);
    try {
      await fetch('/', { method: 'POST', body: data });
      successMsg!.style.display = 'block';
      (form as HTMLFormElement).reset();
      window.scrollTo({ top: form!.offsetTop - 100, behavior: 'smooth' });
    } catch(err) {
      alert('Något gick fel. Ring oss på 072-448 10 00.');
    }
  });
</script>

</Layout>
