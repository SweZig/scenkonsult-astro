---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Varukorg – Scenkonsult"
  description="Granska din varukorg och skicka en förfrågan till Scenkonsult."
>
  <section class="cart-page">
    <div class="cart-wrap">

      <div class="cart-header">
        <h1>Din varukorg</h1>
        <p class="cart-subtitle">Lägg till produkter via produktsidorna, sedan skickar du en förfrågan direkt.</p>
      </div>

      <!-- EMPTY STATE -->
      <div id="cartEmpty" class="cart-empty hidden">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <p>Varukorgen är tom.</p>
        <a href="/#tjanster" class="cart-empty-cta">Se alla tjänster →</a>
      </div>

      <!-- CART TABLE -->
      <div id="cartContent" class="hidden">

        <div class="cart-table-wrap">
          <table class="cart-table">
            <thead>
              <tr>
                <th class="th-product">Produkt</th>
                <th class="th-price">Pris (exkl. moms)</th>
                <th class="th-qty">Antal</th>
                <th class="th-total">Totalt</th>
                <th class="th-remove"></th>
              </tr>
            </thead>
            <tbody id="cartTableBody"></tbody>
          </table>
        </div>

        <!-- SUMMARY -->
        <div class="cart-summary">
          <div class="cart-summary-row">
            <span>Delsumma (exkl. moms)</span>
            <span id="cartSubtotal">–</span>
          </div>
          <div class="cart-summary-row muted">
            <span>Moms 25%</span>
            <span id="cartVat">–</span>
          </div>
          <div class="cart-summary-row total">
            <span>Totalt (inkl. moms)</span>
            <span id="cartTotal">–</span>
          </div>
          <p class="cart-note">* Priserna avser hyra per dygn. Leverans och andra tillägg tillkommer vid bokning.</p>
        </div>

        <!-- ACTIONS -->
        <div class="cart-actions">
          <button id="btnEmail" class="cart-action-btn primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 7L2 7"/></svg>
            Maila offertförfrågan
          </button>
          <button id="btnSave" class="cart-action-btn secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Spara som PDF
          </button>
          <a href="/bokningssida/" class="cart-action-btn accent">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><polyline points="12 5 19 12 12 19"/></svg>
            Boka detta nu
          </a>
          <button id="btnClear" class="cart-action-btn ghost">
            Töm varukorg
          </button>
        </div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .cart-page {
    padding-top: calc(var(--nav-offset, 110px) + 2rem);
    padding-bottom: 6rem;
    min-height: 70vh;
  }
  .cart-wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  .cart-header {
    margin-bottom: 2.5rem;
  }
  .cart-header h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    color: white;
    margin-bottom: 0.5rem;
  }
  .cart-subtitle {
    color: rgba(255,255,255,0.5);
    font-size: 0.95rem;
  }

  /* EMPTY */
  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    padding: 5rem 2rem;
    text-align: center;
    color: rgba(255,255,255,0.35);
    font-size: 1.1rem;
  }
  .cart-empty-cta {
    color: #c4b5f4;
    font-size: 0.9rem;
    text-decoration: none;
    border-bottom: 1px solid rgba(196,181,244,0.4);
    padding-bottom: 2px;
  }
  .cart-empty-cta:hover { border-color: #c4b5f4; }

  /* TABLE */
  .cart-table-wrap {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .cart-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.88rem;
  }
  .cart-table thead {
    background: rgba(30,24,80,0.8);
  }
  .cart-table th {
    padding: 0.85rem 1rem;
    text-align: left;
    color: rgba(255,255,255,0.45);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .th-price, .th-qty, .th-total { text-align: right; }
  .th-remove { width: 2.5rem; }
  .cart-table tbody tr {
    border-top: 1px solid rgba(255,255,255,0.06);
    transition: background 0.15s;
  }
  .cart-table tbody tr:hover { background: rgba(196,181,244,0.04); }
  .cart-table td {
    padding: 1rem;
    color: white;
    vertical-align: middle;
  }
  .td-price, .td-total { text-align: right; color: rgba(255,255,255,0.7); }
  .td-total { color: #c4b5f4; font-weight: 700; }
  .td-remove { text-align: right; }

  /* Product cell */
  .cart-product {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .cart-product-img {
    width: 52px;
    height: 44px;
    object-fit: cover;
    border-radius: 6px;
    background: #1e1850;
    flex-shrink: 0;
  }
  .cart-product-img-placeholder {
    width: 52px;
    height: 44px;
    border-radius: 6px;
    background: #1e1850;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cart-product-name { font-weight: 600; font-size: 0.92rem; }
  .cart-product-cat { color: rgba(255,255,255,0.35); font-size: 0.75rem; }
  .cart-product-note { color: rgba(255,255,255,0.35); font-size: 0.72rem; }

  /* Qty stepper */
  .qty-stepper {
    display: flex;
    align-items: center;
    gap: 0;
    justify-content: flex-end;
  }
  .qty-btn {
    width: 28px;
    height: 28px;
    border: 1px solid rgba(255,255,255,0.15);
    background: transparent;
    color: white;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, border-color 0.15s;
  }
  .qty-btn:first-child { border-radius: 6px 0 0 6px; }
  .qty-btn:last-child { border-radius: 0 6px 6px 0; }
  .qty-btn:hover { background: rgba(196,181,244,0.15); border-color: rgba(196,181,244,0.4); }
  .qty-val {
    width: 32px;
    height: 28px;
    border-top: 1px solid rgba(255,255,255,0.15);
    border-bottom: 1px solid rgba(255,255,255,0.15);
    background: transparent;
    color: white;
    text-align: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0;
  }
  .qty-val:focus { outline: none; }

  /* Remove btn */
  .remove-btn {
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.25);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.15s;
    display: flex;
    align-items: center;
  }
  .remove-btn:hover { color: #f87171; }

  /* SUMMARY */
  .cart-summary {
    background: rgba(30,24,80,0.5);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 1.5rem;
    max-width: 420px;
    margin-left: auto;
    margin-bottom: 2rem;
  }
  .cart-summary-row {
    display: flex;
    justify-content: space-between;
    padding: 0.4rem 0;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.9rem;
    color: white;
  }
  .cart-summary-row.muted { color: rgba(255,255,255,0.5); }
  .cart-summary-row.total {
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    font-weight: 700;
    font-size: 1.05rem;
    color: #c4b5f4;
  }
  .cart-note {
    color: rgba(255,255,255,0.3);
    font-size: 0.72rem;
    margin-top: 0.75rem;
    line-height: 1.5;
  }

  /* ACTIONS */
  .cart-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  .cart-action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    border-radius: 10px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    border: none;
    transition: all 0.2s;
  }
  .cart-action-btn.primary {
    background: rgba(196,181,244,0.15);
    border: 1px solid rgba(196,181,244,0.4);
    color: #c4b5f4;
  }
  .cart-action-btn.primary:hover {
    background: rgba(196,181,244,0.25);
    border-color: #c4b5f4;
  }
  .cart-action-btn.secondary {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.7);
  }
  .cart-action-btn.secondary:hover {
    background: rgba(255,255,255,0.1);
    color: white;
  }
  .cart-action-btn.accent {
    background: #c4b5f4;
    color: #0c0a24;
  }
  .cart-action-btn.accent:hover {
    background: #e2dcfb;
  }
  .cart-action-btn.ghost {
    background: transparent;
    border: 1px solid rgba(255,100,100,0.25);
    color: rgba(255,100,100,0.6);
  }
  .cart-action-btn.ghost:hover {
    background: rgba(255,100,100,0.08);
    border-color: rgba(255,100,100,0.5);
    color: #f87171;
  }

  @media (max-width: 640px) {
    .th-price, .td-price { display: none; }
    .cart-table th, .cart-table td { padding: 0.75rem 0.65rem; }
    .cart-actions { flex-direction: column; align-items: stretch; }
    .cart-action-btn { justify-content: center; }
  }
</style>

<script>
  // ─── RENDER CART ─────────────────────────────────────────────
  function fmt(n: number) {
    return n.toLocaleString('sv') + ' kr';
  }

  function getCart() {
    try { return JSON.parse(localStorage.getItem('sk-cart') || '[]'); } catch { return []; }
  }
  function saveCart(cart: any[]) {
    try { localStorage.setItem('sk-cart', JSON.stringify(cart)); } catch {}
  }
  function updateBadge() {
    const total = getCart().reduce((s: number, i: any) => s + i.qty, 0);
    const badge = document.getElementById('navCartBadge');
    if (badge) { badge.textContent = String(total); badge.classList.toggle('hidden', total === 0); }
  }

  function renderCart() {
    const cart = getCart();
    const empty = document.getElementById('cartEmpty')!;
    const content = document.getElementById('cartContent')!;
    const tbody = document.getElementById('cartTableBody')!;

    if (cart.length === 0) {
      empty.classList.remove('hidden');
      content.classList.add('hidden');
      return;
    }
    empty.classList.add('hidden');
    content.classList.remove('hidden');

    tbody.innerHTML = cart.map((item: any) => `
      <tr data-id="${item.id}">
        <td>
          <div class="cart-product">
            ${item.image
              ? `<img class="cart-product-img" src="${item.image}" alt="${item.name}" loading="lazy" />`
              : `<div class="cart-product-img-placeholder"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg></div>`
            }
            <div>
              <div class="cart-product-name">${item.name}</div>
              <div class="cart-product-cat">${item.category}</div>
              <div class="cart-product-note">${item.priceNote}</div>
            </div>
          </div>
        </td>
        <td class="td-price">${fmt(item.price)}</td>
        <td>
          <div class="qty-stepper">
            <button class="qty-btn" data-action="dec" data-id="${item.id}">−</button>
            <input class="qty-val" type="number" min="1" max="99" value="${item.qty}" data-id="${item.id}" readonly />
            <button class="qty-btn" data-action="inc" data-id="${item.id}">+</button>
          </div>
        </td>
        <td class="td-total">${fmt(item.price * item.qty)}</td>
        <td class="td-remove">
          <button class="remove-btn" data-id="${item.id}" aria-label="Ta bort">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/>
              <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
            </svg>
          </button>
        </td>
      </tr>
    `).join('');

    // Summary
    const subtotal = cart.reduce((s: number, i: any) => s + i.price * i.qty, 0);
    const vat = Math.round(subtotal * 0.25);
    const total = subtotal + vat;
    document.getElementById('cartSubtotal')!.textContent = fmt(subtotal);
    document.getElementById('cartVat')!.textContent = fmt(vat);
    document.getElementById('cartTotal')!.textContent = fmt(total);

    // Event listeners
    tbody.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const el = e.currentTarget as HTMLButtonElement;
        const id = el.dataset.id!;
        const cart = getCart();
        const item = cart.find((i: any) => i.id === id);
        if (!item) return;
        if (el.dataset.action === 'inc') item.qty += 1;
        else if (el.dataset.action === 'dec') item.qty = Math.max(0, item.qty - 1);
        const filtered = cart.filter((i: any) => i.qty > 0);
        saveCart(filtered);
        updateBadge();
        renderCart();
      });
    });

    tbody.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const el = e.currentTarget as HTMLButtonElement;
        const id = el.dataset.id!;
        saveCart(getCart().filter((i: any) => i.id !== id));
        updateBadge();
        renderCart();
      });
    });
  }

  // Email action
  document.getElementById('btnEmail')?.addEventListener('click', () => {
    const cart = getCart();
    if (cart.length === 0) return;
    const subtotal = cart.reduce((s: number, i: any) => s + i.price * i.qty, 0);
    const vat = Math.round(subtotal * 0.25);
    const lines = cart.map((i: any) => `- ${i.name} × ${i.qty}  →  ${(i.price * i.qty).toLocaleString('sv')} kr exkl. moms`).join('\n');
    const body = encodeURIComponent(
      `Hej Scenkonsult!\n\nJag är intresserad av att hyra följande:\n\n${lines}\n\nDelsumma: ${subtotal.toLocaleString('sv')} kr exkl. moms\nMoms (25%): ${vat.toLocaleString('sv')} kr\nTotalt: ${(subtotal + vat).toLocaleString('sv')} kr inkl. moms\n\nKontakta mig gärna för att boka!\n\nMed vänliga hälsningar,`
    );
    window.location.href = `mailto:info@scenkonsult.se?subject=Offertförfrågan%20från%20scenkonsult.se&body=${body}`;
  });

  // Save/print action
  document.getElementById('btnSave')?.addEventListener('click', () => {
    const cart = getCart();
    if (cart.length === 0) return;
    const subtotal = cart.reduce((s: number, i: any) => s + i.price * i.qty, 0);
    const vat = Math.round(subtotal * 0.25);
    const rows = cart.map((i: any) => `
      <tr>
        <td>${i.name}</td>
        <td>${i.category}</td>
        <td style="text-align:center">${i.qty}</td>
        <td style="text-align:right">${i.price.toLocaleString('sv')} kr</td>
        <td style="text-align:right">${(i.price * i.qty).toLocaleString('sv')} kr</td>
      </tr>`).join('');
    const html = `<!DOCTYPE html>
<html lang="sv"><head><meta charset="UTF-8"><title>Varukorg – Scenkonsult</title>
<style>
  body{font-family:Arial,sans-serif;padding:2rem;color:#111;max-width:750px;margin:0 auto}
  h1{color:#1e1850;margin-bottom:0.3rem}
  p.sub{color:#666;font-size:.85rem;margin-bottom:2rem}
  table{width:100%;border-collapse:collapse;margin-bottom:1.5rem}
  th{background:#1e1850;color:white;padding:.6rem 1rem;text-align:left;font-size:.8rem}
  td{padding:.6rem 1rem;border-bottom:1px solid #eee;font-size:.9rem}
  .summary{text-align:right}
  .total{font-weight:700;font-size:1.1rem;color:#1e1850}
  .footer{margin-top:2rem;font-size:.8rem;color:#999;border-top:1px solid #eee;padding-top:1rem}
</style></head><body>
<h1>Scenkonsult – Offertunderlag</h1>
<p class="sub">Genererat ${new Date().toLocaleDateString('sv')} | info@scenkonsult.se | 072-448 10 00</p>
<table>
  <thead><tr><th>Produkt</th><th>Kategori</th><th>Antal</th><th>Styckpris</th><th>Totalt</th></tr></thead>
  <tbody>${rows}</tbody>
</table>
<div class="summary">
  <p>Exkl. moms: <strong>${subtotal.toLocaleString('sv')} kr</strong></p>
  <p>Moms 25%: ${vat.toLocaleString('sv')} kr</p>
  <p class="total">Totalt inkl. moms: ${(subtotal + vat).toLocaleString('sv')} kr</p>
</div>
<p class="footer">Alla priser avser hyra per dygn (22 timmar). Leverans och montering tillkommer. Kontakta oss för slutlig offert och bokning.</p>
</body></html>`;
    const w = window.open('', '_blank');
    if (w) { w.document.write(html); w.document.close(); w.focus(); w.print(); }
  });

  // Clear cart
  document.getElementById('btnClear')?.addEventListener('click', () => {
    if (confirm('Töm hela varukorgen?')) {
      localStorage.removeItem('sk-cart');
      updateBadge();
      renderCart();
    }
  });

  // Init
  renderCart();
  updateBadge();
</script>
