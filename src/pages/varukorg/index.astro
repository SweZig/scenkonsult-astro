  const SK_KEY = 'sk-cart';

  function _getCartData() {
    try {
      const raw = localStorage.getItem(SK_KEY);
      if (!raw) return null;
      const d = JSON.parse(raw);
      if (Array.isArray(d)) return { id: _genId(), expires: Date.now() + SK_TTL, items: d };
      if (d.expires && Date.now() > d.expires) { localStorage.removeItem(SK_KEY); return null; }
      return d;
    } catch { return null; }
  }
  function _genId() {
    const h = () => Math.random().toString(16).slice(2,6).toUpperCase();
    return `SK-${h()}${h()}-${h()}`;
  }
  function getCart()       { return _getCartData()?.items || []; }
  function getCartId()     { return _getCartData()?.id || null; }
