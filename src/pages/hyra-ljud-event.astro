const includes = ["Leverans och upphämtning ingår (Storstockholm)", "Montering, kabeldragning och riggning", "Ljudkalibrering och soundcheck", "Trådlösa mikrofoner (handhållen/headset/lavage)", "Jourtjänst kvällstid", "Kostnadsfri teknisk rådgivning"];
---
<ServiceLayout
  title="Hyra ljud event & konferens Stockholm | Scenkonsult"
  description="Hyra PA-system för seminarier, galor och bolagsstämmor i Stockholm. Trådlösa mikrofoner, proffsljud. Från 749 kr/dygn. Sedan 1986."
  hero_title="Hyra ljud"
  hero_subtitle="Event & konferens"
  category="Uthyrning — Ljud"
  from_price="749"
  intro="PA-system med trådlösa mikrofoner för seminarier, galor och bolagsstämmor. Enkelt att använda, klart och tydligt ljud i hela lokalen."
  packages={packages}
  includes={includes}
/>
