---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const products = [{"title": "Event, Small", "priceImg": "https://scenkonsult.se/wp-content/uploads/2025/09/Pris_799.png", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_event_small_20250824PNG.png", "desc": "Kompakt PA-system för mindre event och konferenser. Passar för upp till 50 gäster."}, {"title": "Event, Small+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_event_small-_20250824PNG.png", "desc": "Utökat PA-system för medelstora event. Trådlösa mikrofoner ingår. Upp till 100 gäster."}, {"title": "Event, Medium", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_event_medium_20250824PNG.png", "desc": "Komplett PA med mixer och trådlösa mikrofoner. Passar för 100-250 gäster."}, {"title": "Event, Medium+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_event_medium-_20250824PNG.png", "desc": "Större PA-system med subbasar och fullrange. Bra för galor och bolagsstämmor. 250-500 gäster."}, {"title": "Event, Large", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_event_large_20250824PNG.png", "desc": "Kraftfullt PA för stora events och konferenser. Line array-system för jämn ljudbild. 500+ gäster."}, {"title": "Analogt Mixerbord, 2+2 kanaler", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_mixer01_20250824PNG.png", "desc": "Kompakt analog mixer för enkel användning. Perfekt till konferens och mindre event."}, {"title": "Analogt Mixerbord, 4+2 kanaler", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_mixer02_20250824PNG.png", "desc": "Analog mixer med 4 mikrofonkanaler. Bra för panelsamtal och presentationer."}, {"title": "Analogt Mixerbord, 4+4 kanaler", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_mixer03_20250824PNG.png", "desc": "Flexibel mixer för event med flera talare och källor."}, {"title": "Trådlöst mikrofonset, 8 kanaler", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_tillbehor20_20250824-1024x853.png", "desc": "8-kanals trådlöst mikrofonset. Handhållna, headset och lavage-mikrofoner. Proffsigt och enkelt."}];
---
<ServiceLayout
  title="Hyra Ljud Event & Konferens Stockholm | Scenkonsult"
  description="Hyra PA-system för event och konferens i Stockholm. Trådlösa mikrofoner, mixerbord. Från 799 kr/dygn. Sedan 1986."
  pageHeading="Uthyrning av Ljud — Event & Konferens"
  intro="PA-system för event, seminarier, galor och bolagsstämmor. Klart och tydligt ljud i hela lokalen — enkelt att använda, proffsigt resultat."
  note="Alla priser är hyra per dygn (22 timmar). Utrustning hämtas enl överenskommelse från kl 13:00 och återlämnas innan kl 11:00 nästkommande dag. Vi erbjuder även leverans- och monteringstjänster."
  products={products}
/>
