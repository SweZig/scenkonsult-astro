---
import Layout from './Layout.astro';
import Price from '../components/Price.astro';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle?: string;
  heroIntro: string;
  heroBullets?: string[];
  breadcrumb: { label: string; href?: string }[];
  schemaExtra?: Record<string, unknown>;
}

const {
  title,
  description,
  heroTitle,
  heroSubtitle,
  heroIntro,
  heroBullets = [],
  breadcrumb,
  schemaExtra,
} = Astro.props;
---

<Layout title={title} description={description} schemaExtra={schemaExtra}>
  <!-- HERO -->
  <section class="svc-hero">
    <!-- dot pattern decoration -->
    <div class="svc-hero-dots" aria-hidden="true"></div>

    <div class="svc-hero-inner">
      <!-- Breadcrumb -->
      <nav class="svc-breadcrumb" aria-label="Brödsmulor">
        <ol>
          {breadcrumb.map((crumb, i) => (
            <li>
              {crumb.href
                ? <a href={crumb.href}>{crumb.label}</a>
                : <span>{crumb.label}</span>
              }
              {i < breadcrumb.length - 1 && <span class="svc-bc-sep">/</span>}
            </li>
          ))}
        </ol>
      </nav>

      <!-- Title -->
      <h1 class="svc-hero-h1">
        {heroTitle}
        {heroSubtitle && <em>{heroSubtitle}</em>}
      </h1>

      <p class="svc-hero-intro">{heroIntro}</p>

      {heroBullets.length > 0 && (
        <ul class="svc-hero-bullets">
          {heroBullets.map(b => <li>{b}</li>)}
        </ul>
      )}

      <div class="svc-hero-btns">
        <a href="/kontakt" class="svc-btn-solid">Boka / Fråga om pris</a>
        <a href="tel:0724481000" class="svc-btn-phone">📞 072-448 10 00</a>
      </div>
    </div>
  </section>

  <!-- PAGE BODY SLOT -->
  <slot />

  <!-- HYRESVILLKOR NOTE -->
  <div class="svc-note-bar">
    Alla priser är hyra per dygn (22 timmar). Utrustning hämtas enl överenskommelse från kl 13:00 och återlämnas innan kl 11:00 nästkommande dag. Längre hyresperioder enl offert.
    <a href="/hyresvillkor">Läs hyresvillkoren →</a>
  </div>

  <!-- BOTTOM CTA -->
  <section class="svc-bottom-cta">
    <div class="svc-bottom-cta-inner">
      <div>
        <span class="overline">Redo att boka?</span>
        <h2 class="svc-cta-h2">Vi svarar inom<br/><em>ett par timmar.</em></h2>
        <p class="svc-cta-sub">Ring eller skicka förfrågan — ingen bindning.</p>
      </div>
      <div class="svc-cta-actions">
        <a href="/kontakt" class="svc-btn-cta">Skicka förfrågan</a>
        <a href="tel:0724481000" class="svc-cta-tel">072-448 10 00</a>
      </div>
    </div>
  </section>
</Layout>

<style>
/* ── SERVICE HERO ── */
.svc-hero {
  background: var(--ink-deep);
  padding: calc(36px + 74px + 3rem) 5vw 4rem;
  position: relative;
  overflow: hidden;
}
.svc-hero-dots {
  position: absolute;
  top: 50%;
  right: -10%;
  width: 520px;
  height: 520px;
  border-radius: 50%;
  background-image: radial-gradient(circle, rgba(255,255,255,0.06) 2px, transparent 2px);
  background-size: 26px 26px;
  transform: translateY(-50%);
  animation: rotateSlow 70s linear infinite;
  pointer-events: none;
}
@keyframes rotateSlow { to { transform: translateY(-50%) rotate(360deg); } }

.svc-hero-inner {
  max-width: 800px;
  position: relative;
  z-index: 2;
}

.svc-breadcrumb ol {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  list-style: none;
  margin-bottom: 2rem;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.svc-breadcrumb a { color: rgba(255,255,255,0.4); text-decoration: none; transition: color .2s; }
.svc-breadcrumb a:hover { color: rgba(255,255,255,0.8); }
.svc-breadcrumb span:last-child { color: rgba(255,255,255,0.7); }
.svc-bc-sep { color: rgba(255,255,255,0.2); }

.svc-hero-h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(2.4rem, 4.5vw, 4rem);
  color: white;
  line-height: 1.05;
  margin-bottom: 1.25rem;
}
.svc-hero-h1 em {
  font-style: italic;
  color: rgba(255,255,255,0.4);
  display: block;
}

.svc-hero-intro {
  font-size: 1rem;
  color: rgba(255,255,255,0.6);
  line-height: 1.8;
  max-width: 600px;
  margin-bottom: 1.5rem;
}

.svc-hero-bullets {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1.5rem;
  margin-bottom: 2rem;
}
.svc-hero-bullets li {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: rgba(255,255,255,0.55);
}
.svc-hero-bullets li::before { content: '✓ '; color: rgba(255,255,255,0.35); }

.svc-hero-btns {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.svc-btn-solid {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 0.9rem 2rem;
  border-radius: 2px;
  background: white;
  color: var(--ink);
  transition: background .2s;
}
.svc-btn-solid:hover { background: var(--ink-tint); }
.svc-btn-phone {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.8rem;
  font-weight: 700;
  color: rgba(255,255,255,0.5);
  text-decoration: none;
  transition: color .2s;
}
.svc-btn-phone:hover { color: white; }

/* ── NOTE BAR ── */
.svc-note-bar {
  background: var(--ink-tint);
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  padding: 1rem 5vw;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--ink);
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1.5rem;
  align-items: center;
}
.svc-note-bar a {
  color: var(--ink);
  text-decoration: underline;
  white-space: nowrap;
}

/* ── BOTTOM CTA ── */
.svc-bottom-cta {
  background: var(--ink-deep);
  margin: 0;
}
.svc-bottom-cta-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 4rem 5vw;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 4rem;
}
.svc-cta-h2 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  color: white;
  line-height: 1.1;
  margin-top: 0.5rem;
  margin-bottom: 0.75rem;
}
.svc-cta-h2 em { font-style: italic; color: rgba(255,255,255,0.4); }
.svc-cta-sub { font-size: 0.9rem; color: rgba(255,255,255,0.4); }
.svc-cta-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}
.svc-btn-cta {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 1rem 2.25rem;
  border-radius: 2px;
  background: white;
  color: var(--ink);
  white-space: nowrap;
  transition: background .2s;
}
.svc-btn-cta:hover { background: var(--ink-tint); }
.svc-cta-tel {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  color: rgba(255,255,255,0.35);
  text-decoration: none;
  transition: color .2s;
}
.svc-cta-tel:hover { color: rgba(255,255,255,0.8); }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .svc-hero {
    padding: calc(32px + 64px + 2.5rem) 6vw 3rem;
  }
  .svc-hero-h1 { font-size: clamp(2rem, 8vw, 2.8rem); }
  .svc-hero-btns { flex-direction: column; align-items: flex-start; gap: 1rem; }
  .svc-btn-solid { width: 100%; text-align: center; }
  .svc-bottom-cta-inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .svc-cta-actions { align-items: flex-start; }
  .svc-btn-cta { width: 100%; text-align: center; }
}
</style>
