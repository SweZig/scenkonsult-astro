async function invSaveFields() {
  const updates = {
    cart_id: currentCart.id,
    invoice_date:     document.getElementById('inv-date')?.value || null,
    invoice_due_date: document.getElementById('inv-due')?.value || null,
    payment_terms_days: parseInt(document.getElementById('inv-terms')?.value || '5'),
  };
  const { ok } = await api('cart-update', { method: 'POST', body: JSON.stringify(updates) });
  if (ok) {
    Object.assign(currentCart, updates);
    toast('Fakturauppgifter sparade!');
    renderTab('faktura');
  } else toast('Kunde inte spara', 'error');
}

async function invSendEmail() {
  if (!currentCart.customer_email) { toast('Kunden saknar e-postadress', 'error'); return; }
  if (!confirm(`Skicka faktura till ${currentCart.customer_email}?`)) return;
  // Spara eventuella ändringar i fakturainfo först
  await invSaveFields().catch(() => {});
  const btn = document.querySelector('[onclick="invSendEmail()"]');
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Genererar PDF…'; }
  try {
    const { ok, data } = await api('invoice-send', {
      method: 'POST',
      body: JSON.stringify({ cart_id: currentCart.id })
    });
    if (ok && data.ok) {
      currentCart.status = 'fakturerad';
      currentCart.invoice_sent_at = new Date().toISOString();
      currentCart.invoice_number = data.invoice_number;
      toast(`Faktura ${data.invoice_number} skickad! 📧`);
      loadCarts();
      renderTab('faktura');
      renderPanelFooter();
    } else {
      toast(data?.error || 'Fel vid utskick', 'error');
    }
  } catch (e) {
    toast('Nätverksfel: ' + e.message, 'error');
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = '📧 Skicka faktura via mail'; }
  }
}

async function invMarkPaid() {
  if (!confirm('Markera ordern som betald?')) return;
  const now = new Date().toISOString();
  const { ok } = await api('cart-update', {
    method: 'POST',
    body: JSON.stringify({ cart_id: currentCart.id, status: 'betald', invoice_paid_at: now })
  });
  if (ok) {
    currentCart.status = 'betald';
    currentCart.invoice_paid_at = now;
    toast('Order markerad som betald! 💚');
    loadCarts();
    renderTab('faktura');
    renderPanelFooter();
  } else toast('Fel vid markering', 'error');
}

function renderPanelFooter() {
  const c = currentCart;
  const footer = $('panel-footer');
  footer.innerHTML = '';

  const makeBtn = (label, cls, fn) => {
    const b = document.createElement('button');
    b.className = `btn-action ${cls}`;
    b.textContent = label;
    b.onclick = fn;
    footer.appendChild(b);
  };

  // Context-sensitive buttons based on status
  if (c.status === 'open') {
    makeBtn('📤 Skapa & skicka offert', 'btn-success', () => { renderTab('products'); });
    makeBtn('❌ Avvisa', 'btn-danger', cancelOrder);
  } else if (c.status === 'proposal') {
    makeBtn('✅ Bekräfta order', 'btn-success', confirmOrder);
    makeBtn('📦 Justera produkter', '', () => renderTab('products'));
    makeBtn('❌ Avbryt', 'btn-danger', cancelOrder);
  } else if (c.status === 'waiting') {
    makeBtn('✅ Bekräfta order', 'btn-success', confirmOrder);
    makeBtn('📩 Påminn kund', '', sendCustomerNotice);
    makeBtn('❌ Avbryt', 'btn-danger', cancelOrder);
  } else if (c.status === 'confirmed') {
    makeBtn('🧾 Skapa faktura', 'btn-success', () => renderTab('faktura'));
    makeBtn('📩 Skicka notis', '', sendCustomerNotice);
  } else if (c.status === 'fakturerad') {
    makeBtn('💚 Markera betald', 'btn-success', invMarkPaid);
    makeBtn('📩 Påminn om betalning', '', sendCustomerNotice);
  } else if (c.status === 'betald') {
    // Avslutad — bara info
  } else if (c.status !== 'cancelled') {
    makeBtn('✅ Bekräfta order', 'btn-success', confirmOrder);
    makeBtn('📤 Skicka offert', '', () => openQuoteModalForCart(c));
    makeBtn('❌ Avbryt', 'btn-danger', cancelOrder);
  }

  // Always: copy customer link if exists
  if (c.cart_token) {
    makeBtn('🔗 Kopiera kundlänk', '', () => {
      const url = `https://scenkonsult.se/order/?cart=${c.id}&token=${c.cart_token}`;
      navigator.clipboard.writeText(url);
      toast('Kundlänk kopierad!');
    });
  }
}

async function confirmOrder() {
  if (!confirm('Bekräfta ordern? Status ändras till Orderbekräftelse och TTL tas bort.')) return;
  const { ok } = await api('cart-update', {
    method: 'POST',
    body: JSON.stringify({ cart_id: currentCart.id, status: 'confirmed' })
  });
  if (ok) {
    currentCart.status = 'confirmed';
    toast('Order bekräftad! ✅');
    loadCarts();
    renderTab('info');
    renderPanelFooter();
  } else toast('Fel vid bekräftelse', 'error');
}

async function cancelOrder() {
  if (!confirm('Avbryt ordern? Den sparas i 90 dagar.')) return;
  const { ok } = await api('cart-update', {
    method: 'POST',
    body: JSON.stringify({ cart_id: currentCart.id, status: 'cancelled' })
  });
  if (ok) {
    currentCart.status = 'cancelled';
    toast('Order avbruten');
    await loadCarts();
    renderTab('info');
    renderPanelFooter();
  } else toast('Fel vid avbrytning', 'error');
}

async function sendCustomerNotice() {
  const msg = prompt('Meddelande till kund (skickas via e-post):');
  if (!msg?.trim()) return;
  const { ok } = await api('cart-message', {
    method: 'POST',
    body: JSON.stringify({ cart_id: currentCart.id, body: msg.trim() })
  });
  if (ok) {
    toast('Notis skickad till kund! 📩');
    currentMessages.push({
      id: Date.now(), cart_id: currentCart.id,
      sender: 'admin', body: msg.trim(),
      read_at: null, created_at: new Date().toISOString()
    });
    if (activeTab === 'chat') renderTab('chat');
  } else toast('Kunde inte skicka notis', 'error');
}

