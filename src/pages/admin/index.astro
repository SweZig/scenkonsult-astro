function prodTogglePopout(idx) {
  const el = document.getElementById('po-' + idx);
  if (el) el.style.display = el.style.display === 'none' ? 'block' : 'none';
}

function prodAddFromCatalog(sel) {
  if (!sel.value) return;
  try {
    const p = JSON.parse(sel.value.replace(/&quot;/g,'"'));
    const items = prodGetItems();
    items.push({ id: p.id||'', name: p.name||'', price: p.price||0, qty: 1, category: p.category||'' });
    currentCart.items = items;
    renderTab('products');
  } catch(e) { toast('Fel vid tillägg', 'error'); }
}

function prodAddFreeRow() {
  const items = prodGetItems();
  items.push({ id: '', name: '', price: 0, qty: 1, category: '' });
  currentCart.items = items;
  renderTab('products');
}

function prodUpdateSvc() {
  // Remove existing service rows, add back selected ones
  const items = prodGetItems().filter(i => !['lev-standard','lev-skrymmande','lev-lastbil','lev-standard-e','montering','fakturaavgift',
    'lev-standard-e','lev-skrymmande-e','lev-lastbil-e'].some(sid => i.id === sid || i.id === sid + '-e'));
  
  const addSvc = (selId) => {
    const sel = document.getElementById(selId);
    if (!sel || !sel.value) return;
    const [name, price, id] = sel.value.split('|');
    if (name && price) items.push({ id, name, price: parseInt(price), qty: 1, category: 'Tjänster' });
  };
  addSvc('svc-leverans');
  addSvc('svc-montering');
  addSvc('svc-faktura');
  currentCart.items = items;
  renderTab('products');
}

async function prodSaveAndSendOffer() {
  await prodSave();
  openQuoteModalForCart(currentCart);
}

