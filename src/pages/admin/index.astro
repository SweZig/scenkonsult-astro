$('new-quote-btn').addEventListener('click', () => openQuoteModal(null));
$('quote-close').addEventListener('click', closeQuoteModal);
$('quote-overlay').addEventListener('click', e => { if (e.target === $('quote-overlay')) closeQuoteModal(); });

let quoteItems = []; // { id, name, price, qty }

function openQuoteModal(prefill) {
  quoteItems = [];
  $('qc-name').value     = prefill?.customer_name || '';
  $('qc-email').value    = prefill?.customer_email || '';
  $('qc-phone').value    = prefill?.customer_phone || '';
  $('qc-date').value     = prefill?.event_date || '';
  $('qc-location').value = prefill?.event_location || '';
  $('qc-note').value     = '';
  $('quote-error').style.display = 'none';
  $('quote-send-btn').disabled = false;
  $('quote-send-btn').textContent = '✉ Skicka offert';

  // Pre-fill items from existing cart
  if (prefill?.items?.length) {
    prefill.items.filter(i => !i._note).forEach(i => {
      quoteItems.push({ id: i.id||'', name: i.name, price: i.price||0, qty: i.qty||1 });
    });
    const note = prefill.items.find(i => i._note);
    if (note) $('qc-note').value = note.name;
  }

  // Init picker
  const catSel = $('qp-cat');
  catSel.innerHTML = '<option value="">— välj kategori —</option>' +
    Object.keys(QUOTE_CATALOG).map(k => `<option value="${k}">${k}</option>`).join('');
  $('qp-sub-wrap').style.display = 'none';
  $('qp-prod').innerHTML = '<option value="">— välj kategori —</option>';

  quoteRenderTable();
  $('quote-overlay').classList.add('open');
  $('qc-name').focus();
}

function openQuoteModalForCart(cart) {
  openQuoteModal(cart);
}

function closeQuoteModal() {
  $('quote-overlay').classList.remove('open');
}

function quotePickerCat() {
  const cat = $('qp-cat').value;
  const entry = QUOTE_CATALOG[cat];
  const subWrap = $('qp-sub-wrap');
  const prodSel = $('qp-prod');

  if (!entry) {
    subWrap.style.display = 'none';
    prodSel.innerHTML = '<option value="">— välj kategori —</option>';
    return;
  }

  if (entry.sub) {
    // Has sub-categories
    const subSel = $('qp-sub');
    subSel.innerHTML = '<option value="">— välj underkategori —</option>' +
      Object.keys(entry.sub).map(k => `<option value="${k}">${k}</option>`).join('');
    subWrap.style.display = '';
    prodSel.innerHTML = '<option value="">— välj underkategori —</option>';
  } else {
    subWrap.style.display = 'none';
    quotePopulateProducts(entry.products);
  }
}

function quotePickerSub() {
  const cat = $('qp-cat').value;
  const sub = $('qp-sub').value;
  const entry = QUOTE_CATALOG[cat];
  if (!entry?.sub || !sub) return;
  quotePopulateProducts(entry.sub[sub] || []);
}

function quotePopulateProducts(prods) {
  const prodSel = $('qp-prod');
  prodSel.innerHTML = '<option value="">— välj produkt —</option>' +
    prods.map(p => `<option value="${p.id}" data-price="${p.price}" data-name="${p.name.replace(/"/g,'&quot;')}">${p.name} — ${p.price.toLocaleString('sv')} kr</option>`).join('');
}

function quotePickerAdd() {
  const prodSel = $('qp-prod');
  const opt = prodSel.options[prodSel.selectedIndex];
  if (!opt || !opt.value) { return; }
  const name  = opt.dataset.name || opt.textContent.split(' — ')[0];
  const price = parseInt(opt.dataset.price) || 0;
  const id    = opt.value;

  // If same product already in list, increment qty
  const existing = quoteItems.find(i => i.id === id && i.name === name);
  if (existing) { existing.qty++; }
  else { quoteItems.push({ id, name, price, qty: 1 }); }

  quoteRenderTable();
  // Reset product selector
  prodSel.selectedIndex = 0;
}

function quoteRenderTable() {
  const tbody = $('quote-prod-tbody');
  const tfoot = $('quote-prod-tfoot');
  if (!tbody) return;
  tbody.innerHTML = quoteItems.map((item, idx) => `
    <tr data-qidx="${idx}">
      <td style="font-size:0.82rem">${item.name}</td>
      <td style="text-align:center">
        <div style="display:flex;align-items:center;justify-content:center;gap:3px">
          <button class="qty-btn" onclick="quoteQtyIdx(${idx},-1)" style="width:22px;height:22px;font-size:0.9rem">−</button>
          <span style="min-width:24px;text-align:center;font-size:0.82rem">${item.qty}</span>
          <button class="qty-btn" onclick="quoteQtyIdx(${idx},1)" style="width:22px;height:22px;font-size:0.9rem">＋</button>
        </div>
      </td>
      <td style="text-align:right">
        <input class="prod-input" value="${item.price}" onchange="quoteEditPrice(${idx},this.value)"
          style="width:80px;text-align:right;font-size:0.82rem;background:#0f0d2a!important;color:#f0eeff!important;color-scheme:dark;border-radius:5px;border:1px solid transparent;padding:0.2rem 0.4rem;">
      </td>
      <td style="text-align:right;font-size:0.82rem;font-weight:600;color:var(--brand-lav)">${fmt(item.price * item.qty)} kr</td>
      <td><button class="qty-btn" style="color:var(--red);border-color:var(--red);width:22px;height:22px" onclick="quoteDelIdx(${idx})">×</button></td>
    </tr>`).join('');

  const total = quoteItems.reduce((s,i) => s + i.price * i.qty, 0);
  tfoot.innerHTML = quoteItems.length
    ? `<tr><td colspan="3" style="font-weight:700;padding-top:0.5rem;font-size:0.82rem">Totalt (exkl. moms)</td>
       <td style="text-align:right;font-weight:700;color:var(--brand-lav);font-size:0.82rem">${fmt(total)} kr</td><td></td></tr>
       <tr><td colspan="3" style="color:var(--text-faint);font-size:0.72rem">Inkl. 25% moms</td>
       <td style="text-align:right;color:var(--text-muted);font-size:0.72rem">${fmt(Math.round(total*1.25))} kr</td><td></td></tr>`
    : '';
}

function quoteQtyIdx(idx, delta) {
  if (!quoteItems[idx]) return;
  quoteItems[idx].qty = Math.max(1, quoteItems[idx].qty + delta);
  quoteRenderTable();
}

function quoteEditPrice(idx, val) {
  if (!quoteItems[idx]) return;
  quoteItems[idx].price = parseFloat(val) || 0;
  quoteRenderTable();
}

function quoteDelIdx(idx) {
  quoteItems.splice(idx, 1);
  quoteRenderTable();
}

async function sendQuote() {
  const name  = $('qc-name').value.trim();
  const email = $('qc-email').value.trim();
  const errEl = $('quote-error');
  errEl.style.display = 'none';

  if (!name)  { errEl.textContent = 'Namn krävs.'; errEl.style.display = 'block'; $('qc-name').focus(); return; }
  if (!email || !email.includes('@')) { errEl.textContent = 'Giltig e-post krävs.'; errEl.style.display = 'block'; $('qc-email').focus(); return; }
  if (quoteItems.length === 0) { errEl.textContent = 'Lägg till minst en produkt.'; errEl.style.display = 'block'; return; }

  const btn = $('quote-send-btn');
  btn.disabled = true; btn.textContent = '⏳ Skickar…';

  const payload = {
    customer: {
      name, email,
      phone:    $('qc-phone').value.trim() || null,
      date:     $('qc-date').value || null,
      location: $('qc-location').value.trim() || null,
    },
    items: quoteItems,
    note: $('qc-note').value.trim() || null,
  };

  try {
    const { ok: success, data } = await api('admin-send-quote', { method: 'POST', body: JSON.stringify(payload) });
    if (success) {
      closeQuoteModal();
      toast(`Offert skickad till ${email}! 🎉`);
      loadCarts();
    } else {
      errEl.textContent = data?.error || 'Kunde inte skicka offert.';
      errEl.style.display = 'block';
      btn.disabled = false; btn.textContent = '✉ Skicka offert';
    }
  } catch (e) {
    errEl.textContent = 'Nätverksfel — försök igen.';
    errEl.style.display = 'block';
    btn.disabled = false; btn.textContent = '✉ Skicka offert';
  }
}

