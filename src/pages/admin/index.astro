  const sum = price * qty;
  const cat = i.category || '';
  const pid = i.id || '';
  return `<tr data-idx="${idx}" class="prod-row">
    <td>
      <input class="prod-input prod-name" value="${(i.name||'').replace(/"/g,'&quot;')}" placeholder="Produktnamn" data-field="name" data-idx="${idx}" style="width:100%;font-size:0.875rem;background:#221f50!important;color:#f0eeff!important;color-scheme:dark;">
      <input class="prod-input prod-meta" value="${cat}" placeholder="Kategori" data-field="category" data-idx="${idx}" style="width:55%;font-size:0.72rem;margin-top:3px;background:#221f50!important;color:#f0eeff!important;color-scheme:dark;">
      <input class="prod-input prod-meta" value="${pid}" placeholder="ID (valfri)" data-field="id" data-idx="${idx}" style="width:40%;font-size:0.72rem;margin-top:3px;margin-left:3%;background:#221f50!important;color:#f0eeff!important;color-scheme:dark;">
    </td>
    <td style="text-align:center;vertical-align:top;padding-top:0.75rem">
      <div style="display:flex;align-items:center;justify-content:center;gap:4px">
        <button class="qty-btn" onclick="prodQty(${idx},-1)">−</button>
        <input class="prod-input prod-qty" value="${qty}" data-field="qty" data-idx="${idx}" style="width:44px;text-align:center;font-size:0.875rem;background:#221f50!important;color:#f0eeff!important;color-scheme:dark;">
        <button class="qty-btn" onclick="prodQty(${idx},1)">＋</button>
