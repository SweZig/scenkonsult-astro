function renderChatTab() {
  const body = $('panel-body');
  const msgs = currentMessages;

  const msgsHTML = msgs.length === 0
    ? '<div class="chat-empty">Ingen chatt ännu.</div>'
    : `<div class="chat-messages">${msgs.map(m => {
        const readMark = m.sender === 'admin'
          ? (m.read_at ? `<span class="read-check">✓✓</span> Läst ${fmtTime(m.read_at)}` : '⏳ Inte läst')
          : (m.read_at ? `Läst ${fmtTime(m.read_at)}` : '');
        return `
          <div class="msg-wrap ${m.sender}">
            <div class="msg-bubble">${m.body.replace(/\n/g,'<br>').replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" style="color:var(--brand-lav)">$1</a>')}</div>
            <div class="msg-meta">
              <span>${m.sender === 'admin' ? '👤 Du' : '🧑 Kund'} · ${fmtTime(m.created_at)}</span>
              ${readMark ? `<span>${readMark}</span>` : ''}
            </div>
          </div>`;
      }).join('')}</div>`;

  body.innerHTML = `
    ${msgsHTML}
    <div class="section-label">Nytt meddelande till kund</div>
    <div class="chat-input-wrap">
      <textarea class="chat-textarea" id="chat-input" placeholder="Skriv ett meddelande… (Ctrl+Enter för att skicka)"></textarea>
      <button class="chat-send-btn" id="chat-send-btn">Skicka till kund →</button>
    </div>`;

  // Scroll to bottom
  setTimeout(() => {
    const msgs = body.querySelector('.chat-messages');
    if (msgs) msgs.scrollTop = msgs.scrollHeight;
    body.scrollTop = body.scrollHeight;
  }, 50);
}

async function sendMessage() {
  const input = $('chat-input');
  const btn   = $('chat-send-btn');
  const text  = input?.value.trim();
  if (!text) return;

  btn.disabled = true;
  btn.textContent = 'Skickar…';

  const { ok, data } = await api('cart-message', {
    method: 'POST',
    body: JSON.stringify({ cart_id: currentCart.id, body: text })
  });

  if (ok) {
    currentMessages.push({
      id: data.message?.id || Date.now(),
      cart_id: currentCart.id,
      sender: 'admin',
      body: text,
      read_at: null,
      created_at: new Date().toISOString()
    });
    input.value = '';
    renderTab('chat');
    toast('Meddelande skickat!');
    loadCarts();
  } else {
    toast(data.error || 'Kunde inte skicka', 'error');
    btn.disabled = false;
    btn.textContent = 'Skicka till kund →';
  }
}

