async function prodSave() {
  const btn = document.getElementById('save-items-btn');
  const status = document.getElementById('prod-save-status');
  const items = prodGetItems();
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Sparar…'; }

  // Lägg till _note om fältet har innehåll
  const noteText = document.getElementById('prod-note')?.value?.trim() || '';
  if (noteText) {
    items.push({ _note: true, id: '_note', name: noteText, price: 0, qty: 1 });
  }

  const total_excl = Math.round(items.filter(i => !i._note).reduce((s,i) => s + i.price * i.qty, 0) * 100);
  const { ok } = await api('cart-update', {
    method: 'POST',
    body: JSON.stringify({ cart_id: currentCart.id, items, total_excl })
  });
  if (ok) {
    currentCart.items = items;
    currentCart.total_excl = total_excl;
    if (status) { status.textContent = '✓ Sparat'; status.style.color = 'var(--green)'; }
    setTimeout(() => { if (status) status.textContent = ''; }, 3000);
    toast('Produkter uppdaterade!');
    // Re-render kanban card if visible
    renderKanban();
  } else {
    if (status) { status.textContent = '✗ Fel – kontrollera konsolen'; status.style.color = 'var(--red)'; }
    toast('Kunde inte spara', 'error');
  }
  if (btn) { btn.disabled = false; btn.textContent = '💾 Spara produkter'; }
}

