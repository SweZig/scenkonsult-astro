  const total = (currentCart.items||[]).filter(i => !i._note).reduce((s,i) => s + ((i.price||0)*(i.qty||i.quantity||1)), 0);
  return `<tr class="total-row"><td colspan="3">Totalt (exkl. moms)</td>
    <td style="text-align:right">${fmt(total)} kr</td><td></td></tr>
  <tr><td colspan="3" style="color:var(--text-faint);font-size:0.8rem">Inkl. 25% moms</td>
    <td style="text-align:right;color:var(--text-muted);font-size:0.85rem">${fmt(Math.round(total*1.25))} kr</td><td></td></tr>`;
