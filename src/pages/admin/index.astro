function buildCatalogOptions() {
  let html = '<option value="">+ Välj produkt att lägga till</option>';
  Object.entries(QUOTE_CATALOG).forEach(([cat, data]) => {
    if (data.products) {
      html += `<optgroup label="${cat}">`;
      data.products.forEach(p => {
        const v = JSON.stringify({id:p.id,name:p.name,price:p.price,category:cat}).replace(/"/g,'&quot;');
        html += `<option value="${v}">${p.name} — ${fmt(p.price)} kr</option>`;
      });
      html += '</optgroup>';
    } else if (data.sub) {
      Object.entries(data.sub).forEach(([sub, prods]) => {
        html += `<optgroup label="${cat} — ${sub}">`;
        prods.forEach(p => {
          const v = JSON.stringify({id:p.id,name:p.name,price:p.price,category:`${cat} — ${sub}`}).replace(/"/g,'&quot;');
          html += `<option value="${v}">${p.name} — ${fmt(p.price)} kr</option>`;
        });
        html += '</optgroup>';
      });
    }
  });
  return html;
}

function catIcon(category) {
  const c = (category||'').toLowerCase();
  if (c.includes('scen'))    return { icon: '🎪', color: 'var(--blue)' };
  if (c.includes('ljud'))    return { icon: '🔊', color: 'var(--green)' };
  if (c.includes('ljus'))    return { icon: '💡', color: 'var(--amber)' };
  if (c.includes('dj'))      return { icon: '🎧', color: 'var(--brand-lav)' };
  if (c.includes('bild'))    return { icon: '📽', color: 'var(--blue)' };
  if (c.includes('tjänst') || c.includes('leverans') || c.includes('montering')) return { icon: '🚚', color: 'var(--gray)' };
  return { icon: '📦', color: 'var(--gray)' };
}

