      <input class="prod-input prod-meta" value="" placeholder="ID (valfri)" data-field="id" data-idx="${idx}" style="width:40%;font-size:0.72rem;margin-top:3px;margin-left:3%;background:#221f50!important;color:#f0eeff!important;color-scheme:dark;">
