---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Scenkonsult Stockholm" description="Scenkonsult – uthyrning av scen, ljud, ljus och DJ i Stockholm sedan 1986.">
  <div class="max-w-4xl mx-auto px-4 py-16 text-center">
    <p class="text-gray-400 mb-8">Sidan är under uppbyggnad. Kontakta oss gärna direkt!</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/kontakt/" class="bg-brand-orange text-white px-6 py-3 rounded-xl font-bold">Kontakta oss</a>
      <a href="/vara-tjanster/" class="border border-white/30 text-white px-6 py-3 rounded-xl font-semibold hover:bg-white/10">Alla tjänster</a>
    </div>
  </div>
</Layout>
