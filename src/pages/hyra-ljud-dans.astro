---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const packages = [{"name": "Dansljud S", "price": "från 999 kr / dygn", "desc": "2× subbasar + 2× fullrangehögtalare. Trådlöst. Upp till 80 gäster."}, {"name": "Dansljud M", "price": "från 1 399 kr / dygn", "desc": "4× subbasar + 4× diskanter. Fyller mellanstor festlokal. 80–200 gäster."}, {"name": "Dansljud L", "price": "från 1 999 kr / dygn", "desc": "Komplett dansgolvssystem med 6× sub och aktiv mixning. 200–600 gäster."}];
const includes = ["Leverans och upphämtning ingår (Storstockholm)", "Montering och kabeldragning", "Ljudkalibrering och EQ-setup", "Subbasar + diskanter i paketpris", "Jourtjänst kvällstid", "Generösa avbokningsregler"];
---
<ServiceLayout
  title="Hyra ljud musik & dans Stockholm | Scenkonsult"
  description="Hyra ljudsystem för fest, bröllop och dans i Stockholm. Subbasar med fysiskt tryck och diskanter som bär. Från 999 kr/dygn."
  hero_title="Hyra ljud"
  hero_subtitle="Musik & dans"
  category="Uthyrning — Ljud"
  from_price="999"
  intro="Subbasar med fysiskt tryck och diskanter som bär. Dansgolvet vaknar till liv. Perfekt för bröllop, födelsedagar och privata fester med riktigt dansljud."
  packages={packages}
  includes={includes}
/>
