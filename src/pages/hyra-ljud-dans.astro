---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const products = [{"title": "Music, Small", "priceImg": "https://scenkonsult.se/wp-content/uploads/2025/09/Pris_999.png", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_small_20250824PNG.png", "desc": "Kompakt musiksystem med sub och diskanter. Passar för hemma-fester och mindre lokaler. Upp till 50 gäster."}, {"title": "Music, Small+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_small-_20250824PNG.png", "desc": "Utökat musiksystem med mer bas och räckvidd. Bra för bröllop och 50-100 gäster."}, {"title": "Music, Medium", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_medium_20250824PNG.png", "desc": "Kraftfullt dansgolvssystem. Fyller medelstora festlokaler med musik. 100-200 gäster."}, {"title": "Music, Large", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_large_20250824PNG.png", "desc": "Stort musiksystem för lager-fester och konserter. Upp till 400 gäster."}, {"title": "Live/Music, XL", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_xl_20250824PNG.png", "desc": "XL-system för stora utomhus-event och konserter. 400-800 gäster."}, {"title": "Live/Music, XL+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_xl-_20250824PNG.png", "desc": "Kraftfullt line array-system för riktigt stora events. 800+ gäster."}, {"title": "Live/Music, XXL", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_xxl_20250824PNG.png", "desc": "Professionellt konsert-PA. Används av turnébolag och vid stora utomhuskonserter."}, {"title": "Live/Music, Concert", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_concert_20250824-1024x853.png", "desc": "Komplett konsert-rigg med front-of-house, side-fills och scenmonitorer. Pris på förfrågan."}];
---
<ServiceLayout
  title="Hyra Ljud Musik & Dans Stockholm | Scenkonsult"
  description="Hyra ljudsystem för fest, bröllop och dans i Stockholm. Subbasar med fysiskt tryck. Från 999 kr/dygn. Sedan 1986."
  pageHeading="Uthyrning av Ljud — Musik & Dans"
  intro="Subbasar med fysiskt tryck och diskanter som bär. Dansgolvet vaknar till liv. Perfekt för bröllop, fester och privata tillställningar med riktigt dansljud."
  note="Alla priser är hyra per dygn (22 timmar). Utrustning hämtas enl överenskommelse från kl 13:00 och återlämnas innan kl 11:00 nästkommande dag. Vi erbjuder även leverans- och monteringstjänster."
  products={products}
/>
