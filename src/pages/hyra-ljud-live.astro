---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import Price from '../components/Price.astro';
import ljud from '../data/ljud.json';

const d = ljud.live;
---

<ServiceLayout
  title="Hyra Liveljud Stockholm – PA-system för Konsert & Trubadur från 749 kr/dygn | Scenkonsult"
  description="Hyr liveljud för konserter, trubadurer och liveband i Stockholm. Kraftfulla sub-basar och fullrange högtalarpaket för 20–1500 personer. Leverans i hela Storstockholm."
  heroTitle="Hyra Ljud för"
  heroSubtitle="Live & Konsert"
  heroIntro={d.intro}
  heroBullets={[
    "Passar 20–1500 personer",
    "Sub-basar + fullrange för liveband",
    "Perfekt för konsert och trubadur",
    "Leverans & riggning tillgängligt"
  ]}
  breadcrumb={[
    { label: "Hem", href: "/" },
    { label: "Tjänster", href: "/#tjanster" },
    { label: "Hyra liveljud" }
  ]}
>
  <section class="svc-products">
    <div class="svc-products-head">
      <span class="overline">Sortiment &amp; priser</span>
      <h2 class="display">Välj rätt paket<br/><em>för ditt event</em></h2>
    </div>
    <div class="prod-grid">
      {d.products.map(p => (
        <article id={p.slug} class="prod-card" itemscope itemtype="https://schema.org/Product">
          <div class="prod-img-wrap">
            <img src={p.image} alt={p.alt} width="400" height="300" loading="lazy" itemprop="image" />
            <span class="prod-persons-badge">{p.persons}</span>
          </div>
          <div class="prod-body">
            <h3 class="prod-name" itemprop="name">{p.name}</h3>
            <p class="prod-desc" itemprop="description">{p.description}</p>
            <ul class="prod-includes">
              {p.includes.map(item => <li>{item}</li>)}
            </ul>
            <div class="prod-footer">
              <span class="prod-price"><Price amount={p.price} size="lg" /></span>
              <a href="/kontakt" class="prod-book-btn">Boka →</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="svc-accessories">
    <div class="svc-accessories-inner">
      <span class="overline">Tillbehör</span>
      <h2 class="display" style="font-size:clamp(1.6rem,3vw,2.4rem); margin-bottom:2rem;">Mixerbord &amp; mikrofoner</h2>
      <div class="acc-grid-4">
        {ljud.mixers.slice(0,4).map(m => (
          <div class="acc-card">
            <div class="acc-img-wrap">
              <img src={m.image} alt={m.alt} width="300" height="200" loading="lazy" />
            </div>
            <div class="acc-body">
              <h3 class="acc-name">{m.name}</h3>
              <p class="acc-desc">{m.description}</p>
              <div class="acc-price-row">
                <span class="acc-price"><Price amount={m.price} size="base" /></span>
                <a href="/kontakt" class="acc-book">Boka →</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLayout>

<style>
.svc-products{background:var(--cream);padding:4rem 5vw 3rem}
.svc-products-head{max-width:1200px;margin:0 auto 3rem;border-bottom:1px solid var(--rule);padding-bottom:2rem}
.prod-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--rule);border:1px solid var(--rule)}
.prod-card{background:var(--white);display:flex;flex-direction:column;transition:background .2s}
.prod-card:hover{background:var(--cream)}
.prod-img-wrap{position:relative;background:#0a0a0f;aspect-ratio:4/3;overflow:hidden;display:flex;align-items:center;justify-content:center}
.prod-img-wrap img{width:100%;height:100%;object-fit:contain;padding:1rem;transition:transform .3s}
.prod-card:hover .prod-img-wrap img{transform:scale(1.04)}
.prod-persons-badge{position:absolute;top:.75rem;right:.75rem;background:var(--ink);color:white;font-family:'Space Grotesk',sans-serif;font-size:.6rem;font-weight:700;letter-spacing:.08em;padding:.25rem .6rem;border-radius:2px}
.prod-body{padding:1.5rem;display:flex;flex-direction:column;flex:1}
.prod-name{font-family:'Space Grotesk',sans-serif;font-size:.9rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--text);margin-bottom:.5rem;transition:color .2s}
.prod-card:hover .prod-name{color:var(--ink)}
.prod-desc{font-size:.84rem;color:var(--mid);line-height:1.7;margin-bottom:1rem;flex:1}
.prod-includes{list-style:none;display:flex;flex-direction:column;gap:.2rem;background:var(--cream);padding:.75rem;border-radius:2px;margin-bottom:1.25rem}
.prod-includes li{font-size:.75rem;color:var(--mid);padding-left:1rem;position:relative}
.prod-includes li::before{content:'—';position:absolute;left:0;color:var(--rule)}
.prod-footer{display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--rule);padding-top:1rem}
.prod-price{font-family:'DM Serif Display',serif;color:var(--ink)}
.prod-book-btn{font-family:'Space Grotesk',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;padding:.55rem 1.25rem;border-radius:2px;background:var(--ink);color:white;white-space:nowrap;transition:background .2s}
.prod-book-btn:hover{background:var(--ink-deep)}
.svc-accessories{background:var(--white);border-top:1px solid var(--rule);padding:3.5rem 5vw}
.svc-accessories-inner{max-width:1200px;margin:0 auto}
.acc-grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--rule);border:1px solid var(--rule)}
.acc-card{background:var(--cream);display:flex;flex-direction:column}
.acc-img-wrap{background:#0a0a0f;aspect-ratio:6/5;overflow:hidden;display:flex;align-items:center;justify-content:center}
.acc-img-wrap img{width:100%;height:100%;object-fit:contain;padding:1rem}
.acc-body{padding:1.25rem;flex:1;display:flex;flex-direction:column}
.acc-name{font-family:'Space Grotesk',sans-serif;font-size:.8rem;font-weight:700;color:var(--text);margin-bottom:.35rem}
.acc-desc{font-size:.78rem;color:var(--mid);line-height:1.6;flex:1;margin-bottom:.75rem}
.acc-price-row{display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--rule);padding-top:.75rem}
.acc-price{font-family:'DM Serif Display',serif;font-size:1rem;color:var(--ink)}
.acc-book{font-family:'Space Grotesk',sans-serif;font-size:.65rem;font-weight:700;letter-spacing:.1em;text-decoration:none;color:var(--ink);transition:opacity .2s}
.acc-book:hover{opacity:.65}
@media(max-width:1024px){.prod-grid{grid-template-columns:1fr 1fr}.acc-grid-4{grid-template-columns:1fr 1fr}}
@media(max-width:640px){.prod-grid{grid-template-columns:1fr}}
@media(max-width:480px){.acc-grid-4{grid-template-columns:1fr}}
</style>
