const products = [{"title": "Live, Small", "priceImg": "https://scenkonsult.se/wp-content/uploads/2025/09/Pris_1624.png", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_live_small_20250824PNG.png", "desc": "Kompakt live-PA med scenmonitor. Passar för band och DJ på mindre scener. Upp till 150 gäster."}, {"title": "Live, Medium", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_live_medium_20250824PNG.png", "desc": "Live-system med subbasar och scenmonitorer. Bra för band och livemusik. 150-400 gäster."}, {"title": "Live, Large", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_live_large_20250824PNG.png", "desc": "Fullskalig live-rigg med stagebox och digitalmixer. Professionell konsert-setup. 400-800 gäster."}, {"title": "Live/Music, XL", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_xl_20250824PNG.png", "desc": "XL line array-system. Jämn ljudbild i hela lokalen. 800+ gäster."}, {"title": "Live/Music, XL+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_xl-_20250824PNG.png", "desc": "Kraftfullt system för utomhuskonserter och festivaler."}, {"title": "Live/Music, XXL", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_xxl_20250824PNG.png", "desc": "XXL live-system med komplett scenrigg och FOH. Turnéstandard."}, {"title": "Live/Music, Concert", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljud_music_concert_20250824-1024x853.png", "desc": "Komplett konsertrigg med front-of-house, side-fills och full monitor-setup. Pris på förfrågan."}];
---
<ServiceLayout
  title="Hyra Ljud Live & Konsert Stockholm | Scenkonsult"
  description="Hyra professionellt PA-system för live-musik och konserter i Stockholm. Line array, monitorer och stagebox. Sedan 1986."
  pageHeading="Uthyrning av Ljud — Live & Konsert"
  intro="Line array, monitorhögtalare och stagebox. Vad proffsen förväntar sig på scen. Samma system som turnébolag."
  note="Alla priser är hyra per dygn (22 timmar). Utrustning hämtas enl överenskommelse från kl 13:00 och återlämnas innan kl 11:00 nästkommande dag. Vi erbjuder även leverans- och monteringstjänster."
  products={products}
/>
