---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const packages = [{"name": "Live S", "price": "från 1 624 kr / dygn", "desc": "2× line array-element + 2× subbasar + 2× scenmonitorer. Upp till 200 pers."}, {"name": "Live M", "price": "från 2 499 kr / dygn", "desc": "4× line array + 4× sub + 4× monitorer + stagebox + digitalmixer. 200–600 pers."}, {"name": "Live XL", "price": "från 3 999 kr / dygn", "desc": "Fullskalig konsertrigg med side-fills, frontfills och komplett monitor-setup. 600–2000 pers."}];
const includes = ["Leverans och upphämtning ingår (Storstockholm)", "Riggning av line array", "Stagebox och kabelrigg på scen", "Scenmonitorer (wedges/in-ear)", "Jourtjänst kvällstid", "Möjlighet till tekniker/ljud-regi"];
---
<ServiceLayout
  title="Hyra ljud live & konsert Stockholm | Scenkonsult"
  description="Hyra professionellt PA-system för live-musik och konserter i Stockholm. Line array, monitorhögtalare och stagebox. Från 1 624 kr/dygn."
  hero_title="Hyra ljud"
  hero_subtitle="Live & konsert"
  category="Uthyrning — Ljud"
  from_price="1 624"
  intro="Line array, monitorhögtalare och stagebox. Vad proffsen förväntar sig på scen. Samma system som turnébolag — hyrt av dig till ditt event."
  packages={packages}
