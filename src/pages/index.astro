---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Hyra Scen, Ljud & Ljus Stockholm | Scenkonsult – Sedan 1986"
  description="Uthyrning av scen, ljud, ljus, bild och DJ-utrustning för fest, bröllop, event och konsert. Komplett scenproduktion i Stockholm. Leverans och montering. Sedan 1986."
>

<!-- ── HERO ── -->
<section class="hero">
  <div class="hero-l">
    <div class="logo-ring"></div>
    <div class="ghost-year">1986</div>
    <p class="hero-eyebrow">
      <span class="hero-eyebrow-line"></span>
      Stockholms mest erfarna eventpartner sedan 1986
    </p>
    <h1 class="hero-h1">
      Hyra scen,<br>
      ljud &amp; ljus<br>
      <em>i Stockholm</em>
    </h1>
    <p class="hero-body">
      Komplett scenproduktion för fest, bröllop, företagsevent och konsert.
      Leverans och montering i hela Storstockholm. Vi svarar inom ett par timmar.
    </p>
    <div class="hero-checks">
      <span class="hero-check">Sedan 1986</span>
      <span class="hero-check">Hela Storstockholm</span>
      <span class="hero-check">Jourtjänst kvällstid</span>
      <span class="hero-check">Generösa avbokningsregler</span>
    </div>
    <div class="hero-btns">
      <a href="/kontakt" class="btn-solid">Boka eller fråga om pris</a>
      <a href="#tjanster" class="btn-ghost-link">Se alla tjänster</a>
    </div>
  </div>
  <div class="hero-r">
    <img src="/images/hero/scen3_hero.webp" alt="Scenproduktion Stockholm" width="960" height="720" fetchpriority="high" />
    <div class="hero-r-tint"></div>
  </div>
</section>

<!-- ── MANIFESTO BAR ── -->
<div class="manifesto" style="background:var(--white);">
  <div class="m-stat">
    <div class="m-stat-n">1986</div>
    <div class="m-stat-l">Grundat</div>
  </div>
  <div class="m-div"></div>
  <div class="m-stat">
    <div class="m-stat-n">500+</div>
    <div class="m-stat-l">Event per år</div>
  </div>
  <div class="m-div"></div>
  <div class="m-stat">
    <div class="m-stat-n">20</div>
    <div class="m-stat-l">Till 2&thinsp;000 gäster</div>
  </div>
  <div class="m-div"></div>
  <div class="m-stat">
    <div class="m-stat-n">100%</div>
    <div class="m-stat-l">Testad utrustning</div>
  </div>
  <div class="m-heritage">
    <strong>Del av Sveriges scener sedan 1986</strong> — erfarenhet som syns i varje detalj
  </div>
</div>

<!-- ── TJÄNSTER ── -->
<section id="tjanster" class="svc2-section">
  <!-- Rubrik -->
  <div class="svc2-head">
    <div>
      <span class="overline" style="color:#c4b5f4;">Vad vill du hyra?</span>
      <h2 class="display" style="margin-top:0.5rem;color:white;">
        Allt du behöver<br><em>för ett lyckat event</em>
      </h2>
    </div>
    <p class="lead" style="color:rgba(255,255,255,0.55);">
      All utrustning testas och kalibreras inför varje uthyrning. Kostnadsfri rådgivning ingår alltid.
    </p>
  </div>

  <!-- Bildkort-grid -->
  <div class="svc2-grid">

    <a href="/vara-tjanster/hyra-scen/" class="svc2-card">
      <div class="svc2-img-wrap">
        <img src="/images/tjanster/plugg_scener.png" alt="Hyra scen Stockholm" width="600" height="338" loading="lazy" />
      </div>
      <div class="svc2-body">
        <h3 class="svc2-title">Hyra scen</h3>
        <p class="svc2-price">från <strong>749 kr</strong> <span>/dygn</span></p>
        <p class="svc2-desc">12 scenpaket, 4–48 m². Med eller utan tak. Leverans och montering ingår.</p>
        <span class="svc2-cta">Se scenpaket →</span>
      </div>
    </a>

    <a href="/vara-tjanster/hyra-ljud/event/" class="svc2-card">
      <div class="svc2-img-wrap">
        <img src="/images/tjanster/plugg_event_ljud.png" alt="Hyra ljud event och konferens" width="600" height="338" loading="lazy" />
      </div>
      <div class="svc2-body">
        <h3 class="svc2-title">Ljud – Event &amp; konferens</h3>
        <p class="svc2-price">från <strong>749 kr</strong> <span>/dygn</span></p>
        <p class="svc2-desc">PA-system med trådlösa mikrofoner för seminarier, galor och bolagsstämmor.</p>
        <span class="svc2-cta">Se paketen →</span>
      </div>
    </a>

    <a href="/vara-tjanster/hyra-ljud/music/" class="svc2-card">
      <div class="svc2-img-wrap">
        <img src="/images/tjanster/plugg_dance_ljud.png" alt="Hyra musikljud och dansljud" width="600" height="338" loading="lazy" />
      </div>
      <div class="svc2-body">
        <h3 class="svc2-title">Ljud – Musik &amp; dans</h3>
        <p class="svc2-price">från <strong>999 kr</strong> <span>/dygn</span></p>
        <p class="svc2-desc">Subbasar med fysiskt tryck. Dansgolvet vaknar till liv. Perfekt för fest och bröllop.</p>
        <span class="svc2-cta">Se paketen →</span>
      </div>
    </a>

    <a href="/vara-tjanster/hyra-ljud/live/" class="svc2-card">
      <div class="svc2-img-wrap">
        <img src="/images/tjanster/plugg_live_ljud.png" alt="Hyra liveljud konsert" width="600" height="338" loading="lazy" />
      </div>
      <div class="svc2-body">
        <h3 class="svc2-title">Ljud – Live &amp; konsert</h3>
        <p class="svc2-price">från <strong>1 624 kr</strong> <span>/dygn</span></p>
        <p class="svc2-desc">Line array, monitorhögtalare och stagebox. Proffsens förväntningar — uppfyllda.</p>
        <span class="svc2-cta">Se paketen →</span>
      </div>
    </a>

    <a href="/vara-tjanster/hyra-ljus/" class="svc2-card">
      <div class="svc2-img-wrap">
        <img src="/images/tjanster/plugg_ljus.png" alt="Hyra ljus Stockholm" width="600" height="338" loading="lazy" />
      </div>
      <div class="svc2-body">
        <h3 class="svc2-title">Hyra ljus</h3>
        <p class="svc2-price">från <strong>399 kr</strong> <span>/dygn</span></p>
        <p class="svc2-desc">Festbelysning till scenlighting med moving heads och DMX-styrning.</p>
        <span class="svc2-cta">Se ljuspaket →</span>
      </div>
    </a>

    <a href="/vara-tjanster/hyra-bild-projektorer-skarmar/" class="svc2-card">
      <div class="svc2-img-wrap">
        <img src="/images/tjanster/plugg_bild.png" alt="Hyra projektor och skärm" width="600" height="338" loading="lazy" />
      </div>
      <div class="svc2-body">
        <h3 class="svc2-title">Projektor &amp; skärm</h3>
        <p class="svc2-price">från <strong>299 kr</strong> <span>/dygn</span></p>
        <p class="svc2-desc">3 500–12 000 ANSI + LED-väggar. Full HD och 4K. Dukar i alla storlekar.</p>
        <span class="svc2-cta">Se bildpaket →</span>
      </div>
    </a>

    <a href="/vara-tjanster/hyra-ljud/portable/" class="svc2-card">
      <div class="svc2-img-wrap">
        <img src="/images/tjanster/plugg_portabelt.png" alt="Hyra portabelt batteridrivet ljud" width="600" height="338" loading="lazy" />
      </div>
      <div class="svc2-body">
        <h3 class="svc2-title">Portabelt ljud</h3>
        <p class="svc2-price">från <strong>499 kr</strong> <span>/dygn</span></p>
        <p class="svc2-desc">Batteridriven, IP-klassad, fri från kablar. Proffsjud utomhus utan eluttag.</p>
        <span class="svc2-cta">Se portabelt ljud →</span>
      </div>
    </a>

    <a href="/vara-tjanster/hyra-dj/" class="svc2-card">
      <div class="svc2-img-wrap">
        <img src="/images/tjanster/plugg_dj.png" alt="Hyr DJ Stockholm" width="600" height="338" loading="lazy" />
      </div>
      <div class="svc2-body">
        <h3 class="svc2-title">Hyr DJ</h3>
        <p class="svc2-price">från <strong>3 500 kr</strong> <span>/kväll</span></p>
        <p class="svc2-desc">6 professionella DJs. 70-tal till 2020-tal. Alla genrer. Utrustning ingår.</p>
        <span class="svc2-cta">Se DJ-tjänsten →</span>
      </div>
    </a>

  </div>

  <!-- Bred CTA-banner: Komplett event -->
  <div class="svc2-cta-banner">
    <div class="svc2-cta-inner">
      <div class="svc2-cta-text">
        <span class="svc2-cta-emoji">🎪</span>
        <div>
          <h3 class="svc2-cta-title">Komplett event — scen + ljud + ljus + teknik</h3>
          <p class="svc2-cta-desc">Vi projekterar hela lösningen på en offert. Ingen scen är för liten eller för stor.</p>
        </div>
      </div>
      <a href="/bokningssida/" class="svc2-cta-btn">Begär offert</a>
    </div>
  </div>

</section>

<style>
/* ── TJÄNSTER BILDKORT ── */
.svc2-section {
  background: #0c0a24;
  padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 5vw, 5rem) clamp(3rem, 7vw, 6rem);
}
.svc2-head {
  display: flex;
  flex-wrap: wrap;
  gap: clamp(0.5rem, 2vw, 1.5rem);
  justify-content: space-between;
  align-items: flex-end;
  max-width: 1280px;
  margin: 0 auto clamp(1.25rem, 3vw, 2.5rem);
}
.svc2-head .lead {
  max-width: 420px;
  flex: 1 1 320px;
}

/* Grid: 4 kolumner desktop → 2 tablet → 1 mobil */
.svc2-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: clamp(0.75rem, 1.5vw, 1.25rem);
  max-width: 1280px;
  margin: 0 auto;
}
@media (max-width: 1100px) { .svc2-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 720px)  { .svc2-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 420px)  { .svc2-grid { grid-template-columns: 1fr; } }

/* Kort */
.svc2-card {
  display: flex;
  flex-direction: column;
  background: #1e1850;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: clamp(12px, 2vw, 20px);
  overflow: hidden;
  text-decoration: none;
  transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  cursor: pointer;
}
.svc2-card:hover {
  border-color: rgba(196,181,244,0.5);
  transform: translateY(-3px);
  box-shadow: 0 12px 40px rgba(196,181,244,0.08);
}

/* Bild */
.svc2-img-wrap {
  width: 100%;
  aspect-ratio: 16/9;
  background: #0c0a24;
  overflow: hidden;
}
.svc2-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
  display: block;
}
.svc2-card:hover .svc2-img-wrap img {
  transform: scale(1.05);
}

/* Kortinnehåll */
.svc2-body {
  padding: clamp(0.85rem, 2vw, 1.25rem);
  display: flex;
  flex-direction: column;
  flex: 1;
}
.svc2-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(0.85rem, 1.5vw, 1rem);
  font-weight: 700;
  color: white;
  margin: 0 0 0.3rem;
  transition: color 0.2s;
}
.svc2-card:hover .svc2-title { color: #c4b5f4; }

.svc2-price {
  font-size: clamp(0.8rem, 1.3vw, 0.9rem);
  color: #c4b5f4;
  margin: 0 0 0.5rem;
}
.svc2-price strong { font-weight: 800; }
.svc2-price span {
  color: rgba(255,255,255,0.35);
  font-size: 0.75em;
  font-weight: 400;
}

.svc2-desc {
  font-size: clamp(0.72rem, 1.2vw, 0.8rem);
  color: rgba(255,255,255,0.45);
  line-height: 1.55;
  margin: 0 0 0.75rem;
  flex: 1;
}

.svc2-cta {
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(0.7rem, 1.2vw, 0.78rem);
  font-weight: 700;
  color: rgba(196,181,244,0.7);
  letter-spacing: 0.03em;
  transition: color 0.2s;
}
.svc2-card:hover .svc2-cta { color: #c4b5f4; }

/* CTA-banner */
.svc2-cta-banner {
  max-width: 1280px;
  margin: clamp(1rem, 2.5vw, 1.75rem) auto 0;
  background: linear-gradient(135deg, #2a245e 0%, #1e1850 100%);
  border: 1px solid rgba(196,181,244,0.2);
  border-radius: clamp(12px, 2vw, 20px);
  overflow: hidden;
}
.svc2-cta-inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  padding: clamp(1.25rem, 3vw, 2rem) clamp(1.25rem, 4vw, 2.5rem);
}
.svc2-cta-text {
  display: flex;
  align-items: center;
  gap: clamp(0.75rem, 2vw, 1.5rem);
  flex: 1 1 300px;
}
.svc2-cta-emoji {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  line-height: 1;
  flex-shrink: 0;
}
.svc2-cta-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(0.9rem, 2vw, 1.1rem);
  font-weight: 700;
  color: white;
  margin: 0 0 0.25rem;
}
.svc2-cta-desc {
  font-size: clamp(0.78rem, 1.5vw, 0.875rem);
  color: rgba(255,255,255,0.5);
  margin: 0;
}
.svc2-cta-btn {
  display: inline-block;
  background: #c4b5f4;
  color: #0c0a24;
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(0.72rem, 1.3vw, 0.82rem);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding: clamp(0.7rem, 1.5vw, 0.9rem) clamp(1.25rem, 3vw, 2rem);
  border-radius: 4px;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background 0.2s, transform 0.15s;
}
.svc2-cta-btn:hover {
  background: #e2dcfb;
  transform: translateY(-1px);
}
@media (max-width: 560px) {
  .svc2-cta-inner { flex-direction: column; align-items: flex-start; }
  .svc2-cta-btn { width: 100%; text-align: center; }
}
</style>

<!-- ── VIDEOR ── -->
<section class="section video-section">
  <div class="video-head">
    <div>
      <span class="overline">Se utrustningen i action</span>
      <h2 class="display" style="margin-top:0.5rem;">
        Utrustning som<br><em>levererar</em>
      </h2>
    </div>
    <p class="lead">
      Från det senaste inom Alto TS-serien till professionell Denon DJ-utrustning — se vår utrustning i rörelse.
    </p>
  </div>
  <div class="video-layout">
    <div class="video-main">
      <div class="video-wrap">
        <video autoplay muted loop playsinline>
          <source src="https://scenkonsult.se/wp-content/uploads/2025/09/Promotion_480_4.mp4" type="video/mp4" />
        </video>
        <div class="video-overlay"></div>
        <div class="video-label">
          <span class="video-tag">Sortiment</span>
          <span class="video-name">Hela vårt breda sortiment</span>
        </div>
      </div>
    </div>
    <div class="video-side-top">
      <div class="video-wrap">
        <video autoplay muted loop playsinline>
          <source src="https://scenkonsult.se/wp-content/uploads/2025/12/Alto_new_720p.mp4" type="video/mp4" />
        </video>
        <div class="video-overlay"></div>
        <div class="video-label">
          <span class="video-tag">Nyhet</span>
          <span class="video-name">Alto TS-serien — hyr nu</span>
        </div>
      </div>
    </div>
    <div class="video-side-bot">
      <div class="video-wrap">
        <video autoplay muted loop playsinline>
          <source src="https://scenkonsult.se/wp-content/uploads/2025/12/Denon_commercial.mp4" type="video/mp4" />
        </video>
        <div class="video-overlay"></div>
        <div class="video-label">
          <span class="video-tag">DJ-utrustning</span>
          <span class="video-name">Denon DJ — pro-utrustning</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── IDENTITY / VARFÖR OSS ── -->
<section class="identity">
  <div class="id-l">
    <div class="id-dots"></div>
    <div class="id-logo">
      <img src="/logo-white.png" alt="Scenkonsult" />
    </div>
    <div class="id-quote">
      <span class="id-qmark">"</span>
      <p class="id-qtext">
        Riktigt professionella — gjorde min fest till en riktig succé!
      </p>
      <p class="id-qsource">— Roger L · Täby</p>
    </div>
  </div>
  <div class="id-r">
    <span class="overline">Varför Scenkonsult</span>
    <h2 class="display">
      Ingen scen är<br>
      <em>för liten — eller för stor</em>
    </h2>
    <p class="lead">
      Sedan 1986 har vi hjälpt privatpersoner, kommuner, ambassader och storbolag med allt från hemma-fester för 20 till företagsevent för 2 000 gäster.
    </p>
    <div class="id-points">
      <div class="id-pt">
        <div class="id-pt-check"><svg viewBox="0 0 10 10"><polyline points="1.5,5 4,7.5 8.5,2.5"/></svg></div>
        <div>
          <div class="id-pt-title">All utrustning testas inför varje uthyrning</div>
          <p class="id-pt-desc">Ingenting lämnar oss utan att ha kontrollerats och kalibrerats.</p>
        </div>
      </div>
      <div class="id-pt">
        <div class="id-pt-check"><svg viewBox="0 0 10 10"><polyline points="1.5,5 4,7.5 8.5,2.5"/></svg></div>
        <div>
          <div class="id-pt-title">Kostnadsfri rådgivning — alltid</div>
          <p class="id-pt-desc">Vi hjälper dig välja rätt storlek och setup för ditt specifika event.</p>
        </div>
      </div>
      <div class="id-pt">
        <div class="id-pt-check"><svg viewBox="0 0 10 10"><polyline points="1.5,5 4,7.5 8.5,2.5"/></svg></div>
        <div>
          <div class="id-pt-title">Jourtjänst kvällstid om något krånglar</div>
          <p class="id-pt-desc">Vi finns tillgängliga under ditt event ifall något oväntat inträffar.</p>
        </div>
      </div>
      <div class="id-pt">
        <div class="id-pt-check"><svg viewBox="0 0 10 10"><polyline points="1.5,5 4,7.5 8.5,2.5"/></svg></div>
        <div>
          <div class="id-pt-title">Generösa avbokningsregler — inga dolda avgifter</div>
          <p class="id-pt-desc">Livet är oförutsägbart. Vi behandlar dig som vi vill bli behandlade.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── KUNDER ── -->
<section class="section customers">
  <div class="customers-head">
    <div>
      <span class="overline">Kunder vi anlitats av</span>
      <h2 class="display" style="margin-top:0.5rem;">
        Ett axplock av<br><em>nöjda kunder</em>
      </h2>
      <p class="lead" style="margin-top:0.75rem;">
        Från privata fester till myndigheter, ambassader och börsbolag — vi har erfarenhet av alla typer av uppdrag.
      </p>
    </div>
    <div class="cust-size">
      <div class="cust-size-item">
        <div class="cust-size-num">20</div>
        <div class="cust-size-label">Privat mottagning</div>
      </div>
      <div class="cust-size-item">
        <div class="cust-size-num">250</div>
        <div class="cust-size-label">Festlokal</div>
      </div>
      <div class="cust-size-item">
        <div class="cust-size-num">600</div>
        <div class="cust-size-label">Konsertlokal</div>
      </div>
      <div class="cust-size-item">
        <div class="cust-size-num">2&thinsp;000</div>
        <div class="cust-size-label">Företagsevent</div>
      </div>
    </div>
  </div>
  <div class="cust-scroll">
    <div class="cust-track">
      {[
        'Stockholm Stad','Solna Stad','ICA Sverige','Akademiska Hus','Mälardalens Universitet',
        'Brasiliens Ambassad','Indiens Ambassad','Kommunalarbetareförbundet','Tyresö Kommun',
        'Haninge Kommun','Ung Företagsamhet','Miljöpartiet','ABG Sundal Collier',
        'Houdini Sportswear','Solna Tingsrätt','Hornbach','Odd Fellow','Vision',
        'Vänsterpartiet','Korpen','A Beautiful Soap','Aiva Productions','Backingminds',
        'Cash In Drop Out','Ekologigruppen','Hacksaw Studios','iOffice','Kameo',
        // duplicate for seamless loop
        'Stockholm Stad','Solna Stad','ICA Sverige','Akademiska Hus','Mälardalens Universitet',
        'Brasiliens Ambassad','Indiens Ambassad','Kommunalarbetareförbundet','Tyresö Kommun',
        'Haninge Kommun','Ung Företagsamhet','Miljöpartiet','ABG Sundal Collier',
        'Houdini Sportswear','Solna Tingsrätt','Hornbach','Odd Fellow','Vision',
      ].map(name => (
        <span class="cust-name">{name}</span>
      ))}
    </div>
  </div>
  <div class="cust-tagline">
    <strong>Ingen scen är för liten — eller för stor</strong> för oss
  </div>
</section>

<!-- ── RECENSIONER ── -->
