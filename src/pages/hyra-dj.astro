---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import Price from '../components/Price.astro';
import dj from '../data/dj.json';
---

<ServiceLayout
  title={dj.metaTitle}
  description={dj.metaDescription}
  heroTitle="Hyra DJ"
  heroSubtitle="i Stockholm"
  heroIntro={dj.intro}
  heroBullets={[
    "6 professionella DJs med mångårig erfarenhet",
    "Disco, R&B, house, schlager, hip-hop m.m.",
    "Kvällen anpassas efter önskemål",
    "Hyr separat DJ-controller – mixa själv"
  ]}
  breadcrumb={[
    { label: "Hem", href: "/" },
    { label: "Tjänster", href: "/#tjanster" },
    { label: "Hyra DJ" }
  ]}
>
  <section class="svc-products">
    <div class="svc-products-head">
      <span class="overline">Sortiment &amp; priser</span>
      <h2 class="display">DJ &amp; utrustning<br/><em>för ditt event</em></h2>
    </div>
    <div class="prod-grid-2">
      {dj.products.map(p => (
        <article id={p.slug} class="prod-card dj-card" itemscope itemtype="https://schema.org/Product">
          <div class="prod-img-wrap">
            <img src={p.image} alt={p.alt} width="500" height="360" loading="lazy" itemprop="image" />
            {p.djs && (
              <div class="dj-names-badge">
                {p.djs.join(' · ')}
              </div>
            )}
          </div>
          <div class="prod-body">
            <h3 class="prod-name" itemprop="name">{p.name}</h3>
            <p class="prod-desc" itemprop="description">{p.description}</p>
            {p.genres && p.genres.length > 0 && (
              <div class="dj-genres">
                {p.genres.map(g => <span class="genre-tag">{g}</span>)}
              </div>
            )}
            {p.includes && p.includes.length > 0 && (
              <ul class="prod-includes">
                {p.includes.map(item => <li>{item}</li>)}
              </ul>
            )}
            {p.note && <p class="prod-note">{p.note}</p>}
            <div class="prod-footer">
              <div>
                <span class="prod-price"><Price amount={p.price} suffix={p.priceNote} size="lg" /></span>
              </div>
              <a href="/kontakt" class="prod-book-btn">Boka →</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ACCESSORIES -->
  <section class="svc-accessories">
    <div class="svc-accessories-inner">
      <span class="overline">Tillbehör</span>
      <h2 class="display" style="font-size:clamp(1.6rem,3vw,2.4rem); margin-bottom:2rem;">DJ-tillbehör</h2>
      <div class="acc-list">
        {dj.tillbehor.map(a => (
          <div class="acc-row">
            <span class="acc-row-name">{a.name}</span>
            <span class="acc-row-desc">{a.desc}</span>
            <span class="acc-row-price"><Price amount={a.price} suffix={a.priceNote} size="sm" /></span>
            <a href="/kontakt" class="acc-row-book">Boka →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="svc-faq">
    <div class="svc-faq-inner">
      <span class="overline">Vanliga frågor</span>
      <h2 class="display" style="font-size:clamp(1.6rem,3vw,2.4rem); margin-bottom:2rem;">Frågor &amp; svar</h2>
      <div class="faq-list">
        {dj.faq.map(item => (
          <details class="faq-item">
            <summary class="faq-q">{item.q}</summary>
            <p class="faq-a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</ServiceLayout>

<style>
.svc-products{background:var(--cream);padding:4rem 5vw 3rem}
.svc-products-head{max-width:1200px;margin:0 auto 3rem;border-bottom:1px solid var(--rule);padding-bottom:2rem}
.prod-grid-2{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--rule);border:1px solid var(--rule)}
.prod-card{background:var(--white);display:flex;flex-direction:column;transition:background .2s}
.prod-card:hover{background:var(--cream)}
.prod-img-wrap{position:relative;background:#0a0a0f;aspect-ratio:4/3;overflow:hidden;display:flex;align-items:center;justify-content:center}
.prod-img-wrap img{width:100%;height:100%;object-fit:contain;padding:1rem;transition:transform .3s}
.prod-card:hover .prod-img-wrap img{transform:scale(1.04)}
.dj-names-badge{position:absolute;bottom:.75rem;left:.75rem;right:.75rem;background:rgba(30,24,80,.85);color:rgba(255,255,255,.75);font-family:'Space Grotesk',sans-serif;font-size:.58rem;font-weight:700;letter-spacing:.1em;text-align:center;padding:.3rem .6rem;border-radius:2px}
.prod-body{padding:1.5rem;display:flex;flex-direction:column;flex:1}
.prod-name{font-family:'Space Grotesk',sans-serif;font-size:.9rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--text);margin-bottom:.5rem;transition:color .2s}
.prod-card:hover .prod-name{color:var(--ink)}
.prod-desc{font-size:.84rem;color:var(--mid);line-height:1.7;margin-bottom:1rem;flex:1}
.dj-genres{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:1rem}
.genre-tag{font-family:'Space Grotesk',sans-serif;font-size:.6rem;font-weight:700;letter-spacing:.08em;padding:.2rem .55rem;border-radius:2px;background:var(--ink-tint);color:var(--ink)}
.prod-includes{list-style:none;display:flex;flex-direction:column;gap:.2rem;background:var(--cream);padding:.75rem;border-radius:2px;margin-bottom:1rem}
.prod-includes li{font-size:.75rem;color:var(--mid);padding-left:1rem;position:relative}
.prod-includes li::before{content:'—';position:absolute;left:0;color:var(--rule)}
.prod-note{font-size:.75rem;color:var(--mid);font-style:italic;margin-bottom:1rem;padding:.5rem .75rem;border-left:2px solid var(--rule)}
.prod-footer{display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--rule);padding-top:1rem;margin-top:auto}
.prod-price{font-family:'DM Serif Display',serif;color:var(--ink)}
.prod-book-btn{font-family:'Space Grotesk',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;padding:.55rem 1.25rem;border-radius:2px;background:var(--ink);color:white;white-space:nowrap;transition:background .2s}
.prod-book-btn:hover{background:var(--ink-deep)}
.svc-accessories{background:var(--white);border-top:1px solid var(--rule);padding:3.5rem 5vw}
.svc-accessories-inner{max-width:1200px;margin:0 auto}
.acc-list{border:1px solid var(--rule);display:flex;flex-direction:column}
.acc-row{display:grid;grid-template-columns:220px 1fr auto auto;gap:1rem;align-items:center;padding:.9rem 1.25rem;border-bottom:1px solid var(--rule);background:var(--cream)}
.acc-row:last-child{border-bottom:none}
.acc-row:hover{background:var(--ink-tint)}
.acc-row-name{font-family:'Space Grotesk',sans-serif;font-size:.8rem;font-weight:700;color:var(--text)}
.acc-row-desc{font-size:.78rem;color:var(--mid)}
.acc-row-price{font-family:'DM Serif Display',serif;font-size:.9rem;color:var(--ink);white-space:nowrap}
.acc-row-book{font-family:'Space Grotesk',sans-serif;font-size:.65rem;font-weight:700;letter-spacing:.1em;text-decoration:none;color:var(--ink);white-space:nowrap}
.svc-faq{background:var(--cream);border-top:1px solid var(--rule);padding:3.5rem 5vw}
.svc-faq-inner{max-width:760px;margin:0 auto}
.faq-list{display:flex;flex-direction:column;border:1px solid var(--rule)}
.faq-item{border-bottom:1px solid var(--rule);background:var(--white)}
.faq-item:last-child{border-bottom:none}
.faq-q{padding:1.25rem 1.5rem;font-family:'Space Grotesk',sans-serif;font-size:.85rem;font-weight:700;color:var(--text);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center}
.faq-q::after{content:'+';font-size:1.2rem;color:var(--ink)}
details[open] .faq-q::after{content:'−'}
.faq-a{padding:0 1.5rem 1.25rem;font-size:.85rem;color:var(--mid);line-height:1.75}
@media(max-width:768px){.prod-grid-2{grid-template-columns:1fr}.acc-row{grid-template-columns:1fr auto}}
</style>
