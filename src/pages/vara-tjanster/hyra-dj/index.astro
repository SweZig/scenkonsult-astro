---
import Layout from '../../../layouts/Layout.astro';
import CategoryHero from '../../../components/CategoryHero.astro';
import dj from '../../../data/dj.json';
---
<Layout
  title={dj.metaTitle}
  description={dj.metaDescription}
>

  <CategoryHero
    h1="Hyr Professionell DJ"
    h1Accent="Stockholm"
    intro={dj.intro}
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Våra tjänster", href: "/vara-tjanster/" },
      { label: "Hyr DJ" }
    ]}
    badges={[
      "6 professionella DJs",
      "70-tal till 2020-tal",
      "Alla genrer",
      "Utrustning ingår"
    ]}
    bannerImage={dj.bannerImage}
    bannerAlt="DJ Stockholm"
    priceFrom={799}
    priceSuffix="/2 tim"
  />

  <!-- HYR PROFESSIONELL DJ: bild + prisbord -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

      <!-- VÄNSTER: DJ-bild + info -->
      <div>
        <div class="rounded-2xl overflow-hidden bg-brand-dark border border-white/10" style="aspect-ratio:4/3">
          <img src={dj.djService.image} alt={dj.djService.alt}
            width="800" height="600" loading="eager" class="w-full h-full object-cover" />
        </div>
        <div class="mt-4">
          <p class="text-gray-400 text-sm leading-relaxed">{dj.djService.description}</p>
          <ul class="mt-3 space-y-1 text-xs text-gray-400">
            {dj.djService.includes.map(item => (
              <li class="flex gap-1.5"><span class="text-green-400">▸</span>{item}</li>
            ))}
          </ul>
          <p class="mt-3 text-xs text-gray-500 italic">{dj.djService.note}</p>
        </div>
      </div>

      <!-- HÖGER: Info-text + prisbord -->
      <div>
        <h2 class="text-2xl font-bold text-white mb-2">HYR PROFESSIONELL DJ</h2>
        <p class="text-gray-300 text-sm mb-5">
          Vi har 6 professionella DJs med mångårig erfarenhet från nattklubbar, bröllop, studentfester
          och företagsevent. Vi spelar 70/80/90/00/10/20-tals musik i alla genre – Disco, R&B, Dance,
          House, Rock, Schlager, Hip-Hop, Soul, Italo Disco, Euro, EDM m.m.
          Vi utformar kvällen efter önskemål i samråd med kunden.
        </p>
        <p class="text-xs text-gray-500 mb-4">
          Alla tider är effektiva speltimmar. DJ-hårdvara ingår. Resa, scen, ljud och ljus tillkommer.
          <br />¹Digital utrustning kräver fungerande internetanslutning.
        </p>

        <!-- PRISBORD -->
        <div class="bg-[#1a1a1a] rounded-2xl overflow-hidden border border-white/10">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/10">
                <th class="text-left px-4 py-3 text-gray-400 font-semibold">Speltid</th>
                <th class="text-center px-4 py-3 text-gray-300 font-semibold">Junior DJ</th>
                <th class="text-center px-4 py-3 text-gray-300 font-semibold">Senior DJ</th>
                <th class="text-center px-4 py-3 text-gray-300 font-semibold">PRO DJ</th>
              </tr>
            </thead>
            <tbody>
              {dj.djService.priceTable.map((row, i) => (
                <tr class={`border-b border-white/5 ${i % 2 === 0 ? '' : 'bg-white/5'}`}>
                  <td class="px-4 py-4 text-gray-300">{row.hours}</td>
                  <td class="px-4 py-4 text-center">
                    <div class="text-white font-bold text-lg">
                      <span class="sk-price-excl">{row.junior.toLocaleString('sv')} kr</span>
                      <span class="sk-price-incl hidden">{row.juniorInkl.toLocaleString('sv')} kr</span>
                    </div>
                    <div class="text-gray-500 text-xs sk-price-excl">exkl moms</div>
                    <div class="text-gray-500 text-xs sk-price-incl hidden">inkl moms</div>
                  </td>
                  <td class="px-4 py-4 text-center">
                    <div class="text-white font-bold text-lg">
                      <span class="sk-price-excl">{row.senior.toLocaleString('sv')} kr</span>
                      <span class="sk-price-incl hidden">{row.seniorInkl.toLocaleString('sv')} kr</span>
                    </div>
                    <div class="text-gray-500 text-xs sk-price-excl">exkl moms</div>
                    <div class="text-gray-500 text-xs sk-price-incl hidden">inkl moms</div>
                  </td>
                  <td class="px-4 py-4 text-center">
                    <div class="text-white font-bold text-lg italic">Offert</div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <a href="/kontakt/" class="mt-5 inline-block bg-brand-orange hover:bg-orange-500 text-white px-6 py-3 rounded-lg font-semibold transition-colors">
          Boka DJ
        </a>
      </div>
    </div>
  </section>

  <!-- KARUSELL: VÅRA DJs -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <h2 class="text-xl font-bold text-white mb-4">BOKA ETT URVAL AV VÅRA DJs</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {dj.djPhotos.map(d => (
        <div class="rounded-2xl overflow-hidden border border-white/10 bg-brand-navy group hover:border-brand-orange/50 transition-all">
          <div class="overflow-hidden" style="aspect-ratio:3/2">
            <img src={d.img} alt={d.name} width="300" height="200" loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
          </div>
          <p class="text-white text-sm font-semibold text-center py-2.5 px-2">{d.name}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- RECENSIONER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <h2 class="text-xl font-bold text-white mb-4">Så här säger kunder som bokat DJ</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {[
        { text: "Hej Scenkonsult och tack, blev ju en riktigt lyckad kväll!", name: "Åsa P, Stockholm" },
        { text: "DJ Måns gjorde kvällen till en succé och ingen ville lämna dansgolvet! Grymt smidigt och bra kommunikation hela vägen. Kan varmt rekommenderas!", name: "Charlotte A, Linköping" },
        { text: "Tack för i Lördags, Allt var toppen! Så bra drag på dansgolvet.", name: "Jenny L, Stockholm" },
        { text: "Riktigt professionella, gjorde min fest till succé!", name: "Roger L, Täby" },
        { text: "Så värt att hyra in en DJ till festen, precis som krogen på 90-talet", name: "Jonas A, Stockholm" },
      ].map(r => (
        <div class="bg-brand-navy/60 border border-white/10 rounded-xl p-4">
          <div class="flex gap-0.5 mb-2"><span class="text-brand-orange text-sm">★★★★★</span></div>
          <p class="text-gray-300 text-sm italic mb-2">"{r.text}"</p>
          <p class="text-gray-400 text-xs font-semibold">{r.name}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- DECENNIER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <h2 class="text-2xl font-bold text-white mb-6">Musik per decennium</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {dj.decades.map((d, i) => {
        const colors = ['#ff6b35','#e040fb','#00bcd4','#f06292','#7c4dff','#00e676'];
        const color = colors[i % colors.length];
        return (
          <div class="bg-brand-navy border border-white/10 rounded-2xl p-5 hover:border-brand-orange/40 transition-colors">
            <div class="text-4xl font-extrabold mb-3" style={`color: ${color}`}>{d.decade}</div>
            <p class="text-gray-300 text-sm leading-relaxed mb-3">{d.history}</p>
            <p class="text-gray-400 text-xs leading-relaxed mb-3 border-t border-white/10 pt-3">
              <span class="text-gray-300 font-semibold">Artister: </span>{d.artists}
            </p>
            <p class="text-gray-500 text-xs italic">{d.ageGroup}</p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- HYR DJ-UTRUSTNING -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <h2 class="text-2xl font-bold text-white mb-6">HYR DJ-UTRUSTNING</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {dj.equipment.map(p => (
        <div class="bg-brand-navy border border-white/10 rounded-2xl overflow-hidden hover:border-brand-orange/40 transition-all flex flex-col">
          <div class="bg-brand-dark overflow-hidden" style="aspect-ratio:4/3">
            <img src={p.image} alt={p.alt} width="400" height="300" loading="lazy"
              class="w-full h-full object-contain p-4" />
          </div>
          <div class="p-5 flex flex-col flex-1">
            <div class="flex items-start justify-between gap-2 mb-3">
              <h3 class="text-white font-bold text-sm leading-snug">{p.name}</h3>
              <div class="text-right shrink-0">
                <span class="text-brand-orange font-extrabold text-lg">{p.price} kr</span>
                <div class="text-gray-500 text-xs">{p.priceNote}</div>
              </div>
            </div>
            <p class="text-gray-400 text-xs leading-relaxed mb-3 flex-1">{p.description}</p>
            {p.includes && p.includes.length > 0 && (
              <ul class="space-y-1 text-xs text-gray-400 border-t border-white/10 pt-3 mb-4">
                {p.includes.map(item => (
                  <li class="flex gap-1.5"><span class="text-green-400">▸</span>{item}</li>
                ))}
              </ul>
            )}
            <a href="/kontakt/" class="mt-auto inline-block bg-brand-orange hover:bg-orange-500 text-white text-center px-4 py-2 rounded-lg text-sm font-semibold transition-colors">
              Boka
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6">Vanliga frågor om DJ-uthyrning</h2>
    <div class="space-y-3">
      {dj.faq.map(f => (
        <details class="bg-brand-navy border border-white/10 rounded-xl overflow-hidden group">
          <summary class="px-5 py-4 text-white font-semibold cursor-pointer text-sm hover:text-brand-orange transition-colors list-none flex justify-between items-center">
            {f.q}
            <span class="text-brand-orange text-lg">+</span>
          </summary>
          <div class="px-5 pb-4 text-gray-400 text-sm leading-relaxed border-t border-white/10 pt-3">
            {f.a}
          </div>
        </details>
      ))}
    </div>
  </section>

</Layout>
