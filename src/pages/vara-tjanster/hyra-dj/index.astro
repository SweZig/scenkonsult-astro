---
import Layout from '../../../layouts/Layout.astro';
import CategoryHero from '../../../components/CategoryHero.astro';
import CartButton from '../../../components/CartButton.astro';
import dj from '../../../data/dj.json';
---
<Layout
  title={dj.metaTitle}
  description={dj.metaDescription}
>

  <CategoryHero
    h1="Hyr DJ eller DJ-utrustning"
    h1Accent="Stockholm"
    intro={dj.intro}
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Våra tjänster", href: "/vara-tjanster/" },
      { label: "Hyr DJ" }
    ]}
    badges={[
      "6 professionella DJs",
      "Alla genrer",
      "70-tal till idag"
    ]}
    priceFrom={799}
    priceSuffix="/dygn"
  />

  <!-- USP-rad med moms-toggle — under hero, ovanför innehåll -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-2 pb-6">
    <div class="flex flex-wrap gap-3 text-xs text-gray-300">
      <span class="bg-brand-navy border border-white/10 rounded-full px-3 py-1">
        🎛️ DJ-controller från
        <span class="sk-price-excl font-semibold text-brand-orange">799 kr</span>
        <span class="sk-price-incl hidden font-semibold text-brand-orange">999 kr</span>
        /dygn
      </span>
      <span class="bg-brand-navy border border-white/10 rounded-full px-3 py-1">
        🎤 DJ-tjänst från
        <span class="sk-price-excl font-semibold text-brand-orange">1 999 kr</span>
        <span class="sk-price-incl hidden font-semibold text-brand-orange">2 499 kr</span>
        /2 tim
      </span>
    </div>
  </div>

  <!-- HYR PROFESSIONELL DJ: bild + prisbord -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

      <!-- VÄNSTER: DJ-bild + info -->
      <div>
        <div class="rounded-2xl overflow-hidden bg-brand-dark border border-white/10 sk-zoomable" style="aspect-ratio:4/3;cursor:zoom-in">
          <img src={dj.djService.image} alt={dj.djService.alt}
            width="800" height="600" loading="eager" class="w-full h-full object-cover" />
        </div>
        <div class="mt-4">
          <p class="text-gray-400 text-sm leading-relaxed">{dj.djService.description}</p>
          <ul class="mt-3 space-y-1 text-xs text-gray-400">
            {dj.djService.includes.map(item => (
              <li class="flex gap-1.5"><span class="text-green-400">▸</span>{item}</li>
            ))}
          </ul>
          <p class="mt-3 text-xs text-gray-400 italic">{dj.djService.note}</p>
        </div>
      </div>

      <!-- HÖGER: Info-text + prisbord -->
      <div>
        <h2 class="text-2xl font-bold text-white mb-2">HYR PROFESSIONELL DJ</h2>
        <p class="text-gray-300 text-sm mb-5">
          Vi har 6 professionella DJs med mångårig erfarenhet från nattklubbar, bröllop, studentfester
          och företagsevent. Vi spelar 70/80/90/00/10/20-tals musik i alla genre – Disco, R&amp;B, Dance,
          House, Rock, Schlager, Hip-Hop, Soul, Italo Disco, Euro, EDM m.m.
          Vi utformar kvällen efter önskemål i samråd med kunden.
        </p>
        <p class="text-xs text-gray-400 mb-4">
          Alla tider är effektiva speltimmar. DJ-hårdvara ingår. Resa, scen, ljud och ljus tillkommer.
          <br />¹Digital utrustning kräver fungerande internetanslutning.
        </p>

        <!-- PRISBORD med CartButton per rad -->
        <div class="bg-[#1a1a1a] rounded-2xl overflow-hidden border border-white/10">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/10">
                <th class="text-left px-3 py-3 text-gray-400 font-semibold text-xs">Speltid</th>
                <th class="text-center px-2 py-3 text-gray-300 font-semibold text-xs">Junior DJ</th>
                <th class="text-center px-2 py-3 text-gray-300 font-semibold text-xs">Senior DJ</th>
                <th class="text-center px-2 py-3 text-gray-300 font-semibold text-xs">PRO DJ</th>
              </tr>
            </thead>
            <tbody>
              {dj.djService.priceTable.map((row, i) => (
                <tr class={`border-b border-white/5 ${i % 2 === 0 ? '' : 'bg-white/5'}`}>
                  <td class="px-3 py-3 text-gray-300 text-xs font-medium whitespace-nowrap">{row.hours}</td>
                  <!-- Junior -->
                  <td class="px-2 py-3">
                    <div class="flex flex-col items-center gap-1.5">
                      <div class="leading-none text-center">
                        <div class="text-white font-bold text-sm">
                          <span class="sk-price-excl">{row.junior.toLocaleString('sv')} kr</span>
                          <span class="sk-price-incl hidden">{row.juniorInkl.toLocaleString('sv')} kr</span>
                        </div>
                        <div class="text-gray-400 text-[10px] sk-price-excl">exkl moms</div>
                        <div class="text-gray-400 text-[10px] sk-price-incl hidden">inkl moms</div>
                      </div>
                      <CartButton id={`dj-junior-${row.hours.replace(' ','')}`} name={`DJ Junior – ${row.hours}`} price={row.junior} category="DJ-tjänst" size="sm" iconOnly={true} />
                    </div>
                  </td>
                  <!-- Senior -->
                  <td class="px-2 py-3">
                    <div class="flex flex-col items-center gap-1.5">
                      <div class="leading-none text-center">
                        <div class="text-white font-bold text-sm">
                          <span class="sk-price-excl">{row.senior.toLocaleString('sv')} kr</span>
                          <span class="sk-price-incl hidden">{row.seniorInkl.toLocaleString('sv')} kr</span>
                        </div>
                        <div class="text-gray-400 text-[10px] sk-price-excl">exkl moms</div>
                        <div class="text-gray-400 text-[10px] sk-price-incl hidden">inkl moms</div>
                      </div>
                      <CartButton id={`dj-senior-${row.hours.replace(' ','')}`} name={`DJ Senior – ${row.hours}`} price={row.senior} category="DJ-tjänst" size="sm" iconOnly={true} />
                    </div>
                  </td>
                  <!-- PRO -->
                  <td class="px-2 py-3 text-center">
                    <div class="text-white font-bold text-sm italic mb-1">Offert</div>
                    <a href="/kontakt/" class="text-brand-orange text-[10px] hover:underline">Kontakta oss</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <a href="/kontakt/" class="mt-5 inline-block bg-brand-orange hover:bg-brand-orange-light text-white px-6 py-3 rounded-lg font-semibold transition-colors text-sm">
          Boka DJ
        </a>
      </div>
    </div>
  </section>

  <!-- KARUSELL: VÅRA DJs — panorama-bilder 2560×654 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <h2 class="text-xl font-bold text-white mb-4">BOKA ETT URVAL AV VÅRA DJs</h2>
    <div class="relative">
      <div id="dj-carousel" class="flex overflow-x-auto gap-4 snap-x snap-mandatory scroll-smooth pb-3"
        style="scrollbar-width:thin; scrollbar-color: rgba(196,181,244,0.3) transparent;">
        {dj.djPhotos.map(d => (
          <div class="snap-center shrink-0 w-full rounded-2xl overflow-hidden border border-white/10 bg-brand-navy hover:border-brand-orange/50 transition-all">
            <img src={d.img} alt={d.name} width="2560" height="654" loading="lazy"
              class="w-full h-auto block" style="aspect-ratio:2560/654; object-fit:cover" />
          </div>
        ))}
      </div>
      <button onclick="document.getElementById('dj-carousel').scrollBy({left:-document.getElementById('dj-carousel').offsetWidth, behavior:'smooth'})"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-3 bg-brand-dark/80 hover:bg-brand-navy border border-white/20 text-white w-9 h-9 rounded-full flex items-center justify-center text-lg transition-colors hidden sm:flex">‹</button>
      <button onclick="document.getElementById('dj-carousel').scrollBy({left:document.getElementById('dj-carousel').offsetWidth, behavior:'smooth'})"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-3 bg-brand-dark/80 hover:bg-brand-navy border border-white/20 text-white w-9 h-9 rounded-full flex items-center justify-center text-lg transition-colors hidden sm:flex">›</button>
    </div>
    <div class="flex justify-center gap-2 mt-3">
      {dj.djPhotos.map((_, i) => (
        <button onclick={`const c=document.getElementById('dj-carousel');c.scrollTo({left:c.offsetWidth*${i},behavior:'smooth'})`}
          class="w-2 h-2 rounded-full bg-white/20 hover:bg-brand-orange transition-colors" aria-label={`Bild ${i+1}`}></button>
      ))}
    </div>
  </section>

  <!-- RECENSIONER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <h2 class="text-xl font-bold text-white mb-4">Så här säger kunder som bokat DJ</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {[
        { text: "Hej Scenkonsult och tack, blev ju en riktigt lyckad kväll!", name: "Åsa P, Stockholm" },
        { text: "DJ Måns gjorde kvällen till en succé och ingen ville lämna dansgolvet! Grymt smidigt och bra kommunikation hela vägen. Kan varmt rekommenderas!", name: "Charlotte A, Linköping" },
        { text: "Tack för i Lördags, Allt var toppen! Så bra drag på dansgolvet.", name: "Jenny L, Stockholm" },
        { text: "Riktigt professionella, gjorde min fest till succé!", name: "Roger L, Täby" },
        { text: "Så värt att hyra in en DJ till festen, precis som krogen på 90-talet", name: "Jonas A, Stockholm" },
      ].map(r => (
        <div class="bg-brand-navy/60 border border-white/10 rounded-xl p-4">
          <div class="flex gap-0.5 mb-2"><span class="text-brand-orange text-sm">★★★★★</span></div>
          <p class="text-gray-300 text-sm italic mb-2">"{r.text}"</p>
          <p class="text-gray-400 text-xs font-semibold">{r.name}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- DECENNIER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <h2 class="text-2xl font-bold text-white mb-6">Musik per decennium</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {dj.decades.map((d) => (
        <div class="bg-brand-navy border border-white/10 rounded-2xl p-5 hover:border-brand-orange/40 transition-colors border-l-2 border-l-brand-orange/60">
          <div class="text-3xl font-extrabold mb-3 text-brand-orange/90 tracking-tight">{d.decade}</div>
          <p class="text-gray-300 text-sm leading-relaxed mb-3">{d.history}</p>
          <p class="text-gray-400 text-xs leading-relaxed mb-3 border-t border-white/10 pt-3">
            <span class="text-gray-300 font-semibold">Artister: </span>{d.artists}
          </p>
          <p class="text-gray-400 text-xs italic">{d.ageGroup}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- HYR DJ-UTRUSTNING — ny bottom-bar layout med CartButton -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <h2 class="text-2xl font-bold text-white mb-6">HYR DJ-UTRUSTNING</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {dj.equipment.map(p => (
        <div class="bg-brand-navy border border-white/10 rounded-2xl overflow-hidden hover:border-brand-orange/40 transition-all flex flex-col">
          <div class="bg-brand-dark overflow-hidden sk-zoomable" style="aspect-ratio:4/3;cursor:zoom-in">
            <img src={p.image} alt={p.alt} width="400" height="300" loading="lazy"
              class="w-full h-full object-contain p-4" />
          </div>
          <div class="p-5 flex flex-col flex-1">
            <h3 class="text-white font-bold text-sm leading-snug mb-2">{p.name}</h3>
              {p.artno && <p class="artno-badge">{p.artno}</p>}
            <p class="text-gray-400 text-xs leading-relaxed mb-3 flex-1">{p.description}</p>
            {p.includes && p.includes.length > 0 && (
              <ul class="space-y-1 text-xs text-gray-400 border-t border-white/10 pt-3 mb-3">
                {p.includes.map(item => (
                  <li class="flex gap-1.5"><span class="text-green-400">▸</span>{item}</li>
                ))}
              </ul>
            )}
            <!-- Bottom-bar: pris vänster, CartButton höger — samma som ljud/ljus -->
            <div class="flex items-center justify-between border-t border-white/10 pt-3 gap-3 mt-auto">
              <div class="leading-none">
                <span class="sk-price-excl text-brand-orange font-extrabold text-lg">{p.price} kr</span>
                <span class="sk-price-incl hidden text-brand-orange font-extrabold text-lg">{Math.round(p.price * 1.25)} kr</span>
                <div class="text-gray-400 text-xs">{p.priceNote}</div>
              </div>
              <CartButton id={`dj-utr-${p.slug}`} name={p.name} price={p.price} category="DJ-utrustning" image={p.image} size="sm" label="Lägg i varukorg" />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6">Vanliga frågor om DJ-uthyrning</h2>
    <div class="space-y-3">
      {dj.faq.map(f => (
        <details class="bg-brand-navy border border-white/10 rounded-xl overflow-hidden group">
          <summary class="px-5 py-4 text-white font-semibold cursor-pointer text-sm hover:text-brand-orange transition-colors list-none flex justify-between items-center">
            {f.q}
            <span class="text-brand-orange text-lg">+</span>
          </summary>
          <div class="px-5 pb-4 text-gray-400 text-sm leading-relaxed border-t border-white/10 pt-3">
            {f.a}
          </div>
        </details>
      ))}
    </div>
  </section>

</Layout>
