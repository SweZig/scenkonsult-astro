---
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import CartButton from '../../../../components/CartButton.astro';
import ElTillbehorCard from '../../../../components/ElTillbehorCard.astro';
import MediaCard from '../../../../components/MediaCard.astro';
import ljusData from '../../../../data/ljus.json';
---
<Layout
  title="Hyr Rökmaskin & Kallgnistmaskin Stockholm – Granulat & Rökvätska | Scenkonsult"
  description="Hyr rökmaskin, kallgnistmaskin, hazer och konfettiavfyrare i Stockholm. Rökmaskin fr 349 kr/dygn. Rökvätska, granulat och ackrylatbensin. Leverans i hela Storstockholm."
>

  <CategoryHero
    h1="Rök & Pyroteknik"
    h1Accent="Stockholm"
    intro="Hyr rökmaskin, kallgnistmaskin och konfettiavfyrare i Stockholm från 349 kr/dygn. Våra rökmaskiner har inbyggt RGB-ljus och fyller lokalen snabbt – perfekt till bröllop, konserter och företagsevent. Kallgnistmaskiner (Cold Spark) producerar kalla gnistor som är helt säkra inomhus, kräver inget tillstånd och ger ett professionellt scen-intryck. Rök och pyro-effekter förstärker alla ljuspaket och gör stor skillnad i upplevelsen. Leverans i hela Storstockholm."
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Hyra ljus", href: "/vara-tjanster/hyra-ljus/" },
      { label: "Rök & Pyroteknik" }
    ]}
    badges={[
      "Rökmaskin & kallgnistmaskin",
      "Konfettiavfyrare",
      "Volymrabatt",
      "Leverans i Storstockholm",
    ]}
    priceFrom={349}
  />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <MediaCard
        title="Rökmaskin, 1500W"
        images={["/images/ljus/pp_ljus_effekt23.png"]}
        videos={["/videos/1200W_Fog_Machine_6LEDs_Remote.mp4"]}
        priceExcl={349}
        priceSuffix="/st/dygn fr"
        artno="SK-LJS-ROK-0001"
        category="Rök & pyro"
        bullets={["6×3W LED RGB inbyggd","Dimeffekt: 85 m³/min","Strömförbrukning: 1 500 W","Mått: 397×302×191 mm, Vikt: 5 kg","1 L rökvätska ingår i priset"]}
        rows={[
          {label:"Volympriser", rows:["1 st – 349 kr","2 st – 649 kr","4 st – 1 249 kr"]},
        ]}
      />

      <MediaCard
        title="Rökmaskin, 650W"
        images={["/images/ljus/pp_ljus_effekt24.png"]}
        videos={["/videos/adj_fog_fury_jett-04.mp4"]}
        priceExcl={449}
        priceSuffix="/st/dygn fr"
        artno="SK-LJS-ROK-0002"
        category="Rök & pyro"
        bullets={["12×3W LED RGB inbyggd","Dimeffekt: 125 m³/min","Strömförbrukning: 650 W","Vikt: 10 kg","1 L rökvätska ingår i priset"]}
        rows={[
          {label:"Volympriser", rows:["1 st – 449 kr","2 st – 849 kr","4 st – 1 699 kr"]},
        ]}
      />

      <MediaCard
        title="Kallgnistmaskin"
        images={["/images/ljus/pp_ljus_effekt25.png"]}
        videos={["/videos/Cold_Spark_Machine.mp4"]}
        priceExcl={499}
        priceSuffix="/st/dygn fr"
        artno="SK-LJS-ROK-0003"
        category="Rök & pyro"
        bullets={["Cold Spark – säkra gnisteffekter","Effekt: 700 W, förvärmningstid ~4 min","DMX 512, Vikt: 8 kg"]}
        rows={[
          {label:"Volympriser", rows:["1 st – 499 kr","2 st – 949 kr","4 st – 1 799 kr"]},
          {label:"Granulat (drivmedel)", rows:["100 g (~3 min) – 299 kr","200 g (~6 min) – 479 kr"]},
        ]}
      />

      <MediaCard
        title="Konfettiavfyrare"
        images={["/images/ljus/pp_ljus_confettimaskin.png"]}
        priceExcl={499}
        priceSuffix="/dygn"
        artno="SK-LJS-ROK-0004"
        category="Rök & pyro"
        bullets={["Utskjutningsvinkel steglöst justerbar","DMX 512 Standard","Strömförbrukning: 100 W","/dygn inkl ett rör"]}
        rows={[
          {label:"Extra konfettirör", rows:["Multifärg – 119 kr","Vit (snöeffekt) – 119 kr","Guld – 139 kr"]},
        ]}
      />

      <MediaCard
        title="Hazer HZ-1500 Pro"
        images={["/images/ljus/pp_ljus_rok3.png"]}
        videos={["/videos/hazer-hz1500.mp4"]}
        priceExcl={649}
        priceSuffix="/st/dygn fr"
        artno="SK-LJS-ROK-0005"
        category="Rök & pyro"
        bullets={["Finfördelat dis – synliggör ljusstrålar","DMX 512-styrning","Touring flightcase","Stabil kontinuerlig output","Inkl 1 l rökvätska"]}
        rows={[
          {label:"Volympriser", rows:["1 st – 649 kr","2 st – 1 199 kr"]},
        ]}
      />
    </div>
  </section>

  <!-- TILLBEHÖR: Rökvätska, Granulat & Ackrylatbensin -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {ljusData.rok.tillbehor.map(t => (
        <ElTillbehorCard
          img={t.image}
          name={t.name}
          excl={t.price}
          desc={t.desc}
          category="Rök tillbehör"
          artno={t.artno}
        />
      ))}
    </div>
  </section>

  <!-- DMX STYRNING -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Ljusstyrning (DMX)</h2>
    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {[
        { img:"/images/ljus/pp_ljus_styrning02.png", name:"Styrenhet 192 kan.", excl:99,  desc:"12 scanners×16 kan, 240 sekvenser, musikstyrning" },
        { img:"/images/ljus/pp_ljus_botex_sdc16.png",name:"Botex SDC-16",       excl:199, desc:"16 kanalfaders + masterfader, startkanal via display" },
        { img:"/images/ljus/pp_ljus_styrning03.png", name:"Styrenhet 512 kan.", excl:299, desc:"48 enheter, 4 600 scener, 96 banker, musikstyrning" },
        { img:"/images/ljus/pp_ljus_styrning04.png", name:"PC-mjukvara DMX",    excl:799, desc:"512 kan, dra/släpp programmering, BPM-analys, SSL2" },
        { img:"/images/ljus/pp_ljus_styrning-m6.png",  name:"Martin M6 Ljusstyrning",    excl:2499, desc:"M6 ljuskontroll med dubbla 15,4\" touchskärmar, 44 playbacks, 4x FastBlend RGB" },
      
      ].map(p => (
        <div class="bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-xl overflow-hidden transition-colors flex flex-col">
          <div class="bg-brand-dark overflow-hidden" style="aspect-ratio:1024/853;cursor:zoom-in">
            <img src={p.img} alt={p.name} width="256" height="213" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="p-3 flex flex-col flex-1">
            <p class="text-white font-bold text-sm mb-1">{p.name}</p>
            {p.artno && <p class="artno-badge">{p.artno}</p>}
            <p class="text-gray-400 text-xs mb-3 flex-1">{p.desc}</p>
            <div class="flex items-center justify-between border-t border-white/10 pt-2 gap-2">
              <div class="shrink-0">
                <span class="sk-price-excl text-brand-orange font-bold text-sm">{p.excl} kr</span>
                <span class="sk-price-incl hidden text-brand-orange font-bold text-sm">{Math.round(p.excl*1.25)} kr</span>
                <div class="text-gray-400 text-[10px]">/dygn</div>
              </div>
              <CartButton id={`rok-dmx-${p.name.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`} name={p.name} price={p.excl} priceNote="/dygn" category="DMX-styrning" image={p.img} size="sm" label="Lägg i korg" />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- TILLBEHÖR RÖK & DMX -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-4 border-b border-white/10 pb-3">Tillbehör – Fästen &amp; DMX</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {[
        { img:"/images/ljus/pp_ljus_half_coupler.png",  name:"Half Coupler 35/50 mm",          excl:20  },
        { img:"/images/ljus/pp_ljus_super_clamp.png",   name:"Super Clamp 50 mm",              excl:32  },
        { img:"/images/ljus/pp_ljus_kablar.png",        name:"DMX-kabel 1–5 m",               excl:20  },
        { img:"/images/ljus/pp_ljus_kablar.png",        name:"DMX-kabel 10–15 m",             excl:40  },
        { img:"/images/ljus/pp_ljus_tradlos01.png",     name:"DMX Trådlös startkit (1+2)",     excl:159 },
        { img:"/images/ljus/pp_ljus_tradlos02.png",     name:"DMX Trådlös extra sändare",      excl:80  },
        { img:"/images/ljus/pp_ljus_tradlos03.png",     name:"DMX Trådlös extra mottagare",    excl:80  },
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} category="DMX-tillbehör" artno={t.artno} />
      ))}
    </div>
  </section>

  <!-- EL-TILLBEHÖR -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-4 border-b border-white/10 pb-3">El-tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {[
        { img:"/images/ljus/pp_ljus_powercon.png",      name:"PowerCon 0,5–1,5 m",         excl:20  },
        { img:"/images/ljus/pp_ljus_iec_kabel.png",     name:"IEC C13/C14 0,5–1,5 m",     excl:20  },
        { img:"/images/ljus/pp_el_grenuttag_sm.png",    name:"Grenuttag 1,5 m",            excl:20  },
        { img:"/images/ljus/pp_el_forlangning.png",     name:"Förlängning 10 m 1-fas",     excl:48  },
        { img:"/images/ljus/pp_ljus_powercon2.png",     name:"PowerCon 5–10 m",            excl:80  },
        { img:"/images/ljus/pp_el_overloppsskydd.png",  name:"Överkörningsskydd 1 m",      excl:80  },
        { img:"/images/ljus/pp_el_grenuttag_lg.png",    name:"Grenuttag 10 m IP44",        excl:100 },
        { img:"/images/ljus/pp_el_grenuttag_25m.png",   name:"Grenuttag 25 m IP44",        excl:159 },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 16A",      excl:236 },
        { img:"/images/ljus/pp_el_omvandlare.png",      name:"Strömomvandlare 3-fas→1-fas",excl:320 },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 32A",      excl:396 },
        { img:"/images/ljud/pp_ljud_tillbehor_elverk-small.png", name:"Elgenerator 2 200 W", excl:799 },
        { img:"/images/ljud/pp_ljud_elverk-kipor.png", name:"Elgenerator 7 700 W", excl:1799 },
      
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} category="El-tillbehör" artno={t.artno} />
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex flex-wrap gap-4">
    <a href="/vara-tjanster/hyra-ljus/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">← Tillbaka till hyra ljus</a>
    <a href="/bokningssida/" class="bg-brand-orange hover:bg-brand-orange-light text-white px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Boka nu</a>
    <a href="/kontakt/" class="border border-white/30 text-white hover:bg-white/10 px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Fråga om offert</a>
  </div>
</Layout>
