---
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import CartButton from '../../../../components/CartButton.astro';
import ElTillbehorCard from '../../../../components/ElTillbehorCard.astro';
import MediaCard from '../../../../components/MediaCard.astro';
import ljusData from '../../../../data/ljus.json';

// Volymrad-helper — läser från JSON, inga hårdkodade priser i mallen
const _rokVolMap: Record<string, {minQty:number,unitPrice:number}[]> = Object.fromEntries(
  (ljusData.rok?.products ?? [])
    .filter((p: any) => p.volumePricing?.length)
    .map((p: any) => [p.artno, p.volumePricing])
);
function volRowsRok(artno: string) {
  const tiers = _rokVolMap[artno];
  if (!tiers?.length) return [];
  return [{ label: 'Volympriser', rows: tiers.map((t: any) => `${t.minQty} st – ${(t.unitPrice * t.minQty).toLocaleString('sv')} kr`) }];
}

const forbr = ljusData.rok.tillbehor.filter(t =>
  !t.slug?.startsWith('ackrylatbensin')
);
---
<Layout
  title="Hyr Rökmaskin & Kallgnistmaskin Stockholm – Granulat & Rökvätska | Scenkonsult"
  description="Hyr rökmaskin, kallgnistmaskin, hazer och konfettiavfyrare i Stockholm. Rökmaskin fr 349 kr/dygn. Rökvätska, granulat och ackrylatbensin. Leverans i hela Storstockholm."
>

  <CategoryHero
    h1="Rök & Pyroteknik"
    h1Accent="Stockholm"
    intro="Hyr rökmaskin, kallgnistmaskin och konfettiavfyrare i Stockholm från 349 kr/dygn. Våra rökmaskiner har inbyggt RGB-ljus och fyller lokalen snabbt – perfekt till bröllop, konserter och företagsevent. Kallgnistmaskiner (Cold Spark) producerar kalla gnistor som är helt säkra inomhus, kräver inget tillstånd och ger ett professionellt scen-intryck. Rök och pyro-effekter förstärker alla ljuspaket och gör stor skillnad i upplevelsen. Leverans i hela Storstockholm."
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Hyra ljus", href: "/vara-tjanster/hyra-ljus/" },
      { label: "Rök & Pyroteknik" }
    ]}
    badges={[
      "Rökmaskin & kallgnistmaskin",
      "Konfettiavfyrare",
      "Volymrabatt",
      "Leverans i Storstockholm",
    ]}
    priceFrom={349}
  />

  <!-- ① RÖKMASKINER, HAZER, KALLGNIST, KONFETTI -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <MediaCard
        title="Rökmaskin, 1500W"
        images={["/images/ljus/pp_ljus_effekt23.png"]}
        videos={["/videos/1200W_Fog_Machine_6LEDs_Remote.mp4"]}
        priceExcl={349}
        priceSuffix="/st/dygn fr"
        id="rokmaskin-1500"
        artno="SK-LJS-ROK-0001"
        category="Rök & pyro"
        bullets={["6×3W LED RGB inbyggd","Dimeffekt: 85 m³/min","Strömförbrukning: 1 500 W","Mått: 397×302×191 mm, Vikt: 5 kg","1 L rökvätska ingår"]}
        rows={volRowsRok('SK-LJS-ROK-0001')}
      />

      <MediaCard
        title="Rökmaskin, 650W"
        images={["/images/ljus/pp_ljus_effekt24.png"]}
        videos={["/videos/adj_fog_fury_jett-04.mp4"]}
        priceExcl={449}
        priceSuffix="/st/dygn fr"
        id="rokmaskin-650"
        artno="SK-LJS-ROK-0002"
        category="Rök & pyro"
        bullets={["12×3W LED RGB inbyggd","Dimeffekt: 125 m³/min","Strömförbrukning: 650 W","Vikt: 10 kg","1 L rökvätska ingår"]}
        rows={volRowsRok('SK-LJS-ROK-0002')}
      />

      <MediaCard
        title="Hazer HZ-1500 Pro"
        images={["/images/ljus/pp_ljus_rok3.png"]}
        videos={["/videos/hazer-hz1500.mp4"]}
        priceExcl={649}
        priceSuffix="/st/dygn fr"
        id="hazer-hz1500"
        artno="SK-LJS-ROK-0005"
        category="Rök & pyro"
        bullets={["Finfördelat dis – synliggör ljusstrålar","DMX 512-styrning","Touring flightcase","Stabil kontinuerlig output","Inkl 1 l rökvätska"]}
        rows={volRowsRok('SK-LJS-ROK-0005')}
      />

      <MediaCard
        title="Kallgnistmaskin"
        images={["/images/ljus/pp_ljus_effekt25.png"]}
        videos={["/videos/Cold_Spark_Machine.mp4"]}
        priceExcl={499}
        priceSuffix="/st/dygn fr"
        id="kallgnistmaskin"
        artno="SK-LJS-ROK-0003"
        category="Rök & pyro"
        bullets={["Cold Spark – säkra gnisteffekter","Effekt: 700 W, förvärmningstid ~4 min","DMX 512, Vikt: 8 kg"]}
        rows={[...volRowsRok('SK-LJS-ROK-0003'), {label:"Granulat (drivmedel)", rows:["100 g (~3 min) – 299 kr","200 g (~6 min) – 479 kr"]}]}
      />

      <MediaCard
        title="Konfettiavfyrare"
        images={["/images/ljus/pp_ljus_confettimaskin.png"]}
        priceExcl={499}
        priceSuffix="/dygn"
        id="konfettiavfyrare"
        artno="SK-LJS-ROK-0004"
        category="Rök & pyro"
        bullets={["Utskjutningsvinkel steglöst justerbar","DMX 512 Standard","Strömförbrukning: 100 W","Inkl ett konfettirör"]}
      />

    </div>
  </section>

  <!-- ② LJUSSTYRNING (DMX) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Ljusstyrning (DMX)</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {[
        { img:"/images/ljus/pp_ljus_styrning02.png",  name:"Styrenhet 192 kan.",     excl:99,   artno:"SK-LJS-DMX-0001", desc:"12 scanners×16 kan, 240 sekvenser, musikstyrning" },
        { img:"/images/ljus/pp_ljus_botex_sdc16.png", name:"Botex SDC-16",           excl:199,  artno:"SK-LJS-DMX-0002", desc:"16 kanalfaders + masterfader, startkanal via display" },
        { img:"/images/ljus/pp_ljus_styrning03.png",  name:"Styrenhet 512 kan.",     excl:299,  artno:"SK-LJS-DMX-0003", desc:"48 enheter, 4 600 scener, 96 banker, musikstyrning" },
        { img:"/images/ljus/pp_ljus_styrning04.png",  name:"PC-mjukvara DMX",        excl:799,  artno:"SK-LJS-DMX-0004", desc:"512 kan, dra/släpp programmering, BPM-analys, SSL2" },
        { img:"/images/ljus/pp_ljus_styrning-m6.png", name:"Martin M6 Ljusstyrning", excl:2499, artno:"SK-LJS-DMX-0005", desc:"Dubbla 15,4\" touchskärmar, 44 playbacks, 4× FastBlend RGB" },
      ].map(p => (
        <ElTillbehorCard img={p.img} name={p.name} excl={p.excl} desc={p.desc} category="DMX-styrning" artno={p.artno} modal={true} specs={[p.desc]} />
      ))}
    </div>
  </section>

  <!-- ③ FÖRBRUKNINGSARTIKLAR: Rökvätska & Granulat -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Förbrukningsartiklar</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {forbr.map(t => (
        <ElTillbehorCard
          img={t.image}
          name={t.name}
          excl={t.price}
          desc={t.desc}
          category="Förbrukningsartiklar"
          artno={t.artno}
        />
      ))}

    </div>
  </section>

  <!-- ④ TILLBEHÖR: Fästen & DMX-kablar -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-4 border-b border-white/10 pb-3">Tillbehör – Fästen &amp; DMX</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {[
        { img:"/images/ljus/pp_ljus_half_coupler.png",  name:"Half Coupler 35/50 mm",        artno:"SK-LJS-STV-0010", excl:20  },
        { img:"/images/ljus/pp_ljus_super_clamp.png",   name:"Super Clamp 50 mm",            artno:"SK-LJS-STV-0011", excl:32  },
        { img:"/images/ljus/pp_ljus_kablar.png",        name:"DMX-kabel 1–5 m",              artno:"SK-LJS-DMX-0006", excl:20  },
        { img:"/images/ljus/pp_ljus_kablar.png",        name:"DMX-kabel 10–15 m",            artno:"SK-LJS-DMX-0007", excl:40  },
        { img:"/images/ljus/pp_ljus_tradlos01.png",     name:"DMX Trådlös startkit (1+2)",   artno:"SK-LJS-DMX-0008", excl:159 },
        { img:"/images/ljus/pp_ljus_tradlos02.png",     name:"DMX Trådlös extra sändare",    artno:"SK-LJS-DMX-0009", excl:80  },
        { img:"/images/ljus/pp_ljus_tradlos03.png",     name:"DMX Trådlös extra mottagare",  artno:"SK-LJS-DMX-0010", excl:80  },
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} category="DMX-tillbehör" artno={t.artno} />
      ))}
    </div>
  </section>

  <!-- ⑤ EL-TILLBEHÖR + Ackrylatbensin sist -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-4 border-b border-white/10 pb-3">El-tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {[
        { img:"/images/ljus/pp_ljus_powercon.png",      name:"PowerCon 0,5–1,5 m",          artno:"SK-LJS-EL-0001", excl:20   },
        { img:"/images/ljus/pp_ljus_iec_kabel.png",     name:"IEC C13/C14 0,5–1,5 m",       artno:"SK-LJS-EL-0002", excl:20   },
        { img:"/images/ljus/pp_el_grenuttag_sm.png",    name:"Grenuttag 1,5 m",              artno:"SK-LJS-EL-0003", excl:20   },
        { img:"/images/ljus/pp_el_forlangning.png",     name:"Förlängning 10 m 1-fas",       artno:"SK-LJS-EL-0004", excl:48   },
        { img:"/images/ljus/pp_ljus_powercon2.png",     name:"PowerCon 5–10 m",              artno:"SK-LJS-EL-0005", excl:80   },
        { img:"/images/ljus/pp_el_overloppsskydd.png",  name:"Överkörningsskydd 1 m",        artno:"SK-LJS-EL-0006", excl:80   },
        { img:"/images/ljus/pp_el_grenuttag_lg.png",    name:"Grenuttag 10 m IP44",          artno:"SK-LJS-EL-0007", excl:100  },
        { img:"/images/ljus/pp_el_grenuttag_25m.png",   name:"Grenuttag 25 m IP44",          artno:"SK-LJS-EL-0008", excl:159  },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 16A",        artno:"SK-LJS-EL-0009", excl:236  },
        { img:"/images/ljus/pp_el_omvandlare.png",      name:"Strömomvandlare 3-fas→1-fas",  artno:"SK-LJS-EL-0010", excl:320  },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 32A",        artno:"SK-LJS-EL-0011", excl:396  },
        { img:"/images/ljud/pp_ljud_tillbehor_elverk-small.png", name:"Elgenerator 2 200 W", artno:"SK-LJS-EL-0012", excl:799  },
        { img:"/images/ljud/pp_ljud_elverk-kipor.png",  name:"Elgenerator 7 700 W",          artno:"SK-LJS-EL-0013", excl:1799 },
        { img:"/images/ljus/pp_ljus_ackrylatbensin_1L.png", name:"Ackrylatbensin 1 l",       artno:"SK-LJS-ROK-ACC-0001", excl:59, desc:"Aspen 4 · 4-taktsmotorer" },
        { img:"/images/ljus/pp_ljus_ackrylatbensin_5L.png", name:"Ackrylatbensin 5 l",       artno:"SK-LJS-ROK-ACC-0002", excl:239, desc:"Aspen 4 · 4-taktsmotorer" },
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} desc={t.desc} category="El-tillbehör" artno={t.artno} />
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex flex-wrap gap-4">
    <a href="/vara-tjanster/hyra-ljus/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">← Tillbaka till hyra ljus</a>
    <a href="/bokningssida/" class="bg-brand-orange hover:bg-brand-orange-light text-white px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Boka nu</a>
    <a href="/kontakt/" class="border border-white/30 text-white hover:bg-white/10 px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Fråga om offert</a>
  </div>
</Layout>
