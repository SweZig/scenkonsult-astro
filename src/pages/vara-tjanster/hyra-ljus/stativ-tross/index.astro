---
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import CartButton from '../../../../components/CartButton.astro';
import ElTillbehorCard from '../../../../components/ElTillbehorCard.astro';
---
<Layout
  title="Hyr Ljusstativ & Trosstorn Stockholm – T-bar, Tross & Traverser | Scenkonsult"
  description="Hyr ljusstativ med T-bar, vevstativ, trosstorn och trossryggar i Stockholm. Stativ fr 40 kr/dygn, trossbåge fr 1500 kr/dygn. Leverans i hela Storstockholm."
>

  <CategoryHero
    h1="Stativ & Tross"
    h1Accent="Stockholm"
    intro="Stativ och tross är grunden för alla häftiga ljusupplevelser. Hyr ljusstativ med T-bar, vevstativ, trosstorn och kompletta trossbågar i Stockholm – från 40 kr/dygn. Välj stativ och tross först för att se hur många effekter du får plats med, välj sedan vilka armaturer du vill ha. Allt från enkla stativ till 6 m breda trossbågar för konserter. Leverans i hela Storstockholm."
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Hyra ljus", href: "/vara-tjanster/hyra-ljus/" },
      { label: "Stativ & Tross" }
    ]}
    badges={[
      "T-bar & vevstativ",
      "Trosstorn & traverser",
      "Passar alla effekter",
      "Leverans i Storstockholm",
    ]}
    priceFrom={40}
  />

  <!-- STATIV -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Ljusstativ med T-bar</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      {[
        { img:"/images/ljus/pp_ljus_stativ06.png", title:"Stativ T-bar 400 mm",      excl:40,  desc:"Standardstativ med 400 mm T-bar. Plats för upp till 2 effekter.", specs:["T-bar: 400 mm","Höjd: 1,25–2,40 m","Max last: 20 kg, Vikt: 3,7 kg"] },
        { img:"/images/ljus/pp_ljus_stativ_1200.png",title:"Stativ T-bar 1200 mm",     excl:40,  desc:"Standardstativ med 1200 mm T-bar. Plats för upp till 4 effekter.", specs:["T-bar: 1 200 mm","Höjd: 1,25–2,40 m","Max last: 20 kg, Vikt: 3,7 kg"] },
        { img:"/images/ljus/pp_ljus_stativ01.png", title:"Stativ T-bar 900 mm ★ Premium",excl:60,desc:"Premiumstativ med 900 mm T-bar. Upp till 2,5 m höjd.", specs:["T-bar: 900 mm","Höjd: 1,10–2,50 m","Max last: 30 kg, Vikt: 5,8 kg"] },
        { img:"/images/ljus/pp_ljus_stativ02.png", title:"Vevstativ T-bar 1200 mm",  excl:120, desc:"Vevstativ för hög monteringshöjd upp till 3,7 m.", specs:["T-bar: 1 200 mm","Höjd: 1,70–3,70 m","Max last: 35 kg, Vikt: 20 kg"] },
      ].map(p => (
        <article class="bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-2xl overflow-hidden transition-all group flex flex-col h-full">
          <div class="bg-brand-dark overflow-hidden" style="aspect-ratio:1024/853">
            <img src={p.img} alt={p.title} width="512" height="427" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="p-4 flex flex-col flex-1">
            <h2 class="font-bold text-white text-base mb-2">{p.title}</h2>
            <p class="text-gray-400 text-xs mb-3">{p.desc}</p>
            <ul class="space-y-1 mb-4 text-xs text-gray-400">
              {p.specs.map(s => <li class="flex gap-1.5"><span class="text-green-400">▸</span>{s}</li>)}
            </ul>
            <div class="flex items-center justify-between border-t border-white/10 pt-3 gap-2 mt-auto">
              <div class="shrink-0">
                <span class="sk-price-excl text-brand-orange font-extrabold text-lg">{p.excl} kr</span>
                <span class="sk-price-incl hidden text-brand-orange font-extrabold text-lg">{Math.round(p.excl*1.25)} kr</span>
                <div class="text-gray-400 text-[10px]">/dygn</div>
              </div>
              <CartButton id={`stativ-${p.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} name={p.title} price={p.excl} priceNote="/dygn" category="Stativ & tross" image={p.img} size="sm" label="Lägg i varukorg" />
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- TROSSTORN -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Trosstorn</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {[
        { img:"/images/ljus/pp_ljus_tross01.png", title:"Trosstorn 1,0 m",excl:300,specs:["4-punkts tross, 50 mm tub","Höjd: 1,0 m","Max last: 50 kg, Vikt: 16 kg"] },
        { img:"/images/ljus/pp_ljus_tross03.png", title:"Trosstorn 1,5 m",excl:360,specs:["4-punkts tross, 50 mm tub","Höjd: 1,5 m","Max last: 50 kg, Vikt: 18 kg"] },
        { img:"/images/ljus/pp_ljus_tross04.png", title:"Trosstorn 2,0 m",excl:400,specs:["4-punkts tross, 50 mm tub","Höjd: 2,0 m","Max last: 50 kg, Vikt: 20 kg"] },
      ].map(p => (
        <article class="bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-2xl overflow-hidden transition-all group flex flex-col h-full">
          <div class="bg-brand-dark overflow-hidden" style="aspect-ratio:1024/853">
            <img src={p.img} alt={p.title} width="512" height="427" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="p-4 flex flex-col flex-1">
            <h2 class="font-bold text-white text-base mb-2">{p.title}</h2>
            <ul class="space-y-1 mb-4 text-xs text-gray-400">
              {p.specs.map(s => <li class="flex gap-1.5"><span class="text-green-400">▸</span>{s}</li>)}
            </ul>
            <div class="flex items-center justify-between border-t border-white/10 pt-3 gap-2 mt-auto">
              <div class="shrink-0">
                <span class="sk-price-excl text-brand-orange font-extrabold text-lg">{p.excl} kr</span>
                <span class="sk-price-incl hidden text-brand-orange font-extrabold text-lg">{Math.round(p.excl*1.25)} kr</span>
                <div class="text-gray-400 text-[10px]">/dygn</div>
              </div>
              <CartButton id={`stativ-${p.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} name={p.title} price={p.excl} priceNote="/dygn" category="Stativ & tross" image={p.img} size="sm" label="Lägg i varukorg" />
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- TROSSTRAVERSER & TROSSBÅGAR -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Trosstraverser &amp; Trossbågar</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { img:"/images/ljus/pp_ljus_stativ03.png", title:"Trosstravers 3,0 m",  excl:460,  desc:"Kan hissas upp till 3,7 m. 3,0 m bred. Upp till 5 effekter.", specs:["4-punkts tross, 50 mm tub","3,0 m bred","Max last: 50 kg, Vikt: 30 kg"] },
        { img:"/images/ljus/pp_ljus_stativ04.png", title:"Trosstravers 4,0 m",  excl:500,  desc:"Kan hissas upp till 3,7 m. 4,0 m bred. Upp till 8 effekter.", specs:["4-punkts tross, 50 mm tub","4,0 m bred","Max last: 50 kg, Vikt: 35 kg"] },
        { img:"/images/ljus/pp_ljus_tross06.png",  title:"Trossbåge 2,5×4,0 m",excl:1500, desc:"Byggs 2,5 m hög och 4,0 m bred. Upp till 18 effekter.", specs:["4-punkts tross, 50 mm tub","Höjd: 2,5 m, Bredd: 4,0 m","Max last: 75 kg, Vikt: 40 kg"] },
        { img:"/images/ljus/pp_ljus_tross08.png",  title:"Trossbåge 3,0×6,0 m",excl:2100, desc:"Byggs 3,0 m hög och 6,0 m bred. Upp till 24 effekter.", specs:["4-punkts tross, 50 mm tub","Höjd: 3,0 m, Bredd: 6,0 m","Max last: 75 kg, Vikt: 60 kg"] },
        { img:"/images/ljus/pp_ljus_tross09.png",  title:"Trossvägg 2,5×2,0 m",excl:2100, desc:"Byggs 2,5 m hög och 2,0 m bred. Passar 8–16 effekter.", specs:["4-punkts tross, 50 mm tub","Höjd: 2,5 m, Bredd: 2,0 m","Max last: 75 kg, Vikt: 60 kg"] },
      ].map(p => (
        <article class="bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-2xl overflow-hidden transition-all group flex flex-col h-full">
          <div class="bg-brand-dark overflow-hidden" style="aspect-ratio:1024/853">
            <img src={p.img} alt={p.title} width="512" height="427" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="p-4 flex flex-col flex-1">
            <h2 class="font-bold text-white text-base mb-2">{p.title}</h2>
            <p class="text-gray-400 text-xs mb-3">{p.desc}</p>
            <ul class="space-y-1 mb-4 text-xs text-gray-400">
              {p.specs.map(s => <li class="flex gap-1.5"><span class="text-green-400">▸</span>{s}</li>)}
            </ul>
            <div class="flex items-center justify-between border-t border-white/10 pt-3 gap-2 mt-auto">
              <div class="shrink-0">
                <span class="sk-price-excl text-brand-orange font-extrabold text-lg">{p.excl} kr</span>
                <span class="sk-price-incl hidden text-brand-orange font-extrabold text-lg">{Math.round(p.excl*1.25)} kr</span>
                <div class="text-gray-400 text-[10px]">/dygn</div>
              </div>
              <CartButton id={`stativ-${p.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} name={p.title} price={p.excl} priceNote="/dygn" category="Stativ & tross" image={p.img} size="sm" label="Lägg i varukorg" />
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- TILLBEHÖR FÄSTEN & DMX -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-4 border-b border-white/10 pb-3">Tillbehör – Fästen, Trossöverdrag &amp; DMX</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      {[
        { img:"/images/ljus/pp_ljus_half_coupler.png",  name:"Half Coupler 35/50 mm",       excl:20  },
        { img:"/images/ljus/pp_ljus_super_clamp.png",   name:"Super Clamp 50 mm",           excl:32  },
        { img:"/images/ljus/pp_ljus_tross05.png",       name:"Trossöverdrag 1,0 m",         excl:60  },
        { img:"/images/ljus/pp_ljus_tross05.png",       name:"Trossöverdrag 1,5 m",         excl:80  },
        { img:"/images/ljus/pp_ljus_tross05.png",       name:"Trossöverdrag 2,0 m",         excl:100 },
        { img:"/images/ljus/pp_ljus_kablar.png",        name:"DMX-kabel 1–5 m",             excl:40  },
        { img:"/images/ljus/pp_ljus_kablar.png",        name:"DMX-kabel 10–15 m",           excl:60  },
        { img:"/images/ljus/pp_ljus_tradlos01.png",     name:"DMX Trådlös startkit (1+2)",  excl:239 },
        { img:"/images/ljus/pp_ljus_tradlos02.png",     name:"DMX Trådlös extra sändare",   excl:80  },
        { img:"/images/ljus/pp_ljus_tradlos03.png",     name:"DMX Trådlös extra mottagare", excl:80  },
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} category="Tillbehör" />
      ))}
    </div>
  </section>

  <!-- EL-TILLBEHÖR -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-4 border-b border-white/10 pb-3">El-tillbehör</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      {[
        { img:"/images/ljus/pp_ljus_powercon.png",      name:"PowerCon 0,5–1,5 m",         excl:20  },
        { img:"/images/ljus/pp_ljus_powercon2.png",     name:"PowerCon 5–10 m",            excl:80  },
        { img:"/images/ljus/pp_ljus_iec_kabel.png",     name:"IEC C13/C14 0,5–1,5 m",     excl:20  },
        { img:"/images/ljus/pp_el_grenuttag_sm.png",    name:"Grenuttag 1,5 m",            excl:20  },
        { img:"/images/ljus/pp_el_forlangning.png",     name:"Förlängning 10 m 1-fas",     excl:48  },
        { img:"/images/ljus/pp_el_grenuttag_lg.png",    name:"Grenuttag 10 m IP44",        excl:100 },
        { img:"/images/ljus/pp_el_grenuttag_25m.png",   name:"Grenuttag 25 m IP44",        excl:159 },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 16A",      excl:236 },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 32A",      excl:396 },
        { img:"/images/ljus/pp_el_omvandlare.png",      name:"Strömomvandlare 3-fas→1-fas",excl:320 },
        { img:"/images/ljus/pp_el_overloppsskydd.png",  name:"Överkörningsskydd 1 m",      excl:80  },
        { img:"/images/ljud/pp_ljud_tillbehor_elverk-small.png", name:"Elgenerator 2 200 W", excl:799 },
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} category="Tillbehör" />
      ))}
    </div>
  </section>

  <!-- STÖRRE EVENT CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="bg-brand-navy border border-white/10 rounded-2xl overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="p-8">
          <h2 class="text-2xl font-bold text-white mb-3">Scenljus för konserter eller större event</h2>
          <p class="text-gray-300 mb-2">Vi har scenljus för alla ändamål – vitt och färgat ljus på travers eller tross.</p>
          <p class="text-gray-400 text-sm mb-6">Kontakta oss och beskriv ditt behov så tar vi fram en lösning. Större ljusriggar hyrs ut inkl. transport och montering.</p>
          <a href="/kontakt/" class="inline-block bg-brand-orange hover:bg-brand-orange-light text-white px-5 py-3 rounded-xl font-semibold text-sm transition-colors">Begär offert</a>
        </div>
        <div class="hidden md:block">
          <img src="/images/ljus/pp_ljus_storre_event.png" alt="Scenljus för konserter" width="600" height="400" loading="lazy" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex flex-wrap gap-4">
    <a href="/vara-tjanster/hyra-ljus/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">← Tillbaka till hyra ljus</a>
    <a href="/vara-tjanster/hyra-ljus/ljuseffekter/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">Lösa effekter</a>
    <a href="/bokningssida/" class="bg-brand-orange hover:bg-brand-orange-light text-white px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Boka nu</a>
  </div>
</Layout>
