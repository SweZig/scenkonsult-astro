---
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import ProductCard from '../../../../components/ProductCard.astro';
import Price from '../../../../components/Price.astro';
import CartButton from '../../../../components/CartButton.astro';
import ElTillbehorCard from '../../../../components/ElTillbehorCard.astro';
---
<Layout
  title="Hyra Musikljud Stockholm – DJ-system med Sub-basar | Scenkonsult"
  description="Hyr musikljud och DJ-system i Stockholm från 999 kr/dygn. Kraftfulla sub-basar och fullrange för dansgolv med 20–1 500 gäster. Leverans i hela Storstockholm."
>

  <CategoryHero
    h1="Musikljud & DJ-system"
    h1Accent="Stockholm"
    intro="Hyr musikljud och DJ-system i Stockholm. Kraftfulla sub-basar och fullrange-system för dansgolv och fest med 20–1 500 gäster. Komplettera med mixerbord och trådlösa mikrofoner nedan."
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Hyra ljud", href: "/vara-tjanster/hyra-ljud/" },
      { label: "Ljud för Musik" }
    ]}
    badges={[
      "Sub-basar för dansgolv",
      "20–1 500 personer",
      "DJ-anpassat",
      "Leverans i Storstockholm",
    ]}
    priceFrom={999}
  />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard name="Music, Small" price={999} persons="20–80 personer"
        image="/images/ljud/pp_ljud_music_small.png"
        description="DJ/trubadur för 20–80 personer. Två 10″ fullrange och en 12″ sub-bas. Bra bas och tryck."
        specs={["10″/1,4″ + 12″ sub","2 000 W peak / 1 000 W RMS","Max 130 dB","36–20 000 Hz","Samlad vikt: 65 kg"]} />
      <ProductCard name="Music, Small+" price={1299} persons="40–100 personer"
        image="/images/ljud/pp_ljud_music_small-.png"
        description="DJ/trubadur för 40–100 personer. Två 10″ fullrange och två 12″ sub-basar."
        specs={["10″/1,4″ + 2×12″ sub","2 000 W peak","Max 130 dB","36–20 000 Hz","Samlad vikt: 90 kg"]} />
      <ProductCard name="Music, Medium" price={1499} persons="60–120 personer"
        image="/images/ljud/pp_ljud_music_medium.png"
        description="DJ för 60–120 personer. Två 12″ fullrange och två 12″ sub-basar."
        specs={["12″/1,4″ + 2×12″ sub","2 000 W peak","Max 130 dB","36–20 000 Hz","Samlad vikt: 95 kg"]} />
      <ProductCard name="Music, Large" price={1899} persons="120–250 personer"
        image="/images/ljud/pp_ljud_music_large.png"
        description="DJ för 120–250 personer. Två 12″ fullrange och två 15″ sub-basar."
        specs={["12″/1,4″ + 2×15″ sub","2 000 W peak","Max 132 dB","29–20 000 Hz","Samlad vikt: 115 kg"]} />
      <ProductCard name="Live/Music, XL" price={2299} persons="180–350 personer"
        image="/images/ljud/pp_ljud_music_xl.png"
        description="DJ för 180–350 personer. Två 15″ fullrange och två 18″ sub-basar."
        specs={["15″/1,4″ + 18″ sub","8 000 W peak / 2 000 W RMS","Max 132 dB","29–20 000 Hz","Samlad vikt: 120 kg"]} />
      <ProductCard name="Live/Music, XL+" price={2999} persons="250–600 personer"
        image="/images/ljud/pp_ljud_music_xl-.png"
        description="DJ för 250–600 personer. 15″ fullrange, 15″ och 18″ sub."
        specs={["15″/1,4″ + 15″/18″ sub","8 000 W peak","Max 132 dB","Samlad vikt: 200 kg"]} />
      <ProductCard name="Live/Music, XXL" price={4999} persons="500–1 500 personer"
        image="/images/ljud/pp_ljud_music_xxl.png"
        description="DJ för 500–1 500 personer. Fyra 15″ fullrange och fyra 18″ sub-basar."
        specs={["4×15″/1,4″ + 4×18″ sub","10 000 W peak","Max 132 dB","Samlad vikt: 320 kg"]} />
      <ProductCard name="Live/Music, Concert" price={6999} persons="500–1 500 personer"
        image="/images/ljud/pp_ljud_music_concert.png"
        description="Konsert. Två 12″ fullrange och fyra 18″ sub-basar. Varje stack 2,3 m hög."
        specs={["2×12″/1,4″ + 4×18″ sub","10 800 W peak","Max 135 dB","Samlad vikt: 360 kg"]} />
    </div>
  </section>

  <!-- MIXERBORD -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-2 border-b border-white/10 pb-3">Mixerbord</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard name="Analogt mixerbord, 2+2 kanaler" price={159} image="/images/ljud/pp_ljud_mixer01.png" description="Alto, 2 mic + 2 stereo, Bluetooth." specs={["2 mic/line","2 stereo","Bluetooth","Fantommatning 48V"]} />
      <ProductCard name="Analogt mixerbord, 4+2 kanaler" price={199} image="/images/ljud/pp_ljud_mixer02.png" description="Alto, 4 mic + 2 stereo, effekter + Bluetooth." specs={["4 mic/line","2 stereo","Effekter + Bluetooth"]} />
      <ProductCard name="Analogt mixerbord, 4+1 kanaler" price={249} image="/images/ljud/pp_ljud_mixer-vibz8dc.png" description="LD System Vibz8dc med 4 mic-kanaler, 2 stereokanaler och inbyggd kompressor på kanal 1 & 2." specs={["4 mic/line (XLR + 6,3 mm)", "Digital effektprocessor + kompressor", "Fantommatning 48V", "Vikt: 2,3 kg"]} />
      <ProductCard name="Analogt mixerbord, 4+4 kanaler" price={299} image="/images/ljud/pp_ljud_mixer03.png" description="Mackie, 4 mic + 4 stereo, 60 dB gain." specs={["4 mic/line","4 stereo","60 dB preamp"]} />
      <ProductCard name="Analogt mixerbord, 6+4 kanaler" price={349} image="/images/ljud/pp_ljud_mixer04.png" description="Allen & Heath ZED14, 6 mic + 4 stereo." specs={["6 mic/line","4 stereo","69 dB preamp"]} />
      <ProductCard name="Analogt mixerbord, 12+4 kanaler" price={399} image="/images/ljud/pp_ljud_mixer05.png" description="Alto Live L16, 12 mic + 4 stereo, 256 effekter." specs={["12 mic/line","256 effekter"]} />
      <ProductCard name="Analogt mixerbord, 16+3 kanaler" price={599} image="/images/ljud/pp_ljud_mixer06.png" description="Allen & Heath ZED22FX, 16 mic + 3 stereo, USB." specs={["16 mic/line","USB","High-pass filter"]} />
      <ProductCard name="Digitalt mixerbord, 32+16 kanaler" price={2499} image="/images/ljud/pp_ljud_mixer-ilive-t80.png" description="Allen & Heath iLive T80 studio- & konsert-mixer med Stagebox på scenen via CAT5/6-kabel." specs={["32 mik/line in, 16 XLR ut", "20 faders – 2 banker, 4 lager = 80 kontroller", "8 in, 8 ut ljud", "Vikt: 32 kg"]} />
    </div>
  </section>

  <!-- MIKROFONER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Mikrofoner &amp; tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3">
      {[
        { name:"Högtalarstativ Gravity",        desc:"Max last 30 kg, vikt 3,7 kg",  price:40,  img:"/images/ljud/pp_ljud_stativ-gravity.png" },
        { name:"Högtalarstativ K&M",             desc:"Max last 30 kg, vikt 3,7 kg",  price:50,  img:"/images/ljud/pp_ljud_stativ-km.png" },
        { name:"Högtalarstativ Gravity Premium",  desc:"Max last 50 kg, vikt 6,4 kg",  price:60,  img:"/images/ljud/pp_ljud_stativ-gravity-premium.png" },
        { name:"Högtalarstativ Gravity med vev",  desc:"Max last 50 kg, vikt 9,1 kg",  price:120, img:"/images/ljud/pp_ljud_stativ-gravity-vev.png" },
        { name:"Mikrofonstativ",                  desc:"Justerbar höjd",                     price:60,   img:"/images/ljud/pp_ljud_tillbehor06.png" },
        { name:"XLR-kablar",                      desc:"1–15 m, fr 40 kr",                  price:40,   img:"/images/ljud/pp_ljud_tillbehor07.png" },
        { name:"XLR Multikabel 15 m, 6 kan.",    desc:"Stagebox, 6 kanaler",                price:276,  img:"/images/ljud/pp_ljud_tillbehor_MK-small.png" },
        { name:"XLR Multikabel 25 m, 8 kan.",    desc:"Stagebox, 8 kanaler",                price:384,  img:"/images/ljud/pp_ljud_tillbehor_MK-medium.png" },
        { name:"XLR Multikabel 15 m, 24+8 kan.", desc:"Stagebox stor, 24+8 kanaler",        price:632,  img:"/images/ljud/pp_ljud_tillbehor_MK-large.png" },
        { name:"DI-box (passiv)",                 desc:"2-kan, XLR ut / 6,35 mm in",         price:160,  img:"/images/ljud/pp_ljud_tillbehor_DI-passiv.png" },
        { name:"DI-box (aktiv)",                  desc:"1-kan, XLR ut / 6,35 mm in, 9V",    price:240,  img:"/images/ljud/pp_ljud_tillbehor_DI-aktiv.png" },
        { name:"Bluetooth-mottagare",             desc:"Trådlös anslutning till PA",         price:100,  img:"/images/ljud/pp_ljud_tillbehor04.png" },
        { name:"Bluetooth-mottagare pro",         desc:"Längre räckvidd",                    price:140,  img:"/images/ljud/pp_ljud_tillbehor_BT-pro.png" },
        { name:"Instrumentmikrofon",              desc:"Gitarr, blås m.m., inkl XLR",        price:64,   img:"/images/ljud/pp_ljud_mik02.png" },
        { name:"Instrumentmikrofon, blås",        desc:"Blåsinstrument, inkl XLR",           price:80,   img:"/images/ljud/pp_ljud_mik02.png" },
        { name:"Handmikrofon",                    desc:"Inkl 6 m XLR-kabel",                 price:80,   img:"/images/ljud/pp_ljud_mik01.png" },
        { name:"Instrumentmikrofoner, slagverk",  desc:"Trumset, inkl XLR-kablar",           price:480,  img:"/images/ljud/pp_ljud_mik03.png" },
        { name:"Trådlös handmikrofon",            desc:"Ca 30 m räckvidd",                   price:400,  img:"/images/ljud/pp_ljud_mik05.png" },
        { name:"Trådlöst headset",                desc:"Ca 30 m räckvidd",                   price:480,  img:"/images/ljud/pp_ljud_mik06.png" },
        { name:"Trådlöst IEM",                    desc:"In-ear monitor, ca 30 m",            price:480,  img:"/images/ljud/pp_ljud_mik06.png" },
        { name:"Shure SLXD – trådlöst system, 1 mik",          desc:"Digitalt, AES-256, 1× SM58-kapsel, ca 100 m",        price:699,  img:"/images/ljud/pp_ljud_mik09.png" },
        { name:"Shure SLXD – trådlöst system, 1 myggmikrofon", desc:"Digitalt, AES-256, 1× bodypack + myggmik, ca 100 m",  price:699,  img:"/images/ljud/pp_ljud_mik13.png" },
        { name:"Shure SLXD – trådlöst system, 1 headset",      desc:"Digitalt, AES-256, 1× bodypack + headset, ca 100 m",  price:749,  img:"/images/ljud/pp_ljud_mik12.png" },
        { name:"Shure SLXD – trådlöst system, 1 lågprofil headset", desc:"Digitalt, AES-256, 1× bodypack + öronhängande headset, ca 100 m", price:799, img:"/images/ljud/pp_ljud_mik14.png" },
        { name:"Effektrack med matrix & feedback-suppressor",   desc:"5-zon ART-matrix + Klark Teknik DP1000",              price:1036, img:"/images/ljud/pp_ljud_effektrack.png" },
        { name:"Shure SLXD – trådlöst system, 2 mik",          desc:"Digitalt, AES-256, 2× SM58, ca 100 m",               price:1299, img:"/images/ljud/pp_ljud_mik-shure-slxd4d.png" },
        { name:"Shure SLXD – trådlöst system, 2 myggmikrofon", desc:"Digitalt, AES-256, 2× bodypack + myggmik, ca 100 m",  price:1299, img:"/images/ljud/pp_ljud_mik10.png" },
        { name:"Shure SLXD – trådlöst system, 2 headset",      desc:"Digitalt, AES-256, 2× bodypack + headset, ca 100 m",  price:1399, img:"/images/ljud/pp_ljud_mik08.png" },
        { name:"Shure SLXD – trådlöst system, 2 lågprofil headset", desc:"Digitalt, AES-256, 2× bodypack + öronhängande headset, ca 100 m", price:1499, img:"/images/ljud/pp_ljud_mik11.png" },
        { name:"Trådlöst mikrofonset 8 kan.",                   desc:"4 hand + 4 headset, antennsplitter",                 price:3999, img:"/images/ljud/pp_ljud_mik04.png" },
      
      
      
      
      
      
      
      ].map(item => (
        <div class="bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-xl p-4 flex flex-col gap-2 transition-colors">
          <div class="aspect-square bg-brand-dark rounded-lg overflow-hidden">
            <img src={item.img} alt={item.name} width="200" height="200" loading="lazy" class="w-full h-full object-contain p-1" />
          </div>
          <p class="text-white font-semibold text-sm">{item.name}</p>
          <p class="text-gray-400 text-xs flex-1">{item.desc}</p>
          <div class="border-t border-white/10 pt-2 flex items-center justify-between gap-1 mt-auto">
            <span class="text-brand-orange font-bold text-sm"><Price amount={item.price} size="sm" /></span>
            <CartButton id={`music-mik-${item.name.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`} name={item.name} price={item.price} category="Ljud tillbehör" image={item.img} size="sm" iconOnly={true} />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- EL-TILLBEHÖR -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">El-tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-2">
      {[
        { img:"/images/ljus/pp_el_grenuttag_sm.png",    name:"Grenuttag 1,5 m",             excl:20,  desc:"Jordat, 3–5 uttag, 16A" },
        { img:"/images/ljus/pp_el_forlangning.png",     name:"Förlängning 10 m",            excl:48,  desc:"1-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_overloppsskydd.png",  name:"Överkörningsskydd 1 m",       excl:80,  desc:"Kabelramp, 2 kanaler" },
        { img:"/images/ljus/pp_el_grenuttag_lg.png",    name:"Grenuttag på rulle 10 m",     excl:100, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_grenuttag_25m.png",   name:"Grenuttag på rulle 25 m",     excl:159, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 20 m 16A",  excl:236, desc:"3-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_omvandlare.png",      name:"Strömomvandlare 3-fas→1-fas", excl:320, desc:"32A 3-fas till 1-fas uttag" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 20 m 32A",  excl:396, desc:"3-fas, 32A, IP44" },
        { img:"/images/ljud/pp_ljud_tillbehor_elverk-small.png", name:"Elgenerator 2 200 W",       excl:799, desc:"1 900 W kontinuerlig, bensin 4-takt" },
        { img:"/images/ljud/pp_ljud_elverk-kipor.png", name:"Elgenerator 7 700 W",       excl:1799, desc:"7 000 W kontinuerlig, bensin 4-takt. Kipor IG6000." },
      
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} desc={t.desc} category="El-tillbehör" />
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex flex-wrap gap-4">
    <a href="/vara-tjanster/hyra-ljud/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">← Tillbaka till hyra ljud</a>
    <a href="/bokningssida/" class="bg-brand-orange hover:bg-brand-orange-light text-white px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Boka nu</a>
    <a href="/kontakt/" class="border border-white/30 text-white hover:bg-white/10 px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Fråga om offert</a>
  </div>
</Layout>
