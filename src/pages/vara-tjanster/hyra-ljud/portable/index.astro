---
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import ProductCard from '../../../../components/ProductCard.astro';
import CartButton from '../../../../components/CartButton.astro';
import ElTillbehorCard from '../../../../components/ElTillbehorCard.astro';
import _ljudData from '../../../../data/ljud.json';
const _artnoAliases: Record<string,string> = {
  'XLR Multikabel 15 m, 6 kan.':          'SK-LJD-MIK-0014',
  'XLR Multikabel 25 m, 8 kan.':          'SK-LJD-MIK-0015',
  'XLR Multikabel 15 m, 24+8 kan.':       'SK-LJD-MIK-0020',
  'Instrumentmikrofon, blås':              'SK-LJD-MIK-0008',
  'Instrumentmikrofoner, slagverk':        'SK-LJD-MIK-0019',
  'Shure SLXD – trådlöst system, 2 mik':  'SK-LJD-MIK-0026',
  'Shure SLXD – trådlöst system, 2 myggmikrofon': 'SK-LJD-MIK-0027',
  'XLR-kablar':                            'SK-LJD-MIK-0002',
  'Bluetooth-mottagare pro':               'SK-LJD-MIK-0011',
  'Trådlöst mikrofonset 8 kan.':           'SK-LJD-MIK-0030',
  'Trådlöst IEM':                          'SK-LJD-MIK-0018',
  // El-tillbehör förkortade namn
  'Grenuttag 1,5 m': 'SK-LJD-EL-0001',
  'Förlängning 10 m': 'SK-LJD-EL-0002',
  'Grenuttag på rulle 10 m': 'SK-LJD-EL-0003',
  'Grenuttag på rulle 25 m': 'SK-LJD-EL-0004',
  'Förlängning 3-fas 16A': 'SK-LJD-EL-0005',
  'Förlängning 3-fas 20 m 16A':     'SK-LJD-EL-0005',
  'Förlängning 3-fas 32A': 'SK-LJD-EL-0006',
  'Förlängning 3-fas 20 m 32A':     'SK-LJD-EL-0006',
  'Strömomvandlare 3-fas→1-fas': 'SK-LJD-EL-0007',
  'Strömomvandlare 3-fas>1-fas': 'SK-LJD-EL-0007',
  'Överkörningsskydd 1 m': 'SK-LJD-EL-0008',
  'Elgenerator 2 200 W': 'SK-LJD-EL-0010',
  'Elgenerator 7 700 W': 'SK-LJD-EL-0011',
  'Regnskydd till högtalare': 'SK-LJD-EL-0009',
  'Elgenerator 7700W': 'SK-LJD-EL-0011',
  'Elgenerator, 2200W': 'SK-LJD-EL-0010',
};
const artnoByName: Record<string,string> = {..._artnoAliases, ...Object.fromEntries(
  [...(_ljudData.tillbehor_mikrofon||[]), ...(_ljudData.tillbehor_el||[]), ...(_ljudData.mixers||[])]
    .filter((p:any) => p.artno)
    .map((p:any) => [p.name, p.artno])
)};
---
<Layout
  title="Hyra Portabelt Ljud Stockholm – Batteridrivet PA-system | Scenkonsult"
  description="Hyr portabelt batteridrivet ljud i Stockholm från 599 kr/dygn. Kompakta kolumnsystem perfekta för utomhus, studentflak och event utan strömkälla. Leverans i hela Storstockholm."
>

  <CategoryHero
    h1="Portabelt Ljud"
    h1Accent="Stockholm"
    intro="Hyr batteridrivet portabelt ljud i Stockholm. Kompakta kolumnsystem som enkelt kan flyttas – flera modeller kräver ingen strömkälla alls. Perfekt för studentflak, gallerior, torg och utomhusbruk. Ju större paket, desto fler åhörare når du och basen ökar markant."
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Hyra ljud", href: "/vara-tjanster/hyra-ljud/" },
      { label: "Portabelt ljud" }
    ]}
    badges={[
      "Batteridrivet",
      "Bluetooth & inbyggd mixer",
      "Ingen strömkälla krävs",
      "Leverans i Storstockholm",
    ]}
    priceFrom={599}
  />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-4">
    <div class="inline-flex items-center gap-2 bg-brand-navy border border-brand-orange/30 rounded-xl px-4 py-2.5">
      <span class="text-brand-orange text-base">🎤</span>
      <span class="text-white text-sm font-medium">Handmikrofon ingår i alla paket</span>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard artno="SK-LJD-POR-0001" name="Portable, Small" price={599} persons="20–60 personer"
        image="/images/ljud/pp_ljud_portable_small.png"
        description="Batteridrift 20+ timmar. Inbyggd mixer och Bluetooth. Perfekt för studentflak, park-event och små utomhusevent. 6,5″ element."
        specs={["6,5″/1″ aktiva element","200 W peak / 100 W RMS","Batteridrift upp till 20 tim","Bluetooth","Vikt: 5,4 kg"]} />
      <ProductCard artno="SK-LJD-POR-0002" name="Portable, Small+" price={699} persons="40–80 personer"
        image="/images/ljud/pp_ljud_portable_small_.png"
        description="Batteridrift 7+ timmar. Inbyggd mixer och Bluetooth. 12″ element för kraftfullare ljud."
        specs={["12″/2″ aktiva element","600 W peak / 300 W RMS","Batteridrift upp till 7 tim","Bluetooth","Vikt: 13,4 kg"]} />
      <ProductCard artno="SK-LJD-POR-0003" name="Portable, Medium" price={799} persons="40–80 personer"
        image="/images/ljud/pp_ljud_portable_medium.png"
        description="Alto TS108 C kolumnhögtalare. 8″ bas och sex 2,75″ diskant. Inbyggd mixer. Smal och snygg design."
        specs={["8″ bas + 6×2,75″ element","600 W peak / 300 W RMS","Max 123 dB","Bluetooth","Vikt: 16 kg"]} />
      <ProductCard artno="SK-LJD-POR-0004" name="Portable, Medium+" price={999} persons="60–100 personer"
        image="/images/ljud/pp_ljud_portable_medium_.png"
        description="Alto TS112 C kolumnhögtalare. 12″ bas och åtta 2,75″ diskant. Inbyggd mixer."
        specs={["12″ bas + 8×2,75″ element","1 200 W peak / 600 W RMS","Max 127 dB","Bluetooth","Vikt: 24,1 kg"]} />
      <ProductCard artno="SK-LJD-POR-0005" name="Portable, Small Duo" price={1099} persons="40–80 personer"
        image="/images/ljud/pp_ljud_portable_small_duo.png"
        description="Två batteridrivna 6,5″ högtalare på stativ. Upp till 20 timmars batteridrift. Inbyggd mixer och Bluetooth. Handmikrofon ingår."
        specs={["2×6,5″/1″ aktiva element","400 W peak / 200 W RMS","Batteridrift upp till 20 tim","Bluetooth","Vikt: 10,8 kg"]} />
      <ProductCard artno="SK-LJD-POR-0006" name="Portable, Large" price={1199} persons="80–120 personer"
        image="/images/ljud/pp_ljud_portable_large.png"
        description="LD Systems Maui 28 G2. Två 8″ basar och 16 st 3″ diskant. Kraftfullt och smidigt kolumnsystem."
        specs={["2×8″ bas + 16×3″ diskant","2 000 W peak / 1 000 W RMS","Max 126 dB","Bluetooth","Vikt: 25,7 kg"]} />
      <ProductCard artno="SK-LJD-POR-0007" name="Portable, Small+ Duo" price={1299} persons="80–120 personer"
        image="/images/ljud/pp_ljud_portable_small__duo.png"
        description="Två batteridrivna 12″ högtalare på stativ. Upp till 7 timmars batteridrift. Inbyggd mixer och Bluetooth. Handmikrofon ingår."
        specs={["2×12″/2″ aktiva element","1 200 W peak / 600 W RMS","Batteridrift upp till 7 tim","Bluetooth","Vikt: 26,8 kg"]} />
      <ProductCard artno="SK-LJD-POR-0008" name="Portable, Medium Duo" price={1499} persons="60–100 personer"
        image="/images/ljud/pp_ljud_portable_medium_duo.png"
        description="Två Alto TS108 C kolumnhögtalare. 8″ bas och sex 2,75″ diskant. Inbyggd mixer. Smal och snygg design."
        specs={["2×8″ bas + 12×2,75″ element","1 200 W peak / 600 W RMS","Max 124 dB","Bluetooth","Vikt: 32 kg"]} />
      <ProductCard artno="SK-LJD-POR-0009" name="Portable, Medium+ Duo" price={1899} persons="100–200 personer"
        image="/images/ljud/pp_ljud_portable_medium_plus_duo.png"
        description="Två Alto TS112 C kolumnhögtalare. 12″ bas och åtta 2,75″ diskant. Inbyggd mixer."
        specs={["2×12″ bas + 16×2,75″ element","2 400 W peak / 1 200 W RMS","Max 129 dB","Bluetooth","Vikt: 48,2 kg"]} />
      <ProductCard artno="SK-LJD-POR-0011" name="Portable, Large Duo" price={2299} persons="100–240 personer"
        image="/images/ljud/pp_ljud_portable_large_.png"
        description="Två LD Systems Maui 28 G2 kolumner. Fyra 8″ basar och 32 st 3″ diskant."
        specs={["4×8″ bas + 32×3″ diskant","4 000 W peak / 2 000 W RMS","Max 126 dB","Bluetooth","Vikt: 51,4 kg"]} />
    </div>
  </section>

  <!-- MIXERBORD -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-2 border-b border-white/10 pb-3">Mixerbord</h2>
    <p class="text-gray-400 mb-8 text-sm">Koppla in mikrofoner och musikspelare. Mixerbord hyrs separat och ansluts till högtalarpaket.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard artno="SK-LJD-MIX-0001" name="Analogt mixerbord, 2+2 kanaler" price={159} image="/images/ljud/pp_ljud_mixer01.png"
        description="Kompakt Alto-mixer med 2 mic-kanaler och 2 stereokanaler. Inbyggd Bluetooth. Passar till Portable Small/Small+."
        specs={["2 mic/line (XLR + 6,3 mm)","2 stereo (RCA + 6,3 mm)","Bluetooth","Fantommatning 48V","Vikt: 1,4 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0002" name="Analogt mixerbord, 4+2 kanaler" price={199} image="/images/ljud/pp_ljud_mixer02.png"
        description="Alto-mixer med 4 mic-kanaler, 2 stereokanaler, inbyggda effekter och Bluetooth."
        specs={["4 mic/line (XLR + 6,3 mm)","2 stereo (RCA + 6,3 mm)","Inbyggda effekter + Bluetooth","Fantommatning 48V","Vikt: 2 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0003" name="Analogt mixerbord, 4+1 kanaler" price={249} image="/images/ljud/pp_ljud_mixer-vibz8dc.png" description="LD System Vibz8dc med 4 mic-kanaler, 2 stereokanaler och inbyggd kompressor på kanal 1 & 2." specs={["4 mic/line (XLR + 6,3 mm)", "Digital effektprocessor + kompressor", "Fantommatning 48V", "Vikt: 2,3 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0004" name="Analogt mixerbord, 4+4 kanaler" price={299} image="/images/ljud/pp_ljud_mixer03.png"
        description="Mackie-mixer med 4 mic och 4 stereokanaler. 60 dB gain. Levereras i transportväska."
        specs={["4 mic/line (XLR + 6,3 mm)","4 stereo","Preamp 60 dB","Fantommatning 48V","Vikt: 3 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0005" name="Analogt mixerbord, 6+4 kanaler" price={349} image="/images/ljud/pp_ljud_mixer04.png"
        description="Allen & Heath ZED14 – 6 mic och 4 stereokanaler. 69 dB gain. Professionell mixer."
        specs={["6 mic/line (XLR + 6,3 mm)","4 stereo","69 dB preamp gain","Fantommatning 48V","Vikt: 4,3 kg"]} />
    </div>
  </section>

  <!-- MIKROFONER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Mikrofoner &amp; tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {[
        { name:"Högtalarstativ Gravity",        desc:"Max last 30 kg, vikt 3,7 kg",  price:40,  img:"/images/ljud/pp_ljud_stativ-gravity.png" },
        { name:"Högtalarstativ K&M",             desc:"Max last 30 kg, vikt 3,7 kg",  price:50,  img:"/images/ljud/pp_ljud_stativ-km.png" },
        { name:"Högtalarstativ Gravity Premium",  desc:"Max last 50 kg, vikt 6,4 kg",  price:60,  img:"/images/ljud/pp_ljud_stativ-gravity-premium.png" },
        { name:"Högtalarstativ Gravity med vev",  desc:"Max last 50 kg, vikt 9,1 kg",  price:120, img:"/images/ljud/pp_ljud_stativ-gravity-vev.png" },
        { name:"Mikrofonstativ",              desc:"Justerbar höjd",                   price:60,   img:"/images/ljud/pp_ljud_tillbehor06.png" },
        { name:"XLR-kablar",                  desc:"1–15 m, fr 40 kr",                 price:40,   img:"/images/ljud/pp_ljud_tillbehor07.png" },
        { name:"Bluetooth-mottagare",         desc:"Koppla in extra enhet trådlöst",   price:100,   img:"/images/ljud/pp_ljud_tillbehor04.png" },
        { name:"Bluetooth-mottagare pro",      desc:"Längre räckvidd",                  price:140,   img:"/images/ljud/pp_ljud_tillbehor_BT-pro.png" },
        { name:"Instrumentmikrofon",          desc:"För trumma, blås, gitarr",          price:64,   img:"/images/ljud/pp_ljud_mik02.png" },
        { name:"Handmikrofon",                desc:"Inkl 6 m XLR-kabel",               price:80,   img:"/images/ljud/pp_ljud_mik01.png" },
        { name:"Trådlös handmikrofon",        desc:"Ca 30 m räckvidd",                 price:400,  img:"/images/ljud/pp_ljud_mik05.png" },
        { name:"Trådlöst headset",            desc:"Ca 30 m räckvidd",                 price:480,  img:"/images/ljud/pp_ljud_mik06.png" },
        { name:"Shure SLXD – trådlöst system, 1 mik",          desc:"Digitalt, AES-256, 1× SM58-kapsel, ca 100 m",       price:699,  img:"/images/ljud/pp_ljud_mik09.png" },
        { name:"Shure SLXD – trådlöst system, 1 myggmikrofon", desc:"Digitalt, AES-256, 1× bodypack + myggmik, ca 100 m", price:699,  img:"/images/ljud/pp_ljud_mik13.png" },
        { name:"Shure SLXD – trådlöst system, 1 headset",      desc:"Digitalt, AES-256, 1× bodypack + headset, ca 100 m", price:749,  img:"/images/ljud/pp_ljud_mik12.png" },
        { name:"Shure SLXD – trådlöst system, 1 lågprofil headset", desc:"Digitalt, AES-256, 1× bodypack + öronhängande headset, ca 100 m", price:799, img:"/images/ljud/pp_ljud_mik14.png" },
        { name:"Effektrack med matrix & feedback-suppressor",   desc:"5-zon ART-matrix + Klark Teknik DP1000",            price:1036, img:"/images/ljud/pp_ljud_effektrack.png" },
        { name:"Shure SLXD – trådlöst system, 2 mik",          desc:"Digitalt, AES-256, 2× SM58, ca 100 m",              price:1299, img:"/images/ljud/pp_ljud_mik-shure-slxd4d.png" },
        { name:"Shure SLXD – trådlöst system, 2 myggmikrofon", desc:"Digitalt, AES-256, 2× bodypack + myggmik, ca 100 m", price:1299, img:"/images/ljud/pp_ljud_mik10.png" },
        { name:"Shure SLXD – trådlöst system, 2 headset",      desc:"Digitalt, AES-256, 2× bodypack + headset, ca 100 m", price:1399, img:"/images/ljud/pp_ljud_mik08.png" },
        { name:"Shure SLXD – trådlöst system, 2 lågprofil headset", desc:"Digitalt, AES-256, 2× bodypack + öronhängande headset, ca 100 m", price:1499, img:"/images/ljud/pp_ljud_mik11.png" },
        { name:"Trådlöst mikrofonset 8 kan.", desc:"4 hand + 4 headset, antennsplitter", price:3999, img:"/images/ljud/pp_ljud_tillbehor20.png" },
      
      
      
      
      
      
      ].map(item => (
        <ElTillbehorCard img={item.img} name={item.name} excl={item.price} desc={item.desc} category="Ljud tillbehör" artno={artnoByName[item.name]} />
      ))}
    </div>
  </section>

  <!-- EL-TILLBEHÖR -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">El-tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {[
        { img:"/images/ljus/pp_el_grenuttag_sm.png",    name:"Grenuttag 1,5 m",             excl:20,  desc:"Jordat, 3–5 uttag, 16A" },
        { img:"/images/ljus/pp_el_forlangning.png",     name:"Förlängning 10 m",            excl:48,  desc:"1-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_overloppsskydd.png",  name:"Överkörningsskydd 1 m",       excl:80,  desc:"Kabelramp, 2 kanaler" },
        { img:"/images/ljus/pp_el_grenuttag_lg.png",    name:"Grenuttag på rulle 10 m",     excl:100, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_grenuttag_25m.png",   name:"Grenuttag på rulle 25 m",     excl:159, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 16A",       excl:236, desc:"3-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_omvandlare.png",      name:"Strömomvandlare 3-fas→1-fas", excl:320, desc:"32A 3-fas till 1-fas" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 32A",       excl:396, desc:"3-fas, 32A, IP44" },
        { img:"/images/ljud/pp_ljud_tillbehor_elverk-small.png", name:"Elgenerator 2 200 W",       excl:799, desc:"1 900 W kontinuerlig, bensin 4-takt" },
        { img:"/images/ljud/pp_ljud_elverk-kipor.png", name:"Elgenerator 7 700 W",       excl:1799, desc:"7 000 W kontinuerlig, bensin 4-takt. Kipor IG6000." },
      
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} desc={t.desc} category="El-tillbehör" artno={artnoByName[t.name]} />
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex flex-wrap gap-4">
    <a href="/vara-tjanster/hyra-ljud/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">← Tillbaka till hyra ljud</a>
    <a href="/bokningssida/" class="bg-brand-orange hover:bg-brand-orange-light text-white px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Boka nu</a>
    <a href="/kontakt/" class="border border-white/30 text-white hover:bg-white/10 px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Fråga om offert</a>
  </div>
</Layout>
