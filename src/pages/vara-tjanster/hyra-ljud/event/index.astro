---
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import ProductCard from '../../../../components/ProductCard.astro';
import Price from '../../../../components/Price.astro';
import CartButton from '../../../../components/CartButton.astro';
import ElTillbehorCard from '../../../../components/ElTillbehorCard.astro';
import _ljudData from '../../../../data/ljud.json';
const _artnoAliases: Record<string,string> = {
  'XLR Multikabel 15 m, 6 kan.':          'SK-LJD-MIK-0014',
  'XLR Multikabel 25 m, 8 kan.':          'SK-LJD-MIK-0015',
  'XLR Multikabel 15 m, 24+8 kan.':       'SK-LJD-MIK-0020',
  'Instrumentmikrofon, blås':              'SK-LJD-MIK-0008',
  'Instrumentmikrofoner, slagverk':        'SK-LJD-MIK-0019',
  'Shure SLXD – trådlöst system, 2 mik':  'SK-LJD-MIK-0026',
  'Shure SLXD – trådlöst system, 2 myggmikrofon': 'SK-LJD-MIK-0027',
  'XLR-kablar':                            'SK-LJD-MIK-0002',
  'Bluetooth-mottagare pro':               'SK-LJD-MIK-0011',
  'Trådlöst mikrofonset 8 kan.':           'SK-LJD-MIK-0030',
  'Trådlöst IEM':                          'SK-LJD-MIK-0018',
  // El-tillbehör förkortade namn
  'Grenuttag 1,5 m': 'SK-LJD-EL-0001',
  'Förlängning 10 m': 'SK-LJD-EL-0002',
  'Grenuttag på rulle 10 m': 'SK-LJD-EL-0003',
  'Grenuttag på rulle 25 m': 'SK-LJD-EL-0004',
  'Förlängning 3-fas 16A': 'SK-LJD-EL-0005',
  'Förlängning 3-fas 20 m 16A':    'SK-LJD-EL-0005',
  'Förlängning 3-fas 20 m 32A':    'SK-LJD-EL-0006',
  'Förlängning 3-fas 32A': 'SK-LJD-EL-0006',
  'Strömomvandlare 3-fas→1-fas': 'SK-LJD-EL-0007',
  'Strömomvandlare 3-fas>1-fas': 'SK-LJD-EL-0007',
  'Överkörningsskydd 1 m': 'SK-LJD-EL-0008',
  'Elgenerator 2 200 W': 'SK-LJD-EL-0010',
  'Elgenerator 7 700 W': 'SK-LJD-EL-0011',
  'Regnskydd till högtalare': 'SK-LJD-EL-0009',
  'Elgenerator 7700W': 'SK-LJD-EL-0011',
  'Elgenerator, 2200W': 'SK-LJD-EL-0010',
};
const artnoByName: Record<string,string> = {..._artnoAliases, ...Object.fromEntries(
  [...(_ljudData.tillbehor_mikrofon||[]), ...(_ljudData.tillbehor_el||[]), ...(_ljudData.mixers||[])]
    .filter((p:any) => p.artno)
    .map((p:any) => [p.name, p.artno])
)};
---
<Layout
  title="Hyra PA-system för Event & Konferens Stockholm | Scenkonsult"
  description="Hyr PA-system för konferenser, galor och presentationer i Stockholm från 799 kr/dygn. Plug & play med fullrange högtalarenheter på stativ – ingen tekniker krävs. Leverans i hela Storstockholm."
>

  <CategoryHero
    h1="Ljud för Event & Konferens"
    h1Accent="Stockholm"
    intro="Hyr PA-system för konferens, gala och företagsevent i Stockholm. Plug & play-paket med fullrange högtalarenheter på stativ – ingen tekniker krävs. Komplettera med mixerbord, trådlösa mikrofoner och el-tillbehör nedan."
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Hyra ljud", href: "/vara-tjanster/hyra-ljud/" },
      { label: "Event & Konferens" }
    ]}
    badges={[
      "Plug & play",
      "Mikrofoner & mixer hyrs separat",
      "Ingen tekniker krävs",
      "Leverans i Storstockholm",
    ]}
    priceFrom={799}
  />

  <!-- PAKET -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard artno="SK-LJD-EVE-0001" name="Event, Small" price={799} persons="Upp till 100 personer"
        image="/images/ljud/pp_ljud_event_small.png"
        description="Passar för tal, sång och bakgrundsmusik för grupper upp till 100 personer. Två kompakta Alto 10″ fullrange högtalarenheter på stativ. Kopplas in i vanliga eluttag. Montering 10–15 min."
        specs={["10″/1,4″ aktiva element","2 000 W peak / 1 000 W RMS","Max 130 dB","48–20 000 Hz","Samlad vikt: 25 kg"]} />
      <ProductCard artno="SK-LJD-EVE-0003" name="Event, Medium" price={1199} persons="Upp till 180 personer"
        image="/images/ljud/pp_ljud-event_medium.png"
        description="Två Alto 12″ fullrange högtalarenheter på stativ. Kraftfullare bas och räckvidd än 10″-systemet. Montering 10–15 min."
        specs={["12″/1,4″ aktiva element","2 500 W peak / 1 250 W RMS","Max 130 dB","48–20 000 Hz","Samlad vikt: 34 kg"]} />
      <ProductCard artno="SK-LJD-EVE-0002" name="Event, Small+" price={1599} persons="Upp till 240 personer"
        image="/images/ljud/pp_ljud_event_small_.png"
        description="Fyra Alto 10″ fullrange högtalarenheter för upp till 240 personer. Bredare ljudbild med fyra enheter. Montering 20–25 min."
        specs={["10″/1,4″ aktiva element","2 000 W peak / 1 000 W RMS","Max 130 dB","48–20 000 Hz","Samlad vikt: 54 kg"]} />
      <ProductCard artno="SK-LJD-EVE-0005" name="Event, Large" price={1599} persons="Upp till 280 personer"
        image="/images/ljud/pp_ljud_event_large2.png"
        description="Två Alto 15″ fullrange högtalarenheter på stativ för upp till 280 personer. Kraftfullt och tydligt ljud. Montering 10–15 min."
        specs={["15″/1,4″ aktiva element","2 500 W peak / 1 250 W RMS","Max 130 dB","48–20 000 Hz","Samlad vikt: 39 kg"]} />
      <ProductCard artno="SK-LJD-EVE-0004" name="Event, Medium+" price={2399} persons="Upp till 380 personer"
        image="/images/ljud/pp_ljud_event_medium-.png"
        description="Fyra Alto 12″ fullrange högtalarenheter för upp till 380 personer. Montering 20–25 min."
        specs={["12″/1,4″ aktiva element","2 500 W peak / 1 250 W RMS","Max 130 dB","62–20 000 Hz","Samlad vikt: 62 kg"]} />
      <ProductCard artno="SK-LJD-EVE-0006" name="Event, Large+" price={3199} persons="Upp till 560 personer"
        image="/images/ljud/pp_ljud_event_large_.png"
        description="Fyra Alto 15″ fullrange högtalarenheter för upp till 560 personer. Montering 20–25 min."
        specs={["15″/1,4″ aktiva element","2 500 W peak / 1 250 W RMS","Max 130 dB","48–20 000 Hz","Samlad vikt: 78 kg"]} />
    </div>
  </section>

  <!-- MIXERBORD -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-2 border-b border-white/10 pb-3">Mixerbord</h2>
    <p class="text-gray-400 mb-8 text-sm">Koppla in mikrofoner och musikspelare. Mixerbord hyrs separat och ansluts till högtalarpaket.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard artno="SK-LJD-MIX-0001" name="Analogt mixerbord, 2+2 kanaler" price={159} image="/images/ljud/pp_ljud_mixer01.png" description="Kompakt Alto-mixer med 2 mic-kanaler och 2 stereokanaler. Inbyggd Bluetooth. Passar till Event Small/Small+." specs={["2 mic/line (XLR + 6,3 mm)","2 stereo (RCA + 6,3 mm)","Bluetooth","Fantommatning 48V","Vikt: 1,4 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0002" name="Analogt mixerbord, 4+2 kanaler" price={199} image="/images/ljud/pp_ljud_mixer02.png" description="Alto-mixer med 4 mic-kanaler, 2 stereokanaler, inbyggda effekter och Bluetooth." specs={["4 mic/line (XLR + 6,3 mm)","2 stereo (RCA + 6,3 mm)","Inbyggda effekter + Bluetooth","Fantommatning 48V","Vikt: 2 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0003" name="Analogt mixerbord, 4+1 kanaler" price={249} image="/images/ljud/pp_ljud_mixer-vibz8dc.png" description="LD System Vibz8dc med 4 mic-kanaler, 2 stereokanaler och inbyggd kompressor på kanal 1 & 2." specs={["4 mic/line (XLR + 6,3 mm)", "Digital effektprocessor + kompressor", "Fantommatning 48V", "Vikt: 2,3 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0004" name="Analogt mixerbord, 4+4 kanaler" price={299} image="/images/ljud/pp_ljud_mixer03.png" description="Mackie-mixer med 4 mic och 4 stereokanaler. 60 dB gain. Levereras i transportväska." specs={["4 mic/line (XLR + 6,3 mm)","4 stereo","Preamp 60 dB","Fantommatning 48V","Vikt: 3 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0005" name="Analogt mixerbord, 6+4 kanaler" price={349} image="/images/ljud/pp_ljud_mixer04.png" description="Allen & Heath ZED14 – 6 mic och 4 stereokanaler. 69 dB gain. Professionell mixer." specs={["6 mic/line (XLR + 6,3 mm)","4 stereo","69 dB preamp gain","Fantommatning 48V","Vikt: 4,3 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0006" name="Analogt mixerbord, 12+4 kanaler" price={399} image="/images/ljud/pp_ljud_mixer05.png" description="Alto Live L16 med 12 mic-kanaler, 4 stereokanaler och 256 inbyggda effekter." specs={["12 mic/line (XLR)","4 stereo","24-bit DSP, 256 effekter","Fantommatning 48V","Vikt: 6,8 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0007" name="Analogt mixerbord, 16+3 kanaler" price={599} image="/images/ljud/pp_ljud_mixer06.png" description="Allen & Heath ZED22FX – 16 mic, 3 stereo, USB och high-pass filter. Toppmixer för live." specs={["16 mic/line (XLR)","3 stereo","USB-anslutning","High-pass filter per kanal","Vikt: 9 kg"]} />
    </div>
  </section>

  <!-- MIKROFONER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Mikrofoner &amp; tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3">
      {[
        { name:"Högtalarstativ Gravity",        desc:"Max last 30 kg, vikt 3,7 kg",  price:40,  img:"/images/ljud/pp_ljud_stativ-gravity.png" },
        { name:"Högtalarstativ K&M",             desc:"Max last 30 kg, vikt 3,7 kg",  price:50,  img:"/images/ljud/pp_ljud_stativ-km.png" },
        { name:"Högtalarstativ Gravity Premium",  desc:"Max last 50 kg, vikt 6,4 kg",  price:60,  img:"/images/ljud/pp_ljud_stativ-gravity-premium.png" },
        { name:"Högtalarstativ Gravity med vev",  desc:"Max last 50 kg, vikt 9,1 kg",  price:120, img:"/images/ljud/pp_ljud_stativ-gravity-vev.png" },
        { name:"Mikrofonstativ",              desc:"Justerbar höjd",                   price:60,   img:"/images/ljud/pp_ljud_tillbehor06.png" },
        { name:"XLR-kablar",                  desc:"1–15 m, fr 40 kr",                 price:40,   img:"/images/ljud/pp_ljud_tillbehor07.png" },
        { name:"Bluetooth-mottagare",         desc:"Koppla in telefon/dator trådlöst", price:100,   img:"/images/ljud/pp_ljud_tillbehor04.png" },
        { name:"Bluetooth-mottagare pro",      desc:"Längre räckvidd",                 price:140,   img:"/images/ljud/pp_ljud_tillbehor_BT-pro.png" },
        { name:"Instrumentmikrofon",          desc:"För trumma, blås, gitarr",          price:64,   img:"/images/ljud/pp_ljud_mik02.png" },
        { name:"Handmikrofon",                desc:"Inkl 6 m XLR-kabel",               price:80,   img:"/images/ljud/pp_ljud_mik01.png" },
        { name:"Trådlös handmikrofon",        desc:"Ca 30 m räckvidd",                 price:400,  img:"/images/ljud/pp_ljud_mik05.png" },
        { name:"Trådlöst headset",            desc:"Ca 30 m räckvidd",                 price:480,  img:"/images/ljud/pp_ljud_mik06.png" },
        { name:"Shure SLXD – trådlöst system, 1 mik",          desc:"Digitalt, AES-256, 1× SM58-kapsel, ca 100 m",       price:699,  img:"/images/ljud/pp_ljud_mik09.png" },
        { name:"Shure SLXD – trådlöst system, 1 myggmikrofon", desc:"Digitalt, AES-256, 1× bodypack + myggmik, ca 100 m", price:699,  img:"/images/ljud/pp_ljud_mik13.png" },
        { name:"Shure SLXD – trådlöst system, 1 headset",      desc:"Digitalt, AES-256, 1× bodypack + headset, ca 100 m", price:749,  img:"/images/ljud/pp_ljud_mik12.png" },
        { name:"Shure SLXD – trådlöst system, 1 lågprofil headset", desc:"Digitalt, AES-256, 1× bodypack + öronhängande headset, ca 100 m", price:799, img:"/images/ljud/pp_ljud_mik14.png" },
        { name:"Effektrack med matrix & feedback-suppressor",   desc:"5-zon ART-matrix + Klark Teknik DP1000",            price:1036, img:"/images/ljud/pp_ljud_effektrack.png" },
        { name:"Shure SLXD – trådlöst system, 2 mik",          desc:"Digitalt, AES-256, 2× SM58, ca 100 m",              price:1299, img:"/images/ljud/pp_ljud_mik-shure-slxd4d.png" },
        { name:"Shure SLXD – trådlöst system, 2 myggmikrofon", desc:"Digitalt, AES-256, 2× bodypack + myggmik, ca 100 m", price:1299, img:"/images/ljud/pp_ljud_mik10.png" },
        { name:"Shure SLXD – trådlöst system, 2 headset",      desc:"Digitalt, AES-256, 2× bodypack + headset, ca 100 m", price:1399, img:"/images/ljud/pp_ljud_mik08.png" },
        { name:"Shure SLXD – trådlöst system, 2 lågprofil headset", desc:"Digitalt, AES-256, 2× bodypack + öronhängande headset, ca 100 m", price:1499, img:"/images/ljud/pp_ljud_mik11.png" },
        { name:"Trådlöst mikrofonset 8 kan.", desc:"4 hand + 4 headset, antennsplitter", price:3999, img:"/images/ljud/pp_ljud_tillbehor20.png" },
      
      
      
      
      
      
      ].map(item => (
        <div class="bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-xl p-4 flex flex-col gap-2 transition-colors">
          <div class="bg-brand-dark overflow-hidden rounded-lg" style="aspect-ratio:1024/853">
            <img src={item.img} alt={item.name} width="200" height="200" loading="lazy" class="max-h-full max-w-full object-contain p-1" />
          </div>
          <p class="text-white font-semibold text-sm">{item.name}</p>
          {artnoByName[item.name] && <p class="artno-badge">{artnoByName[item.name]}</p>}
          <p class="text-gray-400 text-xs flex-1">{item.desc}</p>
          <div class="border-t border-white/10 pt-2 flex items-center justify-between gap-1 mt-auto">
            <span class="text-brand-orange font-bold text-sm"><Price amount={item.price} size="sm" /></span>
            <CartButton id={`event-mik-${item.name.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`} name={item.name} price={item.price} category="Ljud tillbehör" image={item.img} size="sm" iconOnly={true} />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- EL-TILLBEHÖR -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">El-tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-2">
      {[
        { img:"/images/ljus/pp_el_grenuttag_sm.png",    name:"Grenuttag 1,5 m",             excl:20,  desc:"Jordat, 3–5 uttag, 16A" },
        { img:"/images/ljus/pp_el_forlangning.png",     name:"Förlängning 10 m",            excl:48,  desc:"1-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_overloppsskydd.png",  name:"Överkörningsskydd 1 m",       excl:80,  desc:"Kabelramp, 2 kanaler" },
        { img:"/images/ljus/pp_el_grenuttag_lg.png",    name:"Grenuttag på rulle 10 m",     excl:100, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_grenuttag_25m.png",   name:"Grenuttag på rulle 25 m",     excl:159, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 20 m 16A",  excl:236, desc:"3-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_omvandlare.png",      name:"Strömomvandlare 3-fas→1-fas", excl:320, desc:"32A 3-fas till 1-fas uttag" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 20 m 32A",  excl:396, desc:"3-fas, 32A, IP44" },
        { img:"/images/ljud/pp_ljud_tillbehor_elverk-small.png", name:"Elgenerator 2 200 W",       excl:799, desc:"1 900 W kontinuerlig, bensin 4-takt" },
        { img:"/images/ljud/pp_ljud_elverk-kipor.png", name:"Elgenerator 7 700 W",       excl:1799, desc:"7 000 W kontinuerlig, bensin 4-takt. Kipor IG6000." },
      
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} desc={t.desc} category="El-tillbehör" artno={artnoByName[t.name]} />
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex flex-wrap gap-4">
    <a href="/vara-tjanster/hyra-ljud/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">← Tillbaka till hyra ljud</a>
    <a href="/bokningssida/" class="bg-brand-orange hover:bg-brand-orange-light text-white px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Boka nu</a>
    <a href="/kontakt/" class="border border-white/30 text-white hover:bg-white/10 px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Fråga om offert</a>
  </div>
</Layout>
