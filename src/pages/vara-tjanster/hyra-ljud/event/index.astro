---
import Layout from '../../../../layouts/Layout.astro';
import ProductCard from '../../../../components/ProductCard.astro';
---
<Layout
  title="Hyra PA-system för Event & Konferens Stockholm | Scenkonsult"
  description="Hyr PA-system för konferenser, galor och presentationer i Stockholm från 799 kr/dygn. Trådlösa mikrofoner och mixer. Snabb leverans i hela Storstockholm."
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2 text-sm text-gray-400">
    <a href="/" class="hover:text-gray-300">Hem</a> <span class="mx-1">/</span>
    <a href="/vara-tjanster/hyra-ljud/" class="hover:text-gray-300">Hyra ljud</a> <span class="mx-1">/</span>
    <span class="text-white">Event & Konferens</span>
  </nav>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4 pb-4">
    <img src="/images/ljud/plugg_event.png" alt="Ljud för event" width="2560" height="450" loading="eager" class="w-full rounded-2xl object-cover h-48" />
  </div>

  <header class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">Ljud för Event &amp; Konferens i <span class="text-brand-orange">Stockholm</span></h1>
    <p class="text-gray-300 text-lg max-w-3xl">Hyr PA-system för konferenser, galor och presentationer. Alla paket inkluderar högtalarenheter på stativ och kopplas in i vanliga eluttag – ingen tekniker behövs. Komplettera med mixerbord och mikrofoner nedan.</p>
  </header>

  <!-- PAKET -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard name="Event, Small" price={799} persons="Upp till 100 personer"
        image="/images/ljud/pp_ljud_event_small.png"
        description="Passar för tal, sång och bakgrundsmusik för grupper upp till 100 personer. Två kompakta Alto 10″ fullrange högtalarenheter på stativ. Kopplas in i vanliga eluttag. Montering 10–15 min."
        specs={["10″/1,4″ aktiva element","2 000 W peak / 1 000 W RMS","Max 130 dB","48–20 000 Hz","Samlad vikt: 25 kg"]} />
      <ProductCard name="Event, Small+" price={1199} persons="Upp till 180 personer"
        image="/images/ljud/pp_ljud_event_small-.png"
        description="Passar för tal, sång och bakgrundsmusik upp till 180 personer. Två Alto 12″ fullrange högtalarenheter på stativ. Montering 10–15 min."
        specs={["12″/1,4″ aktiva element","2 500 W peak / 1 250 W RMS","Max 130 dB","48–20 000 Hz","Samlad vikt: 34 kg"]} />
      <ProductCard name="Event, Medium" price={1599} persons="Upp till 240 personer"
        image="/images/ljud/pp_ljud_event_medium.png"
        description="Fyra Alto 10″ fullrange högtalarenheter för upp till 240 personer. Bredare ljudbild med fyra enheter. Montering 20–25 min."
        specs={["10″/1,4″ aktiva element","2 000 W peak / 1 000 W RMS","Max 130 dB","48–20 000 Hz","Samlad vikt: 54 kg"]} />
      <ProductCard name="Event, Medium+" price={2299} persons="Upp till 380 personer"
        image="/images/ljud/pp_ljud_event_medium-.png"
        description="Fyra Alto 12″ fullrange högtalarenheter för upp till 380 personer. Montering 20–25 min."
        specs={["12″/1,4″ aktiva element","2 500 W peak / 1 250 W RMS","Max 130 dB","62–20 000 Hz","Samlad vikt: 62 kg"]} />
      <ProductCard name="Event, Large" price={3199} persons="Upp till 560 personer"
        image="/images/ljud/pp_ljud_event_large.png"
        description="Fyra Alto 15″ fullrange högtalarenheter för upp till 560 personer. Montering 20–25 min."
        specs={["15″/1,4″ aktiva element","2 500 W peak / 1 250 W RMS","Max 130 dB","48–20 000 Hz","Samlad vikt: 78 kg"]} />
    </div>
  </section>

  <!-- MIXERBORD -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-2 border-b border-white/10 pb-3">Mixerbord</h2>
    <p class="text-gray-400 mb-8 text-sm">Koppla in mikrofoner och musikspelare. Mixerbord hyrs separat och ansluts till högtalarpaket.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard name="Analogt mixerbord, 2+2 kanaler" price={159}
        image="/images/ljud/pp_ljud_mixer01.png"
        description="Kompakt Alto-mixer med 2 mic-kanaler och 2 stereokanaler. Inbyggd Bluetooth. Passar till Event Small/Small+."
        specs={["2 mic/line (XLR + 6,3 mm)","2 stereo (RCA + 6,3 mm)","Bluetooth","Fantommatning 48V","Vikt: 1,4 kg"]} />
      <ProductCard name="Analogt mixerbord, 4+2 kanaler" price={199}
        image="/images/ljud/pp_ljud_mixer02.png"
        description="Alto-mixer med 4 mic-kanaler, 2 stereokanaler, inbyggda effekter och Bluetooth."
        specs={["4 mic/line (XLR + 6,3 mm)","2 stereo (RCA + 6,3 mm)","Inbyggda effekter + Bluetooth","Fantommatning 48V","Vikt: 2 kg"]} />
      <ProductCard name="Analogt mixerbord, 4+4 kanaler" price={299}
        image="/images/ljud/pp_ljud_mixer03.png"
        description="Mackie-mixer med 4 mic och 4 stereokanaler. 60 dB gain. Levereras i transportväska."
        specs={["4 mic/line (XLR + 6,3 mm)","4 stereo","Preamp 60 dB","Fantommatning 48V","Vikt: 3 kg"]} />
      <ProductCard name="Analogt mixerbord, 6+4 kanaler" price={349}
        image="/images/ljud/pp_ljud_mixer04.png"
        description="Allen & Heath ZED14 – 6 mic och 4 stereokanaler. 69 dB gain. Professionell mixer."
        specs={["6 mic/line (XLR + 6,3 mm)","4 stereo","69 dB preamp gain","Fantommatning 48V","Vikt: 4,3 kg"]} />
      <ProductCard name="Analogt mixerbord, 12+4 kanaler" price={399}
        image="/images/ljud/pp_ljud_mixer05.png"
        description="Alto Live L16 med 12 mic-kanaler, 4 stereokanaler och 256 inbyggda effekter."
        specs={["12 mic/line (XLR)","4 stereo","24-bit DSP, 256 effekter","Fantommatning 48V","Vikt: 6,8 kg"]} />
      <ProductCard name="Analogt mixerbord, 16+3 kanaler" price={599}
        image="/images/ljud/pp_ljud_mixer06.png"
        description="Allen & Heath ZED22FX – 16 mic, 3 stereo, USB och high-pass filter. Toppmixer för live."
        specs={["16 mic/line (XLR)","3 stereo","USB-anslutning","High-pass filter per kanal","Vikt: 9 kg"]} />

    </div>
  </section>

  <!-- MIKROFONER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Mikrofoner &amp; tillbehör</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      {[
        { name:"Handmikrofon", desc:"Inkl 6 m XLR-kabel", price:80, img:"/images/ljud/pp_ljud_mik01.png" },
        { name:"Instrumentmikrofon", desc:"För trumma, blås, gitarr", price:120, img:"/images/ljud/pp_ljud_mik02.png" },
        { name:"Trådlös handmikrofon", desc:"Ca 30 m räckvidd", price:400, img:"/images/ljud/pp_ljud_mik05.png" },
        { name:"Trådlöst headset", desc:"Ca 30 m räckvidd", price:480, img:"/images/ljud/pp_ljud_mik06.png" },
        { name:"Trådlöst mikrofonset, 8 kan.", desc:"4 hand + 4 headset, antennsplitter", price:2999, img:"/images/ljud/pp_ljud_mik04.png" },
        { name:"Mikrofonstativ", desc:"Justerbar höjd", price:60, img:"/images/ljud/pp_ljud_tillbehor06.png" },
        { name:"XLR-kablar", desc:"1–15 m, fr 40 kr", price:40, img:"/images/ljud/pp_ljud_tillbehor07.png" },
        { name:"Bluetooth-mottagare", desc:"Koppla in telefon/dator trådlöst", price:80, img:"/images/ljud/pp_ljud_tillbehor04.png" },
      ].map(item => (
        <div class="bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-xl p-4 flex flex-col gap-2 transition-colors">
          <div class="aspect-square bg-brand-dark rounded-lg overflow-hidden">
            <img src={item.img} alt={item.name} width="200" height="200" loading="lazy" class="w-full h-full object-contain p-1" />
          </div>
          <p class="text-white font-semibold text-sm">{item.name}</p>
          <p class="text-gray-400 text-xs flex-1">{item.desc}</p>
          <p class="text-brand-orange font-bold text-sm border-t border-white/10 pt-2">{item.price} kr <span class="text-gray-400 font-normal">/dygn</span></p>
        </div>
      ))}
    </div>
  </section>


  <!-- EL-TILLBEHÖR -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">El-tillbehör</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      {[
        { img:"/images/ljus/pp_el_grenuttag_sm.png",    name:"Grenuttag 1,5 m",             excl:20,  desc:"Jordat, 3–5 uttag, 16A" },
        { img:"/images/ljus/pp_el_forlangning.png",     name:"Förlängning 10 m",            excl:48,  desc:"1-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_grenuttag_lg.png",    name:"Grenuttag på rulle 10 m",     excl:100, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_grenuttag_25m.png",   name:"Grenuttag på rulle 25 m",     excl:159, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 20 m 16A",  excl:236, desc:"3-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 20 m 32A",  excl:396, desc:"3-fas, 32A, IP44" },
        { img:"/images/ljus/pp_el_omvandlare.png",      name:"Strömomvandlare 3-fas→1-fas", excl:320, desc:"32A 3-fas till 1-fas uttag" },
        { img:"/images/ljus/pp_el_overloppsskydd.png",  name:"Överkörningsskydd 1 m",       excl:80,  desc:"Kabelramp, 2 kanaler" },
      ].map(t => (
        <div class="bg-brand-navy/60 border border-white/10 rounded-xl p-2 text-center">
          <div style="aspect-ratio:300/250" class="bg-brand-dark rounded overflow-hidden mb-1">
            <img src={t.img} alt={t.name} width="150" height="125" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <p class="text-white text-[10px] font-semibold leading-tight mb-0.5">{t.name}</p>
          <p class="text-gray-400 text-[9px] leading-tight mb-0.5">{t.desc}</p>
          <span class="sk-price-incl text-brand-orange text-xs font-bold">{Math.round(t.excl*1.25)} kr</span>
          <span class="sk-price-excl hidden text-brand-orange text-xs font-bold">{t.excl} kr</span>
          <span class="text-gray-400 text-[9px]">/dygn</span>
        </div>
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex flex-wrap gap-4">
    <a href="/vara-tjanster/hyra-ljud/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">← Tillbaka till hyra ljud</a>
    <a href="/bokningssida/" class="bg-brand-orange hover:bg-orange-500 text-white px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Boka nu</a>
    <a href="/kontakt/" class="border border-white/30 text-white hover:bg-white/10 px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Fråga om offert</a>
  </div>
</Layout>
