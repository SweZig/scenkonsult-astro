---
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import ProductCard from '../../../../components/ProductCard.astro';
import Price from '../../../../components/Price.astro';
import CartButton from '../../../../components/CartButton.astro';
import ElTillbehorCard from '../../../../components/ElTillbehorCard.astro';
---
<Layout
  title="Hyra Liveljud Stockholm – PA-system för Konsert & Trubadur | Scenkonsult"
  description="Hyr liveljud för konserter, trubadurer och liveband i Stockholm från 599 kr/dygn. Sub-basar och fullrange paket för 20–1 500 personer. Leverans i hela Storstockholm."
>

  <CategoryHero
    h1="Liveljud & Konsert"
    h1Accent="Stockholm"
    intro="Hyr liveljud för konsert, trubadur och liveband i Stockholm. Kraftfulla sub-basar och fullrange högtalarpaket för 20–1 500 personer. Komplettera med mixerbord, mikrofoner och monitorhögtalare nedan."
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Hyra ljud", href: "/vara-tjanster/hyra-ljud/" },
      { label: "Live & Konsert" }
    ]}
    badges={[
      "Sub-basar & line array",
      "20–1 500 personer",
      "Monitorhögtalare",
      "Leverans i Storstockholm",
    ]}
    priceFrom={599}
  />

  <!-- PAKET -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard name="Live, Small" price={599} persons="20–60 personer"
        image="/images/ljud/pp_ljud_live_small.png"
        description="Passar för trubadur för grupper 20–60 personer. Två Alto 12″ högtalarenheter med inbyggd mixer. Enkel montering 15–20 min."
        specs={["12″/2″ fullrange aktiva element","720 W peak / 360 W RMS","Max 120 dB","60–20 000 Hz","2 inputs (XLR)","8-bands EQ","Samlad vikt: 58 kg"]} />
      <ProductCard name="Live, Medium" price={1199} persons="60–100 personer"
        image="/images/ljud/pp_ljud_live_medium.png"
        description="Trubadur eller DJ för 60–100 personer. Två Alto 15S sub-basar och två Alto 12″ fullrange. Bra tryck i hela registret. Montering 15–20 min."
        specs={["15″ sub-bas + 12″/2″ fullrange","2 000 W peak / 1 080 W RMS","Max 130 dB","45–20 000 Hz","230V, min 2 faser","Samlad vikt: 105 kg"]} />
      <ProductCard name="Live, Large" price={1599} persons="120–200 personer"
        image="/images/ljud/pp_ljud_live_large.png"
        description="Trubadur eller liveband för 120–200 personer. Fyra Alto 15S sub-basar och två Alto 15″ fullrange. Dubbla sub-basar på varje sida. Montering 20–25 min."
        specs={["4×15″ sub + 2×15″ fullrange","3 600 W peak / 1 800 W RMS","Max 120 dB","60–20 000 Hz","230V","Samlad vikt: 140 kg"]} />
      <ProductCard name="Live/Music, XL" price={2299} persons="180–350 personer"
        image="/images/ljud/pp_ljud_music_xl.png"
        description="Trubadur eller DJ för 180–350 personer. Två 15″ fullrange och två 18″ sub-basar."
        specs={["15″/1,4″ + 18″ sub","2 000 W peak / 1 000 W RMS","Max 132 dB","29–20 000 Hz","230V, min 2 faser","Samlad vikt: 120 kg"]} />
      <ProductCard name="Live/Music, XL+" price={2999} persons="250–600 personer"
        image="/images/ljud/pp_ljud_music_xl-.png"
        description="DJ för 250–600 personer. Två 15″ fullrange, en 15″ sub och en 18″ sub."
        specs={["15″/1,4″ + 15″/18″ sub","8 000 W peak / 2 000 W RMS","Max 132 dB","29–20 000 Hz","Samlad vikt: 200 kg"]} />
      <ProductCard name="Live/Music, XXL" price={4999} persons="500–1 500 personer"
        image="/images/ljud/pp_ljud_music_xxl.png"
        description="DJ för 500–1 500 personer. Fyra 15″ fullrange och fyra 18″ sub-basar."
        specs={["4×15″/1,4″ + 4×18″ sub","10 000 W peak / 2 800 W RMS","Max 132 dB","29–20 000 Hz","Samlad vikt: 320 kg"]} />
      <ProductCard name="Live/Music, Concert" price={6999} persons="500–1 500 personer"
        image="/images/ljud/pp_ljud_music_concert.png"
        description="Konsert för liveband eller DJ. Två 12″ fullrange och fyra 18″ sub-basar. Varje stack 2,3 m hög."
        specs={["2×12″/1,4″ + 4×18″ sub","10 800 W peak / 2 700 W RMS","Max 135 dB","37–17 000 Hz","Samlad vikt: 360 kg"]} />
    </div>
  </section>

  <!-- MIXERBORD -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-2 border-b border-white/10 pb-3">Mixerbord</h2>
    <p class="text-gray-400 mb-8 text-sm">Alla mixers på event-sidan finns att hyra. Live-sidan erbjuder dessutom dessa större modeller:</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard name="Analogt mixerbord, 2+2 kanaler" price={159} image="/images/ljud/pp_ljud_mixer01.png" description="Kompakt Alto-mixer, 2 mic + 2 stereo, Bluetooth." specs={["2 mic/line (XLR + 6,3 mm)","2 stereo","Bluetooth","Fantommatning 48V","Vikt: 1,4 kg"]} />
      <ProductCard name="Analogt mixerbord, 4+2 kanaler" price={199} image="/images/ljud/pp_ljud_mixer02.png" description="Alto-mixer 4 mic + 2 stereo, effekter och Bluetooth." specs={["4 mic/line","2 stereo","Inbyggda effekter + Bluetooth","Fantommatning 48V"]} />
      <ProductCard name="Analogt mixerbord, 4+4 kanaler" price={299} image="/images/ljud/pp_ljud_mixer03.png" description="Mackie-mixer 4 mic + 4 stereo. 60 dB gain." specs={["4 mic/line","4 stereo","60 dB preamp","Fantommatning 48V"]} />
      <ProductCard name="Analogt mixerbord, 6+4 kanaler" price={349} image="/images/ljud/pp_ljud_mixer04.png" description="Allen & Heath ZED14 – 6 mic + 4 stereo, 69 dB." specs={["6 mic/line","4 stereo","69 dB preamp","Fantommatning 48V"]} />
      <ProductCard name="Analogt mixerbord, 12+4 kanaler" price={399} image="/images/ljud/pp_ljud_mixer05.png" description="Alto Live L16 – 12 mic + 4 stereo, 256 effekter." specs={["12 mic/line","4 stereo","256 inbyggda effekter"]} />
      <ProductCard name="Analogt mixerbord, 16+3 kanaler" price={599} image="/images/ljud/pp_ljud_mixer06.png" description="Allen & Heath ZED22FX – 16 mic + 3 stereo, USB." specs={["16 mic/line","3 stereo","USB","High-pass filter per kanal"]} />
    </div>
  </section>

  <!-- MIKROFONER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Mikrofoner &amp; tillbehör</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      {[
        { name:"Handmikrofon",                    desc:"Inkl 6 m XLR-kabel",                 price:80,   img:"/images/ljud/pp_ljud_mik01.png" },
        { name:"Instrumentmikrofon",              desc:"Gitarr, blås m.m., inkl XLR",        price:64,   img:"/images/ljud/pp_ljud_mik02.png" },
        { name:"Instrumentmikrofon, blås",        desc:"Blåsinstrument, inkl XLR",           price:80,   img:"/images/ljud/pp_ljud_mik02.png" },
        { name:"Instrumentmikrofoner, slagverk",  desc:"Trumset, inkl XLR-kablar",           price:480,  img:"/images/ljud/pp_ljud_mik03.png" },
        { name:"Trådlös handmikrofon",            desc:"Ca 30 m räckvidd",                   price:400,  img:"/images/ljud/pp_ljud_mik05.png" },
        { name:"Trådlöst headset",                desc:"Ca 30 m räckvidd",                   price:480,  img:"/images/ljud/pp_ljud_mik06.png" },
        { name:"Trådlöst IEM",                    desc:"In-ear monitor, ca 30 m",            price:480,  img:"/images/ljud/pp_ljud_mik06.png" },
        { name:"Trådlöst mikrofonset 8 kan.",     desc:"4 hand + 4 headset, antennsplitter", price:2999, img:"/images/ljud/pp_ljud_mik04.png" },
        { name:"DI-box (passiv)",                 desc:"2-kan, XLR ut / 6,35 mm in",         price:160,  img:"/images/ljud/pp_ljud_dibox.png" },
        { name:"DI-box (aktiv)",                  desc:"1-kan, XLR ut / 6,35 mm in, 9V",    price:240,  img:"/images/ljud/pp_ljud_dibox.png" },
        { name:"Mikrofonstativ",                  desc:"Justerbar höjd",                     price:60,   img:"/images/ljud/pp_ljud_tillbehor06.png" },
        { name:"XLR-kablar",                      desc:"1–15 m, fr 40 kr",                  price:40,   img:"/images/ljud/pp_ljud_tillbehor07.png" },
        { name:"XLR Multikabel 15 m, 6 kan.",    desc:"Stagebox, 6 kanaler",                price:276,  img:"/images/ljud/pp_ljud_tillbehor08.png" },
        { name:"XLR Multikabel 25 m, 8 kan.",    desc:"Stagebox, 8 kanaler",                price:384,  img:"/images/ljud/pp_ljud_tillbehor08.png" },
        { name:"XLR Multikabel 15 m, 24+8 kan.", desc:"Stagebox stor, 24+8 kanaler",        price:632,  img:"/images/ljud/pp_ljud_tillbehor08.png" },
        { name:"Bluetooth-mottagare",             desc:"Trådlös anslutning till PA",         price:100,  img:"/images/ljud/pp_ljud_tillbehor04.png" },
        { name:"Bluetooth-mottagare pro",         desc:"Längre räckvidd",                    price:140,  img:"/images/ljud/pp_ljud_tillbehor04.png" },
        { name:"Monitorhögtalare 12″",           desc:"Scen-monitor för artister",           price:199,  img:"/images/ljud/pp_ljud_tillbehor10.png" },
      ].map(item => (
        <div class="bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-xl p-4 flex flex-col gap-2 transition-colors">
          <div class="aspect-square bg-brand-dark rounded-lg overflow-hidden">
            <img src={item.img} alt={item.name} width="200" height="200" loading="lazy" class="w-full h-full object-contain p-1" />
          </div>
          <p class="text-white font-semibold text-sm">{item.name}</p>
          <p class="text-gray-400 text-xs flex-1">{item.desc}</p>
          <div class="border-t border-white/10 pt-2 flex items-center justify-between gap-1 mt-auto">
            <span class="text-brand-orange font-bold text-sm"><Price amount={item.price} size="sm" /></span>
            <CartButton id={`live-mik-${item.name.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`} name={item.name} price={item.price} category="Ljud tillbehör" image={item.img} size="sm" iconOnly={true} />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- EL-TILLBEHÖR -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">El-tillbehör</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3">
      {[
        { img:"/images/ljus/pp_el_grenuttag_sm.png",    name:"Grenuttag 1,5 m",             excl:20,  desc:"Jordat, 3–5 uttag, 16A" },
        { img:"/images/ljus/pp_el_forlangning.png",     name:"Förlängning 10 m",            excl:48,  desc:"1-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_grenuttag_lg.png",    name:"Grenuttag på rulle 10 m",     excl:100, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_grenuttag_25m.png",   name:"Grenuttag på rulle 25 m",     excl:159, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 20 m 16A",  excl:236, desc:"3-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 20 m 32A",  excl:396, desc:"3-fas, 32A, IP44" },
        { img:"/images/ljus/pp_el_omvandlare.png",      name:"Strömomvandlare 3-fas→1-fas", excl:320, desc:"32A 3-fas till 1-fas uttag" },
        { img:"/images/ljus/pp_el_overloppsskydd.png",  name:"Överkörningsskydd 1 m",       excl:80,  desc:"Kabelramp, 2 kanaler" },
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} desc={t.desc} category="El-tillbehör" />
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex flex-wrap gap-4">
    <a href="/vara-tjanster/hyra-ljud/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">← Tillbaka till hyra ljud</a>
    <a href="/bokningssida/" class="bg-brand-orange hover:bg-orange-500 text-white px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Boka nu</a>
    <a href="/kontakt/" class="border border-white/30 text-white hover:bg-white/10 px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Fråga om offert</a>
  </div>
</Layout>
