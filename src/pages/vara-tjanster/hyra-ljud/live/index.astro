---
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import ProductCard from '../../../../components/ProductCard.astro';
import CartButton from '../../../../components/CartButton.astro';
import ElTillbehorCard from '../../../../components/ElTillbehorCard.astro';
import _ljudData from '../../../../data/ljud.json';
const _artnoAliases: Record<string,string> = {
  'XLR Multikabel 15 m, 6 kan.':          'SK-LJD-MIK-0014',
  'XLR Multikabel 25 m, 8 kan.':          'SK-LJD-MIK-0015',
  'XLR Multikabel 15 m, 24+8 kan.':       'SK-LJD-MIK-0020',
  'Instrumentmikrofon, blås':              'SK-LJD-MIK-0008',
  'Instrumentmikrofoner, slagverk':        'SK-LJD-MIK-0019',
  'Shure SLXD – trådlöst system, 2 mik':  'SK-LJD-MIK-0026',
  'Shure SLXD – trådlöst system, 2 myggmikrofon': 'SK-LJD-MIK-0027',
  'XLR-kablar':                            'SK-LJD-MIK-0002',
  'Bluetooth-mottagare pro':               'SK-LJD-MIK-0011',
  'Trådlöst mikrofonset 8 kan.':           'SK-LJD-MIK-0030',
  'Trådlöst IEM':                          'SK-LJD-MIK-0018',
  // El-tillbehör förkortade namn
  'Grenuttag 1,5 m': 'SK-LJD-EL-0001',
  'Förlängning 10 m': 'SK-LJD-EL-0002',
  'Grenuttag på rulle 10 m': 'SK-LJD-EL-0003',
  'Grenuttag på rulle 25 m': 'SK-LJD-EL-0004',
  'Förlängning 3-fas 16A': 'SK-LJD-EL-0005',
  'Förlängning 3-fas 20 m 16A':    'SK-LJD-EL-0005',
  'Förlängning 3-fas 20 m 32A':    'SK-LJD-EL-0006',
  'Förlängning 3-fas 32A': 'SK-LJD-EL-0006',
  'Strömomvandlare 3-fas→1-fas': 'SK-LJD-EL-0007',
  'Strömomvandlare 3-fas>1-fas': 'SK-LJD-EL-0007',
  'Överkörningsskydd 1 m': 'SK-LJD-EL-0008',
  'Elgenerator 2 200 W': 'SK-LJD-EL-0010',
  'Elgenerator 7 700 W': 'SK-LJD-EL-0011',
  'Regnskydd till högtalare': 'SK-LJD-EL-0009',
  'Elgenerator 7700W': 'SK-LJD-EL-0011',
  'Elgenerator, 2200W': 'SK-LJD-EL-0010',
};
const artnoByName: Record<string,string> = {..._artnoAliases, ...Object.fromEntries(
  [...(_ljudData.tillbehor_mikrofon||[]), ...(_ljudData.tillbehor_el||[]), ...(_ljudData.mixers||[])]
    .filter((p:any) => p.artno)
    .map((p:any) => [p.name, p.artno])
)};
---
<Layout
  title="Hyra Liveljud Stockholm – PA-system för Konsert & Trubadur | Scenkonsult"
  description="Hyr liveljud för konserter, trubadurer och liveband i Stockholm från 599 kr/dygn. Sub-basar och fullrange paket för 20–1 500 personer. Leverans i hela Storstockholm."
>

  <CategoryHero
    h1="Liveljud & Konsert"
    h1Accent="Stockholm"
    intro="Hyr liveljud för konsert, trubadur och liveband i Stockholm. Kraftfulla sub-basar och fullrange högtalarpaket för 20–1 500 personer. Komplettera med mixerbord och mikrofoner nedan."
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Hyra ljud", href: "/vara-tjanster/hyra-ljud/" },
      { label: "Live & Konsert" }
    ]}
    badges={[
      "Sub-basar & line array",
      "20–1 500 personer",
      "Leverans i Storstockholm",
    ]}
    priceFrom={599}
  />

  <!-- PAKET -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard artno="SK-LJD-LIV-0001" name="Live, Small" price={599} persons="20–60 personer"
        image="/images/ljud/pp_ljud_live_small.png"
        description="Passar för trubadur för grupper 20–60 personer. Två Alto 12″ högtalarenheter med inbyggd mixer. Enkel montering 15–20 min."
        specs={["12″/2″ fullrange aktiva element","720 W peak / 360 W RMS","Max 120 dB","60–20 000 Hz","2 inputs (XLR)","8-bands EQ","Samlad vikt: 58 kg"]} />
      <ProductCard artno="SK-LJD-LIV-0002" name="Live, Medium" price={1199} persons="60–100 personer"
        image="/images/ljud/pp_ljud_live_medium.png"
        description="Trubadur eller DJ för 60–100 personer. Två Alto 15S sub-basar och två Alto 12″ fullrange. Bra tryck i hela registret. Montering 15–20 min."
        specs={["15″ sub-bas + 12″/2″ fullrange","2 000 W peak / 1 080 W RMS","Max 130 dB","45–20 000 Hz","230V, min 2 faser","Samlad vikt: 105 kg"]} />
      <ProductCard artno="SK-LJD-LIV-0003" name="Live, Large" price={1599} persons="120–200 personer"
        image="/images/ljud/pp_ljud_live_large.png"
        description="Trubadur eller liveband för 120–200 personer. Fyra Alto 15S sub-basar och två Alto 15″ fullrange. Dubbla sub-basar på varje sida. Montering 20–25 min."
        specs={["4×15″ sub + 2×15″ fullrange","3 600 W peak / 1 800 W RMS","Max 120 dB","60–20 000 Hz","230V","Samlad vikt: 140 kg"]} />
      <ProductCard id="live-xl" artno="SK-LJD-LIV-0004" name="Live/Music, XL" price={2299} persons="180–350 personer"
        image="/images/ljud/pp_ljud_music_xl.png"
        description="Trubadur eller DJ för 180–350 personer. Två 15″ fullrange och två 18″ sub-basar."
        specs={["15″/1,4″ + 18″ sub","2 000 W peak / 1 000 W RMS","Max 132 dB","29–20 000 Hz","230V, min 2 faser","Samlad vikt: 120 kg"]} />
      <ProductCard id="live-xl-plus" artno="SK-LJD-LIV-0005" name="Live/Music, XL+" price={2999} persons="250–600 personer"
        image="/images/ljud/pp_ljud_music_xl-.png"
        description="DJ för 250–600 personer. Två 15″ fullrange, en 15″ sub och en 18″ sub."
        specs={["15″/1,4″ + 15″/18″ sub","8 000 W peak / 2 000 W RMS","Max 132 dB","29–20 000 Hz","Samlad vikt: 200 kg"]} />
      <ProductCard id="live-xxl" artno="SK-LJD-LIV-0006" name="Live/Music, XXL" price={4999} persons="500–1 500 personer"
        image="/images/ljud/pp_ljud_music_xxl.png"
        description="DJ för 500–1 500 personer. Fyra 15″ fullrange och fyra 18″ sub-basar."
        specs={["4×15″/1,4″ + 4×18″ sub","10 000 W peak / 2 800 W RMS","Max 132 dB","29–20 000 Hz","Samlad vikt: 320 kg"]} />
      <ProductCard id="live-concert" artno="SK-LJD-LIV-0007" name="Live/Music, Concert" price={6999} persons="500–1 500 personer"
        image="/images/ljud/pp_ljud_music_concert.png"
        description="Konsert för liveband eller DJ. Två 12″ fullrange och fyra 18″ sub-basar. Varje stack 2,3 m hög."
        specs={["2×12″/1,4″ + 4×18″ sub","10 800 W peak / 2 700 W RMS","Max 135 dB","37–17 000 Hz","Samlad vikt: 360 kg"]} />
      <ProductCard id="line-array-small" artno="SK-LJD-LIV-0008" name="Line Array, Small" price={14999} persons="1 500–2 500 personer"
        image="/images/ljud/pp_ljud_music_linearray1.png"
        description="RCF line array-system för stora konserter och utomhusevent. 8× RCF HDL 6-A fullrange + 2× RCF Sub 8003-AS MK3. Pris från beroende på konfiguration och montering."
        specs={["8×6″ fullrange line array","2×18″ sub-basar","Max 138 dB SPL","Räckvidd upp till 80 m","Kräver lyfttorn eller rigg"]} />
      <ProductCard id="line-array-medium" artno="SK-LJD-LIV-0009" name="Line Array, Medium" price={19999} persons="2 000–3 000 personer"
        image="/images/ljud/pp_ljud_music_linearray2.png"
        description="RCF line array-system för stora konserter och festivaler. 10× RCF HDL 6-A fullrange + 4× RCF Sub 8003-AS MK3. Pris från beroende på konfiguration och montering."
        specs={["10×6″ fullrange line array","4×18″ sub-basar","Max 140 dB SPL","Räckvidd upp till 100 m","Kräver lyfttorn eller rigg"]} />
    </div>
  </section>

  <!-- MIXERBORD -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-2 border-b border-white/10 pb-3">Mixerbord</h2>
    <p class="text-gray-400 mb-8 text-sm">Alla mixers på event-sidan finns att hyra. Live-sidan erbjuder dessutom dessa större modeller:</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard artno="SK-LJD-MIX-0001" name="Analogt mixerbord, 2+2 kanaler" price={159} image="/images/ljud/pp_ljud_mixer01.png" description="Kompakt Alto-mixer, 2 mic + 2 stereo, Bluetooth." specs={["2 mic/line (XLR + 6,3 mm)","2 stereo","Bluetooth","Fantommatning 48V","Vikt: 1,4 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0002" name="Analogt mixerbord, 4+2 kanaler" price={199} image="/images/ljud/pp_ljud_mixer02.png" description="Alto-mixer 4 mic + 2 stereo, effekter och Bluetooth." specs={["4 mic/line","2 stereo","Inbyggda effekter + Bluetooth","Fantommatning 48V"]} />
      <ProductCard artno="SK-LJD-MIX-0003" name="Analogt mixerbord, 4+1 kanaler" price={249} image="/images/ljud/pp_ljud_mixer-vibz8dc.png" description="LD System Vibz8dc med 4 mic-kanaler, 2 stereokanaler och inbyggd kompressor på kanal 1 & 2." specs={["4 mic/line (XLR + 6,3 mm)", "Digital effektprocessor + kompressor", "Fantommatning 48V", "Vikt: 2,3 kg"]} />
      <ProductCard artno="SK-LJD-MIX-0004" name="Analogt mixerbord, 4+4 kanaler" price={299} image="/images/ljud/pp_ljud_mixer03.png" description="Mackie-mixer 4 mic + 4 stereo. 60 dB gain." specs={["4 mic/line","4 stereo","60 dB preamp","Fantommatning 48V"]} />
      <ProductCard artno="SK-LJD-MIX-0005" name="Analogt mixerbord, 6+4 kanaler" price={349} image="/images/ljud/pp_ljud_mixer04.png" description="Allen & Heath ZED14 – 6 mic + 4 stereo, 69 dB." specs={["6 mic/line","4 stereo","69 dB preamp","Fantommatning 48V"]} />
      <ProductCard artno="SK-LJD-MIX-0006" name="Analogt mixerbord, 12+4 kanaler" price={399} image="/images/ljud/pp_ljud_mixer05.png" description="Alto Live L16 – 12 mic + 4 stereo, 256 effekter." specs={["12 mic/line","4 stereo","256 inbyggda effekter"]} />
      <ProductCard artno="SK-LJD-MIX-0007" name="Analogt mixerbord, 16+3 kanaler" price={599} image="/images/ljud/pp_ljud_mixer06.png" description="Allen & Heath ZED22FX – 16 mic + 3 stereo, USB." specs={["16 mic/line","3 stereo","USB","High-pass filter per kanal"]} />
      <ProductCard artno="SK-LJD-MIX-0008" name="Digitalt mixerbord, 32+16 kanaler" price={2499} image="/images/ljud/pp_ljud_mixer-ilive-t80.png" description="Allen & Heath iLive T80 studio- & konsert-mixer med Stagebox på scenen via CAT5/6-kabel." specs={["32 mik/line in, 16 XLR ut", "20 faders – 2 banker, 4 lager = 80 kontroller", "8 in, 8 ut ljud", "Vikt: 32 kg"]} />
    </div>
  </section>

  <!-- MIKROFONER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Mikrofoner &amp; tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {[
        { name:"Högtalarstativ Gravity",        desc:"Max last 30 kg, vikt 3,7 kg",  price:40,  img:"/images/ljud/pp_ljud_stativ-gravity.png" },
        { name:"Högtalarstativ K&M",             desc:"Max last 30 kg, vikt 3,7 kg",  price:50,  img:"/images/ljud/pp_ljud_stativ-km.png" },
        { name:"Högtalarstativ Gravity Premium",  desc:"Max last 50 kg, vikt 6,4 kg",  price:60,  img:"/images/ljud/pp_ljud_stativ-gravity-premium.png" },
        { name:"Högtalarstativ Gravity med vev",  desc:"Max last 50 kg, vikt 9,1 kg",  price:120, img:"/images/ljud/pp_ljud_stativ-gravity-vev.png" },
        { name:"Lyfttorn för line array",            desc:"Max last 200 kg, höjd upp till 6 m", price:2999, img:"/images/ljud/pp_ljud_lift.png" },
        { name:"Mikrofonstativ",                  desc:"Justerbar höjd",                     price:60,   img:"/images/ljud/pp_ljud_tillbehor06.png" },
        { name:"XLR-kablar",                      desc:"1–15 m, fr 40 kr",                  price:40,   img:"/images/ljud/pp_ljud_tillbehor07.png" },
        { name:"XLR Multikabel 15 m, 6 kan.",    desc:"Stagebox, 6 kanaler",                price:276,  img:"/images/ljud/pp_ljud_tillbehor_MK-small.png" },
        { name:"XLR Multikabel 25 m, 8 kan.",    desc:"Stagebox, 8 kanaler",                price:384,  img:"/images/ljud/pp_ljud_tillbehor_MK-medium.png" },
        { name:"XLR Multikabel 15 m, 24+8 kan.", desc:"Stagebox stor, 24+8 kanaler",        price:632,  img:"/images/ljud/pp_ljud_tillbehor_MK-large.png" },
        { name:"DI-box (passiv)",                 desc:"2-kan, XLR ut / 6,35 mm in",         price:160,  img:"/images/ljud/pp_ljud_tillbehor_DI-passiv.png" },
        { name:"DI-box (aktiv)",                  desc:"1-kan, XLR ut / 6,35 mm in, 9V",    price:240,  img:"/images/ljud/pp_ljud_tillbehor_DI-aktiv.png" },
        { name:"Bluetooth-mottagare",             desc:"Trådlös anslutning till PA",         price:100,  img:"/images/ljud/pp_ljud_tillbehor04.png" },
        { name:"Bluetooth-mottagare pro",         desc:"Längre räckvidd",                    price:140,  img:"/images/ljud/pp_ljud_tillbehor_BT-pro.png" },
        { name:"Instrumentmikrofon",              desc:"Gitarr, blås m.m., inkl XLR",        price:64,   img:"/images/ljud/pp_ljud_mik02.png" },
        { name:"Instrumentmikrofon, blås",        desc:"Blåsinstrument, inkl XLR",           price:80,   img:"/images/ljud/pp_ljud_mik04.png" },
        { name:"Handmikrofon",                    desc:"Inkl 6 m XLR-kabel",                 price:80,   img:"/images/ljud/pp_ljud_mik01.png" },
        { name:"Instrumentmikrofoner, slagverk",  desc:"Trumset, inkl XLR-kablar",           price:480,  img:"/images/ljud/pp_ljud_mik03.png" },
        { name:"Trådlös handmikrofon",            desc:"Ca 30 m räckvidd",                   price:400,  img:"/images/ljud/pp_ljud_mik05.png" , specs:['UHF trådlös, ca 30 m räckvidd', 'Mottagarenhet ingår', 'Kräver AA-batteri', 'Plug & play']},
        { name:"Trådlöst headset",                desc:"Ca 30 m räckvidd",                   price:480,  img:"/images/ljud/pp_ljud_mik06.png" , specs:['UHF trådlös, ca 30 m räckvidd', 'Bodypack + headset ingår', 'Kräver AA-batteri']},
        { name:"Trådlöst IEM",                    desc:"In-ear monitor, ca 30 m",            price:480,  img:"/images/ljud/pp_ljud_tillbehor01.png" },
        { name:"Shure SLXD – trådlöst system, 1 mik",          desc:"Digitalt, AES-256, 1× SM58-kapsel, ca 100 m",        price:699,  img:"/images/ljud/pp_ljud_mik09.png" , specs:['Digitalt AES-256 krypterat', 'SM58-kapsel (vokal)', 'Räckvidd ca 100 m', 'Auto-scan frekvens', 'Rack-monterbar mottagare']},
        { name:"Shure SLXD – trådlöst system, 1 myggmikrofon", desc:"Digitalt, AES-256, 1× bodypack + myggmik, ca 100 m",  price:699,  img:"/images/ljud/pp_ljud_mik13.png" , specs:['Digitalt AES-256 krypterat', 'Bodypack + myggmikrofon', 'Räckvidd ca 100 m', 'Auto-scan frekvens', 'Rack-monterbar mottagare']},
        { name:"Shure SLXD – trådlöst system, 1 headset",      desc:"Digitalt, AES-256, 1× bodypack + headset, ca 100 m",  price:749,  img:"/images/ljud/pp_ljud_mik12.png" , specs:['Digitalt AES-256 krypterat', 'Bodypack + headset', 'Räckvidd ca 100 m', 'Auto-scan frekvens', 'Rack-monterbar mottagare']},
        { name:"Shure SLXD – trådlöst system, 1 lågprofil headset", desc:"Digitalt, AES-256, 1× bodypack + öronhängande headset, ca 100 m", price:799, img:"/images/ljud/pp_ljud_mik14.png" , specs:['Digitalt AES-256 krypterat', 'Bodypack + öronhängande headset', 'Räckvidd ca 100 m', 'Diskret lågprofil-design']},
        { name:"Effektrack med matrix & feedback-suppressor",   desc:"5-zon ART-matrix + Klark Teknik DP1000",              price:1036, img:"/images/ljud/pp_ljud_effektrack.png" , specs:['5-zon ART-matrix', 'Klark Teknik DP1000 feedback-suppressor', 'Förhindrar rundgång', 'Rack-monterat 19\"']},
        { name:"Shure SLXD – trådlöst system, 2 mik",          desc:"Digitalt, AES-256, 2× SM58, ca 100 m",               price:1299, img:"/images/ljud/pp_ljud_mik-shure-slxd4d.png" , specs:['Digitalt AES-256 krypterat', '2× SM58 handhållna mikrofoner', 'Dual-channel mottagare', 'Räckvidd ca 100 m']},
        { name:"Shure SLXD – trådlöst system, 2 myggmikrofon", desc:"Digitalt, AES-256, 2× bodypack + myggmik, ca 100 m",  price:1299, img:"/images/ljud/pp_ljud_mik10.png" , specs:['Digitalt AES-256 krypterat', '2× bodypack + myggmikrofon', 'Dual-channel mottagare', 'Räckvidd ca 100 m']},
        { name:"Shure SLXD – trådlöst system, 2 headset",      desc:"Digitalt, AES-256, 2× bodypack + headset, ca 100 m",  price:1399, img:"/images/ljud/pp_ljud_mik08.png" , specs:['Digitalt AES-256 krypterat', '2× bodypack + headset', 'Dual-channel mottagare', 'Räckvidd ca 100 m']},
        { name:"Shure SLXD – trådlöst system, 2 lågprofil headset", desc:"Digitalt, AES-256, 2× bodypack + öronhängande headset, ca 100 m", price:1499, img:"/images/ljud/pp_ljud_mik11.png" , specs:['Digitalt AES-256 krypterat', '2× bodypack + lågprofil headset', 'Dual-channel mottagare', 'Räckvidd ca 100 m']},
        { name:"Trådlöst mikrofonset 8 kan.",                   desc:"4 hand + 4 headset, antennsplitter",                 price:3999, img:"/images/ljud/pp_ljud_tillbehor20.png" , specs:['4× handmikrofon + 4× headset', 'Antennsplitter ingår', '823–832 MHz band', 'Räckvidd upp till 50 m', '8 oberoende kanaler']},
      
      
      
      
      
      
      
      ].map(item => (
        <ElTillbehorCard img={item.img} name={item.name} excl={item.price} desc={item.desc} category="Ljud tillbehör" artno={artnoByName[item.name]} modal={item.price >= 400} specs={item.specs ?? (item.desc ? [item.desc] : [])} />
      ))}
    </div>
  </section>

  <!-- EL-TILLBEHÖR -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">El-tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {[
        { img:"/images/ljus/pp_el_grenuttag_sm.png",    name:"Grenuttag 1,5 m",             excl:20,  desc:"Jordat, 3–5 uttag, 16A" },
        { img:"/images/ljus/pp_el_forlangning.png",     name:"Förlängning 10 m",            excl:48,  desc:"1-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_overloppsskydd.png",  name:"Överkörningsskydd 1 m",       excl:80,  desc:"Kabelramp, 2 kanaler" },
        { img:"/images/ljus/pp_el_grenuttag_lg.png",    name:"Grenuttag på rulle 10 m",     excl:100, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_grenuttag_25m.png",   name:"Grenuttag på rulle 25 m",     excl:159, desc:"4 uttag, 16A, IP44" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 20 m 16A",  excl:236, desc:"3-fas, 16A, IP44" },
        { img:"/images/ljus/pp_el_omvandlare.png",      name:"Strömomvandlare 3-fas→1-fas", excl:320, desc:"32A 3-fas till 1-fas uttag" },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 20 m 32A",  excl:396, desc:"3-fas, 32A, IP44" },
        { img:"/images/ljud/pp_ljud_tillbehor_elverk-small.png", name:"Elgenerator 2 200 W",       excl:799, desc:"1 900 W kontinuerlig, bensin 4-takt" },
        { img:"/images/ljud/pp_ljud_elverk-kipor.png", name:"Elgenerator 7 700 W",       excl:1799, desc:"7 000 W kontinuerlig, bensin 4-takt. Kipor IG6000." },
        { img:"/images/ljus/pp_ljus_ackrylatbensin_1L.png", name:"Ackrylatbensin 1 l", excl:59,  desc:"Aspen 4 · 4-taktsmotorer" },
        { img:"/images/ljus/pp_ljus_ackrylatbensin_5L.png", name:"Ackrylatbensin 5 l", excl:239, desc:"Aspen 4 · 4-taktsmotorer" },
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} desc={t.desc} category="El-tillbehör" artno={artnoByName[t.name]} />
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex flex-wrap gap-4">
    <a href="/vara-tjanster/hyra-ljud/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">← Tillbaka till hyra ljud</a>
    <a href="/bokningssida/" class="bg-brand-orange hover:bg-brand-orange-light text-white px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Boka nu</a>
    <a href="/kontakt/" class="border border-white/30 text-white hover:bg-white/10 px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Fråga om offert</a>
  </div>
</Layout>
