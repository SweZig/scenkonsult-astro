---
import Layout from '../../layouts/Layout.astro';

const services = [
  { title: "Scener", desc: "Från 4m² podie till 48m² XL-scen med tak. Halkfria ytor för inomhus och utomhus.", href: "/vara-tjanster/hyra-scen/", from: "599 kr/dygn", icon: "🎭" },
  { title: "Ljud – Event", desc: "För tal, presentationer och bakgrundsmusik. 20–1000+ åhörare.", href: "/vara-tjanster/hyra-ljud/event/", from: "Offert", icon: "🎤" },
  { title: "Ljud – Live", desc: "PA-system för liveband och konserter. Inomhus och utomhus.", href: "/vara-tjanster/hyra-ljud/live/", from: "Offert", icon: "🎸" },
  { title: "Ljud – Musik/Dans", desc: "Kraftfulla system för disco, DJ och dansgolv. 20–1500 personer.", href: "/vara-tjanster/hyra-ljud/music/", from: "Offert", icon: "🔊" },
  { title: "Portabelt ljud", desc: "Kompakta, smidiga anläggningar för tal, trubadur och mingel.", href: "/vara-tjanster/hyra-ljud/portable/", from: "Offert", icon: "📻" },
  { title: "Färdiga ljuspaket", desc: "Komplett belysning för fest och event – enkelt att installera.", href: "/vara-tjanster/hyra-ljus/fardiga-paket/", from: "Offert", icon: "✨" },
  { title: "Lösa ljuseffekter", desc: "Moving heads, PAR-lampor, laser, stroboskop – bygg din rig.", href: "/vara-tjanster/hyra-ljus/ljuseffekter/", from: "Offert", icon: "💡" },
  { title: "Rök & Pyroteknik", desc: "Rökmaskiner, kolsyraelement och pyroteknik för scen.", href: "/vara-tjanster/hyra-ljus/rok-pyro/", from: "Offert", icon: "💨" },
  { title: "Stativ & Tross", desc: "Traverser, tross och stativ för att rigga din ljus- och ljudrigg.", href: "/vara-tjanster/hyra-ljus/stativ-tross/", from: "Offert", icon: "🏗️" },
  { title: "Projektorer & Skärmar", desc: "HD/4K projektorer, Samsung professionella skärmar och LED-vägg.", href: "/vara-tjanster/hyra-bild-projektorer-skarmar/", from: "Offert", icon: "📽️" },
  { title: "Professionella DJs", desc: "Erfarna DJs till bröllop, fest och företagsevent. 80-tal–idag.", href: "/vara-tjanster/hyra-dj/", from: "2 995 kr", icon: "🎧" },
];
---

<Layout
  title="Våra tjänster – Hyra Scen, Ljud, Ljus & DJ Stockholm | Scenkonsult"
  description="Komplett scenproduktion i Stockholm. Hyr scen, ljud, ljus, projektorer och DJ för fest, bröllop, event och konsert. Leverans i hela Storstockholm. Sedan 1986."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="Brödsmulor">
      <a href="/" class="hover:text-gray-300">Hem</a>
      <span class="mx-2">/</span>
      <span class="text-white">Våra tjänster</span>
    </nav>

    <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">Våra tjänster i Stockholm</h1>
    <p class="text-gray-400 text-lg max-w-3xl mb-12">
      Vi är er kompletta partner för scenproduktion – oavsett om det gäller en privat fest för 20 eller ett stort utomhusvent för 2 000 gäster. Välj bland våra tjänster nedan eller <a href="/kontakt/" class="text-brand-orange hover:underline">kontakta oss</a> för ett komplett paket.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {services.map(s => (
        <a href={s.href} class="group bg-brand-navy hover:bg-white/5 border border-white/10 hover:border-brand-orange/40 rounded-2xl p-6 transition-all">
          <div class="text-3xl mb-3">{s.icon}</div>
          <h2 class="text-white font-bold text-lg mb-2 group-hover:text-brand-orange transition-colors">{s.title}</h2>
          <p class="text-gray-400 text-sm leading-relaxed mb-4">{s.desc}</p>
          <div class="flex items-center justify-between text-sm">
            <span class="text-brand-orange font-semibold">Från {s.from}</span>
            <span class="text-gray-500 group-hover:text-brand-orange transition-colors">Läs mer →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
