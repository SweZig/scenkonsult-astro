---
import Layout from '../../../layouts/Layout.astro';
import CategoryHero from '../../../components/CategoryHero.astro';
import ProductCard from '../../../components/ProductCard.astro';
import ElTillbehorCard from '../../../components/ElTillbehorCard.astro';
import bildData from '../../../data/bild.json';
---
<Layout
  title="Hyr Projektor & Storbildsskärm Stockholm – LED-vägg & Trailerscen | Scenkonsult"
  description="Hyr projektor, storbildsskärm, LED-vägg och trailerscen för event och konferenser i Stockholm. Projektor fr 299 kr/dygn. Leverans i hela Storstockholm."
>

  <CategoryHero
    h1="Hyr Projektor & Skärm"
    h1Accent="Stockholm"
    intro="Hyr projektor, storbildsskärm eller moduluppbyggd LED-vägg för konferens, presentation och event i Stockholm. Vi levererar hela lösningen med stativ, duk och kablar. Transport och montering finns som tilläggstjänst."
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "Våra tjänster", href: "/vara-tjanster/" },
      { label: "Hyr bild, projektorer & skärmar" }
    ]}
    badges={[
      "3 500–12 000 ANSI lumen",
      "Full HD och 4K",
      "LED-vägg & trailerscen",
      "Leverans i Storstockholm"
    ]}
    priceFrom={299}
  />

  <!-- PRODUKTER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {bildData.products.map(p => (
        <ProductCard
          id={p.slug}
          artno={p.artno}
          name={p.name}
          price={p.price}
          priceNote={p.priceNote}
          image={p.image}
          alt={p.alt}
          description={p.description}
          specs={p.includes}
          category="Projektor & skärm"
          bulky={p.bulky}
        />
      ))}
    </div>
  </section>

  <!-- TILLBEHÖR BILD -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">Tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {bildData.tillbehor.map(t => (
        <ElTillbehorCard img={t.image} name={t.name} excl={t.price} desc={t.desc} category="Projektor tillbehör" artno={t.artno} />
      ))}
    </div>
  </section>

  <!-- EL-TILLBEHÖR -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl font-bold text-white mb-4 border-b border-white/10 pb-3">El-tillbehör</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      {[
        { img:"/images/ljus/pp_el_grenuttag_sm.png",    name:"Grenuttag 1,5 m",             excl:20  },
        { img:"/images/ljus/pp_el_forlangning.png",     name:"Förlängning 10 m 1-fas",      excl:48  },
        { img:"/images/ljus/pp_el_overloppsskydd.png",  name:"Överkörningsskydd 1 m",       excl:80  },
        { img:"/images/ljus/pp_el_grenuttag_lg.png",    name:"Grenuttag 10 m IP44",         excl:100 },
        { img:"/images/ljus/pp_el_grenuttag_25m.png",   name:"Grenuttag 25 m IP44",         excl:159 },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 16A",       excl:236 },
        { img:"/images/ljus/pp_el_omvandlare.png",      name:"Strömomvandlare 3-fas→1-fas", excl:320 },
        { img:"/images/ljus/pp_el_forlangning_20m.png", name:"Förlängning 3-fas 32A",       excl:396 },
        { img:"/images/ljud/pp_ljud_tillbehor_elverk-small.png", name:"Elgenerator 2 200 W", excl:799 },
        { img:"/images/ljud/pp_ljud_elverk-kipor.png",  name:"Elgenerator 7 700 W",         excl:1799 },
        { img:"/images/ljus/pp_ljus_ackrylatbensin_1L.png", name:"Ackrylatbensin 1 l", excl:59,  desc:"Aspen 4" },
        { img:"/images/ljus/pp_ljus_ackrylatbensin_5L.png", name:"Ackrylatbensin 5 l", excl:239, desc:"Aspen 4" },
      ].map(t => (
        <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} desc={t.desc} category="El-tillbehör" />
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex flex-wrap gap-4">
    <a href="/vara-tjanster/" class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange px-5 py-3 rounded-xl text-sm font-semibold transition-all">← Tillbaka till tjänster</a>
    <a href="/bokningssida/" class="bg-brand-orange hover:bg-brand-orange-light text-white px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Boka nu</a>
    <a href="/kontakt/" class="border border-white/30 text-white hover:bg-white/10 px-5 py-3 rounded-xl text-sm font-semibold transition-colors">Fråga om offert</a>
  </div>
</Layout>
