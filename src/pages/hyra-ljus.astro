---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const products = [{"title": "Ljuspaket, Small", "priceImg": "https://scenkonsult.se/wp-content/uploads/2025/09/Pris_624.png", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljus_small_20250824PNG.png", "desc": "Enkelt festljuspaket. LED par-spottar och färgat scenljus. Passar för hemma-fester och mindre lokaler."}, {"title": "Ljuspaket, Small+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2026/01/pp_ljus_small-_20260117-1024x853.png", "desc": "Utökat festljus med wash-lampor och effektljus. Bra för bröllop och födelsedagar."}, {"title": "Ljuspaket, Small++", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljus_small-_20250824PNG-1.png", "desc": "Komplett festljus med hazer och fler effekter. Fyller en mellanstor lokal med stämning."}, {"title": "Ljuspaket, Medium", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2026/01/pp_ljus_medium_20260117-1024x853.png", "desc": "Scenljuspaket för band och talare. Front-light, backlight och effektljus. DMX-styrbart."}, {"title": "Ljuspaket, Medium+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljus_medium-_20250824PNG.png", "desc": "Utökat scenljus med moving heads och beam-effekter. Proffsigt scenlook."}, {"title": "Ljuspaket, Large", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljus_large_20250824PNG.png", "desc": "Professionell ljusrigg med moving heads, beam och wash. DMX-programmering. Stora event."}, {"title": "Ljuspaket, Large+", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2026/01/pp_ljus_large-_20260117-1024x853.png", "desc": "Avancerat scenlightingpaket med lasrar och strobos. Konsert- och festivalnivå."}, {"title": "Ljuspaket, XL", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2026/01/pp_ljus_xl_20260122-1-1024x853.png", "desc": "XL-ljusrigg för stora scener och utomhus-event. Komplett DMX-setup."}, {"title": "Scenpaket (ljus-bundle)", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2026/01/pp_ljus_scen_bundle-1024x853.png", "desc": "Komplett scenljusbundle ihoppaketerat med scen. Smidigast när du hyr scen + ljus på en offert."}, {"title": "Scenljus för konserter", "priceImg": "", "prodImg": "https://scenkonsult.se/wp-content/uploads/2025/08/pp_ljus_storre_event.png", "desc": "Professionell konsertljusrigg för stora event och festivaler. Pris på förfrågan."}];
---
<ServiceLayout
  title="Hyra Ljus Scen & Event Stockholm | Scenkonsult"
  description="Hyra scenlighting i Stockholm. Från festbelysning till professionell DMX med moving heads. Färdiga paket. Sedan 1986."
  pageHeading="Uthyrning av Ljus"
  intro="Vi har noggrant valt ut professionella varumärken och produkter för att förse kunder med snabba leveranser och fantastiska upplevelser. Allt från enkel festbelysning till professionella scenlightingpaket."
  note="Alla priser är hyra per dygn (22 timmar). Utrustning hämtas enl överenskommelse från kl 13:00 och återlämnas innan kl 11:00 nästkommande dag. Vi erbjuder även leverans- och monteringstjänster."
  products={products}
/>
