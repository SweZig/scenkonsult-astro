---
import Layout from '../../../layouts/Layout.astro';
import CategoryHero from '../../../components/CategoryHero.astro';

const faq = [
  {
    q: "Hur stor PA-anläggning behöver jag till ett bröllop?",
    a: "För 50–80 gäster inomhus räcker ett Event Small eller Medium-paket. Utomhus dubblas effektbehovet. Vi hjälper dig dimensionera exakt rätt utifrån lokal och antal gäster."
  },
  {
    q: "Kan vi hyra utrustning utan att ha tekniker på plats?",
    a: "Ja, alla våra standardpaket är byggda för självinstallation. Vi går igenom allt vid avhämtning och tillhandahåller instruktioner. Vill du ha tekniker på plats erbjuder vi det som tillägg (600 kr/tim)."
  },
  {
    q: "Behöver vi en scen på ett bröllop?",
    a: "En liten scen (4–6 m²) för trubaduren eller DJ:n ger ett professionellt intryck och skapar tydlig fokuspunkt. Den signalerar till gästerna att det händer saker — och frigör naturligt dansyta framför."
  },
  {
    q: "Vad kostar ett komplett bröllopspaktet?",
    a: "Ett komplett paket med ljud, ljus och scen för 80–100 gäster startar från ca 4 000–7 000 kr för ett dygn. Pris beror på utrustning och eventuell leverans. Begär offert så räknar vi ihop exakt."
  },
  {
    q: "Hur långt i förväg måste vi boka för bröllop?",
    a: "Bröllopssäsongen (maj–september) bokas snabbt. Vi rekommenderar att boka 2–4 månader i förväg för att säkra din dag. Vi hanterar även korta varsel om utrustningen är tillgänglig."
  },
  {
    q: "Kan utrustningen användas utomhus?",
    a: "Ja, all vår utrustning tål normal väta och hög luftfuktighet. Vi rekommenderar alltid väderskydd vid längre utomhusarrangemang och kan råda om rätt lösning för just er plats."
  }
];

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Uthyrning av ljud, ljus och scen till bröllop i Stockholm",
      "provider": {
        "@type": "LocalBusiness",
        "name": "Scenkonsult Norden",
        "telephone": "+46724481000",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Palmfeltsvägen 5",
          "addressLocality": "Stockholm",
          "postalCode": "121 62",
          "addressCountry": "SE"
        }
      },
      "areaServed": "Stockholm",
      "description": "Hyr komplett ljud, ljus och scen till ert bröllop i Stockholm. Leverans, montering och tekniker tillgängligt.",
      "url": "https://scenkonsult.se/for/brollop/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faq.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<Layout
  title="Hyra Ljud, Ljus & Scen till Bröllop i Stockholm | Scenkonsult"
  description="Hyr komplett ljud, ljus och scen till ert bröllop i Stockholm från 599 kr/dygn. Leverans i hela Storstockholm. Tekniker på plats om ni vill. Ring 072-448 10 00."
  schemaExtra={pageSchema}
>

  <CategoryHero
    h1="Teknik till bröllop i"
    h1Accent="Stockholm"
    intro="Ert bröllop förtjänar perfekt ljud, stämningsfull belysning och en scen som lyfter allt. Vi har levererat till hundratals bröllop sedan 1986 — vi vet vad som fungerar."
    breadcrumbs={[
      { label: "Hem", href: "/" },
      { label: "För ditt event", href: "/for/" },
      { label: "Bröllop" }
    ]}
    badges={[
      "Bröllopspaket från 2 500 kr/dygn",
      "Leverans & montering i Storstockholm",
      "Tekniker på plats tillgängligt",
      "Fri avbokning"
    ]}
  />

  <!-- Varför rätt teknik gör skillnad -->
  <section style="background:#111030; padding: clamp(3rem,6vw,5rem) clamp(1rem,5vw,5rem);">
    <div style="max-width:1100px; margin:0 auto;">
      <p style="color:#c4b5f4; font-family:'Space Grotesk',sans-serif; font-size:0.8rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin-bottom:0.75rem;">Bröllopsteknik</p>
      <h2 style="font-family:'DM Serif Display',serif; font-size:clamp(1.8rem,4vw,2.8rem); color:white; margin:0 0 1.25rem; max-width:700px;">Rätt teknik förvandlar en fin fest till ett oförglömligt ögonblick</h2>
      <p style="color:rgba(255,255,255,0.6); font-size:clamp(0.95rem,2vw,1.1rem); line-height:1.75; max-width:680px; margin:0 0 3rem;">
        Dåligt ljud förstör talen. Fel ljussättning dödar stämningen. En scen som vacklar ger fel signaler. Vi hyr ut utrustning som faktiskt fungerar — och vi hjälper er välja rätt storlek för er lokal och era gäster.
      </p>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.5rem;">
        {[
          {
            icon: "🔊",
            title: "Ljud",
            desc: "PA-system dimensionerat för er lokal. Trådlösa mikrofoner för tal, trubadur eller bandet. Kristallklart ljud utan feedback.",
            link: "/vara-tjanster/hyra-ljud/",
            cta: "Se ljudpaket"
          },
          {
            icon: "💡",
            title: "Ljus & stämning",
            desc: "Uplights längs väggarna, spotlights på bordsarrangemangen, dansgolvsbelysning. Rätt ljus sätter hela stämningen.",
            link: "/vara-tjanster/hyra-ljus/",
            cta: "Se ljuspaket"
          },
          {
            icon: "🎭",
            title: "Scen & podium",
            desc: "En liten 4–6 m² scen för DJ:n eller trubaduren. Professionell känsla och tydlig fokuspunkt för gästerna.",
            link: "/vara-tjanster/hyra-scen/",
            cta: "Se scener"
          },
          {
            icon: "🎧",
            title: "DJ-utrustning",
            desc: "Pioneer XDJ-RX3, CDJ-3000 eller kompakta kontroller. Hyr professionell DJ-utrustning om ni har en DJ ni litar på.",
            link: "/vara-tjanster/hyra-dj/",
            cta: "Se DJ-utrustning"
          }
        ].map(item => (
          <div style="background:#1e1850; border:1px solid rgba(255,255,255,0.08); border-radius:16px; padding:1.75rem; display:flex; flex-direction:column; gap:0.75rem; transition:border-color 0.2s;" 
               onmouseenter="this.style.borderColor='rgba(196,181,244,0.35)'" 
               onmouseleave="this.style.borderColor='rgba(255,255,255,0.08)'">
            <div style="font-size:1.75rem;">{item.icon}</div>
            <h3 style="font-family:'DM Serif Display',serif; font-size:1.25rem; color:white; margin:0;">{item.title}</h3>
            <p style="color:rgba(255,255,255,0.55); font-size:0.9rem; line-height:1.65; margin:0; flex:1;">{item.desc}</p>
            <a href={item.link} style="color:#c4b5f4; font-family:'Space Grotesk',sans-serif; font-size:0.8rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; margin-top:0.25rem;">
              {item.cta} →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Checklista / Rekommenderad setup -->
  <section style="background:#0c0a24; padding: clamp(3rem,6vw,5rem) clamp(1rem,5vw,5rem);">
    <div style="max-width:1100px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:start;">
      <div>
        <p style="color:#c4b5f4; font-family:'Space Grotesk',sans-serif; font-size:0.8rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin-bottom:0.75rem;">Bröllopschecklista</p>
        <h2 style="font-family:'DM Serif Display',serif; font-size:clamp(1.6rem,3.5vw,2.4rem); color:white; margin:0 0 1.5rem;">Vad behöver ni till bröllopet?</h2>

        {[
          { fas: "Ljud för tal & tal", items: ["Trådlös mikrofon för toastmaster", "PA-system för 50–200 gäster", "Monitor så artisten hör sig själv"] },
          { fas: "Ceremonin", items: ["Bluetooth-högtalare för processionsmusik", "Trådlöst headset för prästen/celebranten"] },
          { fas: "Middagen", items: ["Bakgrundsmusik i låg volym", "Mikrofon för tal vid bordet"] },
          { fas: "Dansgolvet", items: ["PA med subbasar för dansgolvet", "Discoljus, laser och rökmaskin", "DJ-utrustning eller scen för live"] }
        ].map(block => (
          <div style="margin-bottom:1.5rem;">
            <h3 style="font-family:'Space Grotesk',sans-serif; font-size:0.85rem; font-weight:700; color:#c4b5f4; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 0.6rem;">{block.fas}</h3>
            {block.items.map(item => (
              <div style="display:flex; align-items:center; gap:0.6rem; padding:0.4rem 0; border-bottom:1px solid rgba(255,255,255,0.05);">
                <span style="color:#86efac; font-size:0.8rem;">✓</span>
                <span style="color:rgba(255,255,255,0.65); font-size:0.9rem;">{item}</span>
              </div>
            ))}
          </div>
        ))}
      </div>

      <div>
        <div style="background:#1e1850; border:1px solid rgba(196,181,244,0.2); border-radius:16px; padding:2rem; margin-bottom:1.5rem;">
          <h3 style="font-family:'DM Serif Display',serif; font-size:1.4rem; color:white; margin:0 0 1rem;">Typiskt bröllopspaketet</h3>
          <p style="color:rgba(255,255,255,0.55); font-size:0.9rem; line-height:1.65; margin:0 0 1.25rem;">För 80–120 gäster inomhus rekommenderar vi:</p>
          {[
            ["PA-system", "Event Medium (2 toppar + sub)"],
            ["Mikrofoner", "2× trådlös hand + 1× headset"],
            ["Scenljus", "8× LED par-lampor"],
            ["Scen", "2×3 m podium för DJ/artist"],
            ["Discoljus", "2× moving head + laser"],
            ["Leverans & montering", "Tillgängligt som tillägg"]
          ].map(([label, value]) => (
            <div style="display:flex; justify-content:space-between; align-items:center; padding:0.6rem 0; border-bottom:1px solid rgba(255,255,255,0.07);">
              <span style="color:rgba(255,255,255,0.5); font-size:0.85rem;">{label}</span>
              <span style="color:white; font-size:0.85rem; font-weight:600; text-align:right; max-width:55%;">{value}</span>
            </div>
          ))}
          <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid rgba(196,181,244,0.2);">
            <div style="display:flex; justify-content:space-between; align-items:center;">
              <span style="color:rgba(255,255,255,0.5); font-size:0.85rem;">Från ca</span>
              <span style="font-family:'DM Serif Display',serif; font-size:1.6rem; color:#c4b5f4;">4 500 kr</span>
            </div>
            <p style="color:rgba(255,255,255,0.3); font-size:0.75rem; margin:0.25rem 0 0;">Per dygn, exkl. leverans. Offert utan bindning.</p>
          </div>
        </div>

        <a href="/bokningssida/" style="display:block; background:#c4b5f4; color:#0c0a24; font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:0.85rem; letter-spacing:0.1em; text-transform:uppercase; text-decoration:none; padding:1rem 2rem; border-radius:4px; text-align:center; transition:background 0.2s;" onmouseenter="this.style.background='#e2dcfb'" onmouseleave="this.style.background='#c4b5f4'">
          Begär offert — svar inom 2 timmar
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background:#111030; padding: clamp(3rem,6vw,5rem) clamp(1rem,5vw,5rem);">
    <div style="max-width:820px; margin:0 auto;">
      <p style="color:#c4b5f4; font-family:'Space Grotesk',sans-serif; font-size:0.8rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin-bottom:0.75rem;">Vanliga frågor</p>
      <h2 style="font-family:'DM Serif Display',serif; font-size:clamp(1.6rem,3.5vw,2.4rem); color:white; margin:0 0 2.5rem;">Allt du undrar om bröllopsteknik</h2>

      <div style="display:flex; flex-direction:column; gap:0;">
        {faq.map((item, i) => (
          <details style="border-bottom:1px solid rgba(255,255,255,0.07); padding:0;">
            <summary style="display:flex; justify-content:space-between; align-items:center; padding:1.25rem 0; cursor:pointer; list-style:none; color:white; font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:1rem; gap:1rem;">
              {item.q}
              <span style="color:#c4b5f4; font-size:1.25rem; flex-shrink:0; transition:transform 0.2s;">+</span>
            </summary>
            <p style="color:rgba(255,255,255,0.6); font-size:0.95rem; line-height:1.75; margin:0 0 1.25rem; padding-right:2rem;">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA botten -->
  <section style="background:linear-gradient(135deg,#1e1850,#0c0a24); padding:clamp(3rem,6vw,5rem) clamp(1rem,5vw,5rem); text-align:center;">
    <p style="color:#c4b5f4; font-family:'Space Grotesk',sans-serif; font-size:0.8rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin-bottom:0.75rem;">Sedan 1986</p>
    <h2 style="font-family:'DM Serif Display',serif; font-size:clamp(1.8rem,4vw,3rem); color:white; margin:0 0 1rem; max-width:600px; margin-inline:auto;">Ert bröllop förtjänar teknik som fungerar</h2>
    <p style="color:rgba(255,255,255,0.55); font-size:1rem; max-width:480px; margin:0 auto 2rem;">Ring oss eller begär offert — vi svarar inom ett par timmar och hjälper er välja rätt utrustning för er dag.</p>
    <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
      <a href="/bokningssida/" style="background:#c4b5f4; color:#0c0a24; font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:0.85rem; letter-spacing:0.1em; text-transform:uppercase; text-decoration:none; padding:0.9rem 2rem; border-radius:4px;">Begär offert</a>
      <a data-tel="MDcyNDQ4MTAwMA==" data-prefix="📞 " data-label="072-448 10 00" href="#tel" style="color:rgba(255,255,255,0.55); font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:0.9rem; text-decoration:none; padding:0.9rem 0; align-self:center;"><noscript>📞 072-448 10 00</noscript></a>
    </div>
  </section>

</Layout>
