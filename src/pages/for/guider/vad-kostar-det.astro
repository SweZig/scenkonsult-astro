---
import Layout from '../../../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Vad kostar det att hyra scen, ljud och ljus? Prisguide 2025",
      "description": "Konkreta prisintervall för uthyrning av scen, PA-system, ljus och DJ-utrustning i Stockholm. Uppdaterad 2025.",
      "author": { "@type": "Organization", "name": "Scenkonsult Norden" },
      "publisher": { "@type": "Organization", "name": "Scenkonsult Norden", "url": "https://scenkonsult.se" },
      "datePublished": "2025-01-01",
      "dateModified": "2025-03-01",
      "url": "https://scenkonsult.se/for/guider/vad-kostar-det/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Vad kostar det att hyra ett PA-system i Stockholm?", "acceptedAnswer": { "@type": "Answer", "text": "Ett PA-system för 50–100 gäster kostar 800–2 500 kr/dygn. För 100–300 gäster räknar du 2 500–5 000 kr/dygn. Kompletta system för stora event (300–2000 gäster) kostar 5 000–25 000 kr/dygn." } },
        { "@type": "Question", "name": "Vad kostar det att hyra en scen i Stockholm?", "acceptedAnswer": { "@type": "Answer", "text": "En liten scen (4–6 m²) kostar ca 599–1 200 kr/dygn. En medelscen (12–16 m²) kostar 1 500–3 500 kr/dygn. En stor festival-scen (24–48 m²) kostar 5 000–15 000 kr/dygn beroende på storlek och tillbehör." } },
        { "@type": "Question", "name": "Vad kostar leverans och montering?", "acceptedAnswer": { "@type": "Answer", "text": "Transport inom Storstockholm kostar 600–1 500 kr tur och retur beroende på mängd utrustning och adress. Montering debiteras per timme (600 kr/tim, min 15 min). De flesta standardpaket är klara på 1–2 timmar." } },
        { "@type": "Question", "name": "Är det billigare att hämta själv?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. Avhämtning är alltid gratis. Leverans tillkommer som extra kostnad. Om du har ett lämpligt fordon och tid att hämta och lämna är det ett enkelt sätt att spara 600–1 500 kr." } }
      ]
    }
  ]
};

const priser = [
  { kat: "Ljud — Portabelt", storlek: "1–2 högtalare", gaster: "10–50", pris: "599–999 kr/dygn", link: "/vara-tjanster/hyra-ljud/portable/" },
  { kat: "Ljud — Event", storlek: "Stereo + sub", gaster: "50–150", pris: "799–2 500 kr/dygn", link: "/vara-tjanster/hyra-ljud/event/" },
  { kat: "Ljud — Musik & dans", storlek: "Komplett danspaket", gaster: "100–300", pris: "999–4 500 kr/dygn", link: "/vara-tjanster/hyra-ljud/music/" },
  { kat: "Ljud — Live", storlek: "Line array, subs", gaster: "300–2000", pris: "3 000–15 000 kr/dygn", link: "/vara-tjanster/hyra-ljud/live/" },
  { kat: "Scen — Small", storlek: "4–6 m²", gaster: "20–200", pris: "599–999 kr/dygn", link: "/vara-tjanster/hyra-scen/" },
  { kat: "Scen — Medium", storlek: "12–16 m²", gaster: "100–500", pris: "1 500–3 500 kr/dygn", link: "/vara-tjanster/hyra-scen/" },
  { kat: "Scen — Large", storlek: "24–48 m²", gaster: "500+", pris: "5 000–15 000 kr/dygn", link: "/vara-tjanster/hyra-scen/" },
  { kat: "Ljus — Discoljus", storlek: "4–6 armaturer", gaster: "Alla", pris: "799–1 500 kr/dygn", link: "/vara-tjanster/hyra-ljus/" },
  { kat: "Ljus — Komplett", storlek: "Uplights + moving + laser", gaster: "50–300", pris: "2 500–6 000 kr/dygn", link: "/vara-tjanster/hyra-ljus/" },
  { kat: "DJ-utrustning", storlek: "Controller + högtalare", gaster: "50–200", pris: "1 500–4 000 kr/dygn", link: "/vara-tjanster/hyra-dj/" },
  { kat: "Projektor & duk", storlek: "4000–7000 lm + duk", gaster: "20–300", pris: "1 200–3 500 kr/dygn", link: "/vara-tjanster/hyra-bild-projektorer-skarmar/" },
  { kat: "Leverans (tur&retur)", storlek: "Storstockholm", gaster: "—", pris: "600–1 500 kr", link: "/bokningssida/" },
  { kat: "Montering / tekniker", storlek: "Per timme", gaster: "—", pris: "600 kr/tim", link: "/bokningssida/" },
];

const paket = [
  { title: "Liten fest, 50 gäster", items: ["Ljud: Event Small → 800 kr", "Ljus: Discoljus → 800 kr", "Leverans → 800 kr"], total: "~2 400 kr" },
  { title: "Bröllop, 100 gäster", items: ["Ljud: Music Small + sub → 1 500 kr", "Scen: 2×3 m → 799 kr", "Ljus: Uplights + disco → 2 000 kr", "Leverans + montering → 2 000 kr"], total: "~6 300 kr" },
  { title: "Företagsfest, 200 gäster", items: ["Ljud: Music Medium → 3 000 kr", "Scen: 4×3 m → 2 500 kr", "Ljus: Komplett paket → 4 000 kr", "DJ-utrustning → 2 000 kr", "Leverans + tekniker → 4 000 kr"], total: "~15 500 kr" },
];
---

<Layout
  title="Vad Kostar Det att Hyra Scen, Ljud & Ljus? Prisguide 2025 | Scenkonsult"
  description="Konkreta priser för hyra av PA-system, scen, ljus och DJ-utrustning i Stockholm 2025. Prisguide med exempel-paket. Scenkonsult — sedan 1986."
  schemaExtra={schema}
>

  <div style="background:linear-gradient(135deg,#1e1850 0%,#0c0a24 60%);padding-top:calc(36px + 130px + clamp(2rem,4vw,3.5rem));padding-bottom:clamp(2.5rem,5vw,4rem);padding-inline:clamp(1rem,5vw,5rem);">
    <div style="max-width:820px;margin:0 auto;">
      <nav aria-label="Brödsmulor" style="margin-bottom:1.5rem;">
        <ol style="display:flex;flex-wrap:wrap;gap:0.35rem;list-style:none;margin:0;padding:0;font-size:0.78rem;color:rgba(255,255,255,0.4);">
          <li><a href="/" style="color:rgba(255,255,255,0.5);text-decoration:none;">Hem</a> <span style="opacity:0.3;">/</span></li>
          <li><a href="/for/guider/" style="color:rgba(255,255,255,0.5);text-decoration:none;">Guider</a> <span style="opacity:0.3;">/</span></li>
          <li><span style="color:white;">Vad kostar det?</span></li>
        </ol>
      </nav>
      <p style="color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-size:0.78rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.6rem;">Prisguide 2025 · Av Scenkonsult Norden</p>
      <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2rem,5vw,3.25rem);line-height:1.1;color:white;margin:0 0 1rem;">Vad kostar det att hyra scen, ljud och ljus?</h1>
      <p style="color:rgba(255,255,255,0.6);font-size:clamp(0.95rem,2vw,1.1rem);line-height:1.75;margin:0;">Tydliga prisintervall för uthyrning av AV-utrustning i Stockholm. Alla priser är per dygn och inkluderar moms.</p>
    </div>
  </div>

  <article style="background:#0c0a24;padding:clamp(2.5rem,5vw,5rem) clamp(1rem,5vw,5rem);">
    <div style="max-width:820px;margin:0 auto;color:rgba(255,255,255,0.65);font-size:1rem;line-height:1.8;">

      <!-- Pristabell -->
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1.25rem;">Prisöversikt — alla kategorier</h2>
      <div style="overflow-x:auto;margin-bottom:3rem;">
        <table style="width:100%;border-collapse:collapse;font-size:0.87rem;">
          <thead>
            <tr style="border-bottom:2px solid rgba(196,181,244,0.25);">
              {["Kategori","Storlek/vad ingår","Gäster","Pris inkl. moms"].map(h => (
                <th style="text-align:left;padding:0.75rem 0.5rem;color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {priser.map((r, i) => (
              <tr style={`border-bottom:1px solid rgba(255,255,255,0.06);background:${i%2===0?'transparent':'rgba(255,255,255,0.02)'}`}>
                <td style="padding:0.75rem 0.5rem;"><a href={r.link} style="color:#c4b5f4;text-decoration:none;font-weight:600;">{r.kat}</a></td>
                <td style="padding:0.75rem 0.5rem;color:rgba(255,255,255,0.55);">{r.storlek}</td>
                <td style="padding:0.75rem 0.5rem;color:rgba(255,255,255,0.4);font-size:0.82rem;">{r.gaster}</td>
                <td style="padding:0.75rem 0.5rem;color:white;font-weight:600;">{r.pris}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="color:rgba(255,255,255,0.3);font-size:0.8rem;margin-bottom:3rem;">Priserna är riktpriser. Exakta priser visas på respektive produktsida. Begär offert för komplettering.</p>

      <!-- Exempelpaket -->
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1.5rem;">Exempel: totalkostnad för vanliga event</h2>
      <div style="display:flex;flex-direction:column;gap:1rem;margin-bottom:3rem;">
        {paket.map(p => (
          <div style="background:#1e1850;border-radius:12px;padding:1.5rem;display:flex;justify-content:space-between;align-items:flex-start;gap:2rem;flex-wrap:wrap;">
            <div style="flex:1;min-width:200px;">
              <h3 style="font-family:'Space Grotesk',sans-serif;font-size:0.9rem;font-weight:700;color:white;margin:0 0 0.75rem;">{p.title}</h3>
              {p.items.map(i => (
                <div style="display:flex;gap:0.5rem;padding:0.25rem 0;">
                  <span style="color:rgba(255,255,255,0.3);font-size:0.8rem;">+</span>
                  <span style="color:rgba(255,255,255,0.55);font-size:0.85rem;">{i}</span>
                </div>
              ))}
            </div>
            <div style="text-align:right;">
              <div style="color:rgba(255,255,255,0.3);font-size:0.72rem;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.25rem;">Totalt ca</div>
              <div style="font-family:'DM Serif Display',serif;font-size:1.75rem;color:#c4b5f4;">{p.total}</div>
            </div>
          </div>
        ))}
      </div>

      <!-- Sparatips -->
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1rem;">Sätt att sänka kostnaden</h2>
      <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:3rem;">
        {[
          { t:"Hämta själv", d:"Avhämtning är alltid gratis. Spara 600–1 500 kr i transport." },
          { t:"Hyr helg = betala 1 dygn", d:"Hyr fredag och lämna tillbaka måndag — betala bara för ett dygn om utrustningen inte är bokad." },
          { t:"Installera själv", d:"Standardpaket är byggda för att vara enkla att installera. Spara monteringskostnaden på enklare rigg." },
          { t:"Boka i förväg", d:"Sista-minuten-bokningar kan ha tilläggsavgift. Boka 2–4 veckor i förväg för bästa pris och tillgänglighet." },
        ].map(r => (
          <div style="display:flex;gap:1rem;padding:0.85rem 1rem;background:#1e1850;border-radius:8px;align-items:flex-start;">
            <span style="color:#86efac;font-size:0.8rem;margin-top:0.25rem;flex-shrink:0;">✓</span>
            <div>
              <strong style="color:white;font-size:0.9rem;">{r.t}:</strong>
              <span style="color:rgba(255,255,255,0.55);font-size:0.88rem;margin-left:0.4rem;">{r.d}</span>
            </div>
          </div>
        ))}
      </div>

      <div style="background:linear-gradient(135deg,#1e1850,#0c0a24);border:1px solid rgba(196,181,244,0.2);border-radius:16px;padding:2rem;text-align:center;margin-top:3rem;">
        <h2 style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:white;margin:0 0 0.5rem;">Begär offert — svar inom 2 timmar</h2>
        <p style="color:rgba(255,255,255,0.55);font-size:0.95rem;margin:0 0 1.5rem;">Berätta om ditt event så räknar vi ihop exakt pris för er.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <a href="/bokningssida/" style="background:#c4b5f4;color:#0c0a24;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.82rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:4px;">Begär offert</a>
          <a href="/vara-tjanster/" style="border:1px solid rgba(196,181,244,0.4);color:rgba(255,255,255,0.7);font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:4px;">Se sortiment</a>
        </div>
      </div>

      <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
        <p style="color:rgba(255,255,255,0.3);font-family:'Space Grotesk',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:1rem;">Relaterade guider</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
          <a href="/for/guider/hur-stor-pa/" style="background:#1e1850;border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:0.6rem 1rem;color:rgba(255,255,255,0.6);font-size:0.85rem;text-decoration:none;">Hur stor PA? →</a>
          <a href="/for/guider/hur-stor-scen/" style="background:#1e1850;border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:0.6rem 1rem;color:rgba(255,255,255,0.6);font-size:0.85rem;text-decoration:none;">Hur stor scen? →</a>
          <a href="/for/guider/checklista-event/" style="background:#1e1850;border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:0.6rem 1rem;color:rgba(255,255,255,0.6);font-size:0.85rem;text-decoration:none;">Komplett checklista →</a>
        </div>
      </div>
    </div>
  </article>
</Layout>
