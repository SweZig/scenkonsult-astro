---
import Layout from '../../../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Hur stor scen behöver jag? Komplett guide med tabell",
      "description": "Räkna ut rätt scenstorlek för ditt event. Tabeller för antal artister, eventtyp och publkistorlek.",
      "author": { "@type": "Organization", "name": "Scenkonsult Norden" },
      "publisher": { "@type": "Organization", "name": "Scenkonsult Norden", "url": "https://scenkonsult.se" },
      "datePublished": "2025-01-01",
      "dateModified": "2025-03-01",
      "url": "https://scenkonsult.se/for/guider/hur-stor-scen/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Hur stor scen behöver jag till ett bröllop?", "acceptedAnswer": { "@type": "Answer", "text": "Till ett bröllop med trubadur eller DJ räcker en scen på 4–6 m² (t.ex. 2×2 m eller 2×3 m). Vill ni ha ett band med 3–4 musiker behöver ni 12–16 m². En scen signalerar till gästerna var det händer saker och skapar dansyta framför." } },
        { "@type": "Question", "name": "Hur många kvadratmeter per person på scenen?", "acceptedAnswer": { "@type": "Answer", "text": "Räkna ca 2–4 m² per person på scenen. En ensam DJ klarar 4 m², ett band med 4 musiker behöver 12–16 m², en fullständig band med backline och trummor vill ha 20–30 m²." } },
        { "@type": "Question", "name": "Behöver jag scentak till utomhus-event?", "acceptedAnswer": { "@type": "Answer", "text": "Ja, alltid vid utomhus-event om det finns risk för regn. Scentak skyddar utrustning värd tiotals- eller hundratusentals kronor. Det ger också artister trygghet och ett professionellt intryck. Vi hyr ut scentak till alla scenstorlekar." } },
        { "@type": "Question", "name": "Vilken scenhöjd passar mitt event?", "acceptedAnswer": { "@type": "Answer", "text": "Standard scenhöjder är 40 cm (liten fest/DJ), 60 cm (normalt event, synligt för 50–200 gäster) och 80–100 cm (stor publik, konsert). Vid 60 cm ser en publik på 150–300 gäster scenen utan problem. Höjd över 100 cm kräver räcken." } }
      ]
    }
  ]
};

const scenStorlekar = [
  { storlek: "2×2 m (4 m²)", for: "DJ solo, trubadur", gaster: "20–100", hojd: "40–60 cm", notat: "Minsta praktiska scen" },
  { storlek: "2×3 m (6 m²)", for: "DJ + utrustning, tal", gaster: "50–200", hojd: "40–60 cm", notat: "Populärast för bröllop" },
  { storlek: "4×3 m (12 m²)", for: "Trio, kvartett, DJ-setup", gaster: "100–300", hojd: "60 cm", notat: "Minsta för band" },
  { storlek: "4×4 m (16 m²)", for: "Fullband 4–5 pers", gaster: "200–500", hojd: "60–80 cm", notat: "Standard festival-small" },
  { storlek: "6×4 m (24 m²)", for: "Stor band med backline", gaster: "500–1000", hojd: "80–100 cm", notat: "Festival medium" },
  { storlek: "8×6 m (48 m²)", for: "Proffsband, artister", gaster: "1000+", hojd: "100–120 cm", notat: "Festival large" },
];
---

<Layout
  title="Hur Stor Scen Behöver Jag? Guide & Tabell | Scenkonsult"
  description="Räkna ut rätt scenstorlek för ditt event. Tabell med scenstorlekar, antal artister och gäster. Hyra scen i Stockholm från 599 kr — Scenkonsult sedan 1986."
  schemaExtra={schema}
>

  <div style="background:linear-gradient(135deg,#1e1850 0%,#0c0a24 60%);padding-top:calc(36px + 130px + clamp(2rem,4vw,3.5rem));padding-bottom:clamp(2.5rem,5vw,4rem);padding-inline:clamp(1rem,5vw,5rem);">
    <div style="max-width:820px;margin:0 auto;">
      <nav aria-label="Brödsmulor" style="margin-bottom:1.5rem;">
        <ol style="display:flex;flex-wrap:wrap;gap:0.35rem;list-style:none;margin:0;padding:0;font-size:0.78rem;color:rgba(255,255,255,0.4);">
          <li><a href="/" style="color:rgba(255,255,255,0.5);text-decoration:none;">Hem</a> <span style="opacity:0.3;">/</span></li>
          <li><a href="/for/" style="color:rgba(255,255,255,0.5);text-decoration:none;">För ditt event</a> <span style="opacity:0.3;">/</span></li>
          <li><a href="/for/guider/" style="color:rgba(255,255,255,0.5);text-decoration:none;">Guider</a> <span style="opacity:0.3;">/</span></li>
          <li><span style="color:white;">Hur stor scen behöver jag?</span></li>
        </ol>
      </nav>
      <p style="color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-size:0.78rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.6rem;">Guide · Av Scenkonsult Norden</p>
      <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2rem,5vw,3.25rem);line-height:1.1;color:white;margin:0 0 1rem;">Hur stor scen behöver jag?</h1>
      <p style="color:rgba(255,255,255,0.6);font-size:clamp(0.95rem,2vw,1.1rem);line-height:1.75;margin:0;">Vi har hyrt ut scener sedan 1986. Den vanligaste frågan vi får: "Hur stor scen behöver vi?" Svaret beror på vem som ska stå på den, hur många gäster som ska se och om det är inne eller ute.</p>
    </div>
  </div>

  <article style="background:#0c0a24;padding:clamp(2.5rem,5vw,5rem) clamp(1rem,5vw,5rem);">
    <div style="max-width:820px;margin:0 auto;color:rgba(255,255,255,0.65);font-size:1rem;line-height:1.8;">

      <!-- Snabbsvar -->
      <div style="background:#1e1850;border:1px solid rgba(196,181,244,0.25);border-radius:14px;padding:1.75rem;margin-bottom:3rem;">
        <p style="color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 0.75rem;">Snabbsvar</p>
        <ul style="margin:0;padding:0 0 0 1.25rem;display:flex;flex-direction:column;gap:0.5rem;">
          <li><strong style="color:white;">DJ eller trubadur:</strong> 4–6 m² räcker (2×2 eller 2×3 m)</li>
          <li><strong style="color:white;">Band med 3–4 musiker:</strong> 12–16 m² (4×3 eller 4×4 m)</li>
          <li><strong style="color:white;">Fullband med backline:</strong> 20–30 m² minimum</li>
          <li><strong style="color:white;">Utomhus:</strong> Lägg alltid till scentak</li>
          <li><strong style="color:white;">Tumregel:</strong> 2–4 m² per person på scenen</li>
        </ul>
      </div>

      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1rem;">Varför spelar scenstorleken roll?</h2>
      <p>En för liten scen tvingar artister att stå trångt — det påverkar prestandan och ser oprofessionellt ut. En för stor scen kan kännas tom och lyfter inte stämningen. Rätt storlek signalerar till gästerna att det händer saker, och skapar ett naturligt dansyta framför.</p>
      <p>En scen — även en liten 2×2 m — är alltid värd det. Den höjer upplevelsen dramatiskt jämfört med att DJ:n eller artisten står på golv bland gästerna.</p>

      <!-- Tabell -->
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:3rem 0 1rem;">Scenstorlekar — referenstabell</h2>
      <div style="overflow-x:auto;margin-bottom:2.5rem;">
        <table style="width:100%;border-collapse:collapse;font-size:0.87rem;">
          <thead>
            <tr style="border-bottom:2px solid rgba(196,181,244,0.25);">
              {["Storlek","För","Gäster","Höjd","Notat"].map(h => (
                <th style="text-align:left;padding:0.75rem 0.5rem;color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {scenStorlekar.map((r, i) => (
              <tr style={`border-bottom:1px solid rgba(255,255,255,0.06);background:${i%2===0?'transparent':'rgba(255,255,255,0.02)'}`}>
                <td style="padding:0.75rem 0.5rem;color:white;font-weight:600;white-space:nowrap;">{r.storlek}</td>
                <td style="padding:0.75rem 0.5rem;color:rgba(255,255,255,0.65);">{r.for}</td>
                <td style="padding:0.75rem 0.5rem;color:rgba(255,255,255,0.55);white-space:nowrap;">{r.gaster}</td>
                <td style="padding:0.75rem 0.5rem;color:rgba(255,255,255,0.55);white-space:nowrap;">{r.hojd}</td>
                <td style="padding:0.75rem 0.5rem;color:rgba(255,255,255,0.4);font-size:0.82rem;">{r.notat}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Scenhöjd -->
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:3rem 0 1rem;">Vilken höjd ska scenen ha?</h2>
      <p>Scenhöjden avgörs av hur stor publik som ska se. Grundregeln: ju fler gäster och ju djupare lokalen är, desto högre scen behövs.</p>
      <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:2rem;">
        {[
          { hojd: "40 cm", for: "Intim fest, 20–80 gäster. Enkel trappa, låg säkerhetsrisk." },
          { hojd: "60 cm", for: "Standard för de flesta event, 50–300 gäster. Bra sikt, stabil plattform." },
          { hojd: "80–100 cm", for: "Stora publiker, festival. Räcken krävs enligt säkerhetsregler." },
          { hojd: "100+ cm", for: "Professionell konsert. Räcken, backstage-tillgång och scenkjol." },
        ].map(r => (
          <div style="display:flex;gap:1rem;padding:0.75rem;background:#1e1850;border-radius:8px;align-items:flex-start;">
            <span style="font-family:'DM Serif Display',serif;font-size:1.1rem;color:#c4b5f4;min-width:70px;flex-shrink:0;">{r.hojd}</span>
            <span style="color:rgba(255,255,255,0.6);font-size:0.9rem;line-height:1.6;">{r.for}</span>
          </div>
        ))}
      </div>

      <!-- Tillbehör -->
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:3rem 0 1rem;">Glöm inte tillbehören</h2>
      <p>En scen utan rätt tillbehör ser halvfärdig ut. De viktigaste tillbehören:</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.75rem;margin-bottom:2rem;">
        {[
          { name: "Scentrapp", desc: "Obligatorisk för säker på/avstigning" },
          { name: "Scenkjol", desc: "Döljer benen och ger professionellt utseende" },
          { name: "Backdrop", desc: "Bakgrundstyg — lyfter hela scenbilden" },
          { name: "Scentak", desc: "Obligatoriskt utomhus vid regn-risk" },
        ].map(t => (
          <div style="background:#1e1850;border-radius:8px;padding:1rem;">
            <div style="color:white;font-weight:600;font-size:0.9rem;margin-bottom:0.25rem;">{t.name}</div>
            <div style="color:rgba(255,255,255,0.45);font-size:0.82rem;">{t.desc}</div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div style="background:linear-gradient(135deg,#1e1850,#0c0a24);border:1px solid rgba(196,181,244,0.2);border-radius:16px;padding:2rem;text-align:center;margin-top:3rem;">
        <h2 style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:white;margin:0 0 0.5rem;">Se våra scenpaket</h2>
        <p style="color:rgba(255,255,255,0.55);font-size:0.95rem;margin:0 0 1.5rem;">Modulscener från 4 m² till 48 m². Leverans och montering i hela Storstockholm.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <a href="/vara-tjanster/hyra-scen/" style="background:#c4b5f4;color:#0c0a24;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.82rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:4px;">Se alla scenpaket</a>
          <a href="/bokningssida/" style="border:1px solid rgba(196,181,244,0.4);color:rgba(255,255,255,0.7);font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:4px;">Begär offert</a>
        </div>
      </div>

      <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
        <p style="color:rgba(255,255,255,0.3);font-family:'Space Grotesk',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:1rem;">Relaterade guider</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
          <a href="/for/guider/hur-stor-pa/" style="background:#1e1850;border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:0.6rem 1rem;color:rgba(255,255,255,0.6);font-size:0.85rem;text-decoration:none;">Hur stor PA behöver jag? →</a>
          <a href="/for/guider/dj-eller-liveband/" style="background:#1e1850;border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:0.6rem 1rem;color:rgba(255,255,255,0.6);font-size:0.85rem;text-decoration:none;">DJ eller liveband? →</a>
          <a href="/for/guider/checklista-event/" style="background:#1e1850;border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:0.6rem 1rem;color:rgba(255,255,255,0.6);font-size:0.85rem;text-decoration:none;">Komplett checklista →</a>
        </div>
      </div>
    </div>
  </article>
</Layout>
