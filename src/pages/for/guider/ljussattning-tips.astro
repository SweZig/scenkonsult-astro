---
import Layout from '../../../layouts/Layout.astro';
import MomsToggle from '../../../components/MomsToggle.astro';
const schema = {"@context":"https://schema.org","@graph":[{"@type":"Article","headline":"Ljussättning för event — guide till bättre stämning 2025","author":{"@type":"Organization","name":"Scenkonsult Norden"},"datePublished":"2025-01-01","url":"https://scenkonsult.se/for/guider/ljussattning-tips/"},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Vad kostar det att hyra ljus till ett event?","acceptedAnswer":{"@type":"Answer","text":"Ljuspaket Small (10–30 pers) kostar 399 kr/dygn exkl moms. Medium (40–80 pers) 1 199 kr/dygn. Enstaka LED PAR-armaturer kostar fr 79 kr/dygn. Rökmaskin 349–449 kr/dygn."}},{"@type":"Question","name":"Behöver jag rökmaskin till lasern?","acceptedAnswer":{"@type":"Answer","text":"Ja. En laser utan rök eller haze är knappt synlig. Rökmaskin 1500W kostar 349 kr/dygn."}},{"@type":"Question","name":"Vilket ljuspaket passar 100 gäster?","acceptedAnswer":{"@type":"Answer","text":"Ljuspaket Medium (40–80 pers, 1 199 kr/dygn) eller Medium+ (40–100 pers, 1 299 kr/dygn). Komplettera med enstaka LED PAR-armaturer (fr 79 kr/st) för väggfärg."}}]}]};
const paket = [
  {n:"Ljuspaket, Small",p:399,pers:"10–30 pers.",d:"T-bar med 4× PAR RGBW på stativ. Synkar till musik. Plug and play."},
  {n:"Ljuspaket, Small+",p:599,pers:"20–40 pers.",d:"Trosstorn med moving head 100W COB. Roterar 540°, DMX/musikstyrning."},
  {n:"Ljuspaket, Small++",p:799,pers:"20–60 pers.",d:"4 effekttyper på 2 stativ: PAR, roterande armatur, strobe/UV och laser."},
  {n:"Ljuspaket, Medium",p:1199,pers:"40–80 pers.",d:"Komplett diskoljus med moving heads och PAR-bank. Bra bas för dansgolv."},
  {n:"Ljuspaket, Medium+",p:1299,pers:"40–100 pers.",d:"Utökat medium med extra moving head-täckning."},
  {n:"Ljuspaket, Medium++",p:1499,pers:"50–120 pers.",d:"Maxpaketet för medelstora event. Full täckning, inga blinda fläckar."},
];
const effekter = [
  {n:"LED PAR (14×8W RGBW)",p:79,d:"Väggfärg / uplight"},
  {n:"LED PAR (9×10W RGBW)",p:99,d:"Starkare variant"},
  {n:"LED PAR UV",p:119,d:"UV-ljus / black light"},
  {n:"LED PAR XL (60×2W RGBW)",p:149,d:"Bred wash-täckning"},
  {n:"LED-armatur, uppladdningsbar",p:199,d:"Trådlös, batteri"},
];
const rok = [
  {n:"Rökmaskin (1500W)",p:349},{n:"Rökmaskin (650W)",p:449},{n:"Kallgnistmaskin",p:499},{n:"Konfettiavfyrare",p:499}
];
---
<Layout title="Ljussättning för Event — Guide & Priser 2025 | Scenkonsult" description="Typer av ljus, dramaturgi och vanliga misstag. Priser på ljuspaket fr 399 kr/dygn — matchade mot vårt sortiment. Scenkonsult sedan 1986." schemaExtra={schema}>
  <div style="background:linear-gradient(135deg,#1e1850 0%,#0c0a24 60%);padding-top:calc(36px + 130px + clamp(2rem,4vw,3.5rem));padding-bottom:clamp(2.5rem,5vw,4rem);padding-inline:clamp(1rem,5vw,5rem);">
    <div style="max-width:820px;margin:0 auto;">
      <nav aria-label="Brödsmulor" style="margin-bottom:1.5rem;"><ol style="display:flex;flex-wrap:wrap;gap:0.35rem;list-style:none;margin:0;padding:0;font-size:0.78rem;color:rgba(255,255,255,0.4);"><li><a href="/" style="color:rgba(255,255,255,0.5);text-decoration:none;">Hem</a> <span style="opacity:0.3;">/</span></li><li><a href="/for/guider/" style="color:rgba(255,255,255,0.5);text-decoration:none;">Guider</a> <span style="opacity:0.3;">/</span></li><li style="color:white;">Ljussättning</li></ol></nav>
      <p style="color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-size:0.78rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.6rem;">Guide · Av Scenkonsult Norden</p>
      <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2rem,5vw,3.25rem);line-height:1.1;color:white;margin:0 0 1rem;">Ljussättning för event — rätt stämning med rätt utrustning</h1>
      <p style="color:rgba(255,255,255,0.6);font-size:clamp(0.95rem,2vw,1.1rem);line-height:1.75;margin:0;">Rätt ljus är det billigaste sättet att transformera ett rum. Alla priser nedan är ur vårt faktiska sortiment.</p>
    </div>
  </div>
  <article style="background:#0c0a24;padding:clamp(2.5rem,5vw,5rem) clamp(1rem,5vw,5rem);">
    <div style="max-width:820px;margin:0 auto;color:rgba(255,255,255,0.65);font-size:1rem;line-height:1.8;">
      <MomsToggle />
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1.25rem;">Ljuspaket — välj efter gästantal</h2>
      <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:3rem;">
        {paket.map(p=>(
          <div style="background:#1e1850;border-radius:12px;padding:1.25rem 1.5rem;display:flex;justify-content:space-between;gap:1.5rem;align-items:flex-start;flex-wrap:wrap;">
            <div>
              <div style="color:white;font-weight:700;font-size:0.92rem;margin-bottom:0.2rem;">{p.n}</div>
              <div style="color:#c4b5f4;font-size:0.78rem;margin-bottom:0.4rem;">{p.pers}</div>
              <div style="color:rgba(255,255,255,0.5);font-size:0.87rem;line-height:1.55;">{p.d}</div>
            </div>
            <div style="text-align:right;flex-shrink:0;">
              <div style="color:#c4b5f4;font-family:'DM Serif Display',serif;font-size:1.5rem;white-space:nowrap;"><span data-exkl={p.p}>{p.p}</span> kr</div>
              <div style="color:rgba(255,255,255,0.3);font-size:0.72rem;">per dygn</div>
            </div>
          </div>
        ))}
      </div>
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:3rem 0 1.25rem;">Enstaka armaturer — bygg din egen rigg</h2>
      <p style="margin-bottom:1.25rem;">Komplettera paketet med enstaka LED PAR-armaturer för väggfärg (uplight-effekt), eller bygg en helt custom rigg.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.75rem;margin-bottom:1rem;">
        {effekter.map(e=>(
          <div style="background:#1e1850;border-radius:8px;padding:1rem;display:flex;justify-content:space-between;align-items:center;gap:0.5rem;">
            <div><div style="color:rgba(255,255,255,0.7);font-size:0.87rem;font-weight:600;">{e.n}</div><div style="color:rgba(255,255,255,0.35);font-size:0.75rem;">{e.d}</div></div>
            <div style="color:#c4b5f4;font-weight:700;white-space:nowrap;"><span data-exkl={e.p}>{e.p}</span> kr</div>
          </div>
        ))}
      </div>
      <p style="color:rgba(255,255,255,0.3);font-size:0.8rem;margin-bottom:3rem;">Stativ med T-bar ingår i paketen. Separat: stativ fr <span data-exkl="40">40</span> kr, trosstorn fr <span data-exkl="300">300</span> kr.</p>
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:3rem 0 1.25rem;">Rök, gnistor och konfetti</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.75rem;margin-bottom:3rem;">
        {rok.map(r=>(
          <div style="background:#1e1850;border-radius:8px;padding:1rem;display:flex;justify-content:space-between;align-items:center;">
            <span style="color:rgba(255,255,255,0.7);font-size:0.87rem;">{r.n}</span>
            <span style="color:#c4b5f4;font-weight:700;white-space:nowrap;margin-left:0.5rem;"><span data-exkl={r.p}>{r.p}</span> kr</span>
          </div>
        ))}
      </div>
      <div style="background:#1e1850;border:1px solid rgba(255,100,100,0.2);border-radius:12px;padding:1.5rem;margin-bottom:3rem;">
        <h3 style="font-family:'Space Grotesk',sans-serif;font-size:0.9rem;font-weight:700;color:#fbbf24;margin:0 0 0.75rem;">⚡ Kom ihåg: laser utan rök syns knappt</h3>
        <p style="color:rgba(255,255,255,0.55);font-size:0.88rem;line-height:1.65;margin:0;">Small++ och Medium-paketen inkluderar laser. För maximal effekt behöver du rökmaskin (fr <span data-exkl="349">349</span> kr/dygn) — annars är ljusstrålarna knappt synliga i luften.</p>
      </div>
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1rem;">Ljus-dramaturgi under kvällen</h2>
      <div style="display:flex;flex-direction:column;gap:0;margin-bottom:2.5rem;">
        {[{fas:"Mingel & middag",tid:"18:00–21:00",desc:"Paketet i auto-musik-läge. Varma färger, låg intensitet. Ingen strobe."},{fas:"Tal & underhållning",tid:"20:00–22:00",desc:"Dimma ner. Eventuell spotlight på talare vid scenen."},{fas:"Dansgolvet öppnar",tid:"22:00+",desc:"Höj intensiteten. Aktivera rök. Färgskiftande läge. Strobe sparsamt."}].map(f=>(
          <div style="background:rgba(196,181,244,0.04);border:1px solid rgba(255,255,255,0.07);padding:1.1rem 1.5rem;">
            <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.4rem;">
              <h3 style="font-family:'Space Grotesk',sans-serif;font-size:0.88rem;font-weight:700;color:white;margin:0;">{f.fas}</h3>
              <span style="color:rgba(255,255,255,0.25);font-size:0.75rem;">{f.tid}</span>
            </div>
            <p style="color:rgba(255,255,255,0.55);font-size:0.87rem;line-height:1.6;margin:0;">{f.desc}</p>
          </div>
        ))}
      </div>
      <div style="background:linear-gradient(135deg,#1e1850,#0c0a24);border:1px solid rgba(196,181,244,0.2);border-radius:16px;padding:2rem;text-align:center;margin-top:3rem;">
        <h2 style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:white;margin:0 0 0.5rem;">Se alla ljuspriser</h2>
        <p style="color:rgba(255,255,255,0.55);font-size:0.95rem;margin:0 0 1.5rem;">Ljuspaket fr <span data-exkl="399">399</span> kr/dygn. Enstaka armaturer fr <span data-exkl="79">79</span> kr. Leverans i hela Storstockholm.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <a href="/vara-tjanster/hyra-ljus/" style="background:#c4b5f4;color:#0c0a24;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.82rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:4px;">Se ljuspaket</a>
          <a href="/bokningssida/" style="border:1px solid rgba(196,181,244,0.4);color:rgba(255,255,255,0.7);font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:4px;">Begär offert</a>
        </div>
      </div>
    </div>
  </article>
</Layout>
