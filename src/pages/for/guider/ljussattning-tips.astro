---
import Layout from '../../../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Ljussättning för event — komplett guide till bättre stämning",
      "description": "Lär dig grunderna i ljussättning för fest och event. Typer av ljus, placering, färgtemperatur och de vanligaste misstagen.",
      "author": { "@type": "Organization", "name": "Scenkonsult Norden" },
      "publisher": { "@type": "Organization", "name": "Scenkonsult Norden", "url": "https://scenkonsult.se" },
      "datePublished": "2025-01-01",
      "dateModified": "2025-03-01",
      "url": "https://scenkonsult.se/for/guider/ljussattning-tips/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Vilken typ av ljus behöver jag till ett bröllop?", "acceptedAnswer": { "@type": "Answer", "text": "Till ett bröllop behöver du minst: uplights längs väggarna (8–16 st för en normal festlokal), spotlights på bordsarrangemangen och ett dansgolvspaket med disco/moving heads. Uplights är det enskilt bästa sättet att transformera en lokal." } },
        { "@type": "Question", "name": "Vad är skillnaden på wash och spot-ljus?", "acceptedAnswer": { "@type": "Answer", "text": "Wash-ljus (PAR-lampor, LED-bars) ger brett, mjukt ljus som färgar ytor och skapar stämning. Spot-ljus ger en skarp, riktad stråle — bra för att belysa talare, artister eller specifika platser. De flesta event behöver en kombination av båda." } },
        { "@type": "Question", "name": "Hur mycket ljus behövs till 100 gäster?", "acceptedAnswer": { "@type": "Answer", "text": "Till 100 gäster i en normal festlokal: 8–12 uplights längs väggarna, 4–6 LED-par för scenbelysning, 2–4 moving heads för dansgolvet och eventuellt 1–2 stroboskop. Totalt ca 15–25 armaturer för en bra täckning." } },
        { "@type": "Question", "name": "Vad kostar det att hyra ljus till ett event?", "acceptedAnswer": { "@type": "Answer", "text": "Grundpaket med discoljus för dansgolvet (4–6 lampor) kostar ca 800–1 500 kr/dygn. Ett komplett ljuspaket med uplights, moving heads och rökmaskin för 100 gäster kostar ca 2 500–5 000 kr/dygn." } }
      ]
    }
  ]
};

const ljustyper = [
  { namn: "Uplight / PAR-lampa", anv: "Väggfärg, stämningsljus", styrka: "Stämning", notat: "Enklaste sättet att transformera en lokal" },
  { namn: "Moving head (wash)", anv: "Scenbelysning, färgeffekter", styrka: "Rörelse", notat: "Ger liv åt dansgolvet" },
  { namn: "Moving head (beam)", anv: "Spotlight, dramatik", styrka: "Dramatik", notat: "Laserstrålar i luften" },
  { namn: "Strobe / blixtljus", anv: "Dansgolv, höjdpunkter", styrka: "Energi", notat: "Sparsamt — effektfullt när det används rätt" },
  { namn: "Laser", anv: "Dansgolv, show", styrka: "WOW", notat: "Kräver rök/haze för maxeffekt" },
  { namn: "LED-bar / batten", anv: "Scen-wash, bakgrundsfärg", styrka: "Täckning", notat: "Bra baslager för scener" },
  { namn: "Rökmaskin / hazer", anv: "Synliggör ljusstrålar", styrka: "Synlighet", notat: "Obligatorisk för laser och beam-effekter" },
  { namn: "Discokula", anv: "Klassisk dansstämning", styrka: "Nostalgi", notat: "Kräver en motoriserad spotlight" },
];
---

<Layout
  title="Ljussättning för Event — Guide till Bättre Stämning | Scenkonsult"
  description="Lär dig grunderna i ljussättning för fest och event. Typer av ljus, placering, färgtemperatur och vanliga misstag. Från Scenkonsult — uthyrare sedan 1986."
  schemaExtra={schema}
>

  <div style="background:linear-gradient(135deg,#1e1850 0%,#0c0a24 60%);padding-top:calc(36px + 130px + clamp(2rem,4vw,3.5rem));padding-bottom:clamp(2.5rem,5vw,4rem);padding-inline:clamp(1rem,5vw,5rem);">
    <div style="max-width:820px;margin:0 auto;">
      <nav aria-label="Brödsmulor" style="margin-bottom:1.5rem;">
        <ol style="display:flex;flex-wrap:wrap;gap:0.35rem;list-style:none;margin:0;padding:0;font-size:0.78rem;color:rgba(255,255,255,0.4);">
          <li><a href="/" style="color:rgba(255,255,255,0.5);text-decoration:none;">Hem</a> <span style="opacity:0.3;">/</span></li>
          <li><a href="/for/guider/" style="color:rgba(255,255,255,0.5);text-decoration:none;">Guider</a> <span style="opacity:0.3;">/</span></li>
          <li><span style="color:white;">Ljussättning för event</span></li>
        </ol>
      </nav>
      <p style="color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-size:0.78rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.6rem;">Guide · Av Scenkonsult Norden</p>
      <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2rem,5vw,3.25rem);line-height:1.1;color:white;margin:0 0 1rem;">Ljussättning för event — så sätter du rätt stämning</h1>
      <p style="color:rgba(255,255,255,0.6);font-size:clamp(0.95rem,2vw,1.1rem);line-height:1.75;margin:0;">Rätt ljussättning är det billigaste och mest dramatiska sättet att lyfta ett event. En festlokal som ser trist ut i vanligt lysrör kan bli magisk med rätt ljus — utan att det kostar mer än ett par tusenlappar.</p>
    </div>
  </div>

  <article style="background:#0c0a24;padding:clamp(2.5rem,5vw,5rem) clamp(1rem,5vw,5rem);">
    <div style="max-width:820px;margin:0 auto;color:rgba(255,255,255,0.65);font-size:1rem;line-height:1.8;">

      <div style="background:#1e1850;border:1px solid rgba(196,181,244,0.25);border-radius:14px;padding:1.75rem;margin-bottom:3rem;">
        <p style="color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 0.75rem;">Grundregeln</p>
        <p style="color:white;font-size:1.05rem;margin:0;line-height:1.65;">Varmt ljus (2 700–3 500 K, amber/orange) = stämning och intimitet. Kallt ljus (5 000–6 500 K, vitt/blått) = professionellt, kliniskt. <strong>På dansgolvet: dimma ner det kalla, lägg till rörelse och färg.</strong></p>
      </div>

      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1rem;">Upplights — den enskilt största förändringen</h2>
      <p>Om du bara kan köpa en sak — köp uplights. Åtta till sexton upplights längs väggarna förvandlar en lokal mer än allt annat. De ändrar lokalens färg, döljer fula väggar och skapar en omslutande känsla.</p>
      <p>Placera dem var tredje meter längs väggarna, riktade rakt upp mot taket eller mot en neutral vägg. Välj en färg som passar teman — lavendel/lila för bröllop, blå för företag, varm amber för gala.</p>

      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:3rem 0 1.25rem;">Typer av ljusutrustning</h2>
      <div style="overflow-x:auto;margin-bottom:3rem;">
        <table style="width:100%;border-collapse:collapse;font-size:0.87rem;">
          <thead>
            <tr style="border-bottom:2px solid rgba(196,181,244,0.25);">
              {["Ljustyp","Användning","Styrka","Notat"].map(h => (
                <th style="text-align:left;padding:0.75rem 0.5rem;color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {ljustyper.map((r, i) => (
              <tr style={`border-bottom:1px solid rgba(255,255,255,0.06);background:${i%2===0?'transparent':'rgba(255,255,255,0.02)'}`}>
                <td style="padding:0.75rem 0.5rem;color:white;font-weight:600;white-space:nowrap;">{r.namn}</td>
                <td style="padding:0.75rem 0.5rem;color:rgba(255,255,255,0.6);">{r.anv}</td>
                <td style="padding:0.75rem 0.5rem;"><span style="background:rgba(196,181,244,0.12);color:#c4b5f4;font-size:0.75rem;padding:0.2rem 0.5rem;border-radius:9999px;">{r.styrka}</span></td>
                <td style="padding:0.75rem 0.5rem;color:rgba(255,255,255,0.4);font-size:0.82rem;">{r.notat}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1rem;">Ljus-dramaturgi under kvällen</h2>
      <p>Ljuset ska ändras i takt med kvällen — precis som musiken. Tänk i tre faser:</p>
      <div style="display:flex;flex-direction:column;gap:0;margin-bottom:2.5rem;">
        {[
          { fas:"Mingel & middag", tid:"18:00–21:00", desc:"Varmt, dämpad ljusnivå. Uplights i amber/guld. Bordsbelysning tänd. Inget discoljus ännu.", color:"rgba(255,200,100,0.15)" },
          { fas:"Tal & underhållning", tid:"20:00–22:00", desc:"Spotlight på talare. Uplights dimmas till 50%. Scenljus på artister. Rummet fokuseras.", color:"rgba(196,181,244,0.1)" },
          { fas:"Dansgolvet öppnar", tid:"22:00–02:00", desc:"Moving heads aktiveras. Färgerna skiftar. Rökmaskin och laser på. Upplights till 100% i dansande färger.", color:"rgba(100,150,255,0.1)" },
        ].map(f => (
          <div style={`background:${f.color};border:1px solid rgba(255,255,255,0.08);padding:1.25rem 1.5rem;`}>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;flex-wrap:wrap;gap:0.5rem;">
              <h3 style="font-family:'Space Grotesk',sans-serif;font-size:0.9rem;font-weight:700;color:white;margin:0;">{f.fas}</h3>
              <span style="color:rgba(255,255,255,0.3);font-size:0.78rem;">{f.tid}</span>
            </div>
            <p style="color:rgba(255,255,255,0.6);font-size:0.88rem;line-height:1.6;margin:0;">{f.desc}</p>
          </div>
        ))}
      </div>

      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:3rem 0 1rem;">4 vanliga misstag</h2>
      <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:2.5rem;">
        {[
          { nr:"01", m:"Lämna rumslyset på", lösn:"Dimma ner all fast belysning och låt event-ljuset ta över. Blandat ljus förstör stämningen." },
          { nr:"02", m:"Rikta spottar mot publiken", lösn:"Spottar och moving heads ska lysa på scen, tak och väggar — inte in i ögonen på gästerna." },
          { nr:"03", m:"Använda laser utan rök", lösn:"En laser utan rök eller haze syns knappt. Rökmaskin är obligatorisk för att synliggöra strålarna." },
          { nr:"04", m:"Samma färg hela kvällen", lösn:"Ljuset ska följa dramaturgin. Programmera eller styr ljuset manuellt i takt med kvällen." },
        ].map(m => (
          <div style="background:#1e1850;border-radius:10px;padding:1.25rem 1.5rem;display:flex;gap:1.25rem;">
            <span style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:rgba(196,181,244,0.25);line-height:1;flex-shrink:0;">{m.nr}</span>
            <div>
              <h3 style="font-family:'Space Grotesk',sans-serif;font-size:0.9rem;font-weight:700;color:#ff9999;margin:0 0 0.35rem;">✗ {m.m}</h3>
              <p style="color:rgba(255,255,255,0.55);font-size:0.88rem;line-height:1.6;margin:0;"><span style="color:#86efac;">✓ Lösning:</span> {m.lösn}</p>
            </div>
          </div>
        ))}
      </div>

      <div style="background:linear-gradient(135deg,#1e1850,#0c0a24);border:1px solid rgba(196,181,244,0.2);border-radius:16px;padding:2rem;text-align:center;margin-top:3rem;">
        <h2 style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:white;margin:0 0 0.5rem;">Se våra ljuspaket</h2>
        <p style="color:rgba(255,255,255,0.55);font-size:0.95rem;margin:0 0 1.5rem;">Uplights, moving heads, laser och rökmaskin. Leverans i hela Storstockholm.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <a href="/vara-tjanster/hyra-ljus/" style="background:#c4b5f4;color:#0c0a24;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.82rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:4px;">Se ljuspaket</a>
          <a href="/bokningssida/" style="border:1px solid rgba(196,181,244,0.4);color:rgba(255,255,255,0.7);font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:4px;">Begär offert</a>
        </div>
      </div>

      <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
        <p style="color:rgba(255,255,255,0.3);font-family:'Space Grotesk',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:1rem;">Relaterade guider</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
          <a href="/for/guider/hur-stor-pa/" style="background:#1e1850;border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:0.6rem 1rem;color:rgba(255,255,255,0.6);font-size:0.85rem;text-decoration:none;">Hur stor PA? →</a>
          <a href="/for/guider/checklista-event/" style="background:#1e1850;border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:0.6rem 1rem;color:rgba(255,255,255,0.6);font-size:0.85rem;text-decoration:none;">Komplett checklista →</a>
          <a href="/for/guider/vad-kostar-det/" style="background:#1e1850;border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:0.6rem 1rem;color:rgba(255,255,255,0.6);font-size:0.85rem;text-decoration:none;">Vad kostar det? →</a>
        </div>
      </div>
    </div>
  </article>
</Layout>
