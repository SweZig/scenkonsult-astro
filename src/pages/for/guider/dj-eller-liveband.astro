---
import Layout from '../../../layouts/Layout.astro';
const schema = {"@context":"https://schema.org","@graph":[{"@type":"Article","headline":"DJ eller liveband? Ärlig jämförelse 2025","author":{"@type":"Organization","name":"Scenkonsult Norden"},"datePublished":"2025-01-01","url":"https://scenkonsult.se/for/guider/dj-eller-liveband/"},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Vad kostar en DJ till bröllop?","acceptedAnswer":{"@type":"Answer","text":"Via Scenkonsult kostar en junior DJ 1 999 kr (2 tim) upp till 3 199 kr (4 tim) exkl moms. Senior DJ 2 399–3 999 kr exkl moms. DJ-hårdvara ingår."}},{"@type":"Question","name":"Vad kostar det att hyra DJ-utrustning?","acceptedAnswer":{"@type":"Answer","text":"Numark Mixstream Pro+ kostar 799 kr/dygn. Denon Prime GO+ 999 kr/dygn. Denon Prime 4+ 1 499 kr/dygn. Rane System One 1 999 kr/dygn. Alla priser exkl moms."}},{"@type":"Question","name":"Kan man kombinera DJ och liveband?","acceptedAnswer":{"@type":"Answer","text":"Ja — liveband under cocktail/middag, DJ på dansgolvet. Det kräver scen (fr Scenpaket Medium+ 1 799 kr/dygn) och PA som funkar för båda (Music-serien fr 999 kr/dygn)."}}]}]};
const djUtrustning = [
  {n:"Numark Mixstream Pro+",p:799,d:"Standalone, WiFi-streaming inbyggt. Spotify, Tidal, SoundCloud. Inga kablar till laptop.",link:"/vara-tjanster/hyra-dj/"},
  {n:"Denon Prime GO+",p:999,d:"Kompakt 2-deck standalone. Batteri + WiFi. Perfekt för mindre event.",link:"/vara-tjanster/hyra-dj/"},
  {n:"Denon Prime 4+",p:1499,d:"4-deck standalone. Stor skärm, inbyggt ljudkort. Professionell setup utan laptop.",link:"/vara-tjanster/hyra-dj/"},
  {n:"Rane System One",p:1999,d:"Professionellt Serato-system. Valt av toppnamn. Magistralt ljud och byggkvalitet.",link:"/vara-tjanster/hyra-dj/"},
];
const djService = [
  {tid:"2 tim",junior:1999,juniorInkl:2499,senior:2399,seniorInkl:2999},
  {tid:"3 tim",junior:2599,juniorInkl:3249,senior:3199,seniorInkl:3999},
  {tid:"4 tim",junior:3199,juniorInkl:3999,senior:3999,seniorInkl:4999},
];
---
<Layout title="DJ eller Liveband? Ärlig Jämförelse 2025 | Scenkonsult" description="DJ vs liveband — pris, stämning, logistik och teknikkrav. Konkreta priser från Scenkonsults sortiment. Uthyrare sedan 1986." schemaExtra={schema}>
  <div style="background:linear-gradient(135deg,#1e1850 0%,#0c0a24 60%);padding-top:calc(36px + 130px + clamp(2rem,4vw,3.5rem));padding-bottom:clamp(2.5rem,5vw,4rem);padding-inline:clamp(1rem,5vw,5rem);">
    <div style="max-width:820px;margin:0 auto;">
      <nav aria-label="Brödsmulor" style="margin-bottom:1.5rem;"><ol style="display:flex;flex-wrap:wrap;gap:0.35rem;list-style:none;margin:0;padding:0;font-size:0.78rem;color:rgba(255,255,255,0.4);"><li><a href="/" style="color:rgba(255,255,255,0.5);text-decoration:none;">Hem</a> <span style="opacity:0.3;">/</span></li><li><a href="/for/guider/" style="color:rgba(255,255,255,0.5);text-decoration:none;">Guider</a> <span style="opacity:0.3;">/</span></li><li style="color:white;">DJ eller liveband?</li></ol></nav>
      <p style="color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-size:0.78rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.6rem;">Guide · Av Scenkonsult Norden</p>
      <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2rem,5vw,3.25rem);line-height:1.1;color:white;margin:0 0 1rem;">DJ eller liveband till festen?</h1>
      <p style="color:rgba(255,255,255,0.6);font-size:clamp(0.95rem,2vw,1.1rem);line-height:1.75;margin:0;">Ärlig jämförelse med konkreta priser från vårt sortiment — ingen grönsaksinformation.</p>
    </div>
  </div>
  <article style="background:#0c0a24;padding:clamp(2.5rem,5vw,5rem) clamp(1rem,5vw,5rem);">
    <div style="max-width:820px;margin:0 auto;color:rgba(255,255,255,0.65);font-size:1rem;line-height:1.8;">
      <div class="g2c" style="margin-bottom:3rem;">
        {[{t:"Välj DJ om…",items:["Budget under 10 000 kr",  "Dansgolvet är prioritet","Stor musikbredd önskas","Lång kväll (4+ tim)","Litet utrymme"],c:"#c4b5f4"},{t:"Välj liveband om…",items:["WOW-effekten är viktig","Budget tillåter 20 000+","Gästerna är 40+ år","Cocktail/middag-format","Unikt minnesmärke"],c:"#86efac"}].map(k=>(
          <div style={`background:#1e1850;border:1px solid ${k.c}22;border-radius:14px;padding:1.5rem;`}>
            <h3 style={`font-family:'Space Grotesk',sans-serif;font-size:0.82rem;font-weight:700;color:${k.c};text-transform:uppercase;letter-spacing:0.08em;margin:0 0 1rem;`}>{k.t}</h3>
            {k.items.map(i=><div style="display:flex;gap:0.6rem;padding:0.3rem 0;"><span style={`color:${k.c};font-size:0.75rem;flex-shrink:0;`}>✓</span><span style="color:rgba(255,255,255,0.65);font-size:0.85rem;">{i}</span></div>)}
          </div>
        ))}
      </div>

      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1.25rem;">Hyra DJ-utrustning — vårt sortiment</h2>
      <p style="margin-bottom:1.25rem;">Vi hyr ut standalone DJ-controllers — de behöver <strong style="color:white;">ingen laptop</strong> och har <strong style="color:white;">inbyggd streaming</strong> (Spotify, Tidal, SoundCloud, Amazon Music). Läs mer om varför vi valt dessa modeller i vår guide om <a href="/for/guider/varfor-numark-denon-rane/" style="color:#c4b5f4;">DJ-utrustning och streaming</a>.</p>
      <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:2.5rem;">
        {djUtrustning.map(d=>(
          <div style="background:#1e1850;border-radius:12px;padding:1.25rem 1.5rem;display:flex;justify-content:space-between;gap:1.5rem;align-items:flex-start;flex-wrap:wrap;">
            <div>
              <div style="color:white;font-weight:700;font-size:0.95rem;margin-bottom:0.35rem;">{d.n}</div>
              <div style="color:rgba(255,255,255,0.5);font-size:0.87rem;line-height:1.55;">{d.d}</div>
            </div>
            <div style="text-align:right;flex-shrink:0;">
              <div style="color:#c4b5f4;font-family:'DM Serif Display',serif;font-size:1.5rem;white-space:nowrap;"><span data-exkl={d.p}>{d.p}</span> kr</div>
              <div style="color:rgba(255,255,255,0.3);font-size:0.72rem;">per dygn</div>
            </div>
          </div>
        ))}
      </div>
      <p style="color:rgba(255,255,255,0.35);font-size:0.82rem;margin-bottom:3rem;">DJ-bord: <span data-exkl="80">80</span> kr/dygn. DJ-bord med paneler: <span data-exkl="200">200</span> kr/dygn.</p>

      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1.25rem;">Hyr professionell DJ — priser</h2>
      <p style="margin-bottom:1.25rem;">DJ-hårdvara ingår i priset. Resa, scen, ljud och ljus tillkommer.</p>
      <div style="overflow-x:auto;margin-bottom:2.5rem;">
        <table style="width:100%;border-collapse:collapse;font-size:0.87rem;">
          <thead><tr style="border-bottom:2px solid rgba(196,181,244,0.25);">
            <th style="text-align:left;padding:0.75rem 0.5rem;color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;">Speltid</th>
            <th style="text-align:left;padding:0.75rem 0.5rem;color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;">Junior DJ</th>
            <th style="text-align:left;padding:0.75rem 0.5rem;color:#c4b5f4;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;">Senior DJ</th>
          </tr></thead>
          <tbody>{djService.map((r,i)=>(
            <tr style={`border-bottom:1px solid rgba(255,255,255,0.06);background:${i%2===0?'transparent':'rgba(255,255,255,0.02)'}`}>
              <td style="padding:0.75rem 0.5rem;color:white;font-weight:600;">{r.tid}</td>
              <td style="padding:0.75rem 0.5rem;color:rgba(255,255,255,0.7);"><span data-exkl={r.junior}>{r.junior}</span> kr</td>
              <td style="padding:0.75rem 0.5rem;color:rgba(255,255,255,0.7);"><span data-exkl={r.senior}>{r.senior}</span> kr</td>
            </tr>
          ))}</tbody>
        </table>
      </div>

      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,3vw,1.9rem);color:white;margin:0 0 1rem;">Kombination: liveband + DJ</h2>
      <p>Det bästa av två världar: liveband under cocktail/middag, DJ på dansgolvet. Tekniken som behövs:</p>
      <div class="g2c" style="margin-bottom:2.5rem;">
        {[{t:"Ljud",items:["Music Medium (1 499 kr) — täcker hela lokalen","Mixer 12 kanal (399 kr) — hanterar band + DJ"]},{t:"Scen",items:["Scenpaket Medium+ (1 799 kr) — passar band och DJ","Scentrapp 60 cm (349 kr)"]}].map(k=>(
          <div style="background:#1e1850;border-radius:12px;padding:1.25rem;">
            <h3 style="font-family:'Space Grotesk',sans-serif;font-size:0.85rem;font-weight:700;color:#c4b5f4;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.75rem;">{k.t}</h3>
            {k.items.map(i=><div style="display:flex;gap:0.5rem;padding:0.3rem 0;"><span style="color:#86efac;font-size:0.75rem;flex-shrink:0;">✓</span><span style="color:rgba(255,255,255,0.6);font-size:0.85rem;">{i}</span></div>)}
          </div>
        ))}
      </div>

      <div style="background:linear-gradient(135deg,#1e1850,#0c0a24);border:1px solid rgba(196,181,244,0.2);border-radius:16px;padding:2rem;text-align:center;margin-top:3rem;">
        <h2 style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:white;margin:0 0 0.5rem;">Hyr DJ-utrustning eller boka DJ</h2>
        <p style="color:rgba(255,255,255,0.55);font-size:0.95rem;margin:0 0 1.5rem;">Standalone-utrustning med streaming inbyggt — ingen laptop krävs.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <a href="/vara-tjanster/hyra-dj/" style="background:#c4b5f4;color:#0c0a24;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:0.82rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:4px;">DJ-utrustning & bokning</a>
          <a href="/bokningssida/" style="border:1px solid rgba(196,181,244,0.4);color:rgba(255,255,255,0.7);font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:4px;">Begär offert</a>
        </div>
      </div>
    </div>
  </article>
</Layout>
