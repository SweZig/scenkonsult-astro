---
import CartButton from './CartButton.astro';
/**
 * VideoCard.astro – produktkort med bild och valfri video-overlay.
 */
interface Props {
  title: string;
  img: string;
  imgAlt?: string;
  priceExcl: number;
  priceSuffix?: string;
  videos?: string[];
  bullets?: string[];
  rows?: { label: string; rows: string[] }[];
  tag?: string;
  class?: string;
  category?: string;
}
const {
  title,
  img,
  imgAlt = title,
  priceExcl,
  priceSuffix = '/dygn',
  videos = [],
  bullets = [],
  rows = [],
  tag = '',
  class: extra = '',
  category = 'Produkt',
} = Astro.props;

const cartId = `vc-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;

const vcId = `vc-${Math.random().toString(36).slice(2,7)}`;
---

<article class={`bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-2xl overflow-hidden transition-all group h-full flex flex-col ${extra}`}>

  <!-- Bild / Video-yta -->
  <div class="relative bg-brand-dark overflow-hidden" style="aspect-ratio:1024/853;cursor:zoom-in">
    <img
      id={`${vcId}-img`}
      src={img}
      alt={imgAlt}
      width="512" height="427"
      loading="lazy"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
    />

    {videos.length > 0 && videos.map((v, i) => (
      <video
        id={`${vcId}-vid-${i}`}
        src={v}
        preload="none"
        class="hidden"
      ></video>
    ))}

    {videos.length > 0 && (
      <div class="absolute top-2 right-2 flex flex-col gap-1.5 items-end z-10">
        {videos.map((_, i) => (
          <button
            data-vidcard-play={vcId}
            data-vidcard-idx={i}
            class="flex items-center gap-1 bg-black/60 hover:bg-brand-orange text-white text-[10px] font-bold px-2 py-1 rounded-full transition-colors backdrop-blur-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3"><path d="M8 5v14l11-7z"/></svg>
            {videos.length > 1 ? `Video ${i+1}` : 'Video'}
          </button>
        ))}
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="p-5 flex flex-col flex-1">
    {tag && <div class="text-brand-orange text-[10px] font-semibold uppercase tracking-wider mb-1">{tag}</div>}
    <h3 class="font-bold text-white text-sm leading-snug mb-3">{title}</h3>

    {rows.length > 0 && (
      <div class="border-t border-white/10 pt-3 mb-3 space-y-2">
        {rows.map(g => (
          <div>
            {g.label && <div class="text-gray-400 text-[10px] uppercase tracking-wide mb-1">{g.label}</div>}
            <div class="grid grid-cols-2 gap-x-3 gap-y-0.5">
              {g.rows.map(r => (
                <div class="text-gray-400 text-xs">{r}</div>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}

    {bullets.length > 0 && (
      <ul class="space-y-1 border-t border-white/10 pt-3 flex-1">
        {bullets.map(b => (
          <li class="flex gap-1.5 text-gray-400 text-xs"><span class="text-green-400 shrink-0">▸</span>{b}</li>
        ))}
      </ul>
    )}

    <!-- Bottom bar: pris vänster, knapp höger -->
    <div class="mt-auto flex items-center justify-between border-t border-white/10 pt-3 gap-3">
      <div class="shrink-0">
        <span class="sk-price-excl text-brand-orange font-extrabold text-lg">{priceExcl.toLocaleString('sv')} kr</span>
        <span class="sk-price-incl hidden text-brand-orange font-extrabold text-lg">{Math.round(priceExcl*1.25).toLocaleString('sv')} kr</span>
        <div class="text-gray-400 text-[10px]">{priceSuffix}</div>
      </div>
      <CartButton id={cartId} name={title} price={priceExcl} priceNote={`/${priceSuffix.replace(/^\//, '')}`} category={category} image={img} size="sm" label="Lägg i varukorg" />
    </div>
  </div>
</article>

<script>
// Globalt hanteras av en enda listener – idempotent
if (!window.__vcInit) {
  window.__vcInit = true;
  document.addEventListener('click', e => {
    const playBtn = (e.target as Element).closest('[data-vidcard-play]');
    if (playBtn) {
      const id = (playBtn as HTMLElement).dataset.vidcardPlay;
      const idx = parseInt((playBtn as HTMLElement).dataset.vidcardIdx || '0', 10);
      const vid = document.getElementById(`${id}-vid-${idx}`) as HTMLVideoElement;
      if (vid && window.skLightboxOpen) {
        e.stopPropagation();
        window.skLightboxOpen('video', vid.src, '');
      }
    }
  });
}
</script>
