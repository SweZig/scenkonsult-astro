---
// AccessoryGrid.astro - Reusable tillbehör grid
// Props: items (array of {name, desc, price, priceNote, image?})
//        title (section heading)

interface AccessoryItem {
  name: string;
  desc: string;
  price: number | string;
  priceNote?: string;
  image?: string;
}
interface Props {
  title: string;
  items: AccessoryItem[];
}
const { title, items } = Astro.props;
---
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
  <h2 class="text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3">{title}</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
    {items.map(item => (
      <div class="bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-xl p-4 flex flex-col gap-2 transition-colors">
        {item.image && (
          <div class="bg-brand-dark overflow-hidden rounded-lg mb-1" style="aspect-ratio:1024/853;cursor:zoom-in">
            <img src={item.image} alt={item.name} width="200" height="200" loading="lazy"
              class="w-full h-full object-cover" />
          </div>
        )}
        <p class="text-white font-semibold text-sm leading-tight">{item.name}</p>
        <p class="text-gray-400 text-xs leading-snug flex-1">{item.desc}</p>
        <div class="border-t border-white/10 pt-2 mt-auto">
          <span class="text-brand-orange font-bold text-sm">
            {typeof item.price === 'number' ? (
              <>
                <span class="sk-price-excl">{item.price.toLocaleString('sv')} kr</span>
                <span class="sk-price-incl hidden">{Math.round(item.price * 1.25).toLocaleString('sv')} kr</span>
              </>
            ) : item.price}
          </span>
          {item.priceNote && <span class="text-gray-400 text-xs ml-1">{item.priceNote}</span>}
        </div>
      </div>
    ))}
  </div>
</section>
