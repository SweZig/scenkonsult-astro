---
// CartButton.astro — Lägg i varukorg-knapp
interface Props {
  id: string;
  name: string;
  price: number;
  priceNote?: string;
  category: string;
  image?: string;
  bulky?: boolean;        // skrymmande = kräver bil med släpvagn
  monteringMin?: number;  // monteringstid i minuter
  size?: 'sm' | 'md' | 'lg';
  label?: string;
  iconOnly?: boolean;
}
const {
  id, name, price, priceNote = '/dygn', category,
  image = '', bulky = false, monteringMin, size = 'md', label, iconOnly = false
} = Astro.props;

const sizeClasses = {
  sm: 'px-3 py-1.5 text-xs gap-1.5',
  md: 'px-4 py-2 text-sm gap-2',
  lg: 'px-5 py-2.5 text-sm gap-2',
}[size];
---

<button
  class={`sk-cart-btn inline-flex items-center whitespace-nowrap ${sizeClasses} bg-brand-orange hover:bg-brand-orange-light text-brand-dark font-semibold rounded-lg transition-all duration-200`}
  data-id={id}
  data-name={name}
  data-price={price}
  data-price-note={priceNote}
  data-category={category}
  data-image={image}
  data-bulky={bulky ? 'true' : 'false'}
  data-montering-min={monteringMin ?? ''}
  aria-label={`Lägg ${name} i varukorgen`}
>
  <svg class="sk-cart-icon-add shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
  </svg>
  <svg class="sk-cart-icon-check shrink-0 hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="20 6 9 17 4 12"/>
  </svg>
  {!iconOnly && (
    <span class="sk-cart-btn-label">{label ?? 'Lägg i varukorg'}</span>
  )}
</button>
