---
/**
 * MediaCard.astro — Medelstort produktkort med bildgalleri och autoplay-video.
 *
 * Slides byggs av: images[] (i ordning) + videos[] (i ordning).
 * När ett video-slide visas startar videon automatiskt (muted, loop).
 * Klick på bildyta → skLightboxOpen (bild: zoom, video: med ljud).
 *
 * Props:
 *   title       — produktnamn, visas som h3
 *   images      — array av bildsökvägar (minst 1 krävs)
 *   imgAlt      — alt-text för första bilden (fallback: title)
 *   videos      — array av mp4-sökvägar (valfri)
 *   priceExcl   — pris exkl. moms i kr
 *   priceSuffix — prisenhet t.ex. "/dygn" eller "/st/dygn fr" (default "/dygn")
 *   rows        — volympriser: [{ label: string, rows: string[] }]
 *   bullets     — specs med ▸-prefix
 *   tag         — litet badge ovanför title t.ex. "Nyhet"
 *   artno       — artikelnummer (visas som artno-badge)
 *   category    — produktkategori till varukorg (default "Produkt")
 *   id          — cart-ID (default: genereras från title)
 *   class       — extra CSS-klasser på yttre article
 */
import CartButton from './CartButton.astro';

interface Slide {
  type: 'image' | 'video';
  src: string;
}

interface Props {
  title: string;
  images: string[];
  imgAlt?: string;
  videos?: string[];
  priceExcl: number;
  priceSuffix?: string;
  rows?: { label: string; rows: string[] }[];
  bullets?: string[];
  tag?: string;
  artno?: string;
  category?: string;
  id?: string;
  class?: string;
}

const {
  title,
  images,
  imgAlt = title,
  videos = [],
  priceExcl,
  priceSuffix = '/dygn',
  rows = [],
  bullets = [],
  tag = '',
  artno,
  category = 'Produkt',
  id,
  class: extra = '',
} = Astro.props;

const cartId = id ?? `mc-${title.toLowerCase().replace(/[åä]/g,'a').replace(/ö/g,'o').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g,'')}`;

// Unik instans-ID per kort (används för DOM-refs)
const mcId = `mc-${Math.random().toString(36).slice(2, 8)}`;

// Bygg slides-array: bilder först, sedan videos
const slides: Slide[] = [
  ...images.map(src => ({ type: 'image' as const, src })),
  ...videos.map(src => ({ type: 'video' as const, src })),
];

const hasMultiple = slides.length > 1;

// Serialisera slides till JSON för JS-init
const slidesJson = JSON.stringify(slides);

// Produktdata för modal
const productJson = JSON.stringify({
  name:      title,
  artno:     artno ?? '',
  desc:      bullets.join('||'),
  rows:      rows,
  price:     priceExcl,
  priceNote: priceSuffix,
  category:  category,
  cartId:    cartId,
  images:    images,
  videos:    videos,
});
---

<article
  class={`bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-2xl overflow-hidden transition-all group h-full flex flex-col ${extra}`}
  data-mc-id={mcId}
  data-mc-slides={slidesJson}
  data-sk-product={productJson}
  style="cursor:pointer"
>

  <!-- ── GALLERIYTA ── -->
  <div class="relative bg-brand-dark overflow-hidden" style="aspect-ratio:1024/853">

    <!-- Aktiv slide renderas här av JS; SSR visar första bilden som fallback -->
    <div
      class="mc-slide-area w-full h-full"
      id={`${mcId}-area`}
    >
      <!-- SSR-fallback: första bilden synlig utan JS, JS byter ut vid init -->
      <img
        src={images[0]}
        alt={imgAlt}
        width="512"
        height="427"
        loading="lazy"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </div>

    <!-- Pilar — dolda om bara ett slide -->
    {hasMultiple && (
      <>
        <button
          class="mc-arr mc-arr-l absolute left-1.5 top-1/2 -translate-y-1/2 z-10 w-7 h-8 flex items-center justify-center bg-black/65 hover:bg-brand-orange/70 border border-white/15 rounded-md text-white text-base leading-none transition-colors"
          data-mc-dir="-1"
          aria-label="Föregående"
        >‹</button>
        <button
          class="mc-arr mc-arr-r absolute right-1.5 top-1/2 -translate-y-1/2 z-10 w-7 h-8 flex items-center justify-center bg-black/65 hover:bg-brand-orange/70 border border-white/15 rounded-md text-white text-base leading-none transition-colors"
          data-mc-dir="1"
          aria-label="Nästa"
        >›</button>

        <!-- Dots -->
        <div class="absolute bottom-1.5 left-1/2 -translate-x-1/2 z-10 flex gap-1" id={`${mcId}-dots`}>
          {slides.map((s, i) => (
            <button
              class={`mc-dot transition-all ${i === 0 ? 'bg-brand-orange w-2.5 h-2' : 'bg-white/30 w-2 h-2'} ${s.type === 'video' ? 'rounded-sm' : 'rounded-full'}`}
              data-mc-goto={i}
              aria-label={`Slide ${i + 1}`}
            ></button>
          ))}
        </div>
      </>
    )}
  </div>

  <!-- ── INNEHÅLL ── -->
  <div class="p-5 flex flex-col flex-1">

    {tag && (
      <div class="text-brand-orange text-[10px] font-semibold uppercase tracking-wider mb-1">{tag}</div>
    )}

    <h3 class="font-bold text-white leading-snug mb-3 group-hover:text-brand-orange transition-colors" style="font-size:17px">{title}</h3>

    {artno && <p class="artno-badge mb-2">{artno}</p>}

    {rows.length > 0 && (
      <div class="border-t border-white/10 pt-3 mb-3 space-y-2.5">
        {rows.map(g => (
          <div>
            {g.label && (
              <div class="text-[9px] uppercase tracking-[0.1em] text-white/30 font-semibold mb-1">{g.label}</div>
            )}
            <div class="grid grid-cols-2 gap-x-3 gap-y-0.5">
              {g.rows.map(r => (
                <div class="text-gray-400 text-xs">{r}</div>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}

    {bullets.length > 0 && (
      <ul class="space-y-1 border-t border-white/10 pt-3 flex-1 mb-0">
        {bullets.map(b => (
          <li class="flex gap-1.5 text-gray-400 text-xs">
            <span class="text-green-400 shrink-0">▸</span>
            {b}
          </li>
        ))}
      </ul>
    )}

    <!-- Spacer så bottenraden alltid trycks ned -->
    <div class="flex-1 min-h-[0.25rem]"></div>

    <!-- Bottenrad: pris vänster, knapp höger -->
    <div class="mt-auto flex items-center justify-between border-t border-white/10 pt-3 gap-3">
      <div class="shrink-0 leading-none">
        <span class="sk-price-excl text-brand-orange font-extrabold" style="font-size:17px">
          {priceExcl.toLocaleString('sv')} kr
        </span>
        <span class="sk-price-incl hidden text-brand-orange font-extrabold" style="font-size:17px">
          {Math.round(priceExcl * 1.25).toLocaleString('sv')} kr
        </span>
        <div class="text-gray-400 text-[10px] mt-0.5">{priceSuffix}</div>
      </div>
      <CartButton
        id={cartId}
        name={title}
        price={priceExcl}
        priceNote={`/${priceSuffix.replace(/^\//, '')}`}
        category={category}
        image={images[0]}
        size="sm"
        label="Lägg i varukorg"
      />
    </div>

  </div>
</article>

<script>
// ── MediaCard galleri-motor ──────────────────────────────────────────────────
// Initieras en gång globalt. Hanterar alla mc-instanser på sidan.
// Exponeras på window för att onclick-attribut i innerHTML ska fungera.

if (!window.__mcInit) {
  window.__mcInit = true;

  // State: { [mcId]: { slides, current } }
  const mcState: Record<string, { slides: {type:string,src:string}[], current: number }> = {};

  function mcRenderSlide(mcId: string) {
    const st = mcState[mcId];
    if (!st) return;

    const area = document.getElementById(`${mcId}-area`) as HTMLElement;
    const dotsEl = document.getElementById(`${mcId}-dots`);
    if (!area) return;

    const slide = st.slides[st.current];
    const isVideo = slide.type === 'video';

    // Stoppa eventuell aktiv video
    const oldVideo = area.querySelector('video');
    if (oldVideo) { oldVideo.pause(); oldVideo.src = ''; }

    if (isVideo) {
      // Inline autoplay-video, muted (krävs av browsers)
      area.innerHTML = `
        <video
          src="${slide.src}"
          autoplay
          muted
          loop
          playsinline
          class="w-full h-full object-cover"
          style="display:block"
        ></video>
        <div style="position:absolute;top:8px;left:8px;display:flex;align-items:center;gap:5px;background:rgba(12,10,36,.75);border:1px solid rgba(196,181,244,.3);border-radius:4px;padding:3px 8px;font-size:9px;color:rgba(196,181,244,.85);font-weight:700;letter-spacing:.04em;pointer-events:none">
          <span style="width:6px;height:6px;border-radius:50%;background:#c4b5f4;animation:mcPulse 1.1s ease-in-out infinite;flex-shrink:0"></span>
          SPELAS
        </div>
        <div style="position:absolute;bottom:0;left:0;width:100%;height:2px;background:rgba(255,255,255,.1)">
          <div style="height:100%;background:#c4b5f4;animation:mcProgress 8s linear infinite"></div>
        </div>`;

      // Klick på video-slide → lightbox med ljud
      area.style.cursor = 'pointer';
      area.onclick = (e) => {
        e.stopPropagation();
        if (window.skLightboxOpen) window.skLightboxOpen('video', slide.src, '');
      };
    } else {
      // Vanlig bild
      area.innerHTML = `<img
        src="${slide.src}"
        alt=""
        width="512" height="427"
        loading="lazy"
        class="w-full h-full object-cover"
        style="display:block;transition:transform .3s"
      />`;
      area.style.cursor = 'pointer';
      area.onclick = (e) => {
        e.stopPropagation();
        if (window.skLightboxOpen) window.skLightboxOpen('image', slide.src, '');
      };
    }

    // Uppdatera dots
    if (dotsEl) {
      dotsEl.querySelectorAll('.mc-dot').forEach((dot, i) => {
        const isActive = i === st.current;
        const isVid = st.slides[i].type === 'video';
        (dot as HTMLElement).className = `mc-dot transition-all ${
          isActive ? 'bg-brand-orange w-2.5 h-2' : 'bg-white/30 w-2 h-2'
        } ${isVid ? 'rounded-sm' : 'rounded-full'}`;
      });
    }
  }

  function mcGo(mcId: string, dir: number) {
    const st = mcState[mcId];
    if (!st) return;
    st.current = (st.current + dir + st.slides.length) % st.slides.length;
    mcRenderSlide(mcId);
  }

  function mcGoto(mcId: string, idx: number) {
    const st = mcState[mcId];
    if (!st) return;
    st.current = idx;
    mcRenderSlide(mcId);
  }

  // Exponera på window för onclick-attribut
  window.mcGo = mcGo;
  window.mcGoto = mcGoto;

  // Delegerad event-hantering för pilar och dots
  document.addEventListener('click', (e) => {
    const target = e.target as Element;

    // Pil
    const arr = target.closest('.mc-arr') as HTMLElement | null;
    if (arr) {
      e.stopPropagation();
      const card = arr.closest('[data-mc-id]') as HTMLElement | null;
      if (!card) return;
      const mcId = card.dataset.mcId!;
      const dir = parseInt(arr.dataset.mcDir || '1', 10);
      mcGo(mcId, dir);
      return;
    }

    // Dot
    const dot = target.closest('.mc-dot') as HTMLElement | null;
    if (dot) {
      e.stopPropagation();
      const card = dot.closest('[data-mc-id]') as HTMLElement | null;
      if (!card) return;
      const mcId = card.dataset.mcId!;
      const idx = parseInt(dot.dataset.mcGoto || '0', 10);
      mcGoto(mcId, idx);
      return;
    }
  });

  // Initiering av alla kort på sidan
  function mcInitAll() {
    document.querySelectorAll<HTMLElement>('[data-mc-id]').forEach(card => {
      const mcId = card.dataset.mcId!;
      if (mcState[mcId]) return; // redan initierad
      try {
        const slides = JSON.parse(card.dataset.mcSlides || '[]');
        mcState[mcId] = { slides, current: 0 };
        mcRenderSlide(mcId); // byt ut SSR-fallback mot JS-variant
      } catch {}
    });
  }

  // Kör vid DOMContentLoaded + efter Astro view-transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mcInitAll);
  } else {
    mcInitAll();
  }
  document.addEventListener('astro:page-load', mcInitAll);
}
</script>

<style is:global>
@keyframes mcPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: .4; transform: scale(.7); }
}
@keyframes mcProgress {
  0%   { width: 0% }
  100% { width: 100% }
}
</style>
