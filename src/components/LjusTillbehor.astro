---
import CartButton from './CartButton.astro';
import ElTillbehorCard from './ElTillbehorCard.astro';
// Ljusstyrning + DMX-tillbehör + El-tillbehör – visas på både fardiga-paket och ljuseffekter
---

<!-- LJUSSTYRNING -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
  <h2 class="text-2xl font-bold text-white mb-2">Ljusstyrning</h2>
  <p class="text-gray-400 text-sm mb-6">DMX-512 styrenheter för professionell kontroll. Kompletteras med DMX-kablar eller trådlös styrning (se tillbehör nedan).</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
    {[
      { title:'Styrenhet 192 kanaler', img:'/images/ljus/pp_ljus_styrning02.png', excl:99,
        bullets:['192 DMX-kanaler','12 scannrar × 16 kan.','240 sekvenser i 30 banker','Musikstyrning via mikrofon'] },
      { title:'Botex SDC-16 (16 faders)', img:'/images/ljus/pp_ljus_botex_sdc16.png', excl:199,
        bullets:['192 DMX-kanaler','16 individuella faders + master','Parallellstyrning av 16 kanaler','Startkanal via display'] },
      { title:'Styrenhet 512 kanaler', img:'/images/ljus/pp_ljus_styrning03.png', excl:299,
        bullets:['48-kanals DMX styrenhet','4 600 scener i 96 banker','Mjukpatch alla 512 kanaler','Musikstyrning via mikrofon'] },
      { title:'PC-mjukvara + gränssnitt', img:'/images/ljus/pp_ljus_styrning04.png', excl:799,
        bullets:['512 DMX-kanaler','Dra-och-släpp programmering','Ljud-till-ljus BPM-analys','Live scen-dimning'] },
    ].map(c => (
      <div class="bg-brand-navy border border-white/10 hover:border-brand-orange/40 rounded-2xl overflow-hidden transition-all group flex flex-col">
        <div class="bg-brand-dark overflow-hidden" style="aspect-ratio:1024/853">
          <img src={c.img} alt={c.title} width="512" height="427" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div class="p-4 flex flex-col flex-1">
          <h3 class="font-bold text-white text-xs leading-snug mb-2">{c.title}</h3>
          <ul class="space-y-0.5 mb-3 flex-1">
            {c.bullets.map(b => <li class="text-gray-400 text-[10px] flex gap-1"><span class="text-green-400">▸</span>{b}</li>)}
          </ul>
          <div class="flex items-center justify-between border-t border-white/10 pt-3 gap-2">
            <div class="shrink-0">
              <span class="sk-price-excl text-brand-orange font-extrabold text-sm">{c.excl} kr</span>
              <span class="sk-price-incl hidden text-brand-orange font-extrabold text-sm">{Math.round(c.excl*1.25)} kr</span>
              <div class="text-gray-400 text-[10px]">/dygn</div>
            </div>
            <CartButton id={`ljus-styrning-${c.title.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`} name={c.title} price={c.excl} category="Ljusstyrning" image={c.img} size="sm" label="Lägg i varukorg" />
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- DMX-TILLBEHÖR — fullbredd -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
  <h2 class="text-2xl font-bold text-white mb-4 border-b border-white/10 pb-3">DMX-tillbehör</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
    {[
      { img:'/images/ljus/pp_ljus_half_coupler.png', name:'Half Coupler 35/50 mm', excl:20,  desc:'per coupler' },
      { img:'/images/ljus/pp_ljus_super_clamp.png',  name:'Super Clamp 50 mm',    excl:32,  desc:'per clamp' },
      { img:'/images/ljus/pp_ljus_kablar.png',        name:'DMX-kabel 1–5 m',     excl:20,  desc:'per kabel' },
      { img:'/images/ljus/pp_ljus_kablar.png',        name:'DMX-kabel 10/15 m',   excl:40,  desc:'per kabel' },
      { img:'/images/ljus/pp_ljus_tradlos01.png',     name:'DMX Trådlös startkit',excl:159, desc:'1 sänd + 2 mot.' },
      { img:'/images/ljus/pp_ljus_tradlos02.png',     name:'DMX Trådlös sändare', excl:80,  desc:'extra sändare' },
      { img:'/images/ljus/pp_ljus_tradlos03.png',     name:'DMX Trådlös mottagare',excl:80, desc:'extra mottagare' },
    ].map(t => (
      <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} desc={t.desc} category="DMX-tillbehör" />
    ))}
  </div>
</section>

<!-- EL-TILLBEHÖR — fullbredd -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
  <h2 class="text-2xl font-bold text-white mb-4 border-b border-white/10 pb-3">El-tillbehör</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
    {[
      { img:'/images/ljus/pp_ljus_powercon.png',      name:'PowerCon 0,5–1,5 m',          excl:20  },
      { img:'/images/ljus/pp_ljus_powercon2.png',     name:'PowerCon 5–10 m',             excl:80  },
      { img:'/images/ljus/pp_ljus_iec_kabel.png',     name:'IEC C13/C14 0,5–1,5 m',      excl:20  },
      { img:'/images/ljus/pp_el_grenuttag_sm.png',    name:'Grenuttag 1,5 m',             excl:20  },
      { img:'/images/ljus/pp_el_forlangning.png',     name:'Förlängning 10 m 1-fas',      excl:48  },
      { img:'/images/ljus/pp_el_grenuttag_lg.png',    name:'Grenuttag 10 m IP44',         excl:100 },
      { img:'/images/ljus/pp_el_grenuttag_25m.png',   name:'Grenuttag 25 m IP44',         excl:159 },
      { img:'/images/ljus/pp_el_forlangning_20m.png', name:'Förlängning 20 m 3-fas 16A',  excl:236 },
      { img:'/images/ljus/pp_el_forlangning_20m.png', name:'Förlängning 20 m 3-fas 32A',  excl:396 },
      { img:'/images/ljus/pp_el_omvandlare.png',      name:'3-fas → 1-fas omvandlare',   excl:320 },
      { img:'/images/ljus/pp_el_overloppsskydd.png',  name:'Överkörningsskydd 1 m',       excl:80  },
      { img:'/images/ljud/pp_ljud_tillbehor_elverk-small.png', name:'Elgenerator 2 200 W', excl:799 },
    ].map(t => (
      <ElTillbehorCard img={t.img} name={t.name} excl={t.excl} category="El-tillbehör" />
    ))}
  </div>
</section>

<!-- Större event — 2-kolumn: text vänster, bild höger på mörk bakgrund -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
  <div class="bg-brand-navy border border-white/10 rounded-2xl overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-2">
      <div class="p-8 flex flex-col justify-center">
        <h2 class="text-2xl font-bold text-white mb-3">Scenljus för konserter & större event</h2>
        <p class="text-gray-300 mb-2">Vi har scenljus för alla ändamål – vitt och färgat ljus på travers eller tross.</p>
        <p class="text-gray-400 text-sm mb-6">Beskriv ditt behov så tar vi fram lösningen. Större ljusriggar hyrs ut inkl. transport och montering.</p>
        <div>
          <a href="/kontakt/" class="inline-block bg-brand-orange hover:bg-brand-orange-light text-white px-6 py-3 rounded-xl font-semibold text-sm transition-colors">Fråga om offert</a>
        </div>
      </div>
      <div class="hidden md:block">
        <img src="/images/ljus/pp_ljus_storre_event.png" alt="Scenljus för konserter och större event" width="600" height="400" loading="lazy" class="w-full h-full object-cover" />
      </div>
    </div>
  </div>
</section>
