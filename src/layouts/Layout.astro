  <!-- VAT TOGGLE -->
  <div id="sk-vat-toggle" aria-label="Momsvisning">
    <span class="sk-vat-label">Visa priser</span>
    <button id="sk-vat-excl" class="sk-vat-btn sk-vat-active" aria-pressed="true">Exkl. moms</button>
    <button id="sk-vat-incl" class="sk-vat-btn" aria-pressed="false">Inkl. moms</button>
  </div>

  <script>
    const nav = document.getElementById('mainNav');
    function updateNav() {
      nav?.classList.toggle('scrolled', window.scrollY > 40);
    }
    updateNav();
    window.addEventListener('scroll', updateNav, { passive: true });

    // Hamburger menu
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    hamburger?.addEventListener('click', () => {
      const isOpen = hamburger.classList.toggle('open');
      mobileMenu?.classList.toggle('open', isOpen);
      hamburger.setAttribute('aria-expanded', String(isOpen));
      mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
    });
    // Mobile accordion: Tjänster
    document.getElementById('mobTjänsterBtn')?.addEventListener('click', () => {
      const sub = document.getElementById('mobTjänsterSub');
      const btn = document.getElementById('mobTjänsterBtn');
      sub?.classList.toggle('open');
      const arrow = btn?.querySelector('.nav-arrow') as HTMLElement;
      if (arrow) arrow.style.transform = sub?.classList.contains('open') ? 'rotate(180deg)' : '';
    });

    // Desktop dropdown med stängningsfördröjning
    const ddParent = document.querySelector('.nav-dropdown') as HTMLElement;
    const ddMenu = document.querySelector('.nav-dropdown-menu') as HTMLElement;
    let closeTimer: ReturnType<typeof setTimeout> | null = null;
    const openDD = () => {
      if (closeTimer) clearTimeout(closeTimer);
      ddMenu?.classList.add('dd-open');
    };
    const closeDD = () => {
      closeTimer = setTimeout(() => ddMenu?.classList.remove('dd-open'), 2500);
    };
    ddParent?.addEventListener('mouseenter', openDD);
    ddParent?.addEventListener('mouseleave', closeDD);
    ddMenu?.addEventListener('mouseenter', openDD);
    ddMenu?.addEventListener('mouseleave', closeDD);
    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!hamburger?.contains(e.target as Node) && !mobileMenu?.contains(e.target as Node)) {
        hamburger?.classList.remove('open');
        mobileMenu?.classList.remove('open');
        hamburger?.setAttribute('aria-expanded', 'false');
        mobileMenu?.setAttribute('aria-hidden', 'true');
      }
    });
    // Close on nav link click
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        hamburger?.classList.remove('open');
        mobileMenu?.classList.remove('open');
      });
    });

    // VAT TOGGLE
    function applyVat(mode: 'excl' | 'incl') {
      const showExcl = mode === 'excl';

      // Legacy: show/hide paired elements (.sk-price-excl / .sk-price-incl)
      document.querySelectorAll('.sk-price-excl').forEach(el => {
        (el as HTMLElement).classList.toggle('hidden', !showExcl);
      });
      document.querySelectorAll('.sk-price-incl').forEach(el => {
        (el as HTMLElement).classList.toggle('hidden', showExcl);
      });

      // Guide pages: compute +25% from data-exkl attribute
      document.querySelectorAll('[data-exkl]').forEach(el => {
        const base = parseInt((el as HTMLElement).dataset.exkl || '0', 10);
        const val  = showExcl ? base : Math.round(base * 1.25);
        el.textContent = val.toLocaleString('sv-SE');
      });

      // Toggle button states
      const btnExcl = document.getElementById('sk-vat-excl');
      const btnIncl = document.getElementById('sk-vat-incl');
      if (btnExcl && btnIncl) {
        btnExcl.classList.toggle('sk-vat-active', showExcl);
        btnIncl.classList.toggle('sk-vat-active', !showExcl);
        btnExcl.setAttribute('aria-pressed', String(showExcl));
        btnIncl.setAttribute('aria-pressed', String(!showExcl));
      }

      // Show toggle only on pages that have prices
      const hasPrices = document.querySelector('[data-exkl], .sk-price-excl, .sk-price-incl');
      const vatWidget = document.getElementById('sk-vat-toggle');
      if (vatWidget) vatWidget.style.display = hasPrices ? '' : 'none';

      try { localStorage.setItem('sk-vat', mode); } catch {}
    }

    // Apply saved or default preference on load
    let savedVat: 'excl' | 'incl' = 'excl';
    try { savedVat = (localStorage.getItem('sk-vat') as 'excl' | 'incl') || 'excl'; } catch {}
    applyVat(savedVat);

    document.getElementById('sk-vat-excl')?.addEventListener('click', () => applyVat('excl'));
    document.getElementById('sk-vat-incl')?.addEventListener('click', () => applyVat('incl'));

    // ─── CART SYSTEM ─────────────────────────────────────────────
    const SK_CART_KEY = 'sk-cart';

    function skGetCart() {
      try { return JSON.parse(localStorage.getItem(SK_CART_KEY) || '[]'); } catch { return []; }
    }
    function skSaveCart(cart) {
      try { localStorage.setItem(SK_CART_KEY, JSON.stringify(cart)); } catch {}
    }
    function skCartTotal() {
      return skGetCart().reduce((sum, item) => sum + item.qty, 0);
    }
    function skUpdateBadge() {
      const total = skCartTotal();
      const badge = document.getElementById('navCartBadge');
      const mobileBadge = document.getElementById('mobileCartBadge');
      [badge, mobileBadge].forEach(el => {
        if (!el) return;
        el.textContent = String(total);
        el.classList.toggle('hidden', total === 0);
      });
    }
    function skAddToCart(item) {
      const cart = skGetCart();
      const existing = cart.find(i => i.id === item.id);
      if (existing) {
        existing.qty += 1;
      } else {
        cart.push({ ...item, qty: 1 });
      }
      skSaveCart(cart);
      skUpdateBadge();
    }
    function skRemoveFromCart(id) {
      const cart = skGetCart().filter(i => i.id !== id);
      skSaveCart(cart);
      skUpdateBadge();
    }
    function skUpdateQty(id, qty) {
      const cart = skGetCart();
      const item = cart.find(i => i.id === id);
      if (item) { item.qty = qty; if (item.qty <= 0) return skRemoveFromCart(id); }
      skSaveCart(cart);
      skUpdateBadge();
    }
    // Expose globally for checkout page
    window.skCart = { get: skGetCart, save: skSaveCart, add: skAddToCart, remove: skRemoveFromCart, updateQty: skUpdateQty, badge: skUpdateBadge };

    // Init badge on load
    skUpdateBadge();

    // Wire up all cart buttons on this page
    document.querySelectorAll('.sk-cart-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const item = {
          id: this.dataset.id,
          name: this.dataset.name,
          price: Number(this.dataset.price),
          priceNote: this.dataset.priceNote || '/dygn',
          category: this.dataset.category || '',
          image: this.dataset.image || '',
          bulky: this.dataset.bulky === 'true',
          monteringMin: this.dataset.monteringMin ? Number(this.dataset.monteringMin) : null,
        };
        skAddToCart(item);
        // Visual feedback
        const iconAdd = this.querySelector('.sk-cart-icon-add');
        const iconCheck = this.querySelector('.sk-cart-icon-check');
        const lbl = this.querySelector('.sk-cart-btn-label');
        iconAdd?.classList.add('hidden');
        iconCheck?.classList.remove('hidden');
        if (lbl) lbl.textContent = 'Tillagd!';
        this.style.background = '#7c3aed';
        setTimeout(() => {
          iconAdd?.classList.remove('hidden');
          iconCheck?.classList.add('hidden');
          if (lbl) lbl.textContent = 'Lägg i varukorg';
          this.style.background = '';
        }, 1400);
      });
    });

  </script>

  <!-- KONTAKTSKYDD: dekoda tel/mail ur base64 vid runtime — ej synligt i HTML-källan -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Tel-länkar
      document.querySelectorAll('a[data-tel]').forEach(el => {
        const num = atob(el.getAttribute('data-tel'));
        const prefix = el.getAttribute('data-prefix') || '';
        const lbl = el.getAttribute('data-label') || num.replace(/(\d{3})(\d{3})(\d{2})(\d{2})/, '$1-$2 $3 $4');
        el.href = 'tel:' + num;
        el.textContent = prefix + lbl;
      });
      // Mail-länkar
      document.querySelectorAll('a[data-mail]').forEach(el => {
        const addr = atob(el.getAttribute('data-mail'));
        const lbl = el.getAttribute('data-label') || addr;
        el.href = 'mailto:' + addr;
        el.textContent = lbl;
      });
    });
  </script>

  <InlineEditor />

  <!-- ========== SVEN INTENDENTEN — CHATBOT ========== -->
  <div id="sven-chat-widget" aria-label="Chatta med Sven">

    <!-- Trigger-knapp -->
    <button id="sven-toggle" aria-label="Öppna chatten med Sven" title="Chatta med Sven – intendenten">
      <span id="sven-icon-open">
        <!-- Headset-ikon -->
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
          <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/>
          <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
        </svg>
      </span>
      <span id="sven-icon-close" style="display:none">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </span>
      <span id="sven-unread" style="display:none"></span>
    </button>

    <!-- Chattfönster -->
    <div id="sven-window" role="dialog" aria-modal="true" aria-label="Chatta med Sven">
      <!-- Header -->
      <div id="sven-header">
        <div id="sven-avatar">S</div>
        <div id="sven-header-text">
          <strong>Sven — Intendenten</strong>
          <span>Fråga om utrustning & priser</span>
        </div>
        <button id="sven-close-btn" aria-label="Stäng chatten">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <!-- Meddelanden -->
      <div id="sven-messages" role="log" aria-live="polite"></div>

      <!-- Snabbval -->
      <div id="sven-chips"></div>

      <!-- Inmatning -->
      <div id="sven-input-row">
        <input
          id="sven-input"
          type="text"
          placeholder="Skriv din fråga…"
          maxlength="500"
          autocomplete="off"
          aria-label="Din fråga till Sven"
        />
        <button id="sven-send" aria-label="Skicka" title="Skicka">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </div>

      <!-- Betygsättning -->
      <div id="sven-rating-row">
        <span id="sven-rating-label">Betygsätt Sven</span>
        <div id="sven-stars" role="group" aria-label="Betyg 1–5 stjärnor">
          {[1,2,3,4,5].map(n => (
            <button class="sven-star" data-star={n} aria-label={`${n} stjärnor`} title={`${n} stjärnor`}>★</button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <style>
    /* === Widget container === */
    #sven-chat-widget {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 9999;
      font-family: 'Source Sans 3', system-ui, sans-serif;
    }

    /* === Toggle-knapp === */
    #sven-toggle {
      width: 58px;
      height: 58px;
      border-radius: 50%;
      border: none;
      background: #c4b5f4;
      color: #0c0a24;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 20px rgba(196,181,244,0.45);
      transition: background 0.2s, transform 0.2s;
      position: relative;
      margin-left: auto;
    }
    #sven-toggle:hover { background: #e2dcfb; transform: scale(1.07); }

    /* Unread badge */
    #sven-unread {
      position: absolute;
      top: -2px; right: -2px;
      width: 14px; height: 14px;
      background: #e63946;
      border-radius: 50%;
      border: 2px solid #0c0a24;
    }

    /* === Chattfönster === */
    #sven-window {
      display: none;
      flex-direction: column;
      position: absolute;
      bottom: 70px;
      right: 0;
      width: 340px;
      max-height: 520px;
      background: #13112e;
      border: 1px solid rgba(196,181,244,0.25);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 12px 48px rgba(0,0,0,0.55);
      animation: svenSlideIn 0.22s ease;
    }
    #sven-window.open { display: flex; }

    @keyframes svenSlideIn {
      from { opacity: 0; transform: translateY(12px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Header */
    #sven-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 16px;
      background: #1e1850;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      flex-shrink: 0;
    }
    #sven-avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #c4b5f4;
      color: #0c0a24;
      font-weight: 900;
      font-size: 16px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    #sven-header-text { flex: 1; line-height: 1.2; }
    #sven-header-text strong { display: block; color: #fff; font-size: 14px; }
    #sven-header-text span { color: rgba(255,255,255,0.5); font-size: 11px; }
    #sven-close-btn {
      background: none; border: none; cursor: pointer;
      color: rgba(255,255,255,0.4); padding: 4px;
      border-radius: 6px; transition: color 0.15s;
    }
    #sven-close-btn:hover { color: #fff; }

    /* Meddelandelista */
    #sven-messages {
      flex: 1;
      overflow-y: auto;
      padding: 16px 14px 8px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      scroll-behavior: smooth;
    }
    #sven-messages::-webkit-scrollbar { width: 4px; }
    #sven-messages::-webkit-scrollbar-track { background: transparent; }
    #sven-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 4px; }

    /* Bubblor — #sven-messages scope för att slå global CSS */
    #sven-messages .sven-bubble {
      max-width: 85% !important;
      padding: 9px 13px !important;
      border-radius: 14px !important;
      font-size: 13.5px !important;
      line-height: 1.55 !important;
      word-break: break-word !important;
      margin: 0 !important;
    }
    #sven-messages .sven-bubble.bot {
      background: #1e1850 !important;
      color: rgba(255,255,255,0.9) !important;
      border-bottom-left-radius: 4px !important;
      align-self: flex-start !important;
    }
    #sven-messages .sven-bubble.user {
      background: #c4b5f4 !important;
      color: #0c0a24 !important;
      border-bottom-right-radius: 4px !important;
      align-self: flex-end !important;
      font-weight: 500 !important;
    }
    #sven-messages .sven-bubble a {
      color: #c4b5f4 !important;
      text-decoration: underline !important;
    }
    #sven-messages .sven-bubble.bot a { color: #c4b5f4 !important; }

    /* Skrivindikator */
    #sven-messages .sven-typing {
      display: flex !important; gap: 4px !important; align-items: center !important;
      padding: 10px 13px !important;
      background: #1e1850 !important;
    }
    #sven-messages .sven-typing span {
      width: 7px !important; height: 7px !important;
      background: rgba(196,181,244,0.6) !important;
      border-radius: 50% !important;
      animation: svenBounce 1.1s infinite !important;
      display: block !important;
    }
    #sven-messages .sven-typing span:nth-child(2) { animation-delay: 0.18s; }
    #sven-messages .sven-typing span:nth-child(3) { animation-delay: 0.36s; }
    @keyframes svenBounce {
      0%,60%,100% { transform: translateY(0); }
      30%          { transform: translateY(-6px); }
    }

    /* Snabbval-chips */
    #sven-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      padding: 0 14px 10px;
      flex-shrink: 0;
    }
    .sven-chip {
      background: rgba(196,181,244,0.1);
      border: 1px solid rgba(196,181,244,0.3);
      color: #c4b5f4;
      border-radius: 20px;
      padding: 5px 12px;
      font-size: 12px;
      cursor: pointer;
      transition: background 0.15s;
      white-space: nowrap;
    }
    .sven-chip:hover { background: rgba(196,181,244,0.22); }

    /* Inmatning */
    #sven-input-row {
      display: flex;
      gap: 8px;
      padding: 10px 14px 14px;
      border-top: 1px solid rgba(255,255,255,0.08);
      flex-shrink: 0;
    }
    #sven-input {
      flex: 1;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 9px 12px;
      color: #fff;
      font-size: 13.5px;
      outline: none;
      font-family: inherit;
      transition: border-color 0.15s;
    }
    #sven-input:focus { border-color: rgba(196,181,244,0.5); }
    #sven-input::placeholder { color: rgba(255,255,255,0.3); }
    #sven-send {
      width: 38px; height: 38px;
      border-radius: 10px;
      border: none;
      background: #c4b5f4;
      color: #0c0a24;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      transition: background 0.15s;
    }
    #sven-send:hover { background: #e2dcfb; }
    #sven-send:disabled { opacity: 0.4; cursor: not-allowed; }

    /* Betygsättning */
    #sven-rating-row {
      display: none;
      align-items: center;
      justify-content: space-between;
      padding: 8px 14px 12px;
      border-top: 1px solid rgba(255,255,255,0.06);
      flex-shrink: 0;
    }
    #sven-rating-row.visible { display: flex; }
    #sven-rating-label {
      font-size: 11px;
      color: rgba(255,255,255,0.35);
      font-family: 'Space Grotesk', sans-serif;
    }
    #sven-stars { display: flex; gap: 3px; }
    .sven-star {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 20px;
      color: rgba(255,255,255,0.2);
      padding: 0 1px;
      transition: color 0.15s, transform 0.1s;
      line-height: 1;
    }
    .sven-star:hover,
    .sven-star.active { color: #c4b5f4; }
    .sven-star:hover { transform: scale(1.2); }
    .sven-star.rated { color: #c4b5f4; cursor: default; }

    /* Mobilanpassning */
    @media (max-width: 400px) {
      #sven-window { width: calc(100vw - 32px); right: -8px; }
      #sven-chat-widget { right: 16px; bottom: 16px; }
    }
  </style>

  <script>
    (function() {
      const CHIPS_INITIAL = [
        "Vad kostar en scen?",
        "Ljud för 100 gäster",
        "Ljuseffekter till festen",
        "Leverans?",
      ];

      const toggle      = document.getElementById('sven-toggle');
      const win         = document.getElementById('sven-window');
      const messages    = document.getElementById('sven-messages');
      const input       = document.getElementById('sven-input');
      const sendBtn     = document.getElementById('sven-send');
      const closeBtn    = document.getElementById('sven-close-btn');
      const chips       = document.getElementById('sven-chips');
      const iconOpen    = document.getElementById('sven-icon-open');
      const iconClose   = document.getElementById('sven-icon-close');
      const unread      = document.getElementById('sven-unread');
      const ratingRow   = document.getElementById('sven-rating-row');
      const starBtns    = document.querySelectorAll('.sven-star');

      let history    = [];
      let isOpen     = false;
      let hasGreeted = false;
      let hasRated   = false;
      const sessionId = Math.random().toString(36).slice(2, 10);

      function open() {
        isOpen = true;
        win.classList.add('open');
        iconOpen.style.display = 'none';
        iconClose.style.display = 'flex';
        unread.style.display = 'none';
        input.focus();
        if (!hasGreeted) {
          hasGreeted = true;
          setTimeout(() => {
            addBubble('bot',
              'Hej! Sven här — intendent på Scenkonsult. Hade jag fått bestämma hade jag stått på scenen nu istället, men här är vi. 🎭\n\nVad kan jag hjälpa dig med?'
            );
            renderChips(CHIPS_INITIAL);
          }, 300);
        }
      }

      function close() {
        isOpen = false;
        win.classList.remove('open');
        iconOpen.style.display = 'flex';
        iconClose.style.display = 'none';
      }

      toggle.addEventListener('click', () => isOpen ? close() : open());
      closeBtn.addEventListener('click', close);
      document.addEventListener('keydown', e => { if (e.key === 'Escape' && isOpen) close(); });

      function escapeHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }

      function formatMessage(text) {
        return escapeHtml(text)
          .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
          .replace(/\[([^\]]+)\]\((\/[^)]+)\)/g, '<a href="$1">$1 →</a>')
          .replace(/\n/g, '<br>');
      }

      function addBubble(role, text) {
        const div = document.createElement('div');
        div.className = `sven-bubble ${role}`;
        div.innerHTML = formatMessage(text);
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
        // Visa betygsstjärnor efter 2 bot-svar
        if (role === 'bot' && !hasRated) {
          const botCount = messages.querySelectorAll('.sven-bubble.bot').length;
          if (botCount >= 2) ratingRow.classList.add('visible');
        }
        return div;
      }

      function showTyping() {
        const div = document.createElement('div');
        div.className = 'sven-bubble bot sven-typing';
        div.id = 'sven-typing-indicator';
        div.innerHTML = '<span></span><span></span><span></span>';
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
      }

      function removeTyping() {
        document.getElementById('sven-typing-indicator')?.remove();
      }

      function renderChips(list) {
        chips.innerHTML = '';
        list.forEach(label => {
          const btn = document.createElement('button');
          btn.className = 'sven-chip';
          btn.textContent = label;
          btn.addEventListener('click', () => { chips.innerHTML = ''; sendMessage(label); });
          chips.appendChild(btn);
        });
      }

      // ── Betygsättning ──
      starBtns.forEach(btn => {
        btn.addEventListener('mouseenter', () => {
          if (hasRated) return;
          const n = +btn.dataset.star;
          starBtns.forEach(s => s.classList.toggle('active', +s.dataset.star <= n));
        });
        btn.addEventListener('mouseleave', () => {
          if (hasRated) return;
          starBtns.forEach(s => s.classList.remove('active'));
        });
        btn.addEventListener('click', async () => {
          if (hasRated) return;
          const stars = +btn.dataset.star;
          hasRated = true;
          starBtns.forEach(s => {
            s.classList.remove('active');
            s.classList.toggle('rated', +s.dataset.star <= stars);
            s.disabled = true;
          });
          document.getElementById('sven-rating-label').textContent =
            '★'.repeat(stars) + '☆'.repeat(5 - stars);
          try {
            const res = await fetch('/api/sven-chat', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ action: 'rate', stars, sessionId, messageCount: history.length }),
            });
            const data = await res.json();
            if (data.comment) addBubble('bot', data.comment);
          } catch {
            addBubble('bot', 'Betyget noterat, tack! (Sven log det mentalt och log sedan bort i sina tankar.)');
          }
        });
      });

      // ── Skicka meddelande ──
      async function sendMessage(text) {
        const msg = text.trim();
        if (!msg) return;
        input.value = '';
        chips.innerHTML = '';
        addBubble('user', msg);
        history.push({ role: 'user', content: msg });
        sendBtn.disabled = true;
        showTyping();
        try {
          const res = await fetch('/api/sven-chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ messages: history, sessionId }),
          });
          removeTyping();
          if (!res.ok) throw new Error('HTTP ' + res.status);
          const data = await res.json();
          const reply = data.reply || 'Något gick fel, försök igen.';
          addBubble('bot', reply);
          history.push({ role: 'assistant', content: reply });
          if (/offert|kontakt|boka|formulär/i.test(reply)) {
            renderChips(['Skicka offertförfrågan →']);
          }
        } catch {
          removeTyping();
          addBubble('bot', 'Hm, något krånglar. Prova att ringa oss på 072-448 10 00 — vi svarar genast!');
        } finally {
          sendBtn.disabled = false;
          input.focus();
        }
      }

      sendBtn.addEventListener('click', () => sendMessage(input.value));
      input.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(input.value); }
      });

      setTimeout(() => {
        if (!isOpen && !hasGreeted) unread.style.display = 'block';
      }, 8000);
    })();
  </script>
