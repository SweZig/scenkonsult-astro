      try {
        var raw = localStorage.getItem('sk_cookie_consent');
        if (raw) {
          var data = JSON.parse(raw);
          var value = typeof data === 'string' ? data : data.value;
          var expires = typeof data === 'object' ? data.expires : null;
          var valid = !expires || Date.now() < expires;
          if (value === 'accepted' && valid) {
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
