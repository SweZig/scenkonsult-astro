---
import '../styles/global.css';
import InlineEditor from '../components/InlineEditor.astro';
import Tel from '../components/Tel.astro';
import Mail from '../components/Mail.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Hyra Scen, Ljud & Ljus Stockholm | Scenkonsult – Sedan 1986',
  description = 'Uthyrning av scen, ljud, ljus, bild och DJ-utrustning för fest, bröllop, event och konsert. Komplett scenproduktion i Stockholm. Leverans och montering. Sedan 1986.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/logo-icon.png" />
  <!-- Preconnect for fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>

  <!-- TICKER -->
  <div class="ticker">
    <div class="ticker-track">
      <span class="tick-item">Uthyrning av scen, ljud, ljus &amp; bild<span class="tick-dot"></span></span>
      <span class="tick-item">Del av Sveriges scener sedan 1986<span class="tick-dot"></span></span>
      <span class="tick-item">Ingen scen är för liten — eller för stor<span class="tick-dot"></span></span>
      <span class="tick-item">Leverans och montering i hela Storstockholm<span class="tick-dot"></span></span>
      <span class="tick-item">Jourtjänst kvällstid<span class="tick-dot"></span></span>
      <span class="tick-item">Fest · Bröllop · Event · Konsert<span class="tick-dot"></span></span>
      <!-- duplicate for seamless loop -->
      <span class="tick-item">Uthyrning av scen, ljud, ljus &amp; bild<span class="tick-dot"></span></span>
      <span class="tick-item">Del av Sveriges scener sedan 1986<span class="tick-dot"></span></span>
      <span class="tick-item">Ingen scen är för liten — eller för stor<span class="tick-dot"></span></span>
      <span class="tick-item">Leverans och montering i hela Storstockholm<span class="tick-dot"></span></span>
      <span class="tick-item">Jourtjänst kvällstid<span class="tick-dot"></span></span>
      <span class="tick-item">Fest · Bröllop · Event · Konsert<span class="tick-dot"></span></span>
    </div>
  </div>

  <!-- NAV -->
  <nav class="nav" id="mainNav">
    <a href="/" class="nav-logo" aria-label="Scenkonsult – Startsida">
      <img class="logo-w" src="/logo-white.png" alt="Scenkonsult" />
      <img class="logo-c" src="/logo-color.png" alt="Scenkonsult" />
    </a>
    <button class="nav-hamburger" id="hamburger" aria-label="Öppna meny" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li class="nav-dropdown">
        <a href="/vara-tjanster/" class="nav-dropdown-trigger">Tjänster <span class="nav-arrow">▾</span></a>
        <div class="nav-dropdown-menu">
          <div class="nav-dd-col">
            <span class="nav-dd-heading">Hårdvara</span>
            <a href="/vara-tjanster/hyra-scen/">🎪 Hyra scen</a>
            <a href="/vara-tjanster/hyra-ljud/portable/">🔊 Portabelt ljud</a>
            <a href="/vara-tjanster/hyra-ljud/event/">🎙 Ljud – Event & konferens</a>
            <a href="/vara-tjanster/hyra-ljud/music/">🎵 Ljud – Musik & dans</a>
            <a href="/vara-tjanster/hyra-ljud/live/">🎸 Ljud – Live & konsert</a>
            <a href="/vara-tjanster/hyra-ljus/">💡 Hyra ljus</a>
            <a href="/vara-tjanster/hyra-bild-projektorer-skarmar/">📽 Projektor & skärm</a>
            <a href="/vara-tjanster/hyra-dj/">🎧 DJ & DJ-utrustning</a>
          </div>
          <div class="nav-dd-col">
            <span class="nav-dd-heading">Tjänster</span>
            <a href="/vara-tjanster/">✨ Komplett event</a>
            <a href="/bokningssida/">📋 Begär offert</a>
            <a href="/kontakt/">📞 Kontakta oss</a>
          </div>
          <div class="nav-dd-col">
            <span class="nav-dd-heading">För ditt event</span>
            <a href="/for/brollop/">💍 Bröllop</a>
            <a href="/for/foretagsfest/">🎉 Företagsfest & kickoff</a>
            <a href="/for/konferens/">🎤 Konferens & föreläsning</a>
            <a href="/for/festival/">🎸 Festival & utomhus</a>
            <a href="/for/studentflak/">🎓 Studentflak</a>
            <a href="/for/guider/" style="margin-top:0.5rem;padding-top:0.5rem;border-top:1px solid rgba(255,255,255,0.07);">📖 Guider & tips</a>
          </div>
        </div>
      </li>
      <li><a href="/kontakt/">Kontakta oss</a></li>
    </ul>
    <Tel class="nav-phone" prefix="📞 " />
    <a href="/varukorg/" class="nav-cart" id="navCartBtn" aria-label="Varukorg" style="margin-left:auto"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg><span class="nav-cart-badge hidden" id="navCartBadge">0</span></a>
  </nav>

  <!-- MOBILE MENU -->
  <div class="nav-mobile-menu" id="mobileMenu" aria-hidden="true">
    <ul>
      <li class="nav-mob-parent">
        <button class="nav-mob-trigger" id="mobTjänsterBtn">Tjänster <span class="nav-arrow">▾</span></button>
        <ul class="nav-mob-sub" id="mobTjänsterSub">
          <li><a href="/vara-tjanster/hyra-scen/">Hyra scen</a></li>
          <li><a href="/vara-tjanster/hyra-ljud/portable/">Portabelt ljud</a></li>
          <li><a href="/vara-tjanster/hyra-ljud/event/">Ljud – Event</a></li>
          <li><a href="/vara-tjanster/hyra-ljud/music/">Ljud – Musik & dans</a></li>
          <li><a href="/vara-tjanster/hyra-ljud/live/">Ljud – Live</a></li>
          <li><a href="/vara-tjanster/hyra-ljus/">Hyra ljus</a></li>
          <li><a href="/vara-tjanster/hyra-bild-projektorer-skarmar/">Projektor & skärm</a></li>
          <li><a href="/vara-tjanster/hyra-dj/">DJ & DJ-utrustning</a></li>
          <li><a href="/vara-tjanster/">Komplett event</a></li>
          <li style="margin-top:0.5rem; padding-top:0.5rem; border-top:1px solid rgba(255,255,255,0.08);"><span style="color:rgba(196,181,244,0.6); font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding: 0.25rem 0; display:block;">För ditt event</span></li>
          <li><a href="/for/brollop/">💍 Bröllop</a></li>
          <li><a href="/for/foretagsfest/">🎉 Företagsfest & kickoff</a></li>
          <li><a href="/for/konferens/">🎤 Konferens & föreläsning</a></li>
          <li><a href="/for/festival/">🎸 Festival & utomhus</a></li>
          <li><a href="/for/studentflak/">🎓 Studentflak</a></li>
          <li><a href="/for/guider/">📖 Guider & tips</a></li>
        </ul>
      </li>
      <li><a href="/kontakt/">Kontakta oss</a></li>
    </ul>
    <Tel class="nav-mobile-phone" prefix="📞 " />
    <a href="/varukorg/" class="nav-mobile-cart">🛒 Varukorg <span class="nav-cart-badge hidden" id="mobileCartBadge" style="position:static;display:inline-flex;margin-left:0.4rem">0</span></a>
  </div>

  <!-- PAGE CONTENT -->
  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/logo-white.png" alt="Scenkonsult" />
        <p class="footer-desc">
          Uthyrning av scen, ljud, ljus, bild och DJ-utrustning för fest,
          bröllop, event och konserter i Stockholm och hela Storstockholm.
        </p>
        <span class="footer-badge">— Del av Sveriges scener sedan 1986</span>
      </div>
      <div class="footer-col">
        <h5>Hårdvara</h5>
        <ul>
          <li><a href="/vara-tjanster/hyra-scen/">Hyra scen</a></li>
          <li><a href="/vara-tjanster/hyra-ljud/">Hyra ljud</a></li>
          <li><a href="/vara-tjanster/hyra-ljus/">Hyra ljus</a></li>
          <li><a href="/vara-tjanster/hyra-bild-projektorer-skarmar/">Hyra projektor &amp; skärm</a></li>
          <li><a href="/vara-tjanster/hyra-dj/">Hyra DJ-utrustning</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Tjänster</h5>
        <ul>
          <li><a href="/vara-tjanster/">Alla tjänster</a></li>
          <li><a href="/kontakt/">Komplett event / offert</a></li>
          <li><a href="/vara-tjanster/hyra-dj/">Boka DJ</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Information</h5>
        <ul>
          <li><a href="/om-oss/">Om oss</a></li>
          <li><a href="/referenser/">Våra referenser</a></li>
          <li><a href="/vara-vanligaste-fragor-faq/">FAQ</a></li>
          <li><a href="/guide-till-eventlokaler-i-stockholm/">Guide: Eventlokaler</a></li>
          <li><a href="/den-ultimata-guiden-till-minnesvarda-fester/">Guide: Minnesvärda fester</a></li>
          <li><a href="/hyresvillkor/">Hyresvillkor</a></li>
          <li><a href="/feedback/">Feedback</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Kontakt</h5>
        <Tel class="footer-phone" />
        <ul>
          <li><a href="/bokningssida/">Boka / Begär offert</a></li>
          <li><a href="/kontakt/">Skicka meddelande</a></li>
          <li><a href="/kontakt/">Hitta till oss – Vällingby</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2025 Scenkonsult Norden AB. Alla rättigheter förbehållna.</span>
      <span class="footer-copy">
        <a href="/personuppgiftpolicy/" style="color:inherit;">Integritetspolicy</a>
        &nbsp;·&nbsp;
        <a href="/personuppgiftpolicy/" style="color:inherit;">Cookies</a>
        &nbsp;·&nbsp;
        <a href="/hyresvillkor/" style="color:inherit;">Hyresvillkor</a>
      </span>
    </div>
  </footer>

  <!-- VAT TOGGLE -->
  <div id="sk-vat-toggle" aria-label="Momsvisning">
    <span class="sk-vat-label">Visa priser</span>
    <button id="sk-vat-excl" class="sk-vat-btn sk-vat-active" aria-pressed="true">Exkl. moms</button>
    <button id="sk-vat-incl" class="sk-vat-btn" aria-pressed="false">Inkl. moms</button>
  </div>

  <script>
    const nav = document.getElementById('mainNav');
    function updateNav() {
      nav?.classList.toggle('scrolled', window.scrollY > 40);
    }
    updateNav();
    window.addEventListener('scroll', updateNav, { passive: true });

    // Hamburger menu
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    hamburger?.addEventListener('click', () => {
      const isOpen = hamburger.classList.toggle('open');
      mobileMenu?.classList.toggle('open', isOpen);
      hamburger.setAttribute('aria-expanded', String(isOpen));
      mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
    });
    // Mobile accordion: Tjänster
    document.getElementById('mobTjänsterBtn')?.addEventListener('click', () => {
      const sub = document.getElementById('mobTjänsterSub');
      const btn = document.getElementById('mobTjänsterBtn');
      sub?.classList.toggle('open');
      const arrow = btn?.querySelector('.nav-arrow') as HTMLElement;
      if (arrow) arrow.style.transform = sub?.classList.contains('open') ? 'rotate(180deg)' : '';
    });

    // Desktop dropdown med stängningsfördröjning
    const ddParent = document.querySelector('.nav-dropdown') as HTMLElement;
    const ddMenu = document.querySelector('.nav-dropdown-menu') as HTMLElement;
    let closeTimer: ReturnType<typeof setTimeout> | null = null;
    const openDD = () => {
      if (closeTimer) clearTimeout(closeTimer);
      ddMenu?.classList.add('dd-open');
    };
    const closeDD = () => {
      closeTimer = setTimeout(() => ddMenu?.classList.remove('dd-open'), 2500);
    };
    ddParent?.addEventListener('mouseenter', openDD);
    ddParent?.addEventListener('mouseleave', closeDD);
    ddMenu?.addEventListener('mouseenter', openDD);
    ddMenu?.addEventListener('mouseleave', closeDD);
    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!hamburger?.contains(e.target as Node) && !mobileMenu?.contains(e.target as Node)) {
        hamburger?.classList.remove('open');
        mobileMenu?.classList.remove('open');
        hamburger?.setAttribute('aria-expanded', 'false');
        mobileMenu?.setAttribute('aria-hidden', 'true');
      }
    });
    // Close on nav link click
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        hamburger?.classList.remove('open');
        mobileMenu?.classList.remove('open');
      });
    });

    // VAT TOGGLE
    function applyVat(mode: 'excl' | 'incl') {
      const showExcl = mode === 'excl';

      // Legacy: show/hide paired elements (.sk-price-excl / .sk-price-incl)
      document.querySelectorAll('.sk-price-excl').forEach(el => {
        (el as HTMLElement).classList.toggle('hidden', !showExcl);
      });
      document.querySelectorAll('.sk-price-incl').forEach(el => {
        (el as HTMLElement).classList.toggle('hidden', showExcl);
      });

      // Guide pages: compute +25% from data-exkl attribute
      document.querySelectorAll('[data-exkl]').forEach(el => {
        const base = parseInt((el as HTMLElement).dataset.exkl || '0', 10);
        const val  = showExcl ? base : Math.round(base * 1.25);
        el.textContent = val.toLocaleString('sv-SE');
      });

      // Toggle button states
      const btnExcl = document.getElementById('sk-vat-excl');
      const btnIncl = document.getElementById('sk-vat-incl');
      if (btnExcl && btnIncl) {
        btnExcl.classList.toggle('sk-vat-active', showExcl);
        btnIncl.classList.toggle('sk-vat-active', !showExcl);
        btnExcl.setAttribute('aria-pressed', String(showExcl));
        btnIncl.setAttribute('aria-pressed', String(!showExcl));
      }

      // Show toggle only on pages that have prices
      const hasPrices = document.querySelector('[data-exkl], .sk-price-excl, .sk-price-incl');
      const vatWidget = document.getElementById('sk-vat-toggle');
      if (vatWidget) vatWidget.style.display = hasPrices ? '' : 'none';

      try { localStorage.setItem('sk-vat', mode); } catch {}
    }

    // Apply saved or default preference on load
    let savedVat: 'excl' | 'incl' = 'excl';
    try { savedVat = (localStorage.getItem('sk-vat') as 'excl' | 'incl') || 'excl'; } catch {}
    applyVat(savedVat);

    document.getElementById('sk-vat-excl')?.addEventListener('click', () => applyVat('excl'));
    document.getElementById('sk-vat-incl')?.addEventListener('click', () => applyVat('incl'));

    // ─── CART SYSTEM ─────────────────────────────────────────────
    const SK_CART_KEY = 'sk-cart';

    function skGetCart() {
      try { return JSON.parse(localStorage.getItem(SK_CART_KEY) || '[]'); } catch { return []; }
    }
    function skSaveCart(cart) {
      try { localStorage.setItem(SK_CART_KEY, JSON.stringify(cart)); } catch {}
    }
    function skCartTotal() {
      return skGetCart().reduce((sum, item) => sum + item.qty, 0);
    }
    function skUpdateBadge() {
      const total = skCartTotal();
      const badge = document.getElementById('navCartBadge');
      const mobileBadge = document.getElementById('mobileCartBadge');
      [badge, mobileBadge].forEach(el => {
        if (!el) return;
        el.textContent = String(total);
        el.classList.toggle('hidden', total === 0);
      });
    }
    function skAddToCart(item) {
      const cart = skGetCart();
      const existing = cart.find(i => i.id === item.id);
      if (existing) {
        existing.qty += 1;
      } else {
        cart.push({ ...item, qty: 1 });
      }
      skSaveCart(cart);
      skUpdateBadge();
    }
    function skRemoveFromCart(id) {
      const cart = skGetCart().filter(i => i.id !== id);
      skSaveCart(cart);
      skUpdateBadge();
    }
    function skUpdateQty(id, qty) {
      const cart = skGetCart();
      const item = cart.find(i => i.id === id);
      if (item) { item.qty = qty; if (item.qty <= 0) return skRemoveFromCart(id); }
      skSaveCart(cart);
      skUpdateBadge();
    }
    // Expose globally for checkout page
    window.skCart = { get: skGetCart, save: skSaveCart, add: skAddToCart, remove: skRemoveFromCart, updateQty: skUpdateQty, badge: skUpdateBadge };

    // Init badge on load
    skUpdateBadge();

    // Wire up all cart buttons on this page
    document.querySelectorAll('.sk-cart-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const item = {
          id: this.dataset.id,
          name: this.dataset.name,
          price: Number(this.dataset.price),
          priceNote: this.dataset.priceNote || '/dygn',
          category: this.dataset.category || '',
          image: this.dataset.image || '',
          bulky: this.dataset.bulky === 'true',
          monteringMin: this.dataset.monteringMin ? Number(this.dataset.monteringMin) : null,
        };
        skAddToCart(item);
        // Visual feedback
        const iconAdd = this.querySelector('.sk-cart-icon-add');
        const iconCheck = this.querySelector('.sk-cart-icon-check');
        const lbl = this.querySelector('.sk-cart-btn-label');
        iconAdd?.classList.add('hidden');
        iconCheck?.classList.remove('hidden');
        if (lbl) lbl.textContent = 'Tillagd!';
        this.style.background = '#7c3aed';
        setTimeout(() => {
          iconAdd?.classList.remove('hidden');
          iconCheck?.classList.add('hidden');
          if (lbl) lbl.textContent = 'Lägg i varukorg';
          this.style.background = '';
        }, 1400);
      });
    });

  </script>

  <!-- KONTAKTSKYDD: dekoda tel/mail ur base64 vid runtime — ej synligt i HTML-källan -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Tel-länkar
      document.querySelectorAll('a[data-tel]').forEach(el => {
        const num = atob(el.getAttribute('data-tel'));
        const prefix = el.getAttribute('data-prefix') || '';
        const lbl = el.getAttribute('data-label') || num.replace(/(\d{3})(\d{3})(\d{2})(\d{2})/, '$1-$2 $3 $4');
        el.href = 'tel:' + num;
        el.textContent = prefix + lbl;
      });
      // Mail-länkar
      document.querySelectorAll('a[data-mail]').forEach(el => {
        const addr = atob(el.getAttribute('data-mail'));
        const lbl = el.getAttribute('data-label') || addr;
        el.href = 'mailto:' + addr;
        el.textContent = lbl;
      });
    });
  </script>

  <InlineEditor />

</body>
</html>
