import '../styles/global.css';
import InlineEditor from '../components/InlineEditor.astro';
import Tel from '../components/Tel.astro';
import Mail from '../components/Mail.astro';

// ── Bygg SVEN_PRODUCTS från JSON-filer (auto-synkad vid varje deploy) ──
import scenesJson from '../data/scenes.json';
import ljudJson   from '../data/ljud.json';
import ljusJson   from '../data/ljus.json';
import djJson     from '../data/dj.json';
import bildJson   from '../data/bild.json';

type SvenProduct = { name: string; price: number; category: string };
const svenProducts: Record<string, SvenProduct> = {};

// Scen: cart-id = scen-{id}
(scenesJson.products as any[]).forEach(p => {
  if (p.id && p.price) svenProducts[`scen-${p.id}`] = { name: p.name, price: p.price, category: 'Scen' };
});

// Ljud: event / live / music / portable / mixers
(['event','live','music','portable'] as const).forEach(sec => {
  ((ljudJson as any)[sec]?.products as any[] || []).forEach((p: any) => {
    if (p.slug && p.price) svenProducts[p.slug] = { name: p.name, price: p.price, category: 'Ljud' };
  });
});
((ljudJson as any).mixers as any[] || []).forEach((p: any) => {
  if (p.slug && p.price) svenProducts[p.slug] = { name: p.name, price: p.price, category: 'Ljud' };
});

// Ljus: paket / effekter / rok products + rok tillbehör
(['paket','effekter'] as const).forEach(sec => {
  ((ljusJson as any)[sec]?.products as any[] || []).forEach((p: any) => {
    if (p.slug && p.price) svenProducts[p.slug] = { name: p.name, price: p.price, category: 'Ljus' };
  });
});
((ljusJson as any).rok?.products as any[] || []).forEach((p: any) => {
  if (p.slug && p.price) svenProducts[p.slug] = { name: p.name, price: p.price, category: 'Ljus' };
});
((ljusJson as any).rok?.tillbehor as any[] || []).forEach((p: any) => {
  if (p.slug && p.price) svenProducts[p.slug] = { name: p.name, price: p.price, category: 'Ljus tillbehör' };
});

// DJ
Object.values((djJson as any).equipment || {}).forEach((p: any) => {
  if (p.slug && p.price) svenProducts[p.slug] = { name: p.name, price: p.price, category: 'DJ' };
});

// Bild
((bildJson as any).products as any[] || []).forEach((p: any) => {
  if (p.slug && p.price) svenProducts[p.slug] = { name: p.name, price: p.price, category: 'Bild' };
});
((bildJson as any).tillbehor as any[] || []).forEach((p: any) => {
  if (p.slug && p.price) svenProducts[p.slug] = { name: p.name, price: p.price, category: 'Bild' };
});

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schemaExtra?: object;
}

const {
  title = 'Hyra Scen, Ljud & Ljus Stockholm | Scenkonsult – Sedan 1986',
  description = 'Uthyrning av scen, ljud, ljus, bild och DJ-utrustning för fest, bröllop, event och konsert. Komplett scenproduktion i Stockholm. Leverans och montering. Sedan 1986.',
  image = '/images/hero/scen3_hero.webp',
  schemaExtra,
