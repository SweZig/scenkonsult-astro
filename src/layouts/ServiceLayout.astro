---
import Layout from './Layout.astro';
interface Props {
  title: string;
  description: string;
  pageHeading: string;
  intro?: string;
  products: { title: string; priceImg: string; prodImg: string; desc: string }[];
  note?: string;
}
const { title, description, pageHeading, intro, products, note } = Astro.props;
---
<Layout title={title} description={description}>
<style>
.svc-hero{background:var(--ink-deep);padding:calc(36px + 74px + 3rem) 5vw 3.5rem;position:relative;overflow:hidden;}
.svc-hero-dot{position:absolute;right:-5%;top:50%;transform:translateY(-50%);width:480px;height:480px;border-radius:50%;background-image:radial-gradient(circle,rgba(255,255,255,0.05) 2px,transparent 2px);background-size:24px 24px;animation:rotateSlow 80s linear infinite;pointer-events:none;}
.svc-hero .overline{color:rgba(255,255,255,0.4);}
.svc-hero .overline::after{background:rgba(255,255,255,0.3);}
.svc-hero h1{color:white;margin-top:0.5rem;margin-bottom:0.75rem;}
.svc-hero p{color:rgba(255,255,255,0.55);font-size:1rem;line-height:1.8;max-width:560px;margin-bottom:1.75rem;}
.svc-hero-btns{display:flex;gap:1.5rem;align-items:center;flex-wrap:wrap;}
.btn-white{font-family:'Space Grotesk',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;padding:0.9rem 2rem;border-radius:2px;background:white;color:var(--ink);transition:background 0.2s;}
.btn-white:hover{background:var(--ink-tint);}
.btn-tel{font-family:'Space Grotesk',sans-serif;font-size:0.8rem;font-weight:700;color:rgba(255,255,255,0.5);text-decoration:none;transition:color 0.2s;}
.btn-tel:hover{color:white;}

/* Product grid */
.products{padding:4rem 5vw;background:var(--cream);}
.prod-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--rule);border:1px solid var(--rule);margin-top:2.5rem;}
.prod-card{background:var(--white);display:flex;flex-direction:column;transition:background 0.2s;}
.prod-card:hover{background:var(--ink-tint);}
.prod-img-wrap{position:relative;background:#0a0514;overflow:hidden;}
.prod-img-wrap img{width:100%;height:220px;object-fit:contain;padding:1rem;display:block;transition:transform 0.3s;}
.prod-card:hover .prod-img-wrap img{transform:scale(1.03);}
.prod-price-badge{position:absolute;top:1rem;right:1rem;}
.prod-price-badge img{height:52px;width:auto;}
.prod-body{padding:1.5rem 1.5rem 2rem;flex:1;display:flex;flex-direction:column;}
.prod-title{font-family:'Space Grotesk',sans-serif;font-size:0.8rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--text);margin-bottom:0.6rem;}
.prod-desc{font-size:0.84rem;color:var(--mid);line-height:1.75;flex:1;}
.prod-boka{margin-top:1.25rem;display:inline-flex;align-items:center;gap:0.3rem;font-family:'Space Grotesk',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink);text-decoration:none;transition:gap 0.2s;}
.prod-boka::after{content:'→';}
.prod-boka:hover{gap:0.6rem;}
.prod-cta-card{background:var(--ink);display:flex;flex-direction:column;justify-content:center;align-items:flex-start;padding:2.5rem 2rem;}
.prod-cta-card h3{font-family:'DM Serif Display',serif;font-size:1.4rem;color:white;margin-bottom:0.75rem;line-height:1.2;}
.prod-cta-card p{font-size:0.85rem;color:rgba(255,255,255,0.6);line-height:1.7;margin-bottom:1.5rem;}
.prod-cta-card a{font-family:'Space Grotesk',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;padding:0.8rem 1.75rem;border-radius:2px;background:white;color:var(--ink);transition:background 0.2s;}
.prod-cta-card a:hover{background:var(--ink-tint);}

.note-bar{background:var(--white);border-top:1px solid var(--rule);padding:2rem 5vw;}
.note-bar p{font-size:0.82rem;color:var(--mid);max-width:700px;line-height:1.8;}
.note-bar strong{color:var(--text);}

.svc-bottom-cta{background:var(--ink-deep);padding:4rem 5vw;text-align:center;position:relative;overflow:hidden;}
.svc-bottom-cta h2{color:white;margin-bottom:0.75rem;}
.svc-bottom-cta p{color:rgba(255,255,255,0.5);margin-bottom:2rem;font-size:0.95rem;}

@media(max-width:768px){
  .svc-hero{padding-top:calc(32px+64px+2.5rem);}
  .prod-grid{grid-template-columns:1fr;}
  .svc-hero-btns{flex-direction:column;align-items:flex-start;}
}
@media(min-width:769px) and (max-width:1024px){
  .prod-grid{grid-template-columns:1fr 1fr;}
}
</style>

<div class="svc-hero">
  <div class="svc-hero-dot"></div>
  <span class="overline">Uthyrning — Scenkonsult</span>
  <h1 class="display">{pageHeading}</h1>
  {intro && <p>{intro}</p>}
  <div class="svc-hero-btns">
    <a href="/kontakt" class="btn-white">Boka / Fråga om pris</a>
    <a href="tel:0724481000" class="btn-tel">📞 072-448 10 00</a>
  </div>
</div>

<section class="products">
  <span class="overline">Sortiment & priser</span>
  <h2 class="display" style="margin-top:0.5rem;font-size:clamp(1.8rem,2.8vw,2.8rem);">
    Välj rätt paket<br><em>för ditt event</em>
  </h2>
  <div class="prod-grid">
    {products.map(p => (
      <div class="prod-card">
        {p.prodImg && (
          <div class="prod-img-wrap">
            <img src={p.prodImg} alt={p.title} loading="lazy" />
            {p.priceImg && (
              <div class="prod-price-badge">
                <img src={p.priceImg} alt="Pris" loading="lazy" />
              </div>
            )}
          </div>
        )}
        <div class="prod-body">
          <div class="prod-title">{p.title}</div>
          {p.desc && <p class="prod-desc">{p.desc}</p>}
          <a href="/kontakt" class="prod-boka">Boka detta paket</a>
        </div>
      </div>
    ))}
    <div class="prod-cta-card">
      <h3>Inget paket passar exakt?</h3>
      <p>Beskriv ditt event så sätter vi ihop en lösning som passar — kostnadsfritt.</p>
      <a href="/kontakt">Begär offert</a>
    </div>
  </div>
</section>

{note && (
  <div class="note-bar">
    <p>{note}</p>
  </div>
)}

<div class="svc-bottom-cta">
  <h2 class="display" style="color:white;font-size:clamp(1.8rem,2.5vw,2.5rem);">Redo att boka?</h2>
  <p>Vi svarar inom ett par timmar. Ring eller skicka förfrågan — ingen bindning.</p>
  <a href="/kontakt" class="btn-white">Skicka förfrågan</a>
</div>
</Layout>
